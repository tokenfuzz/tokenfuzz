#!/usr/bin/env python3
"""Bounded digest of one or more agent scratch directories."""

from __future__ import annotations

import argparse
import os
import re
import sys
import time
from collections import Counter
from pathlib import Path


SCRIPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))
import quality  # noqa: E402
import verdict as verdict_lib  # noqa: E402


def family_of(filename: str) -> str:
    stem = filename.split(".", 1)[0]
    while re.search(r"[-_]\d+$", stem):
        stem = re.sub(r"[-_]\d+$", "", stem)
    return stem


def verdict_for(testcase: Path) -> str:
    base = testcase.with_suffix("")
    candidates = (Path(f"{base}.asan.txt"), Path(f"{testcase}.asan.txt"))
    output = next((path for path in candidates if path.is_file()), None)
    if output is None:
        return "ORPHAN"
    try:
        if output.stat().st_size == 0:
            return "NO_EXEC"
    except OSError:
        return "NO_EXEC"
    if verdict_lib.file_has_crash(output):
        return "CRASH"
    if verdict_lib.file_is_clean(output):
        return "CLEAN"
    text = output.read_text(encoding="utf-8", errors="replace")
    if re.search(r"EXECUTION_RATE: [1-9][0-9]*/[0-9]+", text):
        return "EXEC_FAIL"
    return "NO_EXEC"


def ago(modified: float) -> str:
    delta = int(time.time() - modified)
    if delta < 60:
        return f"{delta}s ago"
    if delta < 3600:
        return f"{delta // 60}m ago"
    if delta < 86400:
        return f"{delta // 3600}h ago"
    return f"{delta // 86400}d ago"


def file_kind(path: Path) -> str:
    name = path.name
    if (
        name.endswith((".asan.txt", ".ubsan.txt"))
        or name.startswith(("asan_output", "asan-output"))
    ):
        return "sanitizer-output"
    if re.match(r"^(?:.*_harness|harness.*)\.(?:c|cc|cpp)$", name, re.IGNORECASE):
        return "harness"
    if name.endswith((".o", ".a", ".so", ".dylib")):
        return "build-artifact"
    return "testcase" if quality.testcase_mode_for_file(str(path)) else "artifact"


def harness_count(directory: Path) -> int:
    return sum(
        1
        for path in directory.iterdir()
        if path.is_file()
        and re.match(r"^(?:.*_harness|harness.*)\.(?:c|cc|cpp)$", path.name, re.IGNORECASE)
    )


def emit_recent_files(directory: Path, limit: int) -> None:
    files = [path for path in directory.iterdir() if path.is_file()]
    if not files:
        return
    files.sort(key=lambda path: path.stat().st_mtime, reverse=True)
    print(f"  recent files (newest {limit} of {len(files)}):")
    for path in files[:limit]:
        info = path.stat()
        print(
            f"    {path.name:<50} {info.st_size:>8} B  "
            f"{ago(info.st_mtime):<16} [{file_kind(path)}]"
        )
    remaining = len(files) - min(limit, len(files))
    if remaining:
        print(
            f"    ... ({remaining} more files; narrow by name with "
            "bin/scratch-search PATTERN)"
        )


def emit_scratch(directory: Path, *, terse: bool, files: bool, file_limit: int) -> None:
    label = directory.name
    if not directory.is_dir():
        print(f"[{label}] (missing)")
        return
    testcases = [Path(path) for path in quality.list_testcases(str(directory))]
    harnesses = harness_count(directory)
    if not testcases and not harnesses:
        print(f"[{label}] empty")
        return

    entries = []
    counts: Counter[str] = Counter()
    families: dict[str, Counter[str]] = {}
    for testcase in testcases:
        state = verdict_for(testcase)
        counts[state] += 1
        family = family_of(testcase.name)
        family_counts = families.setdefault(family, Counter())
        family_counts["total"] += 1
        family_counts[state] += 1
        entries.append((testcase.stat().st_mtime, testcase, state, family))
    entries.sort(key=lambda row: row[0], reverse=True)

    header = (
        f"[{label}] {len(testcases)} testcases | {counts['CLEAN']} CLEAN | "
        f"{counts['CRASH']} CRASH"
    )
    for state in ("EXEC_FAIL", "NO_EXEC"):
        if counts[state]:
            header += f" | {counts[state]} {state}"
    if counts["ORPHAN"]:
        header += f" | ** {counts['ORPHAN']} ORPHAN **"
    if harnesses:
        header += f" | {harnesses} harness sources"
    print(header)
    if terse:
        return

    if counts["ORPHAN"]:
        print("  ORPHANS (run bin/probe on these):")
        orphans = [entry for entry in entries if entry[2] == "ORPHAN"]
        for modified, path, _state, _family in orphans[:10]:
            print(f"    {path}  {ago(modified)}")
        if len(orphans) > 10:
            print(f"    ... ({len(orphans) - 10} more orphan testcases)")

    if families:
        print("  families:")
        ranked = sorted(families.items(), key=lambda item: (-item[1]["total"], item[0]))
        for family, family_counts in ranked[:10]:
            marks = ""
            if family_counts["CRASH"]:
                marks += f" CRASH×{family_counts['CRASH']}"
            if family_counts["ORPHAN"]:
                marks += f" ORPHAN×{family_counts['ORPHAN']}"
            print(
                f"    {family:<30} {family_counts['total']} testcase(s){marks}"
            )
        if len(ranked) > 10:
            print(f"    ... ({len(ranked) - 10} more families)")

    if entries:
        print("  newest 5:")
        for modified, path, state, _family in entries[:5]:
            print(f"    {path.name:<50} {ago(modified):<10} [{state}]")
    if files:
        emit_recent_files(directory, file_limit)
    if label.startswith("scratch-"):
        hint = f"bin/scratch-status --files --agent {label.removeprefix('scratch-')}"
    else:
        hint = f"bin/scratch-status --files {directory}"
    print(f"  (file inventory: {hint})")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="scratch-status",
        description="Bounded digest of agent scratch directories.",
    )
    parser.add_argument("directories", nargs="*")
    parser.add_argument("--agent", action="append", default=[])
    parser.add_argument("--terse", action="store_true")
    parser.add_argument("--files", nargs="?", const="20")
    parser.add_argument("--file-limit", default="")
    args = parser.parse_args()
    raw_limit = args.file_limit or args.files or "20"
    try:
        args.file_limit = int(raw_limit)
    except ValueError:
        parser.error("--files / --file-limit must be numeric")
    if args.file_limit < 0:
        parser.error("--files / --file-limit must be numeric")
    return args


def main() -> int:
    args = parse_args()
    results_dir = os.environ.get("RESULTS_DIR", "")
    if args.directories:
        directories = []
        for raw in args.directories:
            path = Path(raw)
            candidate = Path(results_dir) / path if results_dir and not path.is_absolute() else path
            directories.append(candidate if candidate.is_dir() else path)
    elif args.agent:
        if not results_dir:
            print(
                "[scratch-status] --agent requires RESULTS_DIR "
                "(run inside an audit session)",
                file=sys.stderr,
            )
            return 2
        directories = [Path(results_dir) / f"scratch-{agent}" for agent in args.agent]
    else:
        base = Path(results_dir or os.getcwd())
        directories = sorted(path for path in base.glob("scratch-*") if path.is_dir())
    if not directories:
        print(
            f"[scratch-status] no scratch dirs found "
            f"(RESULTS_DIR={results_dir or 'unset'})",
            file=sys.stderr,
        )
        return 1
    for directory in directories:
        emit_scratch(
            directory,
            terse=args.terse,
            files=args.files is not None,
            file_limit=args.file_limit,
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
