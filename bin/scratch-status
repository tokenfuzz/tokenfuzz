#!/usr/bin/env bash
# scratch-status — digest of an agent scratch dir.
#
# Replaces `ls -la output/<slug>/<backend>/results/scratch-N`, which can dump
# 30-40 KB once scratch has hundreds of testcase / asan.txt pairs and the
# permissions/owner/size columns the agent never uses dominate the output.
#
# What the agent actually needs from "what's in my scratch":
#   - counts: testcases written, ASan-verified, ORPHAN (no .asan.txt)
#   - verdict breakdown: CRASH vs CLEAN
#   - families (testcases sharing a stem-minus-variant) for at-a-glance recall
#   - newest activity, especially unverified testcases that need bin/probe
#   - harness sources present (so the agent reuses them via // HARNESS:)
#
# Testcase classification + orphan detection reuses lib/quality.sh so the
# digest's notion of "runnable testcase" matches the harness's auto-enforce
# pass — agents that see "0 orphan" here will not be surprised by the
# enforcement gate.
#
# Usage:
#   bin/scratch-status                       # all scratch-* under $RESULTS_DIR
#   bin/scratch-status --agent N             # only scratch-N
#   bin/scratch-status scratch-1             # explicit dir (relative or abs)
#   bin/scratch-status --terse               # one summary line per scratch
#
# Output ~1-3 KB typical, capped near 5 KB. If an agent really needs the raw
# listing they can still run `ls -la <scratch>` directly — this command is
# the digest, not a replacement gate.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/platform.sh
source "$SCRIPT_ROOT/lib/platform.sh"
# shellcheck source=../lib/quality.sh
source "$SCRIPT_ROOT/lib/quality.sh"
# shellcheck source=../lib/verdict.sh
source "$SCRIPT_ROOT/lib/verdict.sh"

TERSE=0
EXPLICIT_AGENTS=()
EXPLICIT_DIRS=()

usage() {
  sed -n '2,28p' "$0"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --agent)
      [ $# -ge 2 ] || { echo "[scratch-status] --agent needs a value" >&2; exit 2; }
      EXPLICIT_AGENTS+=("$2"); shift 2 ;;
    --agent=*) EXPLICIT_AGENTS+=("${1#--agent=}"); shift ;;
    --terse) TERSE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; while [ $# -gt 0 ]; do EXPLICIT_DIRS+=("$1"); shift; done ;;
    -*) echo "[scratch-status] unknown option: $1" >&2; usage >&2; exit 2 ;;
    *) EXPLICIT_DIRS+=("$1"); shift ;;
  esac
done

# ── Resolve target scratch dirs ───────────────────────────────────────
SCRATCH_DIRS=()

if [ "${#EXPLICIT_DIRS[@]}" -gt 0 ]; then
  for d in "${EXPLICIT_DIRS[@]}"; do
    # If relative and we have $RESULTS_DIR, resolve against it; else cwd.
    case "$d" in
      /*) SCRATCH_DIRS+=("$d") ;;
      *)
        if [ -n "${RESULTS_DIR:-}" ] && [ -d "$RESULTS_DIR/$d" ]; then
          SCRATCH_DIRS+=("$RESULTS_DIR/$d")
        else
          SCRATCH_DIRS+=("$d")
        fi
        ;;
    esac
  done
elif [ "${#EXPLICIT_AGENTS[@]}" -gt 0 ]; then
  if [ -z "${RESULTS_DIR:-}" ]; then
    echo "[scratch-status] --agent requires RESULTS_DIR (run inside an audit session)" >&2
    exit 2
  fi
  for n in "${EXPLICIT_AGENTS[@]}"; do
    SCRATCH_DIRS+=("$RESULTS_DIR/scratch-$n")
  done
else
  # Default: every scratch-* under $RESULTS_DIR (or cwd as fallback).
  base="${RESULTS_DIR:-$PWD}"
  while IFS= read -r d; do
    SCRATCH_DIRS+=("$d")
  done < <(find "$base" -maxdepth 1 -type d -name 'scratch-*' 2>/dev/null | sort)
fi

if [ "${#SCRATCH_DIRS[@]}" -eq 0 ]; then
  echo "[scratch-status] no scratch dirs found (RESULTS_DIR=${RESULTS_DIR:-unset})" >&2
  exit 1
fi

# ── Helpers ──────────────────────────────────────────────────────────

# Family name = testcase stem minus trailing -<digits> variant suffix.
# Examples:
#   altsvc-expire-size-3.txt   -> altsvc-expire-size
#   socks5-gss-len-12.bin      -> socks5-gss-len
#   solo-tc.html               -> solo-tc
family_of() {
  local stem="$1"
  # Strip ALL extensions (everything after the first dot). Handles common
  # double-extensions like foo-3.txt.hsts where the variant number lives
  # before the inner extension. Single-dot names round-trip correctly.
  stem="${stem%%.*}"
  # Strip trailing variant index: -<digits> or _<digits>. Loop to support
  # multi-digit variants (-99). Agents use both dash and underscore.
  while [[ "$stem" =~ [-_][0-9]+$ ]]; do
    if [[ "$stem" =~ -[0-9]+$ ]]; then
      stem="${stem%-*}"
    else
      stem="${stem%_*}"
    fi
  done
  printf '%s' "$stem"
}

# Verdict for a testcase: CRASH | CLEAN | NO_EXEC | ORPHAN.
# Read-only on disk; classification uses the shared lib/verdict.sh
# helpers, so a testcase reads the same here as in bin/probe.
verdict_for() {
  local tc="$1"
  local base="${tc%.*}"
  local out=""
  if [ -f "${base}.asan.txt" ]; then out="${base}.asan.txt";
  elif [ -f "${tc}.asan.txt" ]; then out="${tc}.asan.txt";
  else printf '%s' ORPHAN; return; fi
  if [ ! -s "$out" ]; then printf '%s' NO_EXEC; return; fi
  if verdict_file_has_crash "$out"; then
    printf '%s' CRASH
  elif verdict_file_is_clean "$out"; then
    printf '%s' CLEAN
  else
    printf '%s' NO_EXEC
  fi
}

# Human "N sec/min/hr/day ago" from a mtime epoch.
ago_of() {
  local mtime="$1"
  local now; now=$(date +%s)
  local d=$((now - mtime))
  if   [ "$d" -lt 60 ];     then printf '%ds ago' "$d"
  elif [ "$d" -lt 3600 ];   then printf '%dm ago' "$((d / 60))"
  elif [ "$d" -lt 86400 ];  then printf '%dh ago' "$((d / 3600))"
  else                            printf '%dd ago' "$((d / 86400))"
  fi
}

# mtime epoch for a file (portable across BSD / GNU stat).
mtime_of() {
  audit_stat_mtime_epoch "$1"
}

# Sort entries by mtime desc. Input lines: "<mtime>\t<path>\t<verdict>"
sort_newest() {
  sort -t $'\t' -k1,1nr
}

# ── Per-scratch digest ───────────────────────────────────────────────

emit_scratch() {
  local dir="$1"
  local label="${dir##*/}"

  if [ ! -d "$dir" ]; then
    printf '[%s] (missing)\n' "$label"
    return
  fi

  # Gather testcase paths via lib/quality.sh classifier.
  local testcases=()
  while IFS= read -r -d '' f; do
    testcases+=("$f")
  done < <(list_scratch_testcases "$dir")

  local tc_count="${#testcases[@]}"
  local harness_count
  harness_count=$(find "$dir" -maxdepth 1 -type f \( \
                    -name '*_harness.c' -o -name '*_harness.cc' -o -name '*_harness.cpp' \
                    -o -name 'harness*.c' -o -name 'harness*.cc' -o -name 'harness*.cpp' \
                    \) 2>/dev/null | wc -l | tr -d ' ')

  if [ "$tc_count" -eq 0 ] && [ "$harness_count" -eq 0 ]; then
    printf '[%s] empty\n' "$label"
    return
  fi

  # Classify each testcase once. Build a flat record per testcase:
  #   <mtime>\t<path>\t<verdict>\t<family>
  # Downstream pipelines aggregate via awk so we don't need bash-4
  # associative arrays (macOS default bash is 3.2).
  local n_crash=0 n_clean=0 n_noexec=0 n_orphan=0
  local entries=""
  local fam_count=0

  local tc verdict stem fam mt
  for tc in "${testcases[@]}"; do
    verdict=$(verdict_for "$tc")
    case "$verdict" in
      CRASH)   n_crash=$((n_crash + 1))   ;;
      CLEAN)   n_clean=$((n_clean + 1))   ;;
      NO_EXEC) n_noexec=$((n_noexec + 1)) ;;
      ORPHAN)  n_orphan=$((n_orphan + 1)) ;;
    esac
    stem="${tc##*/}"
    fam=$(family_of "$stem")
    mt=$(mtime_of "$tc")
    entries+="${mt}"$'\t'"${tc}"$'\t'"${verdict}"$'\t'"${fam}"$'\n'
  done

  # Header line — always emitted.
  local hdr
  hdr=$(printf '[%s] %d testcases | %d CLEAN | %d CRASH' \
          "$label" "$tc_count" "$n_clean" "$n_crash")
  [ "$n_noexec" -gt 0 ] && hdr="$hdr | $n_noexec NO_EXEC"
  [ "$n_orphan" -gt 0 ] && hdr="$hdr | ** $n_orphan ORPHAN **"
  [ "$harness_count" -gt 0 ] && hdr="$hdr | $harness_count harness sources"
  printf '%s\n' "$hdr"

  if [ "$TERSE" -eq 1 ]; then
    return
  fi

  # Orphans first — actionable, agent must run bin/probe.
  if [ "$n_orphan" -gt 0 ]; then
    printf '  ORPHANS (run bin/probe on these):\n'
    printf '%s' "$entries" \
      | awk -F'\t' '$3=="ORPHAN"' \
      | sort_newest \
      | head -10 \
      | while IFS=$'\t' read -r mt path _v _fam; do
          printf '    %s  %s\n' "$path" "$(ago_of "$mt")"
        done
    [ "$n_orphan" -gt 10 ] && printf '    ... (%d more orphan testcases)\n' "$((n_orphan - 10))"
  fi

  # Families — aggregate via awk, top 10 by testcase count. Mark families
  # that contain crashes or orphans so the agent can target follow-up.
  local fam_table
  fam_table=$(printf '%s' "$entries" | awk -F'\t' '
    NF >= 4 {
      tot[$4]++
      if ($3 == "CRASH")  cr[$4]++
      if ($3 == "ORPHAN") orph[$4]++
    }
    END {
      for (k in tot) printf "%d\t%s\t%d\t%d\n", tot[k], k, cr[k]+0, orph[k]+0
    }
  ')
  fam_count=$(printf '%s\n' "$fam_table" | awk 'NF{n++} END{print n+0}')
  if [ "$fam_count" -gt 0 ]; then
    printf '  families:\n'
    printf '%s\n' "$fam_table" | sort -rn -k1,1 | head -10 \
      | while IFS=$'\t' read -r tot fam cr orph; do
          [ -z "$fam" ] && continue
          marks=""
          [ "${cr:-0}" -gt 0 ]   && marks="$marks CRASH×$cr"
          [ "${orph:-0}" -gt 0 ] && marks="$marks ORPHAN×$orph"
          printf '    %-30s %d testcase(s)%s\n' "$fam" "$tot" "$marks"
        done
    [ "$fam_count" -gt 10 ] && printf '    ... (%d more families)\n' "$((fam_count - 10))"
  fi

  # Newest 5 testcases (any verdict) so the agent sees recent activity.
  if [ "$tc_count" -gt 0 ]; then
    printf '  newest 5:\n'
    printf '%s' "$entries" \
      | sort_newest \
      | head -5 \
      | while IFS=$'\t' read -r mt path verdict _fam; do
          printf '    %-50s %-10s [%s]\n' "${path##*/}" "$(ago_of "$mt")" "$verdict"
        done
  fi

  printf '  (full ls: ls -la %s)\n' "$dir"
}

for d in "${SCRATCH_DIRS[@]}"; do
  emit_scratch "$d"
done
