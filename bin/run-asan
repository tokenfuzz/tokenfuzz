#!/usr/bin/env python3
"""AddressSanitizer runner for browser, shell, CLI, and fuzz testcases."""

from __future__ import annotations

import filecmp
import os
import shutil
import sys
import tempfile
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))

import sanitizer
import target_config
from sanitizer_helpers import (
    _BROWSER_NOISE, copy_file, copy_filtered, file_contains, firefox_fuzz_targets,
)
from timeout import capture_timeout, run_timeout

PROFILE_PREFS = '''user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
user_pref("toolkit.telemetry.reportingpolicy.firstRun", false);
user_pref("browser.aboutConfig.showWarning", false);
user_pref("browser.tabs.warnOnClose", false);
user_pref("browser.warnOnQuit", false);
user_pref("browser.discovery.enabled", false);
user_pref("browser.newtabpage.enabled", false);
user_pref("browser.newtabpage.activity-stream.telemetry", false);
user_pref("browser.newtabpage.activity-stream.feeds.topsites", false);
user_pref("browser.newtabpage.activity-stream.feeds.section.topstories", false);
user_pref("browser.newtabpage.activity-stream.feeds.section.highlights", false);
user_pref("browser.newtabpage.activity-stream.discoverystream.enabled", false);
user_pref("browser.newtabpage.activity-stream.asrouter.userprefs.cfr.addons", false);
user_pref("browser.newtabpage.activity-stream.asrouter.userprefs.cfr.features", false);
user_pref("browser.newtabpage.activity-stream.showSponsored", false);
user_pref("browser.newtabpage.activity-stream.showSponsoredTopSites", false);
user_pref("browser.newtabpage.activity-stream.unifiedAds.tiles.enabled", false);
user_pref("browser.newtabpage.activity-stream.unifiedAds.spocs.enabled", false);
user_pref("browser.newtabpage.activity-stream.showWeather", false);
user_pref("dom.ipc.processCount", 1);
user_pref("dom.allow_scripts_to_close_windows", true);
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("startup.homepage_welcome_url", "");
user_pref("startup.homepage_welcome_url.additional", "");
user_pref("browser.startup.homepage_override.mstone", "ignore");
user_pref("browser.startup.page", 0);
user_pref("app.normandy.enabled", false);
user_pref("extensions.webcompat.enable_interventions", false);
user_pref("extensions.webcompat.enable_shims", false);
user_pref("extensions.webcompat.smartblockEmbeds.enabled", false);
user_pref("extensions.webcompat-reporter.enabled", false);
user_pref("devtools.console.stdout.content", true);
'''


def load_config():
    probe = sys.argv[2] if len(sys.argv) > 2 else Path.cwd()
    try:
        return target_config.load(probe)
    except (FileNotFoundError, ValueError):
        return None


CONFIG = load_config()
BASE_ENV = dict(os.environ)
TARGET_ROOT = CONFIG.target_root if CONFIG else BASE_ENV.get("TARGET_ROOT", str(ROOT / "targets/firefox"))
BUILD_DIR = sanitizer.build_dir("asan", TARGET_ROOT, BASE_ENV)


def browser_binary() -> str:
    if BASE_ENV.get("ASAN_BROWSER"):
        return BASE_ENV["ASAN_BROWSER"]
    if CONFIG and CONFIG.asan_bin:
        return CONFIG.resolve_path(CONFIG.asan_bin)
    darwin = BUILD_DIR / "dist/Nightly.app/Contents/MacOS/firefox"
    linux = BUILD_DIR / "dist/bin/firefox"
    preferred = darwin if sys.platform == "darwin" else linux
    fallback = linux if sys.platform == "darwin" else darwin
    return str(preferred if os.access(preferred, os.X_OK) else fallback)


def options(mode: str) -> str:
    return sanitizer.compose_options("asan", sanitizer.options_for("asan", mode), CONFIG)


def runtime_env(option_string: str, selected: str = "asan") -> dict[str, str]:
    environment = sanitizer.prepare_runtime_env(selected, BASE_ENV)
    if selected == "asan":
        environment["ASAN_OPTIONS"] = sanitizer.runtime_options("asan", option_string, BASE_ENV)
    if CONFIG:
        swift = {"asan": "address"}.get(selected, "")
        replacements = {
            "{TESTCASE}": "",
            "{SANITIZER}": selected,
            "{SWIFT_SANITIZER}": swift,
            "{TARGET_ROOT}": CONFIG.target_root,
            "{RESULTS_DIR}": CONFIG.results_dir,
            "{TARGET_SLUG}": CONFIG.slug,
        }
        for entry in CONFIG.runner_env:
            for token, value in replacements.items():
                entry = entry.replace(token, value)
            key, value = entry.split("=", 1)
            environment[key] = value
    return environment


def run_browser(option_string: str, timeout: int, args: list[str]) -> int:
    resolved = [
        Path(arg).resolve().as_uri() if not arg.startswith("-") and Path(arg).is_file() else arg
        for arg in args
    ]
    with tempfile.TemporaryDirectory(prefix="asan-profile-") as profile_name, tempfile.TemporaryDirectory(prefix="asan-output-") as output_name:
        profile = Path(profile_name)
        output_dir = Path(output_name)
        prefs = PROFILE_PREFS
        if BASE_ENV.get("FIREFOX_EXTRA_PREFS"):
            prefs += "\n" + BASE_ENV["FIREFOX_EXTRA_PREFS"] + "\n"
        (profile / "user.js").write_text(prefs)
        (profile / "prefs.js").write_text(prefs)
        environment = runtime_env(f"{option_string}:log_path={output_dir / 'asan.log'}")
        environment.update({"MOZ_DISABLE_CONTENT_SANDBOX": "1", "MOZ_HEADLESS": "1"})
        with capture_timeout(
            [browser_binary(), "--profile", str(profile), "--no-remote", *resolved],
            timeout,
            env=environment,
        ) as (completed, output):
            copy_filtered(output, sys.stdout.buffer, _BROWSER_NOISE)
            reports = [path for path in output_dir.glob("asan.log.*") if path.stat().st_size]
            for report in reports:
                print(f"=== ASan report: {report.name} ===")
                copy_file(report, sys.stdout.buffer)
            if reports:
                print("[run-asan] CRASH DETECTED: ASan error found", file=sys.stderr)
                persist = BASE_ENV.get("ASAN_CRASH_LOG_DIR")
                if persist and Path(persist).is_dir():
                    for report in reports:
                        shutil.copy2(report, persist)
                    shutil.copy2(output, Path(persist) / "browser-output.txt")
                    print(f"[run-asan] Raw ASan logs preserved in {persist}", file=sys.stderr)
            elif file_contains(output, b"TESTCASE_EXECUTED"):
                print("[run-asan] browser EXECUTION VERIFIED (post-run, marker=TESTCASE_EXECUTED)", file=sys.stderr)
            else:
                print("[run-asan] WARNING: no crash and no execution evidence - testcase may not have run", file=sys.stderr)
            return completed.returncode


def split_js_args(args: list[str]) -> tuple[list[str], list[str], list[str]]:
    testcase, *rest = args
    flags: list[str] = []
    script_args: list[str] = []
    for arg in rest:
        if not script_args and arg.startswith("-"):
            flags.append(arg)
        else:
            script_args.append(arg)
    return [testcase], flags, script_args


def run_js(option_string: str, timeout: int, args: list[str]) -> int:
    if not args:
        print("Usage: run-asan js <testcase.js> [shell flags or script args...]", file=sys.stderr)
        return 1
    testcase, flags, script_args = split_js_args(args)
    js = BASE_ENV.get("ASAN_JS", str(BUILD_DIR / "dist/bin/js"))
    completed = run_timeout([js, *flags, *testcase, *script_args], timeout, env=runtime_env(option_string))
    if completed.returncode == 124:
        print(f"[run-asan] JS shell timed out after {timeout}s", file=sys.stderr)
    elif completed.returncode == 0:
        print("[run-asan] js EXECUTION VERIFIED (post-run, rc=0)", file=sys.stderr)
    else:
        print(f"[run-asan] js EXECUTION INCONCLUSIVE (post-run, rc={completed.returncode})", file=sys.stderr)
    return completed.returncode


def run_xpcshell(option_string: str, timeout: int, args: list[str]) -> int:
    if not args:
        print("Usage: run-asan xpcshell <testcase.js> [extra args...]", file=sys.stderr)
        return 1
    testcase, *extra = args
    xpcshell = BASE_ENV.get("ASAN_XPCSHELL", str(BUILD_DIR / "dist/bin/xpcshell"))
    app = Path(BASE_ENV.get("ASAN_APP", str(BUILD_DIR / "dist/Nightly.app")))
    appdir = Path(BASE_ENV.get("ASAN_XPCSHELL_APPDIR", str(app / "Contents/Resources/browser")))
    command = [xpcshell, testcase]
    browser = browser_binary()
    if sys.platform == "darwin" and os.access(browser, os.X_OK) and appdir.is_dir():
        command = [browser, "--xpcshell", "-g", str(BUILD_DIR / "dist/bin"), "-a", str(appdir), "-m", testcase]
    if not os.access(command[0], os.X_OK):
        print(f"[run-asan] xpcshell runner missing: {command[0]}", file=sys.stderr)
        print("[run-asan] Build with ff-bsan asan first (the build-asan build produces xpcshell).", file=sys.stderr)
        return 2
    environment = runtime_env(option_string)
    environment["MOZ_DISABLE_CONTENT_SANDBOX"] = "1"
    completed = run_timeout([*command, *extra], timeout, env=environment)
    if completed.returncode == 124:
        print(f"[run-asan] xpcshell timed out after {timeout}s", file=sys.stderr)
    elif completed.returncode == 0:
        print("[run-asan] xpcshell EXECUTION VERIFIED (post-run, rc=0)", file=sys.stderr)
    else:
        print(f"[run-asan] xpcshell EXECUTION INCONCLUSIVE (post-run, rc={completed.returncode})", file=sys.stderr)
    return completed.returncode


def run_js_diff(option_string: str, timeout: int, args: list[str]) -> int:
    if not args:
        print("Usage: run-asan js-diff <testcase.js> [extra args...]", file=sys.stderr)
        return 1
    testcase, flags, script_args = split_js_args(args)
    eager = CONFIG.s4_diff_pairs.get("jit_eager", []) if CONFIG else []
    off = CONFIG.s4_diff_pairs.get("jit_off", []) if CONFIG else []
    eager = eager or ["--ion-eager"]
    off = off or ["--no-ion"]
    js = BASE_ENV.get("ASAN_JS", str(BUILD_DIR / "dist/bin/js"))
    print(f"=== Running with {' '.join(eager)} (JIT eager) ===", file=sys.stderr)
    with capture_timeout(
        [js, *eager, *flags, *testcase, *script_args], timeout,
        env=runtime_env(option_string),
    ) as (eager_run, eager_out):
        print(f"=== Running with {' '.join(off)} (JIT off) ===", file=sys.stderr)
        with capture_timeout(
            [js, *off, *flags, *testcase, *script_args], timeout,
            env=runtime_env(option_string),
        ) as (off_run, off_out):
            print(f"=== {' '.join(eager)} output ===")
            copy_file(eager_out, sys.stdout.buffer)
            print(f"\n=== {' '.join(off)} output ===")
            copy_file(off_out, sys.stdout.buffer)
            print()
            result = 0
            if filecmp.cmp(eager_out, off_out, shallow=False):
                print("[run-asan] DIFFERENTIAL: outputs MATCH (no divergence)", file=sys.stderr)
            else:
                result = 1
                print("[run-asan] DIFFERENTIAL: outputs DIFFER - potential JIT bug!", file=sys.stderr)
            if file_contains(eager_out, b"ERROR: AddressSanitizer"):
                print(f"[run-asan] CRASH in {' '.join(eager)} mode", file=sys.stderr)
                result = 1
            if file_contains(off_out, b"ERROR: AddressSanitizer"):
                print(f"[run-asan] CRASH in {' '.join(off)} mode", file=sys.stderr)
                result = 1
            return result


def resolve_command(name: str) -> str:
    found = shutil.which(name)
    return found or name


def run_generic(option_string: str, timeout: int, args: list[str]) -> int:
    if not args:
        print("Usage: run-asan generic <testcase> [target args...]", file=sys.stderr)
        return 1
    testcase, *extra = args
    binary = BASE_ENV.get("ASAN_GENERIC_BIN", "")
    if not binary and CONFIG and CONFIG.asan_bin:
        binary = CONFIG.resolve_path(CONFIG.asan_bin)
    if not binary and CONFIG and CONFIG.runner_bin:
        binary = shutil.which(CONFIG.runner_bin) or (
            CONFIG.runner_bin if os.access(CONFIG.runner_bin, os.X_OK) else CONFIG.resolve_path(CONFIG.runner_bin)
        )
    if not binary:
        print("[run-asan] generic runner unset (and no asan_bin/runner.bin in target.toml)", file=sys.stderr)
        print("[run-asan] set one of:\n  - asan_bin\n  - [runner] bin = ...\n  - ASAN_GENERIC_BIN=", file=sys.stderr)
        return 2
    binary = resolve_command(binary)
    if not os.access(binary, os.X_OK):
        print(f"[run-asan] generic runner not executable / not on PATH: {binary}", file=sys.stderr)
        return 2
    disabled = BASE_ENV.get("ASAN_GENERIC_DISABLE_OPTIONS") == "1" or bool(CONFIG and CONFIG.sanitizers_explicitly_disabled)
    environment = runtime_env(option_string, "none" if disabled else "asan")
    offline = not disabled and sanitizer.symbolize_available()
    if offline:
        environment["ASAN_OPTIONS"] += ":symbolize=0"
    command = [binary]
    if BASE_ENV.get("ASAN_GENERIC_SKIP_TESTCASE", "0") != "1":
        command.append(testcase)
    command.extend(extra)
    if offline:
        with capture_timeout(
            command, timeout, rss_mb=sanitizer.generic_rss_limit_mb(BASE_ENV),
            env=environment,
        ) as (completed, report):
            sanitizer.symbolize_file(report)
            copy_file(report, sys.stdout.buffer)
    else:
        completed = run_timeout(
            command, timeout, rss_mb=sanitizer.generic_rss_limit_mb(BASE_ENV),
            env=environment,
        )
    if completed.returncode == 124:
        print(f"[run-asan] generic runner timed out after {timeout}s", file=sys.stderr)
    elif completed.returncode == 0:
        print("[run-asan] generic EXECUTION VERIFIED (post-run, rc=0)", file=sys.stderr)
    else:
        print(f"[run-asan] generic EXECUTION INCONCLUSIVE (post-run, rc={completed.returncode})", file=sys.stderr)
    return completed.returncode


def require_fuzzer() -> tuple[str, int]:
    fuzzer = BASE_ENV.get("FUZZER", "")
    if not fuzzer:
        print("Error: FUZZER env var must be set.", file=sys.stderr)
        return "", 1
    if not sanitizer.validate_fuzzer_name(fuzzer):
        print(f"Error: FUZZER must match ^[A-Za-z_][A-Za-z0-9_]*$ (got '{fuzzer}')", file=sys.stderr)
        return "", 2
    return fuzzer, 0


def fuzz_environment(option_string: str, fuzzer: str) -> dict[str, str]:
    environment = runtime_env(option_string)
    environment.update({
        "FUZZER": fuzzer, "MOZ_RUN_GTEST": "1", "MOZ_FUZZ": "1",
        "LIBFUZZER": "1", "MOZ_DISABLE_CONTENT_SANDBOX": "1",
    })
    return environment


def run_fuzz(option_string: str, timeout: int, args: list[str], repro: bool = False) -> int:
    fuzzer, error = require_fuzzer()
    if error:
        return error
    if fuzzer == "list" and not repro:
        if not Path(TARGET_ROOT).is_dir():
            print(f"Error: source tree not found at {TARGET_ROOT}", file=sys.stderr)
            return 1
        print("Registered fuzz targets (MOZ_FUZZING_INTERFACE_{RAW,STREAM}):")
        print("\n".join(firefox_fuzz_targets(TARGET_ROOT)))
        return 0
    if repro and not args:
        print("Error: provide a crash file to reproduce.", file=sys.stderr)
        return 1
    clean_args = [
        str(Path(arg).resolve()) if repro and not arg.startswith("-") and Path(arg).is_file() else arg
        for arg in args if repro or not arg.startswith("-fork=")
    ]
    crash_dir = Path(BASE_ENV.get("FUZZ_CRASH_DIR", str(sanitizer.default_fuzz_crash_dir(BASE_ENV))))
    crash_dir.mkdir(parents=True, exist_ok=True)
    completed = run_timeout(
        [browser_binary(), *clean_args], timeout, kill=True, cwd=crash_dir,
        env=fuzz_environment(option_string, fuzzer),
    )
    if completed.returncode in {124, 137}:
        print(f"[run-asan] Fuzz {'repro ' if repro else ''}killed after {timeout}s", file=sys.stderr)
    if not repro:
        noise = crash_dir / "crash-da39a3ee5e6b4b0d3255bfef95601890afd80709"
        if noise.is_file():
            destination = crash_dir / "shutdown-noise" / f"{noise.name}.{int(time.time())}"
            destination.parent.mkdir(exist_ok=True)
            noise.replace(destination)
        print(f"[run-asan] Fuzz artifacts (if any): {crash_dir}", file=sys.stderr)
    return 0 if not repro else completed.returncode


def run_fuzz_js(option_string: str, timeout: int, args: list[str]) -> int:
    fuzzer, error = require_fuzzer()
    if error:
        return error
    binary = BUILD_DIR / "dist/bin/fuzz-tests"
    if not os.access(binary, os.X_OK):
        print(f"Error: fuzz-tests binary not found at {binary}. Run ff-bsan asan first.", file=sys.stderr)
        return 1
    clean_args = [
        str(Path(arg).resolve()) if not arg.startswith("-") and Path(arg).exists() else arg
        for arg in args if not arg.startswith("-fork=")
    ]
    crash_dir = Path(BASE_ENV.get("FUZZ_CRASH_DIR", str(sanitizer.default_fuzz_crash_dir(BASE_ENV))))
    crash_dir.mkdir(parents=True, exist_ok=True)
    run_timeout([str(binary), *clean_args], timeout, cwd=crash_dir, env=runtime_env(option_string) | {"FUZZER": fuzzer})
    print(f"[run-asan] Fuzz artifacts (if any): {crash_dir}", file=sys.stderr)
    return 0


def main(argv: list[str]) -> int:
    modes = {"browser", "browser-minimal", "js", "xpcshell", "js-diff", "generic", "fuzz", "fuzz-repro", "fuzz-js"}
    if not argv or argv[0] not in modes:
        print("Usage: run-asan {browser|browser-minimal|js|xpcshell|js-diff|generic|fuzz|fuzz-repro|fuzz-js} [args...]")
        return 1
    mode, args = argv[0], argv[1:]
    sanitizer.warn_if_disabled("asan", CONFIG)
    normal_timeout = int(BASE_ENV.get("ASAN_TIMEOUT", "15"))
    if mode == "browser": return run_browser(options("full"), normal_timeout, args)
    if mode == "browser-minimal": return run_browser(options("minimal"), normal_timeout, args)
    if mode == "js": return run_js(options("js"), int(BASE_ENV.get("ASAN_TIMEOUT", "10")), args)
    if mode == "xpcshell": return run_xpcshell(options("xpcshell"), normal_timeout, args)
    if mode == "js-diff": return run_js_diff(options("js"), int(BASE_ENV.get("ASAN_TIMEOUT", "10")), args)
    if mode == "generic": return run_generic(options("full"), normal_timeout, args)
    if mode == "fuzz": return run_fuzz(options("fuzz"), int(BASE_ENV.get("FUZZ_ASAN_TIMEOUT", "600")), args)
    if mode == "fuzz-repro": return run_fuzz(options("fuzz-repro"), int(BASE_ENV.get("ASAN_FUZZ_REPRO_TIMEOUT", "20")), args, True)
    return run_fuzz_js(options("fuzz"), int(BASE_ENV.get("FUZZ_ASAN_TIMEOUT", "600")), args)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
