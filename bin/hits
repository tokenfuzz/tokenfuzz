#!/usr/bin/env python3
"""Run a testcase under SanitizerCoverage and report symbol reachability."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import os
import re
import shutil
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))

import edges
import sanitizer
import target_config
from timeout import run_timeout

NOISE_RE = re.compile(
    r"ne_context_new|cubeb_|nrappkit|nspr|nss_init|sqlite3|^ld-|^dyld_|gmp_|"
    r"dns_init|libsystem_|CoreFoundation|NSApplication|XPCOMGlueLoad|nsAppRunner|"
    r"NS_LogInit|InitGlobalCallback|GeckoMain|XRE_main$|loadXULBundle|"
    r"MOZ_NewProcessBinding"
)
PROFILE_PREFS = '''user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.tabs.warnOnClose", false);
user_pref("dom.allow_scripts_to_close_windows", true);
user_pref("devtools.console.stdout.content", true);
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("browser.startup.page", 0);
'''


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(description=__doc__)
    result.add_argument("--testcase", required=True)
    result.add_argument("--want", required=True)
    result.add_argument("--mode", choices=("browser", "js"), default="browser")
    result.add_argument("--timeout", type=int, default=20)
    result.add_argument("--save")
    result.add_argument("--log")
    result.add_argument("--slug", default=os.environ.get("TARGET_SLUG", ""))
    result.add_argument("--agent", default=os.environ.get("AUDIT_AGENT_NUM", os.environ.get("AGENT_NUM", "0")))
    result.add_argument("extra", nargs=argparse.REMAINDER)
    return result


def llvm_tool(name: str, override: str = "") -> str:
    return override or sanitizer.llvm_tool(name)


def stat_key(path: Path) -> str:
    stat = path.stat()
    return f"{path}:{int(stat.st_mtime)}:{stat.st_size}"


def cache_dir() -> Path:
    base = os.environ.get("RESULTS_DIR", os.environ.get("LOGDIR", ""))
    if base:
        result = Path(base) / ".hits-cache"
    else:
        result = Path(tempfile.gettempdir()) / f"audit-hits-cache-{os.environ.get('USER', 'user')}"
    result.mkdir(parents=True, exist_ok=True)
    return result


def probe_sancov(label: str, binary: Path) -> None:
    if os.environ.get("HITS_SKIP_SANCOV_PROBE") == "1":
        return
    key_text = stat_key(binary)
    cache = cache_dir() / f"sancov-{hashlib.sha1(key_text.encode()).hexdigest()}.ok"
    if cache.is_file() and cache.stat().st_size:
        return
    if sys.platform == "darwin":
        command = ["otool", "-l", str(binary)]
        needle = "sectname __sancov_guards"
    else:
        tool = shutil.which("readelf") or shutil.which("llvm-readelf") or shutil.which("objdump")
        if not tool:
            raise RuntimeError(f"cannot inspect ELF sections for {label} ({binary}): install binutils or LLVM tools")
        command = [tool, "-WS" if Path(tool).name == "readelf" else "-S" if Path(tool).name == "llvm-readelf" else "-h", str(binary)]
        needle = "__sancov_guards"
    completed = subprocess.run(command, capture_output=True, text=True, check=False)
    output = completed.stdout + completed.stderr
    if completed.returncode:
        raise RuntimeError(f"{Path(command[0]).name} failed on {label} ({binary}): {output or '<no output>'}")
    if needle not in output:
        raise RuntimeError(f"{label} lacks sancov instrumentation (__sancov_guards section not present in {binary}) - rebuild with ff-bsan coverage")
    cache.write_text(key_text + "\n")


class Hits:
    def __init__(self, args: argparse.Namespace):
        self.args = args
        self.testcase = Path(args.testcase)
        if not self.testcase.is_file():
            raise ValueError(f"testcase not found: {self.testcase}")
        try:
            self.want = re.compile(args.want)
        except re.error as exc:
            raise ValueError(f"invalid --want regex: {exc}") from exc
        try:
            self.config = target_config.load(self.testcase)
        except (FileNotFoundError, ValueError):
            self.config = None
        self.target_root = Path(self.config.target_root if self.config else os.environ.get("TARGET_ROOT", ROOT / "targets/firefox"))
        self.asan_build = sanitizer.build_dir("asan", str(self.target_root))
        self.build = sanitizer.build_dir("asan-cov", str(self.target_root))
        self.app = Path(os.environ.get("COV_APP", self.build / "dist/Nightly.app"))
        self.browser = Path(os.environ.get("COV_BROWSER", self._browser_from_config()))
        self.xul = Path(os.environ.get("COV_XUL", self._default_xul()))
        self.js = Path(os.environ.get("COV_JS", self.build / "dist/bin/js"))
        self.sancov = Path(llvm_tool("sancov", os.environ.get("SANCOV", "")))
        self.symbolizer = Path(llvm_tool("llvm-symbolizer", os.environ.get("SYMBOLIZER", "")))
        self.edge_count = 0
        self.new_edges = 0

    def _browser_from_config(self) -> Path:
        if self.config and self.config.asan_bin:
            configured = self.config.asan_bin
            configured = configured.replace(self.asan_build.name + "/", self.build.name + "/")
            return Path(self.config.resolve_path(configured))
        if sys.platform == "darwin":
            return self.build / "dist/Nightly.app/Contents/MacOS/firefox"
        return self.build / "dist/bin/firefox"

    def _default_xul(self) -> Path:
        if sys.platform == "darwin":
            return self.build / "dist/Nightly.app/Contents/MacOS/XUL"
        return self.build / "dist/bin/libxul.so"

    def validate(self) -> None:
        if self.args.mode == "browser":
            if not os.access(self.browser, os.X_OK):
                raise RuntimeError(f"coverage browser missing: {self.browser} - run ff-bsan coverage first")
            if not self.xul.is_file():
                raise RuntimeError(f"coverage XUL missing: {self.xul} - run ff-bsan coverage first")
            probe_sancov("XUL", self.xul)
        else:
            if not os.access(self.js, os.X_OK):
                raise RuntimeError(f"coverage js shell missing: {self.js}")
            probe_sancov("coverage js shell", self.js)
        if not os.access(self.sancov, os.X_OK):
            raise RuntimeError(f"sancov not found at {self.sancov} - install LLVM tools or set LLVM_PREFIX")
        if not os.access(self.symbolizer, os.X_OK):
            raise RuntimeError(f"llvm-symbolizer not found at {self.symbolizer} - install LLVM tools or set LLVM_PREFIX")

    def append_verdict(self, verdict: str, frame: str = "") -> None:
        if not self.args.log:
            return
        destination = Path(self.args.log)
        destination.parent.mkdir(parents=True, exist_ok=True)
        timestamp = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        with destination.open("a") as stream:
            stream.write(
                f"{verdict} {timestamp} testcase={self.testcase} want={self.args.want!r} "
                f"edges={self.edge_count} new={self.new_edges} frame={frame or '<none>'}\n"
            )

    def run_target(self, coverage_dir: Path) -> tuple[Path, int | None]:
        option_string = f"detect_leaks=0:coverage=1:halt_on_error=0:coverage_dir={coverage_dir}"
        environment = sanitizer.prepare_runtime_env("asan")
        environment["ASAN_OPTIONS"] = option_string
        output = coverage_dir / "target-output.raw"
        if self.args.mode == "js":
            flags: list[str] = []
            script_args: list[str] = []
            for arg in self.args.extra:
                if not script_args and arg.startswith("-"):
                    flags.append(arg)
                else:
                    script_args.append(arg)
            with output.open("wb") as stream:
                run_timeout(
                    [str(self.js), *flags, str(self.testcase), *script_args],
                    self.args.timeout, env=environment,
                    stdout=stream, stderr=subprocess.STDOUT,
                )
            return output, None

        environment.update({"MOZ_DISABLE_CONTENT_SANDBOX": "1", "MOZ_HEADLESS": "1"})
        with tempfile.TemporaryDirectory(prefix="hits-profile-") as profile_name:
            profile = Path(profile_name)
            prefs = PROFILE_PREFS
            if os.environ.get("FIREFOX_EXTRA_PREFS"):
                prefs += "\n" + os.environ["FIREFOX_EXTRA_PREFS"] + "\n"
            (profile / "user.js").write_text(prefs)
            (profile / "prefs.js").write_text(prefs)
            with output.open("wb") as stream:
                process = subprocess.Popen(
                    [str(self.browser), "--profile", str(profile), "--no-remote", *self.args.extra, self.testcase.resolve().as_uri()],
                    stdout=stream, stderr=subprocess.STDOUT, env=environment,
                    start_new_session=True,
                )
                parent_pid = process.pid
                deadline = time.monotonic() + self.args.timeout
                while process.poll() is None and time.monotonic() < deadline:
                    time.sleep(0.1)
                # A browser parent can exit before content processes. Always
                # close the unique process group before reading coverage.
                try:
                    os.killpg(parent_pid, signal.SIGTERM)
                except ProcessLookupError:
                    pass
                group_deadline = time.monotonic() + 25
                while time.monotonic() < group_deadline:
                    try:
                        os.killpg(parent_pid, 0)
                    except ProcessLookupError:
                        break
                    time.sleep(0.1)
                else:
                    try:
                        os.killpg(parent_pid, signal.SIGKILL)
                    except ProcessLookupError:
                        pass
                try:
                    process.wait(timeout=1)
                except subprocess.TimeoutExpired:
                    process.kill()
                    process.wait()
            time.sleep(0.5)
            return output, parent_pid

    def binary_map(self) -> tuple[list[Path], Path]:
        dist = self.build / "dist/bin"
        if self.args.mode == "js":
            return [self.js, *dist.glob("*.dylib"), *dist.glob("*.so")], self.js
        if sys.platform == "darwin":
            mac = self.app / "Contents/MacOS"
            return [self.browser, self.xul, mac / "plugin-container", *mac.glob("*.dylib")], self.xul
        return [self.browser, self.xul, dist / "plugin-container", *dist.glob("*.so")], self.xul

    def symbolize(self, coverage_dir: Path, parent_pid: int | None) -> tuple[list[str], list[str]]:
        binaries, fallback = self.binary_map()
        by_name = {path.name: path for path in binaries if path.is_file()}
        all_lines: list[str] = []
        content_lines: list[str] = []
        for coverage in coverage_dir.glob("*.sancov"):
            stem = coverage.name.removesuffix(".sancov")
            base, _, pid_text = stem.rpartition(".")
            target = by_name.get(base, fallback)
            with tempfile.TemporaryDirectory(prefix="hits-symbolize-") as tmp:
                addresses = Path(tmp) / "addresses"
                symbolized = Path(tmp) / "symbolized"
                with addresses.open("wb") as output:
                    subprocess.run(
                        [str(self.sancov), "-print", str(coverage)],
                        stdout=output, stderr=subprocess.DEVNULL, check=False,
                    )
                with addresses.open("rb") as source, symbolized.open("wb") as output:
                    subprocess.run(
                        [str(self.symbolizer), "-e", str(target), "--inlines", "--demangle"],
                        stdin=source, stdout=output, stderr=subprocess.DEVNULL, check=False,
                    )
                with symbolized.open(encoding="utf-8", errors="replace") as source:
                    for raw in source:
                        line = raw.rstrip("\n")
                        all_lines.append(line)
                        if self.args.mode == "js" or parent_pid is None or pid_text != str(parent_pid):
                            content_lines.append(line)
        return all_lines, content_lines

    def write_hits(self, lines: list[str], content: list[str]) -> Path:
        if self.args.save:
            destination = Path(self.args.save)
        else:
            fd, name = tempfile.mkstemp(prefix="hits-list-")
            os.close(fd)
            destination = Path(name)
        destination.write_text("\n".join(lines) + ("\n" if lines else ""))
        Path(str(destination) + ".content").write_text("\n".join(content) + ("\n" if content else ""))
        return destination

    def update_edges(self, hits_file: Path) -> None:
        try:
            extracted = edges.extract(hits_file)
            self.edge_count = len(extracted)
            if self.args.slug and extracted:
                with tempfile.NamedTemporaryFile(mode="w") as run_edges:
                    run_edges.write("\n".join(extracted) + "\n")
                    run_edges.flush()
                    self.new_edges = len(edges.diff_new(self.args.slug, run_edges.name))
                    if self.new_edges:
                        edges.record_run(self.args.slug, str(self.args.agent), run_edges.name)
        except OSError:
            self.edge_count = self.new_edges = 0

    def result(self, hits_file: Path, all_lines: list[str], content: list[str]) -> int:
        self.update_edges(hits_file)
        print(f"EDGES_HIT: {self.edge_count}")
        print(f"NEW_EDGES: {self.new_edges}")
        content_match = next((line for line in content if self.want.search(line)), "")
        full_match = next((line for line in all_lines if self.want.search(line)), "")
        match = content_match or full_match
        if match:
            if not content_match and content and not any(value in self.args.want for value in ("chrome/", "browser/", "toolkit/components/")):
                print(f"MISSED - want symbol only seen in parent process (likely startup noise): {match}")
                print(f"hits-file: {hits_file}", file=sys.stderr)
                self.append_verdict("MISSED:", f"parent-only:{match}")
                return 1
            print(f"HIT: {match}")
            print(f"hits-file: {hits_file}", file=sys.stderr)
            self.append_verdict("HIT:", match)
            return 0
        closest = self.closest(content, all_lines)
        if closest:
            print(f"MISSED - closest reached: {closest}")
            self.append_verdict("MISSED:", closest)
        else:
            print("MISSED - NO_PROXIMITY: testcase ran but no want-related code executed (likely upstream guard rejection)")
            self.append_verdict("MISSED:", "NO_PROXIMITY")
        print(f"hits-file: {hits_file}", file=sys.stderr)
        return 1

    def closest(self, content: list[str], all_lines: list[str]) -> str:
        tokens = re.findall(r"[A-Za-z_][A-Za-z_0-9:./]+", self.args.want.replace("\\", ""))
        tokens = sorted(set(tokens), key=lambda token: (-len(token), token))
        for token in tokens:
            if len(token) < 5:
                continue
            for label, pool in (("content", content), ("full", all_lines)):
                line = next((line for line in pool if token in line and not NOISE_RE.search(line)), "")
                if line:
                    return f"{line} [pool={label} (token={token})]"
        line = next((line for line in content if not NOISE_RE.search(line)), "")
        return f"{line} [pool=content (denoised head)]" if line else ""

    def run(self) -> int:
        self.validate()
        with tempfile.TemporaryDirectory(prefix="hits-cov-") as coverage_name:
            coverage_dir = Path(coverage_name)
            output, parent_pid = self.run_target(coverage_dir)
            if self.args.mode == "browser" and output.stat().st_size == 0:
                print("EXEC_FAIL - browser produced no stdout/stderr at all (launch failure)")
                self.append_verdict("EXEC_FAIL:")
                return 3
            all_lines, content = self.symbolize(coverage_dir, parent_pid)
            hits_file = self.write_hits(all_lines, content)
            if not all_lines:
                print("NO_COVERAGE - no sancov files or empty hit list (check mozconfig + ASAN_OPTIONS coverage=1)")
                print(f"hits-file: {hits_file}", file=sys.stderr)
                self.append_verdict("NO_COVERAGE:")
                return 3
            return self.result(hits_file, all_lines, content)


def main(argv: list[str] | None = None) -> int:
    args = parser().parse_args(argv)
    if args.extra and args.extra[0] == "--":
        args.extra.pop(0)
    try:
        return Hits(args).run()
    except (ValueError, RuntimeError, OSError) as exc:
        print(f"[hits] {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
