#!/usr/bin/env python3
"""bin/cluster-findings — group FIND-* dirs by shared root cause.

Findings are filed without sanitizer output and span heterogeneous bug
classes (memory-safety, auth, injection, info-disclosure, crypto, race,
config, logic, ...). Every finding gets ONE identity computed from its
report alone — identical for harness, recon, and model-direct findings:

  (class, file, line) — the normalized issue class at the source site the
                report pins. Class is normalized first (mechanism labels like
                integer-overflow fold into memory-safety), and the line is the
                discriminator that keeps distinct bugs in one large function
                apart where (file, func) alone would fuse them.
  crash state — ClusterFuzz-normalized top frames, when the report embeds a
                sanitizer stack (reused from lib/stack_frames.py).

Findings merge on an identical (class, file, line) site, or an identical crash
state (lib/finding_dedup.py). Both signals are deterministic and LLM-free.
See lib/finding_signature.py for the per-field extraction.

Output (mirrors bin/cluster-crashes):
  * <results>/findings/FINDING-CLUSTERS.md
                                           — sortable markdown summary
  * output/<target>/FINDING-CLUSTERS.md   — cross-backend aggregate summary
  * each FIND-*/{report.md,REPORT.md}    — Cluster: <ID> field
  * non-canonical members get .dup-of    — pointer to canonical FIND id

Usage:
  bin/cluster-findings <results-dir>            # writes FINDING-CLUSTERS.md
  bin/cluster-findings <results-dir> --dry-run  # print plan only
  bin/cluster-findings <results-dir> --json     # emit JSON to stdout
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import tempfile
from pathlib import Path

SCRIPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import finding_signature  # noqa: E402
import finding_dedup  # noqa: E402
from cluster_common import (  # noqa: E402
    exact_child_file,
    remove_legacy_cluster_files,
    render_member_report_siblings,
    render_md_sibling,
    run_under_aggregate_lock,
    texts_differ_beyond_padding,
)


_SEVERITY_RANK = {"critical": 4, "high": 3, "medium": 2, "low": 1, "info": 0}


def _atomic_write_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp",
                               dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            fh.write(text)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def _read_text(path: Path) -> str:
    try:
        return path.read_text("utf-8", errors="replace")
    except OSError:
        return ""


def _find_report(find_dir: Path) -> Path | None:
    return exact_child_file(
        find_dir,
        ("REPORT.md", "report.md", "description.md", "analysis.md", "README.md"),
    )


def _read_llm_cache(find_dir: Path) -> dict:
    p = find_dir / ".llm-find-quality.json"
    if not p.is_file():
        return {}
    try:
        return json.loads(p.read_text("utf-8", errors="replace"))
    except (OSError, json.JSONDecodeError):
        return {}


def _severity_rank(severity: str) -> int:
    return _SEVERITY_RANK.get((severity or "").strip().lower(), 0)


# Proven Exploit-Maturity (E:P reproducer/probe, E:A active) in the report's
# CVSS vector; `/E:` appears only there, so this never matches prose.
_PROVEN_E_RE = re.compile(r"/E:[PA]\b")


def _evidence_rank(report_text: str) -> int:
    """1 if the report shows proven exploit evidence (E:P/E:A), else 0.

    First key in the canonical pick, so a proven member represents a mixed
    cluster; when members share an evidence tier (e.g. an all-E:U cluster)
    severity alone decides, unchanged — a real unproven High is never demoted.
    """
    return 1 if _PROVEN_E_RE.search(report_text or "") else 0


def _severity_label(severity: str) -> str:
    """Display label for a finding's severity in the cluster table.

    A blank severity means the find-quality gate has not yet rendered a
    final verdict on this finding — typical when the LLM has been disabled
    for a run, or when a finding is pinned by `.keep`/`.reviewed` and so
    bypassed the gate. Render `Pending` (over a bare `—`) so the reader can
    tell missing-because-unscored from missing-because-no-data, and so it
    is visually distinct from the score column when both are blank.
    Genuinely rejected findings are moved to findings-rejected/ by the
    gate (the in-call quorum settles every reject before the gate exits),
    so they never reach this table.
    """
    s = (severity or "").strip().lower()
    if not s:
        return "Pending"
    return s.capitalize()


_STRATEGY_BARE_RE = re.compile(
    r"^Strategy:\s*(?P<val>.+?)\s*$", re.MULTILINE | re.IGNORECASE,
)
_STRATEGY_TABLE_RE = re.compile(
    r"^\|\s*Strategy\s*\|\s*(?P<val>.+?)\s*\|\s*$", re.MULTILINE | re.IGNORECASE,
)
_STRATEGY_TOKEN_RE = re.compile(r"\b(S[1-8]|REF)\b", re.IGNORECASE)


def _extract_strategy(report_text: str) -> str:
    """Return the canonical S1..S8 / REF token recorded in the FIND report, or "".

    Matches bin/cluster-crashes' extractor; accepts both the bare-label and
    Fields-table forms. Free-form labels collapse to the first S<N>/REF token
    so FINDING-CLUSTERS.md's Strategy column stays terse."""
    for rx in (_STRATEGY_BARE_RE, _STRATEGY_TABLE_RE):
        m = rx.search(report_text)
        if not m:
            continue
        val = m.group("val").strip()
        if not val or val in {"—", "-", "TBD", "?"}:
            continue
        tok = _STRATEGY_TOKEN_RE.search(val)
        return tok.group(1).upper() if tok else val
    return ""


def _signature(find_dir: Path, target_root: str) -> dict:
    report = _find_report(find_dir)
    text = _read_text(report) if report else ""
    cache = _read_llm_cache(find_dir)
    # Identity is a pure function of the report: class, file, line, and
    # crash-state are parsed from report.md (the find-quality cache only
    # supplies the accepted class as a hint). This single source is identical
    # for harness, recon, and model-direct findings; nothing here depends on
    # which produced the report.
    sig = finding_signature.finding_signature(
        text,
        llm_class=cache.get("class", "") if cache.get("accept") else "",
        target_root=target_root,
    )
    sig["id"] = find_dir.name
    sig["path"] = str(find_dir)
    sig["report"] = str(report) if report else ""
    sig["report_text"] = text
    sig["title"] = _report_title(text)
    if not text:
        sig["kind"] = "missing"
        sig["key"] = (sig["class"], "", find_dir.name)
    # Severity comes from the REPORT — the CVSS v4.0 score that
    # bin/severity writes and --regenerate refreshes — so the cluster
    # table always agrees with the report it links to. The find-quality
    # cache's coarse severity is only a fallback for a report that has not
    # been scored yet (carries no Severity line), which would otherwise show
    # as Pending. Mirrors how bin/cluster-crashes already sources severity.
    report_level, _report_rank, report_score = finding_signature.extract_severity(text)
    if report_level and report_level != "—":
        sev = report_level.lower()
    else:
        sev = (cache.get("severity") or "") if cache.get("accept") else ""
    sig["severity"] = sev
    sig["severity_label"] = _severity_label(sev)
    sig["severity_rank"] = _severity_rank(sev)
    sig["severity_score"] = report_score
    sig["evidence_rank"] = _evidence_rank(text)
    sig["strategy"] = _extract_strategy(text)
    status = "OK" if report and text else "NEEDS CONTENT"
    if (find_dir / ".needs-content").is_file():
        status = "NEEDS CONTENT"
    elif (find_dir / ".needs-attention").is_file():
        status = "NEEDS ATTENTION"
    if (find_dir / ".reviewed").is_file() or (find_dir / ".keep").is_file():
        status = "OK (override)"
    sig["status"] = status
    return sig


def _report_title(text: str) -> str:
    """First H1 of the report, used as a lexical signal for clustering."""
    for line in (text or "").splitlines():
        s = line.strip()
        if s.startswith("# "):
            return s.lstrip("#").strip()
    return ""


def _component_cluster_id(canonical_sig: dict, display_key: str = "id") -> str:
    """Stable, component-UNIQUE FCL id anchored on the canonical finding.

    Evidence clustering can leave two components with identical canonical
    keys (e.g. same file:func that bias-to-separate kept apart), so the id
    folds in the canonical finding's own identifier to avoid collisions
    while staying stable as long as the canonical member is stable."""
    key = tuple(canonical_sig.get("key") or (canonical_sig.get("class", ""),))
    anchor = canonical_sig.get(display_key, canonical_sig["id"])
    return finding_signature.cluster_id(key + (anchor,))


def _make_clusters(sigs: list[dict], display_key: str = "id") -> list[dict]:
    """Group signatures into clusters via deterministic finding_dedup.

    Components come from union-find over high-precision auto-merges only
    (a shared (class, file, line) site or crash state — see
    lib/finding_dedup.py). The canonical member's signature supplies the
    display key/kind and class, so rendering, report stamping, and .dup-of
    markers are unchanged. Every member of a site-merged cluster already
    carries the canonical class (it is part of the merge edge).

    display_key selects the member identifier ("id" per-results, or
    "display_id" = "<agent>/<id>" cross-agent, which is unique when two
    agents file the same bare FIND id)."""
    def disp(s: dict) -> str:
        return s.get(display_key, s["id"])

    by_disp = {disp(s): s for s in sigs}
    # finding_dedup keys on record["id"]; feed it the (unique) display id
    # so cross-agent findings with a shared bare id don't collide.
    records: list[dict] = []
    report_texts: dict[str, str] = {}
    for s in sigs:
        d = disp(s)
        r = dict(s)
        r["id"] = d
        records.append(r)
        report_texts[d] = s.get("report_text", "")

    components = finding_dedup.cluster(records, report_texts=report_texts)

    clusters: list[dict] = []
    for comp in components:
        members = [by_disp[i] for i in comp["members"]]
        # Canonical = proven-over-unproven, then severity, then id: an unproven
        # theory can't outrank a proven duplicate. One evidence tier → falls
        # through to severity, unchanged.
        canonical = max(members, key=lambda m: (
            m.get("evidence_rank", 0), m["severity_rank"], -_lex_rank(disp(m))))
        cid = _component_cluster_id(canonical, display_key)
        can_disp = disp(canonical)
        ordered = sorted(members, key=lambda m: (
            -m.get("evidence_rank", 0), -m["severity_rank"], _lex_rank(disp(m))))
        for m in members:
            m["cluster"] = cid
            m["is_canonical"] = (disp(m) == can_disp)
        strategies = sorted({m.get("strategy", "") for m in members if m.get("strategy")})
        clusters.append({
            "id": cid,
            "class": canonical.get("class", "") or "other",
            # key_kind/key drive the canonical's "Signature" display + the
            # cluster stamp; merged_via is how the CLUSTER was formed.
            "key_kind": canonical["kind"],
            "key": list(canonical["key"]),
            # The merge signals carried by the canonical member, so the
            # Signature column can render the actual algorithm — (class, file,
            # line) and/or crash state — not just the one that drove the merge.
            "file": canonical.get("file", ""),
            "line": canonical.get("line", ""),
            "crash_state": list(finding_dedup.crash_state(
                canonical.get("report_text", ""))),
            "merged_via": comp["merged_via"],
            "canonical": can_disp,
            "members": [disp(m) for m in ordered],
            # Per-member severity so a cross-condition cluster can be scored by
            # one condition's own members (mirrors bin/cluster-crashes). Findings
            # carry no numeric score, so score is 0.
            "member_severity": {
                disp(m): {
                    "level": m["severity_label"],
                    "rank": m["severity_rank"],
                    "score": 0,
                }
                for m in ordered
            },
            "size": len(members),
            "severity_label": canonical["severity_label"],
            "severity_rank": canonical["severity_rank"],
            "strategy": ", ".join(strategies),
            "status": _status_summary(members),
            "_full": members,
        })
    clusters.sort(key=lambda c: (
        -c["severity_rank"],
        -c["size"],
        c["id"],
    ))
    return clusters


def cluster_findings(findings_root: Path, target_root: str = "") -> list[dict]:
    sigs: list[dict] = []
    if not findings_root.is_dir():
        return sigs
    for d in sorted(findings_root.iterdir()):
        if not d.is_dir() or not d.name.startswith("FIND-"):
            continue
        sigs.append(_signature(d, target_root))
    return _make_clusters(sigs, display_key="id")


def _lex_rank(s: str) -> int:
    """Lower lexicographic id sorts as canonical."""
    return sum((256 ** (8 - i)) * ord(c) for i, c in enumerate(s[:8]))


# ── Output: FINDING-CLUSTERS.md + Cluster: stamp + .dup-of markers ──


_CLUSTER_LINE_RE = re.compile(r"^(Cluster:\s*).*$", re.MULTILINE)
_CLUSTER_TABLE_ROW_RE = re.compile(r"^(\|\s*Cluster\s*\|).*", re.MULTILINE)
_DEDUP_KEY_LINE_RE = re.compile(r"^(Dedup key:\s*).*$", re.MULTILINE)
_DEDUP_KEY_TABLE_ROW_RE = re.compile(r"^(\|\s*Dedup key\s*\|).*", re.MULTILINE)


def _move_leading_metadata_after_title(text: str) -> str:
    lines = text.splitlines()
    leading: list[str] = []
    rest_start = 0
    while rest_start < len(lines):
        line = lines[rest_start]
        if line.startswith("Cluster:") or line.startswith("Dedup key:") or (
            not line.strip() and leading
        ):
            leading.append(line)
            rest_start += 1
            continue
        break
    if not any(line.startswith("Cluster:") or line.startswith("Dedup key:") for line in leading):
        return text
    rest = lines[rest_start:]
    title_idx = next((i for i, line in enumerate(rest) if line.startswith("# ")), None)
    if title_idx is None:
        return text
    metadata = [line for line in leading if line.strip()]
    new_lines = rest[: title_idx + 1] + [""] + metadata + [""] + rest[title_idx + 1:]
    return "\n".join(new_lines) + ("\n" if text.endswith("\n") else "")


def _set_cluster_line(report_text: str, cluster_id: str, members: list[str],
                      own_id: str, canonical: str, kind: str,
                      key_text: str) -> str:
    siblings = [m for m in members if m != own_id]
    role = " (canonical)" if own_id == canonical else f" (duplicate of {canonical})"
    if siblings:
        if len(siblings) <= 4:
            sib_str = ", ".join(siblings)
        else:
            sib_str = ", ".join(siblings[:4]) + f", +{len(siblings) - 4} more"
        cell = f"{cluster_id} ({len(members)} reports: {sib_str}){role}"
    else:
        cell = f"{cluster_id} (singleton)"

    text = report_text
    if _CLUSTER_LINE_RE.search(text):
        text = _CLUSTER_LINE_RE.sub(lambda mm: f"{mm.group(1)}{cell}", text, count=1)
    else:
        # Keep the report title as the first visible line. Index generation
        # and human reviewers both prefer the issue title over dedup metadata.
        m = re.search(r"^# .*$", text, re.MULTILINE)
        if m:
            text = text[: m.end()] + f"\n\nCluster: {cell}" + text[m.end():]
        else:
            text = f"Cluster: {cell}\n" + text

    if _CLUSTER_TABLE_ROW_RE.search(text):
        text = _CLUSTER_TABLE_ROW_RE.sub(
            lambda mm: f"{mm.group(1)} {cell} |", text, count=1,
        )

    if key_text:
        dk_line = f"Dedup key: [{kind}] {key_text}"
        if _DEDUP_KEY_LINE_RE.search(text):
            text = _DEDUP_KEY_LINE_RE.sub(dk_line, text, count=1)
        else:
            # Insert directly after the Cluster: bare-label line.
            m = re.search(r"^Cluster:.*$", text, re.MULTILINE)
            if m:
                text = text[: m.end()] + f"\n{dk_line}" + text[m.end():]
        if _DEDUP_KEY_TABLE_ROW_RE.search(text):
            text = _DEDUP_KEY_TABLE_ROW_RE.sub(
                lambda mm: f"{mm.group(1)} [{kind}] {key_text} |", text, count=1,
            )
    return _move_leading_metadata_after_title(text)


def _key_display(key: list, kind: str) -> str:
    if kind == "loc":
        # key is (class, file, line) — or (class, file, func) when no line.
        f = key[1] if len(key) > 1 else ""
        tail = key[2] if len(key) > 2 else ""
        if f and tail:
            return f"{f}:{tail}"
        return f or tail
    if kind in ("title", "missing"):
        return key[2] if len(key) > 2 else ""
    return ""


def _signature_display(c: dict) -> str:
    """Render the merge signals the canonical finding carries, ` or `-joined.

    finding_dedup merges two findings on either an identical (class, file,
    line) site or an identical crash state. The Signature column shows the
    signals present on the canonical member so it reflects the actual
    algorithm: `(class, file, line)`, and ` or <crash state>` appended when
    the report embeds a sanitizer stack (the rare case for findings). The site
    term needs both file and line, as its merge edge does. Falls back to the
    canonical display key when no merge signal is present, so the cell is
    never blank."""
    parts: list[str] = []
    file = c.get("file", "")
    line = str(c.get("line", "") or "")
    if file and line:
        cls = c.get("class", "") or "other"
        parts.append(f"`({cls}, {file}, {line})`")
    state = c.get("crash_state") or ()
    if state:
        parts.append("`" + " → ".join(state) + "`")
    if parts:
        return " or ".join(parts)
    fallback = _key_display(c.get("key", []), c.get("key_kind", ""))
    return f"`{fallback}`" if fallback else "—"


def _status_summary(members: list[dict]) -> str:
    statuses = sorted({m.get("status", "OK") for m in members})
    return statuses[0] if len(statuses) == 1 else "; ".join(statuses)


def _write_dup_marker(find_path: Path, canonical: str, cluster_id: str,
                      key_kind: str, key_text: str) -> None:
    marker_text = (
        f"Marker: duplicate-of\n"
        f"Canonical: {canonical}\n"
        f"Cluster: {cluster_id}\n"
        f"Reason: same signature as {canonical} "
        f"([{key_kind}] {key_text})\n"
        f"Hint: review the canonical FIND and either merge "
        f"this report's evidence in or delete this dir.\n"
    )
    dup_marker = find_path / ".dup-of"
    if not dup_marker.is_file() or _read_text(dup_marker) != marker_text:
        _atomic_write_text(dup_marker, marker_text)


def _clear_dup_marker(find_path: Path) -> None:
    dup_marker = find_path / ".dup-of"
    if dup_marker.is_file():
        try:
            dup_marker.unlink()
        except OSError:
            pass


def update_reports(clusters: list[dict], dry_run: bool = False) -> int:
    n = 0
    for c in clusters:
        key_text = _key_display(c["key"], c["key_kind"])
        for m in c["_full"]:
            report_path = Path(m["report"]) if m.get("report") else None
            if report_path is None or not report_path.is_file():
                continue
            text = _read_text(report_path)
            new_text = _set_cluster_line(
                text, c["id"], c["members"], m["id"],
                c["canonical"], c["key_kind"], key_text,
            )
            if texts_differ_beyond_padding(text, new_text):
                if not dry_run:
                    _atomic_write_text(report_path, new_text)
                n += 1

            # .dup-of marker for non-canonical members. Canonical members
            # never carry a marker; deleting any stale marker keeps the
            # state consistent across re-runs.
            if m["id"] != c["canonical"]:
                if not dry_run:
                    _write_dup_marker(
                        Path(m["path"]), c["canonical"], c["id"],
                        c["key_kind"], key_text,
                    )
            else:
                if not dry_run:
                    _clear_dup_marker(Path(m["path"]))
    return n


def update_aggregate_reports(clusters: list[dict], dry_run: bool = False) -> int:
    """Stamp cross-agent cluster membership into each member report."""
    n = 0
    for c in clusters:
        key_text = _key_display(c["key"], c["key_kind"])
        for m in c["_full"]:
            report_path = Path(m["report"]) if m.get("report") else None
            if report_path is None or not report_path.is_file():
                continue
            own_display = m.get("display_id", m["id"])
            text = _read_text(report_path)
            new_text = _set_cluster_line(
                text, c["id"], c["members"], own_display,
                c["canonical"], c["key_kind"], key_text,
            )
            if texts_differ_beyond_padding(text, new_text):
                if not dry_run:
                    _atomic_write_text(report_path, new_text)
                n += 1

            find_path = Path(m["path"])
            if own_display != c["canonical"]:
                if not dry_run:
                    _write_dup_marker(
                        find_path, c["canonical"], c["id"],
                        c["key_kind"], key_text,
                    )
            else:
                if not dry_run:
                    _clear_dup_marker(find_path)
    return n


def _format_clusters_md(clusters: list[dict], findings_root: Path,
                        link_prefix: str = "findings/") -> str:
    lines = ["# Finding Clusters", ""]
    lines.append(
        f"_Auto-generated by bin/cluster-findings from `{findings_root.name}/`. "
        f"Sorted by max-member severity, then cluster size._  "
        f"Each row is a unique root cause; **Members** links to every "
        f"FIND-* report sharing the same signature. Duplicates carry a "
        f"`.dup-of` marker pointing at the canonical FIND. "
        f"A `Pending` severity means the find-quality gate has not "
        f"rendered a final verdict yet (typically because the LLM was "
        f"disabled for this run, or the finding is pinned by "
        f"`.keep`/`.reviewed` and bypassed the gate)."
    )
    lines.append("")
    n_findings = sum(c["size"] for c in clusters)
    n_unique = len(clusters)
    lines.append(f"**{n_findings} FIND dir(s) → {n_unique} unique cluster(s).**")
    if n_findings and n_unique:
        lines.append(f"Dedup ratio: {n_findings / max(n_unique, 1):.2f}x.")
    lines.append("")
    lines.append("| Severity | Cluster | Size | Class | Strategy | Signature | Canonical | Members | Status |")
    lines.append("|:---------|:--------|-----:|:------|:---------|:----------|:----------|:--------|:-------|")
    for c in clusters:
        sig_text = _signature_display(c)
        members = []
        for mid in c["members"]:
            link = _member_link(findings_root, mid, link_prefix)
            if mid == c["canonical"]:
                members.append(f"**{link}**")
            else:
                members.append(link)
        members_cell = ", ".join(members)
        canonical_link = _member_link(findings_root, c["canonical"], link_prefix)
        cls = c["class"] or "—"
        sev = c["severity_label"] or "Pending"
        strategy = c.get("strategy", "") or "—"
        lines.append(
            f"| {sev} | `{c['id']}` | {c['size']} | "
            f"{cls} | {strategy} | {sig_text} | {canonical_link} | "
            f"{members_cell} | {c.get('status', 'OK')} |"
        )
    lines.append("")
    # Footer: always point readers at the sibling rejected report. Live audit
    # and benchmark pool builders both write this named report, with INDEX.md
    # kept as a compatibility alias for older links.
    lines.append("---")
    lines.append("")
    lines.append(
        "_Findings triaged out as non-actionable (out-of-scope, false "
        "positive, or robustness-only) are tracked separately — see the "
        f"[rejected findings index]({_rejected_report_link(findings_root)})._"
    )
    lines.append("")
    return "\n".join(lines) + "\n"


def _resolve_report_basename(find_dir: Path) -> str:
    report = _find_report(find_dir)
    if report is not None:
        return report.name
    return "report.md"


def _member_link(findings_root: Path, member_id: str, link_prefix: str = "") -> str:
    name = _resolve_report_basename(findings_root / member_id)
    return f"[{member_id}]({link_prefix}{member_id}/{name})"


def _rejected_report_link(findings_root: Path) -> str:
    rejected_root = findings_root.parent / "findings-rejected"
    if not (rejected_root / "REJECTED-FINDINGS.md").is_file():
        return "../findings-rejected/INDEX.md"
    return "../findings-rejected/REJECTED-FINDINGS.md"


def _derive_target_root(path: Path) -> str:
    """Derive the `targets/<slug>` strip-prefix from an output/<slug>/... path.

    Reports cite paths as `targets/<slug>/src/foo.cpp`; stripping this
    prefix yields the stable target-relative `src/foo.cpp`. The slug is the
    path from directly under `output/` up to the `<agent>/results` (or
    `logs`) marker, so a nested slug like `samples/sample-ruby` keeps every
    segment. Returns "" when no `output` ancestor is present (caller leaves
    paths as-is).
    """
    parts = path.parts
    if "output" not in parts:
        return ""
    tail = parts[parts.index("output") + 1:]
    if not tail:
        return ""
    # output/<slug...>/<agent>/{results,logs}/... — the slug is every segment
    # before the <agent> dir that owns the results/logs marker. Scan from the
    # RIGHT: the structural <agent>/results (or /logs) suffix is the deepest
    # one, so a slug component that happens to be named "results"/"logs"
    # (appearing earlier) is not mistaken for the marker.
    for marker in ("results", "logs"):
        if marker in tail:
            k = len(tail) - 1 - tail[::-1].index(marker)
            if k >= 2:
                return "targets/" + "/".join(tail[:k - 1])
    # No <agent>/results marker: the path is the bare output/<slug> target
    # root, so the whole tail is the slug.
    return "targets/" + "/".join(tail)


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("results_dir", type=Path,
                    help="Path containing findings/FIND-*/ subdirs, the findings/ dir itself, or an output/<slug>/ target root (aggregates every <agent>/results/findings/)")
    ap.add_argument("--target-root", default=os.environ.get("TARGET_ROOT", ""),
                    help="Strip this prefix from absolute paths in report text")
    ap.add_argument("--dry-run", action="store_true",
                    help="Don't write FINDING-CLUSTERS.md, report.md, or .dup-of markers")
    ap.add_argument("--json", action="store_true",
                    help="Emit cluster JSON to stdout")
    args = ap.parse_args(argv)

    rd = args.results_dir.resolve()
    # Reports cite the bug site as `targets/<slug>/...`; the cluster key
    # must strip that prefix to a stable target-relative path. The env
    # TARGET_ROOT is usually unset at cluster time, so derive the prefix
    # from the output/<slug>/ layout when --target-root was not given.
    target_root = args.target_root or _derive_target_root(rd)

    # Layouts:
    #   * <results>/                       -> writes findings/FINDING-CLUSTERS.md
    #   * <results>/findings              -> findings/FINDING-CLUSTERS.md
    #   * output/<slug>/                   -> aggregate every agent
    if (rd / "findings").is_dir():
        findings_root = rd / "findings"
        out_md = findings_root / "FINDING-CLUSTERS.md"
        link_prefix = ""
    elif rd.name == "findings":
        findings_root = rd
        out_md = findings_root / "FINDING-CLUSTERS.md"
        link_prefix = ""
    elif (rd / "target.toml").is_file():
        # A target root is identified only by its target.toml (the canonical
        # rule in lib/target_config.py), so a nested container like
        # output/samples/ — which has no target.toml — is not mistaken for one.
        return _aggregate_target_root(rd, target_root, dry_run=args.dry_run,
                                      want_json=args.json)
    else:
        findings_root = rd
        out_md = rd / "FINDING-CLUSTERS.md"
        link_prefix = ""

    clusters = cluster_findings(findings_root, target_root=target_root)

    if args.json:
        emitted = [{k: v for k, v in c.items() if k != "_full"} for c in clusters]
        json.dump({"findings_root": str(findings_root), "clusters": emitted},
                  sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
        return 0

    md = _format_clusters_md(clusters, findings_root, link_prefix=link_prefix)
    if args.dry_run:
        sys.stdout.write(md)
        return 0

    _atomic_write_text(out_md, md)
    remove_legacy_cluster_files([out_md.parent / "FIND-CLUSTERS.md"])
    n_updated = update_reports(clusters, dry_run=False)
    render_member_report_siblings(clusters)
    render_md_sibling(out_md)

    print(f"[cluster-findings] {len(clusters)} cluster(s) over "
          f"{sum(c['size'] for c in clusters)} finding(s)")
    print(f"[cluster-findings] wrote {out_md}")
    print(f"[cluster-findings] updated Cluster: line in {n_updated} report(s)")
    return 0


def _aggregate_target_root(target_root: Path, llm_target_root_prefix: str,
                           dry_run: bool, want_json: bool) -> int:
    """Walk every <agent>/results/findings/ under output/<slug>/, cluster
    across all of them, and write output/<slug>/FINDING-CLUSTERS.md.

    Per-agent FINDING-CLUSTERS.md files are still owned by per-results
    invocations from lib/triage.sh; this top-level write is the
    cross-agent rollup. Concurrent backends serialize through an
    advisory flock on <slug>/.find-cluster-lock — see
    lib/cluster_common.run_under_aggregate_lock.
    """
    return run_under_aggregate_lock(
        target_root, ".find-cluster-lock", "cluster-findings",
        lambda: _aggregate_target_root_locked(
            target_root, llm_target_root_prefix, dry_run, want_json),
    )


def _aggregate_target_root_locked(target_root: Path, llm_target_root_prefix: str,
                                  dry_run: bool, want_json: bool) -> int:
    all_sigs: list[dict] = []
    per_agent: dict[str, Path] = {}
    for agent_dir in sorted(target_root.iterdir()):
        if not agent_dir.is_dir():
            continue
        findings_root = agent_dir / "results" / "findings"
        if not findings_root.is_dir():
            continue
        per_agent[agent_dir.name] = findings_root
        for d in sorted(findings_root.iterdir()):
            if not d.is_dir() or not d.name.startswith("FIND-"):
                continue
            sig = _signature(d, llm_target_root_prefix)
            sig["agent"] = agent_dir.name
            sig["display_id"] = f"{agent_dir.name}/{d.name}"
            all_sigs.append(sig)

    clusters = _make_clusters(all_sigs, display_key="display_id")

    if want_json:
        emitted = [{k: v for k, v in c.items() if k != "_full"} for c in clusters]
        json.dump({"target_root": str(target_root), "clusters": emitted},
                  sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
        return 0

    out_md = target_root / "FINDING-CLUSTERS.md"
    md_lines = [f"# Finding Clusters — {target_root.name}", ""]
    md_lines.append(
        f"_Auto-generated by bin/cluster-findings from agent(s): "
        f"{', '.join(per_agent.keys()) or '(none)'}. "
        f"Sorted by max-member severity, then cluster size._  "
        f"Aggregated across every `<agent>/results/findings/` directory; "
        f"**Members** links jump to each report. "
        f"A `Pending` severity means the find-quality gate has not "
        f"rendered a final verdict yet (LLM disabled, or pinned by "
        f"`.keep`/`.reviewed`)."
    )
    md_lines.append("")
    md_lines.append(
        f"**{len(all_sigs)} FIND dir(s) → {len(clusters)} unique cluster(s).**"
    )
    if all_sigs and clusters:
        md_lines.append(f"Dedup ratio: {len(all_sigs) / max(len(clusters), 1):.2f}x.")
    md_lines.append("")
    md_lines.append("| Severity | Cluster | Size | Class | Strategy | Signature | Canonical | Members | Status |")
    md_lines.append("|:---------|:--------|-----:|:------|:---------|:----------|:----------|:--------|:-------|")
    for c in clusters:
        sig_text = _signature_display(c)
        link_cells: list[str] = []
        for m in c["_full"]:
            agent = m.get("agent", "")
            mid = m["id"]
            findings_root = per_agent.get(agent)
            display = m["display_id"]
            if findings_root is not None:
                name = _resolve_report_basename(findings_root / mid)
                link = f"[{display}]({agent}/results/findings/{mid}/{name})"
            else:
                link = display
            if display == c["canonical"]:
                link_cells.append(f"**{link}**")
            else:
                link_cells.append(link)
        cls = c["class"] or "—"
        sev = c["severity_label"] or "Pending"
        strategy = c.get("strategy", "") or "—"
        md_lines.append(
            f"| {sev} | `{c['id']}` | {c['size']} | "
            f"{cls} | {strategy} | {sig_text} | {c['canonical']} | "
            f"{', '.join(link_cells)} | {c.get('status', 'OK')} |"
        )
    md_lines.append("")
    md = "\n".join(md_lines) + "\n"

    if dry_run:
        sys.stdout.write(md)
        return 0

    _atomic_write_text(out_md, md)
    remove_legacy_cluster_files([target_root / "FIND-CLUSTERS.md"])
    n_updated = update_aggregate_reports(clusters, dry_run=False)
    render_member_report_siblings(clusters)
    render_md_sibling(out_md)

    print(f"[cluster-findings] {len(clusters)} cluster(s) over "
          f"{len(all_sigs)} finding(s) across {len(per_agent)} agent(s)")
    print(f"[cluster-findings] wrote {out_md}")
    print(f"[cluster-findings] updated Cluster: line in {n_updated} report(s)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
