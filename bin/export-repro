# Reproducer runtime presets mirror bin/run-{asan,ubsan,msan,tsan}. These are
# execution modes, not target categories:
#   browser          Full browser/web-content run, expensive but high-signal.
#   browser-minimal  Fast browser smoke mode with smaller sanitizer options.
#   generic          Target CLI or probe-built HARNESS executable.
#   js               Standalone JS shell script execution.
#   js-diff          Differential JS shell execution; reports divergence.
#   xpcshell         Firefox parent-process JS/XPCOM runner.
#   fuzz             libFuzzer corpus run; halt_on_error=0 to keep collecting.
#   fuzz-repro       Single fuzzer crash replay; halt_on_error=1 for a clean
#                    diagnostic.
#   fuzz-js          SpiderMonkey `fuzz-tests` libFuzzer binary, distinct from
#                    normal `js` shell execution.
#
# The option strings themselves live in lib/sanitizer_options.conf (the
# single source of truth shared with the shell runners), keyed by the
# canonical modes full/minimal/js/xpcshell/fuzz/fuzz-repro. The map below
# translates each export-repro mode onto its canonical row — e.g. browser
# and generic both run the `full` options; fuzz-js reuses `fuzz`.
_EXPORT_MODE_TO_CANONICAL = {
    "": "full",
    "browser": "full",
    "browser-minimal": "minimal",
    "generic": "full",
    "js": "js",
    "js-diff": "js",
    "xpcshell": "xpcshell",
    "fuzz": "fuzz",
    "fuzz-js": "fuzz",
    "fuzz-repro": "fuzz-repro",
}


def _load_sanitizer_mode_options() -> dict[str, dict[str, str]]:
    """Parse lib/sanitizer_options.conf into {sanitizer: {mode: options}}.

    This is the single source of truth shared with the bin/run-* shell
    runners (lib/sanitizer.sh:sanitizer_options_for). Keys are the canonical
    modes; export-repro modes reach them via _EXPORT_MODE_TO_CANONICAL.
    """
    table: dict[str, dict[str, str]] = {}
    conf = SCRIPT_ROOT / "lib" / "sanitizer_options.conf"
    try:
        text = conf.read_text(encoding="utf-8")
    except OSError:
        return table
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(None, 2)
        if len(parts) != 3:
            continue
        san, mode, opts = parts
        table.setdefault(san, {})[mode] = opts
    return table


SANITIZER_MODE_OPTIONS = _load_sanitizer_mode_options()


def sanitizer_meta(name: str) -> dict[str, str]:
    return SANITIZER_META.get(name.lower(), SANITIZER_META["asan"])


def _append_colon_options(*parts: str) -> str:
    return ":".join(p for p in parts if p)


def sanitizer_default_options(sanitizer: str, mode: str = "") -> str:
    """Canonical *_OPTIONS string for a sanitizer/export-repro-mode pair.

    Resolves through lib/sanitizer_options.conf. An unknown mode, or a mode
    a sanitizer does not define, falls back to that sanitizer's `full` row;
    a sanitizer with no rows at all (e.g. the Go race detector) yields "".
    """
    san = sanitizer.lower()
    canonical = _EXPORT_MODE_TO_CANONICAL.get((mode or "generic").lower(), "full")
    per_mode = SANITIZER_MODE_OPTIONS.get(san, {})
    return per_mode.get(canonical) or per_mode.get("full") or ""


def _parse_header_line(line: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    for token in line.strip().split():
        if "=" not in token:
            continue
        k, v = token.split("=", 1)
        fields[k] = v
    return fields


def sanitizer_run_header_fields(text: str) -> dict[str, str]:
    for line in text.splitlines():
        if line.startswith("SANITIZER_RUN_HEADER:"):
            fields = _parse_header_line(line.split(":", 1)[1])
            if "sanitizer" in fields:
                return fields
        if line.startswith("ASAN_RUN_HEADER:"):
            fields = _parse_header_line(line.split(":", 1)[1])
            fields.setdefault("sanitizer", "asan")
            return fields
    return {}


def decode_header_b64(value: str) -> str:
    if not value:
        return ""
    try:
        return base64.b64decode(value.encode("ascii"), validate=True).decode("utf-8", errors="replace")
    except Exception:
        return ""


def infer_sanitizer_from_text(text: str) -> str:
    fields = sanitizer_run_header_fields(text)
    if fields:
        san = fields.get("sanitizer", "").lower()
        if san in SANITIZER_META:
            return san
    header = re.search(r"\bSANITIZER_RUN_HEADER:\s+[^\n]*\bsanitizer=([A-Za-z0-9_-]+)", text)
    if header:
        san = header.group(1).lower()
        if san in SANITIZER_META:
            return san
    if "WARNING: DATA RACE" in text and "ThreadSanitizer" not in text:
        return "race"
    if "MemorySanitizer" in text:
        return "msan"
    if "ThreadSanitizer" in text:
        return "tsan"
    if "UndefinedBehaviorSanitizer" in text or re.search(r"\bruntime error:", text):
        return "ubsan"
    if "AddressSanitizer" in text or "ASAN_RUN_HEADER" in text:
        return "asan"
    return "asan"


def sanitizer_runtime_env_block(
    sanitizer: str,
    extra_options: str = "",
    mode: str = "",
    recorded_env_options: str = "",
) -> str:
    meta = sanitizer_meta(sanitizer)
    unset_env = meta["unset_env"]
    env_name = meta["env"]
    if not env_name:
        return f"unset {unset_env}\n"
    base = _append_colon_options(
        sanitizer_default_options(sanitizer, mode),
        extra_options,
        recorded_env_options,
    )
    quoted = shq(base)
    return (
        f"unset {unset_env}\n"
        f'{env_name}={quoted}"${{{env_name}:+:${env_name}}}" \\\n'
    )


def cfg_sanitizer_bin(cfg: target_config.Config, sanitizer: str) -> str:
    if hasattr(cfg, "sanitizer_bin"):
        return cfg.sanitizer_bin(sanitizer)
    return getattr(cfg, f"{sanitizer}_bin", "") if sanitizer != "asan" else cfg.asan_bin


def cfg_sanitizer_lib(cfg: target_config.Config, sanitizer: str) -> str:
    if hasattr(cfg, "sanitizer_lib"):
        return cfg.sanitizer_lib(sanitizer)
    return getattr(cfg, f"{sanitizer}_lib", "") if sanitizer != "asan" else cfg.asan_lib


def shell_join_args(args: Iterable[str]) -> str:
    # Items already containing a `$` are shell expressions
    # (`"$link_lib_0"` from emit_link_libs_with_resolves); shell-quoting
    # them would freeze the variable name as a literal. Pass those through
    # verbatim — they were produced by us and don't need further escaping.
    return "".join(
        (f" {a}" if "$" in a else f" {shq(a)}") for a in args if a
    )


_LINK_LIB_RESOLVE_BLOCK = """\
__VAR__="$build"/__REL_Q__
if [ ! -e "$__VAR__" ]; then
  __VAR__=$(find "$build" \\( -type f -o -type l \\) -name __NAME_Q__ -print 2>/dev/null | head -1)
fi
[ -n "$__VAR__" ] && [ -e "$__VAR__" ] || { echo "link archive not found under $build: __NAME_MSG__ (target.toml link_libs hint: __REL_MSG__)" >&2; exit 2; }
"""

_LINK_SOURCE_RESOLVE_BLOCK = """\
__VAR__="$src"/__REL_Q__
if [ ! -e "$__VAR__" ]; then
  __VAR__=$(find "$src" -type d \\( -iname .git -o -iname build -o -iname 'build-*' -o -iname CMakeFiles -o -iname test -o -iname tests -o -iname _deps \\) -prune \\
    -o -type f -name __NAME_Q__ -print 2>/dev/null | head -1)
fi
[ -n "$__VAR__" ] && [ -e "$__VAR__" ] || { echo "link source not found under $src: __NAME_MSG__ (target.toml link_libs hint: __REL_MSG__)" >&2; exit 2; }
"""

_LINK_SOURCE_EXTS = {
    ".c", ".cc", ".cpp", ".cxx", ".c++",
    ".m", ".mm", ".s", ".S", ".asm",
}


def _is_source_link_item(path: str) -> bool:
    lower = path.rsplit("/", 1)[-1].lower()
    return any(lower.endswith(ext.lower()) for ext in _LINK_SOURCE_EXTS)


def emit_link_libs_with_resolves(link_libs: list[str], sanitizer: str) -> tuple[str, str]:
    """Build a pre-link resolver block + the link args for the clang line.

    The link_libs field can name archives at audit-side paths that don't
    exist after a fresh maintainer build (e.g. archive installed to
    `lib/libfoo.a` locally but the .audit/build.sh leaves it at
    `libfoo.a`). For each path-shaped entry we emit a small resolver
    that tries `$build/<rel>` first and falls back to a basename find —
    matching the LIB_RESOLVE semantics used for the primary san_lib. It can
    also name source files that should be compiled into the reproducer link
    command; those resolve from `$src` instead of `$build`.

    Flag entries (`-lm`, `-L…`, `-Wl,…`) pass through verbatim.
    """
    resolves: list[str] = []
    link_args: list[str] = []
    archive_idx = 0
    for raw in link_libs:
        if not raw:
            continue
        item = raw if (raw.startswith("-") or "$" in raw) else _strip_sanitizer_build_prefix(raw, sanitizer)
        if raw.startswith("-") or "$" in raw:
            link_args.append(shq(item))
            continue
        # Bare path: emit a resolver and reference the variable. Source files
        # are compile/link inputs from the upstream checkout; archives/shared
        # objects are build outputs.
        var = f"link_lib_{archive_idx}"
        archive_idx += 1
        name = item.rsplit("/", 1)[-1]
        template = _LINK_SOURCE_RESOLVE_BLOCK if _is_source_link_item(item) else _LINK_LIB_RESOLVE_BLOCK
        resolves.append(
            template
            .replace("__VAR__", var)
            .replace("__REL_Q__", shq(item))
            .replace("__REL__", item)
            .replace("__NAME_Q__", shq(name))
            .replace("__REL_MSG__", shdq_text(item))
            .replace("__NAME_MSG__", shdq_text(name))
            .replace("__NAME__", name)
        )
        link_args.append(f'"${var}"')
    resolver_block = "".join(resolves)
    link_args_string = "".join(f" {a}" for a in link_args)
    return resolver_block, link_args_string


def _bash_glob_sort_key(p: Path) -> str:
    """Sort key matching bash's default `*` glob ordering on a UTF-8 locale —
    case-insensitive lexical. Bash on a C locale puts uppercase first, but
    every developer setup we ship to has LANG=*.UTF-8.
    """
    return p.name.casefold()


def _list_visible_entries(d: Path) -> list[Path]:
    """Equivalent to bash `for f in "$d"/*` — skips dotfiles and sorts
    case-insensitively.
    """
    return sorted(
        (e for e in d.iterdir() if not e.name.startswith(".")),
        key=_bash_glob_sort_key,
    )


def find_first_in_scan(scan_dirs: list[Path], pattern: str) -> Optional[Path]:
    """Glob `pattern` against each scan dir in order. First match wins.

    Mirrors the bash `for dir in SCAN_DIRS; for f in $dir/$pattern; do ...`.
    """
    for d in scan_dirs:
        for f in sorted(d.glob(pattern), key=_bash_glob_sort_key):
            if f.is_file():
                return f
    return None


def find_harness(scan_dirs: list[Path],
                 exclude: Optional[Path] = None) -> Optional[Path]:
    """Any C/C++ file in scan dirs whose body contains a main() definition.

    `exclude` is the already-selected testcase; a source the ASAN_RUN_HEADER
    records as the input must not also be staged as the harness.
    """
    return crash_artifacts.find_harness_source(scan_dirs, exclude=exclude)


_SHELL_SHEBANG_RE = re.compile(r"^\s*#!.*\b(?:sh|bash|zsh|ksh)\b")
_SHELL_WRAPPER_HINT_RE = re.compile(
    r'(?m)(?:'
    r'^\s*set\s+-|'
    r'^\s*(?:ROOT|SRC|BUILD|SCRATCH|HARNESS_C|HARNESS_BIN|CATALOG_BIN|BIN)=|'
    r'^\s*(?:if|for|while)\s+|'
    r'^\s*exec\s+|'
    r'"\$(?:CATALOG_BIN|BIN|HARNESS_BIN|san_bin)"|'
    r'\$(?:CATALOG_BIN|BIN|HARNESS_BIN|san_bin|repro_src)\b|'
    r'/build-(?:a|ub|m|t)san/'
    r')'
)


def looks_like_shell_wrapper(path: Path) -> bool:
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return False
    first_line = text.splitlines()[0] if text.splitlines() else ""
    if _SHELL_SHEBANG_RE.search(first_line):
        return True
    return bool(_SHELL_WRAPPER_HINT_RE.search(text))


def find_shell_wrapper(scan_dirs: list[Path]) -> Optional[Path]:
    # `harness.sh` / `harness.bash` is the documented convention in
    # lib/languages.py: a `// HARNESS:` directive may name a shell driver
    # that compiles+runs upstream sources directly (no pre-built asan_bin).
    # `testcase.sh` / `reproducer.sh` are legacy hand-coded wrappers that
    # launch an already-built CLI binary. Do not treat every .sh with one of
    # those names as shell code: language runners can preserve a `.sh`
    # testcase that contains only probe metadata plus input bytes. Those must
    # be staged as `input.sh` and passed to the runner, not inlined as shell.
    for d in scan_dirs:
        for name in ("harness.sh", "harness.bash"):
            p = d / name
            if p.is_file():
                return p
        for name in ("testcase.sh", "reproducer.sh"):
            p = d / name
            if p.is_file() and looks_like_shell_wrapper(p):
                return p
    return None


def find_testcase(scan_dirs: list[Path], crash_dir: Path, audit_subdir: Path) -> Optional[Path]:
    """Find a non-script, non-binary, non-bundle file to use as the testcase.

    Mirrors the bash globber:
      - skip canonical bundle filenames (REPORT.md / reproduce.sh /
        sanitizer.txt / harness.c / severity.json; plus legacy
        asan.txt left behind by older bundles)
      - skip files whose suffix is a known artifact type
      - skip executable Mach-O/ELF/scripts
      - prefer .audit/ originals when both new- and old-layout files exist

    Iteration order matches bash's `for f in "$dir"/*` — dotfiles skipped,
    case-insensitive sort.
    """
    asan = crash_artifacts.find_primary_asan(scan_dirs)
    return crash_artifacts.find_testcase(scan_dirs, asan_files=[asan] if asan else [])


def demangle(text: str) -> str:
    """Pipe `text` through c++filt if available; else return unchanged."""
    if shutil.which("c++filt") is None:
        return text
    try:
        out = subprocess.run(
            ["c++filt"], input=text, capture_output=True, text=True, timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired):
        return text
    if out.returncode != 0:
        return text
    return out.stdout


# ─── reproduce.sh templates ─────────────────────────────────────────
# Templates use literal `__PLACEHOLDER__` tokens for substitutions. The
# bash heredoc text is preserved byte-for-byte except for those tokens
# (so a diff against a pre-port bundle on the same input is empty for
# everything not being substituted).

PREAMBLE_MACH = """\
#!/usr/bin/env bash
# Reproduces a __SANITIZER_LABEL__ diagnostic against an upstream Firefox checkout.
# Usage:
#   ./reproduce.sh /path/to/firefox-src      (REQUIRED — point at hg checkout)
#   REPRO_AUTO_CLONE=1 ./reproduce.sh        (clone mozilla-central next to script — slow)
set -eu
URL=__UPSTREAM_URL__
REV=__PINNED_REV__

if [ $# -ge 1 ]; then
  src="$1"
elif [ "${REPRO_AUTO_CLONE:-0}" = "1" ]; then
  src="$(dirname "$0")"/__SLUG__
  [ -d "$src/.hg" ] || hg clone "$URL" "$src"
  hg --cwd "$src" update -r "$REV" 2>/dev/null || true
else
  echo "Usage: $0 /path/to/firefox-src   (or set REPRO_AUTO_CLONE=1 for fresh clone)" >&2
  exit 2
fi
[ -d "$src" ] || { echo "src not found: $src" >&2; exit 2; }

# build is unused for mach (mach uses sanitizer objdir inside src), but keep the var
# so emit_build templates can reference it consistently.
build="$src/__MACH_OBJDIR__"
TARGET_SAN_BIN_INLINE=__SAN_BIN_REL__
"""

PREAMBLE_GENERIC = """\
#!/usr/bin/env bash
# Reproduces a __SANITIZER_LABEL__ diagnostic against upstream sources.
# Usage:
#   ./reproduce.sh                     (clones $URL@$REV next to script)
#   ./reproduce.sh /path/to/checkout   (uses an existing checkout)
# Local-only targets (no recorded upstream — a symlinked or plain local source
# tree) carry the FILL_ME url sentinel; for those the clone is skipped and you
# must pass a checkout path.
set -eu
URL=__UPSTREAM_URL__
REV=__PINNED_REV__
# Audit-tree-relative source path (e.g. targets/<slug>) for a local-only
# target; empty for VCS targets. Kept relative — not a host-absolute path — so
# the bundle stays portable and leaks no host layout. Resolve it against the
# first ancestor of this script that contains it (the audit repo root) so
# `./reproduce.sh` finds the in-place source on the machine that produced the
# bundle; stays empty when the bundle was copied elsewhere.
LOCAL_SRC=__LOCAL_SRC__
resolved_local=""
if [ -n "$LOCAL_SRC" ]; then
  _d="$(cd "$(dirname "$0")" && pwd)"
  while :; do
    if [ -d "$_d/$LOCAL_SRC" ]; then resolved_local="$_d/$LOCAL_SRC"; break; fi
    [ "$_d" = "/" ] && break
    _d="$(dirname "$_d")"
  done
fi

default_src="$(dirname "$0")"/__SLUG__
# Choose the source tree: an explicit argument wins; else the resolved in-place
# source recorded at audit time; else the clone/checkout location next to the
# script.
if [ $# -ge 1 ]; then
  src="$1"
elif [ -n "$resolved_local" ]; then
  src="$resolved_local"
else
  src="$default_src"
fi
# Fetch the source when it is absent — but clone only with a real upstream AND
# a usable revision. FILL_ME / norev are seed sentinels: a local-only or
# unpinned target cannot clone (this mirrors the report, which offers a
# path-based repro in that case), so ask for a checkout instead of attempting a
# doomed `git clone`.
if [ ! -d "$src" ]; then
  can_clone=1
  case "$URL" in FILL_ME|''|norev|no-vcs|unknown) can_clone=0 ;; esac
  case "$REV" in ''|norev|no-vcs|unknown|'?') can_clone=0 ;; esac
  if [ "$can_clone" -eq 1 ]; then
    git clone --recurse-submodules "$URL" "$src"
  else
    echo "reproduce.sh: no source tree at '$src' and no cloneable upstream recorded for this target." >&2
    [ -n "$LOCAL_SRC" ] && echo "Recorded source '$LOCAL_SRC' was not found near this bundle." >&2
    echo "Pass a local checkout: $0 /path/to/src" >&2
    exit 2
  fi
fi
# Pin to the recorded revision when this is a VCS checkout; a plain tree
# (no .git / .hg) is used as-is. Both git and hg are handled so a checkout the
# operator passes in is pinned either way.
if [ -d "$src/.git" ]; then
  git -C "$src" checkout --quiet "$REV" 2>/dev/null || true
  # Re-sync submodules after pinning: the recorded REV can point them at
  # different commits than the clone fetched, and an operator-supplied checkout
  # may not have them initialized at all. Submodule-dependent builds (e.g. a JIT
  # engine vendored under deps/) need their sources present. No-op when the repo
  # has no submodules.
  git -C "$src" submodule update --init --recursive 2>/dev/null || true
elif [ -d "$src/.hg" ]; then
  hg --cwd "$src" update -r "$REV" 2>/dev/null || true
fi

# Canonicalize to an absolute path now that the tree exists. Out-of-tree
# autotools builds (and the inlined audit recipe) `cd "$build"` and then run
# "$src/configure", which only resolves when $src is absolute. Running
# `./reproduce.sh` yields a relative src (./<slug>), so resolve it here once;
# $build derives from it and is absolute too.
src="$(cd "$src" && pwd)"
build="$src/__BUILD_DIR__"
"""

CMAKE_BUILD_TOP = """\
# Prereqs: cmake + a C compiler (Xcode CLT / build-essential).
# Discard any stale cache from a previous (possibly failed) configure so we
# can switch generators / flags without cmake refusing to reconfigure.
# Build type is Release with explicit -g/-DNDEBUG so the sanitizer runs
# optimized shipped code paths while preserving symbolized traces. Debug
# builds enable project-defined debug macros (DEBUGBUILD, MOZ_DEBUG,
# DCHECK_IS_ON, ...) that turn DEBUGASSERT / MOZ_ASSERT / DCHECK /
# assert() into real aborts; those vanish in the shipped binary, so a
# debug-only abort is a robustness signal, not a security bug.
#
# Full -g here (vs the audit build's lighter -g1) is deliberate:
# this script is handed to a maintainer to reproduce and debug the crash
# interactively, where variable/type DWARF earns its keep. The audit's
# own builds only need function + file:line for clustering, so they use
# the lighter line-tables-only flag.
rm -f "$build/CMakeCache.txt"
rm -rf "$build/CMakeFiles"
cmake -S "$src" -B "$build" \\
    -DCMAKE_BUILD_TYPE=Release \\
    -DCMAKE_C_COMPILER="${CC:-clang}" \\
    -DCMAKE_CXX_COMPILER="${CXX:-clang++}" \\
    -DCMAKE_C_FLAGS="-fsanitize=__SANITIZER_FLAG__ -O2 -g -DNDEBUG -fno-omit-frame-pointer" \\
    -DCMAKE_CXX_FLAGS="-fsanitize=__SANITIZER_FLAG__ -O2 -g -DNDEBUG -fno-omit-frame-pointer" \\
    -DCMAKE_EXE_LINKER_FLAGS="-fsanitize=__SANITIZER_FLAG__" \\
    -DBUILD_SHARED_LIBS=OFF
cmake --build "$build" -j__TARGET_ARG__
"""

AUTOTOOLS_BUILD = """\
# Default optimization level (no --enable-debug). Debug toggles compile
# in project-defined DEBUGBUILD / DEBUGASSERT / assert() macros that are
# no-ops in the shipped release binary; aborts on those are robustness
# signals, not security bugs.
mkdir -p "$build"
( cd "$build" && \\
  CC=clang CFLAGS="-fsanitize=__SANITIZER_FLAG__ -O2 -g -DNDEBUG -fno-omit-frame-pointer" LDFLAGS="-fsanitize=__SANITIZER_FLAG__" \\
  "$src/configure" --disable-shared --enable-static && make -j )
"""

MACH_BUILD = """\
# Firefox / mach build. Reuses an existing sanitizer objdir if present; otherwise
# writes a minimal mozconfig and runs `./mach build` (slow — 1+ hour).
if { [ -z "$TARGET_SAN_BIN_INLINE" ] || [ ! -x "$src/${TARGET_SAN_BIN_INLINE}" ]; } && [ ! -x "$src/__MACH_OBJDIR__/dist/Nightly.app/Contents/MacOS/firefox" ] && [ ! -x "$src/__MACH_OBJDIR__/dist/bin/firefox" ]; then
  mozconfig="$src/.mozconfig-__MOZCONFIG_KIND__-repro"
  cat > "$mozconfig" <<'MZ'
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/__MACH_OBJDIR__
ac_add_options __MACH_SANITIZER_OPTION__
ac_add_options --disable-jemalloc
ac_add_options --disable-debug
ac_add_options --enable-optimize="-O1 -fno-omit-frame-pointer"
MZ
  ( cd "$src" && MOZCONFIG="$mozconfig" ./mach build )
fi
"""

MESON_BUILD = """\
# release + ndebug so the sanitizer mirrors shipped optimized code while
# keeping symbols via -g. `--buildtype=debug` / `debugoptimized` would
# enable project-defined debug-only checks (DEBUGASSERT / MOZ_ASSERT /
# DCHECK / assert()) that are compiled out in production; aborts on those
# are robustness signals, not security bugs.
CC=clang meson setup "$build" "$src" --buildtype=release \\
    -Db_sanitize=__SANITIZER_FLAG__ -Db_ndebug=true -Ddefault_library=static \\
    -Dc_args="-g -fno-omit-frame-pointer" \\
    -Dcpp_args="-g -fno-omit-frame-pointer"
ninja -C "$build"
"""

UNKNOWN_BUILD = """\
echo "build_system unknown — edit this block for your project" >&2
exit 2
"""

# ── Language-ecosystem build templates ───────────────────────────────
#
# These templates run a representative `<tool> build` (or fetch deps and
# emit a stub when the language doesn't compile) so reproduce.sh produces
# a runnable build before the runtime step. None of them assume ASan is
# enabled — sanitizer enablement is a per-language opt-in handled by the
# operator (e.g. RUSTFLAGS for cargo, GORACE for go). reproduce.sh is
# language-agnostic; it just gives the maintainer a fast `<lang> run`.

CARGO_BUILD = """\
# Rust / Cargo build. Add `-Z sanitizer=address` via RUSTFLAGS for ASan
# (requires nightly + a target with sanitizer support).
( cd "$src" && cargo build --offline 2>/dev/null || cd "$src" && cargo build )
"""

GO_BUILD = """\
# Go build. Add `-race` for the race detector. The result lives at $build/repro.
mkdir -p "$build"
( cd "$src" && go build -o "$build/repro" ./... )
"""

NPM_BUILD = """\
# Node.js / npm build. Installs deps when node_modules/ is missing. No
# compile step in the canonical Node flow — testcases run directly.
( cd "$src" && ( [ -d node_modules ] || npm install --no-audit --no-fund ) )
"""

PYTHON_BUILD = """\
# Python: build a virtualenv and install the package in editable mode if
# there's a pyproject.toml / setup.py. Skip silently otherwise — script
# targets can run without installing anything.
mkdir -p "$build"
python3 -m venv "$build/venv" 2>/dev/null || true
. "$build/venv/bin/activate" 2>/dev/null || true
if [ -f "$src/pyproject.toml" ] || [ -f "$src/setup.py" ]; then
  pip install --quiet -e "$src" 2>/dev/null || \\
    echo "[repro] pip install failed — running without project install" >&2
fi
"""

BUNDLER_BUILD = """\
# Ruby + Bundler: install gemset. Skip silently if Bundler not on PATH.
( cd "$src" && command -v bundle >/dev/null 2>&1 && bundle install --quiet 2>/dev/null || true )
"""

COMPOSER_BUILD = """\
# PHP + Composer: install dependencies if vendor/ is missing.
( cd "$src" && [ -d vendor ] || composer install --quiet --no-interaction 2>/dev/null || true )
"""

MAVEN_BUILD = """\
( cd "$src" && mvn --quiet --batch-mode package -DskipTests )
"""

GRADLE_BUILD = """\
( cd "$src" && ./gradlew --quiet --no-daemon build -x test 2>/dev/null || gradle --quiet build -x test )
"""

KOTLIN_BUILD = """\
# Kotlin single-file/script targets. Gradle Kotlin projects use the gradle
# build_system; this fallback compiles plain .kt sources when present and lets
# .kts probes run directly through the captured runner.
mkdir -p "$build"
if find "$src" -maxdepth 3 -type f -name '*.kt' | grep -q .; then
  find "$src" -maxdepth 3 -type f -name '*.kt' -print0 | \
    xargs -0 kotlinc -include-runtime -d "$build/repro.jar"
fi
"""

SWIFT_BUILD = """\
( cd "$src" && swift build --quiet )
"""

RLANG_BUILD = """\
# R packages: install dependencies declared in DESCRIPTION.
( cd "$src" && Rscript -e 'install.packages(".", repos=NULL, type="source", quiet=TRUE)' 2>/dev/null || true )
"""

PERL_BUILD = """\
# Perl module: install deps via cpanm if present; otherwise skip.
( cd "$src" && command -v cpanm >/dev/null 2>&1 && cpanm --quiet --installdeps . 2>/dev/null || true )
"""

# Make and Bazel build templates: even though we no longer detect Make
# or Bazel as standalone "languages", many C/C++ test corpora ship with
# ad-hoc Makefiles or BUILD files for their fixtures, and an exported
# repro often needs to rebuild one of those before the testcase runs.
# Keep the templates available so target.toml can opt in via
# `build_system = "make"` or `"bazel"` even when no first-class language
# detector exists for them.
MAKE_BUILD = """\
( cd "$src" && make -j 2>/dev/null || make )
"""

BAZEL_BUILD = """\
( cd "$src" && bazel build --noshow_progress //... )
"""

# Map build_system → template string. Used by emit_build.
_LANGUAGE_BUILD_TEMPLATES = {
    "cargo": CARGO_BUILD,
    "go": GO_BUILD,
    "npm": NPM_BUILD,
    "python": PYTHON_BUILD,
    "bundler": BUNDLER_BUILD,
    "composer": COMPOSER_BUILD,
    "maven": MAVEN_BUILD,
    "gradle": GRADLE_BUILD,
    "kotlin": KOTLIN_BUILD,
    "swift": SWIFT_BUILD,
    "rlang": RLANG_BUILD,
    "perl": PERL_BUILD,
    "make": MAKE_BUILD,
    "bazel": BAZEL_BUILD,
}

BIN_RESOLVE = """\
san_bin="$build"/__SAN_BIN_TAIL__
[ -x "$san_bin" ] || san_bin="$src"/__SAN_BIN_REL__
[ -x "$san_bin" ] || { echo "__SANITIZER_LABEL__ binary not found at $san_bin" >&2; exit 2; }
"""

LIB_RESOLVE = """\
san_lib="$build"/__SAN_LIB_TAIL__
[ -e "$san_lib" ] || san_lib="$src"/__SAN_LIB_REL__
if [ ! -e "$san_lib" ]; then
  # target.toml records the local audit build path, but maintainer CMake
  # builds may place the same archive in a different subdirectory. Resolve by
  # archive basename after the fresh build, but only accept an unambiguous hit.
  san_lib_name="${san_lib##*/}"
  if [ -n "$san_lib_name" ] && [ -d "$build" ]; then
    matches=$(find "$build" \\( -type f -o -type l \\) -name "$san_lib_name" -print)
    match_count=$(printf '%s\n' "$matches" | sed '/^$/d' | wc -l | tr -d ' ')
    if [ "$match_count" = "1" ]; then
      san_lib=$(printf '%s\n' "$matches" | sed -n '1p')
    elif [ "$match_count" != "0" ]; then
      echo "__SANITIZER_LABEL__ static library name is ambiguous under $build: $san_lib_name" >&2
      printf '%s\n' "$matches" >&2
      exit 2
    fi
  fi
fi
if [ ! -e "$san_lib" ]; then
  # Audit-recorded name (libfoo-d.a, libfoo-asan.a) often doesn't match
  # what a fresh upstream build produces (libfoo.a / .dylib).
  # Strip audit-side decoration from the stem and find any matching artifact.
  # Accept symlinks (-type l): shared libs ship as libfoo.dylib -> libfoo.N.dylib
  # -> libfoo.X.Y.Z.dylib (macOS) or libfoo.so -> libfoo.so.N (Linux), and the
  # linker accepts a symlink. Dot-versioned name patterns catch the real-file
  # end (libfoo.X.Y.Z.dylib, libfoo.so.X.Y.Z) when no unversioned symlink is
  # installed in the build tree.
  stem="${san_lib##*/}"; stem="${stem%.*}"
  while :; do
    case "$stem" in
      *-asan|*-ubsan|*-msan|*-tsan|*-d|*-debug) stem="${stem%-*}" ;;
      *) break ;;
    esac
  done
  if [ -n "$stem" ] && [ -d "$build" ]; then
    san_lib=$(find "$build" \\( -type f -o -type l \\) \\( \\
        -name "${stem}.a" -o -name "${stem}.dylib" -o -name "${stem}.so" \\
        -o -name "${stem}-*.a" -o -name "${stem}-*.dylib" -o -name "${stem}-*.so" \\
        -o -name "${stem}.*.dylib" -o -name "${stem}.so.*" \\
      \\) -print 2>/dev/null | head -1)
  fi
fi
if [ ! -e "$san_lib" ]; then
  # TODO(post-launch): this is a repro-time band-aid. The proper fix lives
  # in bin/auto-build-script — verify that the configured asan_lib exists
  # under build/ after convergence, and if not, re-converge with an
  # explicit "must produce <asan_lib>" hint so .audit/build.sh learns to
  # build the subproject. Once that lands upstream, delete this block.
  #
  # The configured asan_lib often hints at a cmake subproject the agent
  # built ad-hoc during recon, but the converged .audit/build.sh only
  # covers the top-level cmake. When the path looks like `<subdir>/<lib>`,
  # see if upstream carries a matching `<src>/<subdir>` or
  # `<src>/contrib/<subdir>` cmake project and build it inline. Mirrors
  # the audit build's flags so the ASan ABI matches.
  san_lib_rel=__SAN_LIB_REL__
  subdir_hint="${san_lib_rel#build-*/}"
  subdir_hint="${subdir_hint%%/*}"
  case "$subdir_hint" in
    ""|"$san_lib_rel"|lib|build|src) subdir_hint="" ;;
  esac
  if [ -n "$subdir_hint" ]; then
    # Install the top-level build first so the subproject's
    # find_package() / find_dependency() calls can locate it via
    # <Project>Config.cmake under $build/install/lib/cmake/<project>/.
    if [ ! -d "$build/install/lib/cmake" ]; then
      cmake --install "$build" --prefix "$build/install" >&2 || true
    fi
    for cand_subdir in "$src/$subdir_hint" "$src/contrib/$subdir_hint"; do
      if [ -f "$cand_subdir/CMakeLists.txt" ]; then
        echo "=== __SANITIZER_LABEL__: building cmake subproject for $subdir_hint at $cand_subdir ===" >&2
        cmake -S "$cand_subdir" -B "$build/$subdir_hint" \\
            -DCMAKE_BUILD_TYPE=Release \\
            -DCMAKE_PREFIX_PATH="$build/install" \\
            -DCMAKE_C_FLAGS="-fsanitize=__SANITIZER_FLAG__ -O2 -g -DNDEBUG -fno-omit-frame-pointer" \\
            -DCMAKE_CXX_FLAGS="-fsanitize=__SANITIZER_FLAG__ -O2 -g -DNDEBUG -fno-omit-frame-pointer" \\
            -DCMAKE_EXE_LINKER_FLAGS="-fsanitize=__SANITIZER_FLAG__" >&2 \\
          && cmake --build "$build/$subdir_hint" -j >&2 \\
          || true
        break
      fi
    done
    san_lib=$(find "$build" \\( -type f -o -type l \\) -name "$san_lib_name" -print 2>/dev/null | head -1)
  fi
fi
if [ ! -e "$san_lib" ]; then
  # Header-only libraries can get placeholder anchor archives at audit
  # time (one .o with no extern symbols) so target.toml's asan_lib field
  # validates. The fresh maintainer build doesn't reproduce those
  # placeholders, but the harness link doesn't actually need them.
  # Degrade to a warning + blank san_lib so the link line's
  # ${san_lib:+"$san_lib"} expansion skips the archive cleanly. If the
  # harness *does* need the archive, the linker errors out next with an
  # undefined-symbol that points the maintainer at the real fix.
  echo "WARNING: __SANITIZER_LABEL__ library '__SAN_LIB_REL__' not found under '$build' after fallbacks." >&2
  echo "         Proceeding without it — fine for header-only libraries; if the harness needs it," >&2
  echo "         the linker will report undefined symbols below." >&2
  san_lib=""
fi
# Loader hint for shared libs. ${san_lib%/*} is the directory side of the
# resolved artifact; embedding it as an rpath at link time and exporting it
# via LD_LIBRARY_PATH/DYLD_LIBRARY_PATH at run time means the harness loads
# the instrumented .so/.dylib regardless of where the build placed it. For
# static archives the variable is set but unused. Empty san_lib_dir is
# fine: the harness link line uses ${san_lib_dir:+...} to skip the
# variable entirely when it's not set.
san_lib_dir="${san_lib%/*}"
[ -n "$san_lib" ] || san_lib_dir=""
"""


# Emitted instead of LIB_RESOLVE when target.toml names no <san>_lib but a
# C/C++ harness is present. The build above already produced the project's
# instrumented library; the harness must link it. Discover it in the fresh
# $build tree rather than trusting a config field that was never filled —
# robust to the seed-before-build ordering and to header-only false
# negatives. Covers both platforms' conventions: static archives (.a),
# macOS shared objects (lib*.dylib, versioned lib*.N.dylib) and Linux
# shared objects (lib*.so, versioned lib*.so.N). Prefer a static archive,
# else the canonical unversioned shared object — shortest basename wins, so
# libfoo.dylib beats libfoo.2.dylib and libfoo.so beats libfoo.so.6. An
# empty result means header-only: ${san_lib:+...} then skips the link
# cleanly, and the linker reports undefined symbols if the harness did need
# a library.
LIB_DISCOVER = """\
# target.toml names no __SANITIZER_LABEL__ library, so link the one the
# build just produced: prefer a static archive, else the canonical shared
# object (unversioned over its SONAME-versioned siblings). The pruned dirs
# are build-system-internal — CMakeFiles/ scaffolding, test-framework
# archives under test(s)/ (Unity, gtest), and FetchContent _deps/ builds —
# not normal project library output.
san_lib=""
if [ -d "$build" ]; then
  san_lib=$(find "$build" -type d \\( -iname CMakeFiles -o -iname test -o -iname tests -o -iname _deps \\) -prune \\
      -o -type f -name '*.a' ! -name '*posix*' -print 2>/dev/null \\
    | LC_ALL=C sort | head -1)
  if [ -z "$san_lib" ]; then
    san_lib=$(find "$build" -type d \\( -iname CMakeFiles -o -iname test -o -iname tests -o -iname _deps \\) -prune \\
      -o \\( -type f -o -type l \\) \\( \\
        -name 'lib*.so' -o -name 'lib*.dylib' \\
        -o -name 'lib*.so.*' -o -name 'lib*.*.dylib' \\
      \\) ! -name '*posix*' -print 2>/dev/null \\
      | awk -F/ '{ print length($NF), $0 }' | LC_ALL=C sort -n -k1,1 \\
      | sed 's/^[0-9]*  *//' | head -1)
  fi
fi
if [ -n "$san_lib" ]; then
  echo "=== __SANITIZER_LABEL__: linking auto-discovered library: $san_lib ===" >&2
fi
san_lib_dir="${san_lib%/*}"
[ -n "$san_lib" ] || san_lib_dir=""
"""


def emit_lib_discover(sanitizer: str = "asan") -> str:
    return _sub_template(
        LIB_DISCOVER,
        __SANITIZER_LABEL__=sanitizer_meta(sanitizer)["label"],
    )


# The `rc=0; <cmd> || rc=$?` pattern is intentional: the script starts
# with `set -eu`, so a normal `<cmd>; rc=$?` would never reach the rc=
# assignment when the harness reports a sanitizer diagnostic (the script would exit
# at <cmd> and the user would see no [repro] exit= line). Using the
# `|| rc=$?` form in a list context disables -e for that one command.

BROWSER_RUN = """\
san_bin=""
[ -n __SAN_BIN_REL__ ] && san_bin="$src"/__SAN_BIN_REL__
[ -x "$san_bin" ] || san_bin="$src/__MACH_OBJDIR__/dist/Nightly.app/Contents/MacOS/firefox"
[ -x "$san_bin" ] || san_bin="$src/__MACH_OBJDIR__/dist/bin/firefox"
[ -x "$san_bin" ] || { echo "__SANITIZER_LABEL__ firefox not found at $san_bin" >&2; exit 2; }

profile=$(mktemp -d "${TMPDIR:-/tmp}/firefox-repro-profile-XXXXXX")
trap 'rm -rf "$profile"' EXIT
testcase_url="file://$(cd "$(dirname "$0")" && pwd)/__INPUT_NAME__"
echo "=== running __SANITIZER_LABEL__ repro: $testcase_url ===" >&2
rc=0
__SANITIZER_ENV_BLOCK__  MOZ_HEADLESS=1 MOZ_DISABLE_CONTENT_SANDBOX=1 \\
  "$san_bin" --headless --no-remote --profile "$profile" "$testcase_url" || rc=$?
echo "[repro] exit=$rc" >&2
exit "$rc"
"""

JS_SHELL_RUN = """\
san_bin="$src/__MACH_OBJDIR__/dist/bin/js"
[ -x "$san_bin" ] || { echo "__SANITIZER_LABEL__ js shell not found at $san_bin" >&2; exit 2; }
testcase="$(cd "$(dirname "$0")" && pwd)/__INPUT_NAME__"
echo "=== running __SANITIZER_LABEL__ repro: $testcase ===" >&2
rc=0
__SANITIZER_ENV_BLOCK__  "$san_bin" "$testcase" || rc=$?
echo "[repro] exit=$rc" >&2
exit "$rc"
"""

C_HARNESS_RUN = """\

here=$(cd "$(dirname "$0")" && pwd)
# CMake/Meson frequently emit generated public headers (a config header, a
# version header, or the project's API header configured from a .in
# template) into a build subdirectory that target.toml's `includes` doesn't
# name — e.g. pcre2 writes the generated pcre2.h under $build/interface/.
# Add every build directory that directly contains a header to the search
# path so the harness #include resolves wherever this build placed it.
# Configured includes still come first (they win on collision); CMakeFiles/
# is pruned (private build scaffolding, no public API).
gen_inc=""
if [ -d "$build" ]; then
  for d in $(find "$build" -type d \\( -iname CMakeFiles -o -iname test -o -iname tests -o -iname _deps \\) -prune \\
               -o -type f \\( -name '*.h' -o -name '*.hpp' -o -name '*.hh' \\) -print 2>/dev/null \\
             | sed 's|/[^/]*$||' | LC_ALL=C sort -u); do
    gen_inc="$gen_inc -I$d"
  done
fi
# A harness that includes a library's *private* headers (pcre2_internal.h,
# ares_setup.h, …) needs the per-TU config the build applies to its own
# sources. Those headers gate `#include "<proj>config.h"` on -DHAVE_CONFIG_H
# — the autotools/cmake convention — and that config header supplies macros
# (symbol visibility, feature flags) the library's headers assume but a
# generic harness compile lacks. Define HAVE_CONFIG_H when the build emitted
# such a header (config.h or <proj>_config.h); its directory is already on
# the include path via the discovery above. No-op for harnesses that include
# no config-gated header.
have_config=""
if [ -d "$build" ]; then
  cfg_h=$(find "$build" -type d \\( -iname CMakeFiles -o -iname test -o -iname tests -o -iname _deps \\) -prune \\
            -o -type f \\( -name 'config.h' -o -name '*_config.h' \\) -print 2>/dev/null | head -1)
  [ -n "$cfg_h" ] && have_config=" -DHAVE_CONFIG_H"
fi
echo "=== compiling harness: __HARNESS_NAME__ ===" >&2
__HARNESS_COMPILER__ -fsanitize=__SANITIZER_FLAG__ -g -O1__INCLUDES_ARGS__$gen_inc$have_config \\
    "$here/__HARNESS_NAME__"__SAN_LIB_ARG____LINK_LIBS__ \\
    -o "$build/repro"
echo "=== running __SANITIZER_LABEL__ repro: __INPUT_DESC__ ===" >&2
rc=0
__SAN_LIB_RUN_ENV____SANITIZER_ENV_BLOCK__  "$build/repro"__HARNESS_ARGS__ || rc=$?
echo "[repro] exit=$rc" >&2
exit "$rc"
"""

CLI_RUN = """\

testcase="$(dirname "$0")/__INPUT_NAME__"
echo "=== running __SANITIZER_LABEL__ repro: $testcase ===" >&2
rc=0
__SANITIZER_ENV_BLOCK__  "$san_bin" __CLI_ARGS__ || rc=$?
echo "[repro] exit=$rc" >&2
exit "$rc"
"""

SWIFT_RUN = """\

testcase="$(dirname "$0")/__INPUT_NAME__"
echo "=== running __SANITIZER_LABEL__ repro: $testcase ===" >&2
rc=0
__SANITIZER_ENV_BLOCK__  swift run --quiet -c release -Xswiftc -sanitize=__SWIFT_SANITIZER__ -Xswiftc -O --package-path "$src" __SWIFT_EXECUTABLE__ "$testcase" || rc=$?
echo "[repro] exit=$rc" >&2
exit "$rc"
"""

SHELL_WRAPPER_INTRO = """\

# --- inlined audit-side reproducer body ---
"""


def _sub_template(text: str, **kw: str) -> str:
    out = text
    for placeholder, value in kw.items():
        out = out.replace(placeholder, value)
    return out


def emit_preamble(build_system: str, upstream_url: str, pinned_rev: str,
                  slug: str, san_bin_rel: str, sanitizer: str = "asan",
                  local_src: str = "") -> str:
    quoted_url = shq(upstream_url)
    quoted_rev = shq(pinned_rev)
    quoted_slug = shq(safe_slug(slug))
    quoted_san_bin_rel = shq(san_bin_rel)
    meta = sanitizer_meta(sanitizer)
    if build_system == "mach":
        return _sub_template(
            PREAMBLE_MACH,
            __UPSTREAM_URL__=quoted_url,
            __PINNED_REV__=quoted_rev,
            __SLUG__=quoted_slug,
            __SAN_BIN_REL__=quoted_san_bin_rel,
            __SANITIZER_LABEL__=meta["label"],
            __MACH_OBJDIR__=meta["mach_objdir"],
        )
    return _sub_template(
        PREAMBLE_GENERIC,
        __UPSTREAM_URL__=quoted_url,
        __PINNED_REV__=quoted_rev,
        # Recorded local source for a local-only target (empty for VCS targets,
        # which clone from upstream instead). shq("") -> '' so the LOCAL_SRC
        # branch is simply skipped at run time.
        __LOCAL_SRC__=shq(local_src),
        __SLUG__=quoted_slug,
        __SANITIZER_LABEL__=meta["label"],
        __BUILD_DIR__=meta["build_dir"],
    )


def _sub_sanitizer_build_template(template: str, sanitizer: str) -> str:
    meta = sanitizer_meta(sanitizer)
    if not meta["flag"]:
        return (
            f"echo \"{meta['label']} needs a project-specific build command; "
            "edit this block for your target\" >&2\n"
            "exit 2\n"
        )
    return _sub_template(
        template,
        __SANITIZER_FLAG__=meta["flag"],
        __MACH_OBJDIR__=meta["mach_objdir"],
        __MOZCONFIG_KIND__=meta["mozconfig"],
        __MACH_SANITIZER_OPTION__=meta["mach_option"],
    )


def emit_cmake_build(extra_target: str = "", sanitizer: str = "asan") -> str:
    target_arg = f" --target {shq(extra_target)}" if extra_target else ""
    return _sub_template(
        _sub_sanitizer_build_template(CMAKE_BUILD_TOP, sanitizer),
        __TARGET_ARG__=target_arg,
    )


# Sentinel proving a reproduce.sh build block was inlined from the audit's
# converged recipe rather than a generic bucket template. Emitted by
# emit_audit_build_script and asserted by the dispatch-level guard, so a writer
# that forgets to thread audit_build_script fails loudly instead of silently
# shipping a guessed build.
AUDIT_BUILD_MARKER = ".audit-build.sh"


def emit_audit_build_script(script_text: str) -> str:
    """Emit a reproduce.sh fragment that materializes and runs the
    audit-validated build recipe verbatim, in place of the hardcoded
    cmake/autotools/meson template.

    The reproducer's build then matches the audit's build by
    construction — no flag-set drift, no library-name drift, no
    "we forgot CURL_USE_LIBPSL=OFF" surprises. The audit converges
    on a working script once via bin/auto-build-script; every
    downstream reproduce.sh splices in that exact script.
    """
    delim = "__AUDIT_BUILD_SCRIPT_EOF__"
    counter = 1
    while delim in script_text:
        delim = f"__AUDIT_BUILD_SCRIPT_EOF_{counter}__"
        counter += 1
    body = script_text if script_text.endswith("\n") else script_text + "\n"
    return (
        "# Build recipe inlined from the audit's .audit/build.sh — the EXACT\n"
        "# script bin/auto-build-script converged on at audit time. Inlined\n"
        "# verbatim so the reproducer build matches the audit build.\n"
        f"cat > \"$src/{AUDIT_BUILD_MARKER}\" <<'{delim}'\n"
        f"{body}{delim}\n"
        f'chmod +x "$src/{AUDIT_BUILD_MARKER}"\n'
        f'"$src/{AUDIT_BUILD_MARKER}" "$src" "$build"\n'
    )


def emit_build(build_system: str, extra_target: str = "", sanitizer: str = "asan",
               audit_build_script: str = "") -> str:
    if audit_build_script:
        return emit_audit_build_script(audit_build_script)
    if build_system == "cmake":
        return emit_cmake_build(extra_target, sanitizer)
    if build_system == "autotools":
        return _sub_sanitizer_build_template(AUTOTOOLS_BUILD, sanitizer)
    if build_system == "mach":
        return _sub_sanitizer_build_template(MACH_BUILD, sanitizer)
    if build_system == "meson":
        return _sub_sanitizer_build_template(MESON_BUILD, sanitizer)
    # Language ecosystems (cargo/go/python/npm/...) get a runnable build
    # step suitable for `<lang> run`. Sanitizer enablement remains mostly
    # operator-owned for ecosystems with bespoke sanitizer flags; Go's race
    # detector is the one generic flag we can add safely.
    if sanitizer == "race" and build_system == "go":
        return GO_BUILD.replace("go build -o \"$build/repro\" ./...", "go build -race -o \"$build/repro\" ./...")
    tmpl = _LANGUAGE_BUILD_TEMPLATES.get(build_system)
    if tmpl is not None:
        return tmpl
    return UNKNOWN_BUILD


def _strip_sanitizer_build_prefix(path: str, sanitizer: str) -> str:
    meta = sanitizer_meta(sanitizer)
    # The path may carry an AUDIT_BUILD_SUFFIX-suffixed root
    # (build-asan-<image-id>/...) when target.toml was generated inside a
    # container. Strip the literal roots first, then fall back to a generic
    # "build-<san>*/..." prefix match so suffixed roots also resolve.
    for root in (meta["build_dir"], meta["fallback_build"]):
        prefix = f"{root}/"
        if path.startswith(prefix):
            return path[len(prefix):]
    san_prefix = f"build-{sanitizer}"
    head, sep, tail = path.partition("/")
    if sep and head.startswith(san_prefix):
        return tail
    if sanitizer != "asan" and sep and head.startswith("build-asan"):
        return tail
    return path


def emit_bin_resolve(san_bin_rel: str, sanitizer: str = "asan") -> str:
    if not san_bin_rel:
        return f'echo "{sanitizer_meta(sanitizer)["label"]} binary not configured in target.toml" >&2\nexit 2\n'
    tail = _strip_sanitizer_build_prefix(san_bin_rel, sanitizer)
    return _sub_template(
        BIN_RESOLVE,
        __SAN_BIN_TAIL__=shq(tail),
        __SAN_BIN_REL__=shq(san_bin_rel),
        __SANITIZER_LABEL__=sanitizer_meta(sanitizer)["label"],
    )


def _san_lib_is_unset(san_lib_rel: str) -> bool:
    """A target.toml sanitizer lib field is "unset" if absent, empty, or
    still carrying the FILL_ME placeholder from seed_toml. Header-only C++ libs
    legitimately have no archive; treat all three cases the same so the
    generated reproduce.sh has no broken library reference.
    """
    return not san_lib_rel or "FILL_ME" in san_lib_rel


def _asan_lib_is_unset(asan_lib_rel: str) -> bool:
    return _san_lib_is_unset(asan_lib_rel)


def emit_lib_resolve(san_lib_rel: str, sanitizer: str = "asan") -> str:
    if _san_lib_is_unset(san_lib_rel):
        return ""
    tail = _strip_sanitizer_build_prefix(san_lib_rel, sanitizer)
    return _sub_template(
        LIB_RESOLVE,
        __SAN_LIB_TAIL__=shq(tail),
        __SAN_LIB_REL__=shq(san_lib_rel),
        __SANITIZER_LABEL__=sanitizer_meta(sanitizer)["label"],
        __SANITIZER_FLAG__=sanitizer_meta(sanitizer)["flag"] or "address",
    )


def emit_include_args(includes: list[str]) -> str:
    args = ""
    saw_src_root = False
    for inc in includes:
        if not inc:
            continue
        build_tail = ""
        # AUDIT_BUILD_SUFFIX may have produced build-<san>-<image-id>/... in
        # target.toml; match by prefix instead of literal "build-asan/".
        head, sep, tail = inc.partition("/")
        if sep and head.startswith(("build-asan", "build-ubsan",
                                    "build-msan", "build-tsan", "build-race")):
            build_tail = tail
        if build_tail:
            tail = build_tail
            args += f' -I "$build"/{shq(tail)}'
            # Some CMake projects, including zlib, generate public headers
            # directly in the build root rather than build/include.
            if tail == "include":
                args += ' -I "$build"'
        elif inc.startswith("/"):
            args += f" -I {shq(inc)}"
        else:
            args += f' -I "$src"/{shq(inc)}'
            if inc == ".":
                saw_src_root = True
    # Many small C projects (cJSON, sqlite, lua) keep public headers at the
    # source root rather than under include/. Add -I "$src" as a safety net
    # so a target.toml that only lists include/ still resolves root headers.
    if not saw_src_root:
        args += ' -I "$src"'
    return args


# Audit-side reproducer body rewriter (the second awk in bin/export-repro).
_REWRITE_INTERNAL_HEADER_RE = re.compile(
    r"^\s*#\s*(?:TARGET|HYPOTHESIS-ID|CATEGORY|CARD-ID|HARNESS):"
)
_REWRITE_VAR_INIT_RE = re.compile(
    r"^\s*(?:ROOT|SRC|BUILD|SCRATCH|HARNESS_C|HARNESS_BIN|CATALOG_BIN|BIN)="
)
_REWRITE_SET_EU_RE = re.compile(r"^\s*set\s+-eu[a-zA-Z]*\s*$")
_REWRITE_HARNESS_BIN_GUARD_RE = re.compile(r"^\s*if\s+\[\s+!.*HARNESS_BIN")
_REWRITE_FI_RE = re.compile(r"^\s*fi\s*$")
_REWRITE_BIN_QUOTED = re.compile(r'"\$CATALOG_BIN"|"\$BIN"|"\$HARNESS_BIN"')
# Any absolute, double-quoted path that ends in `/build-<sanitizer>/<binary>`
# is an audit-side hardcoded binary path that the wrapper template
# replaces with `$san_bin`. We do NOT anchor on `/Users/` (that broke
# under Docker `/root/work`, CI `/workspace`, NixOS `/nix/...`, WSL
# `/mnt/...`) — the `/build-(a|ub|m|t)san/` infix is the load-bearing
# discriminator and is target-agnostic.
_REWRITE_HARDCODED_PATH = re.compile(
    r'"/[^"]+/build-(?:a|ub|m|t)san/[A-Za-z0-9_.-]+"'
)


def rewrite_audit_script_body(in_path: Path, slug: str = "",
                              target_root: str = "") -> str:
    """Strip audit-internals and rewrite hardcoded paths to $san_bin / $src.

    Mirrors the awk pipeline in bin/export-repro:rewrite_audit_script_body.
    Self-compiling shell harnesses (e.g. `harness.sh` that calls clang on
    `<audit_root>/targets/<slug>/foo.c`) need those audit-machine paths
    rerouted to the maintainer's cloned upstream tree (`$src`). We rewrite
    both forms — the original absolute `target_root/foo` (this rewriter
    runs before `_normalize_bundle_paths`) and the slug-relative
    `targets/<slug>/foo` (defensive, in case the wrapper was pre-normalized).
    """
    # Each rewrite replaces a directory-prefix reference to the audit-side
    # source tree with `"$repro_src"` (the maintainer's cloned checkout).
    # We deliberately use `$repro_src` and not `$src` because self-compiling
    # wrappers commonly reassign `src` to their own scratch file (e.g.
    # `src="$work/repro.c"`), which would shadow our outer variable. The
    # caller is responsible for emitting `repro_src="$src"` before the
    # wrapper body.
    #
    # We don't require a trailing `/` — `-I/.../targets/<slug>` (used as
    # an include dir) must rewrite as cleanly as `/.../targets/<slug>/foo.c`.
    # The trailing word-boundary blocks accidental matches into siblings
    # like `targets/<slug>_old`.
    _TRAILING = r"(?![A-Za-z0-9_-])"
    path_rewrites: list[tuple[re.Pattern[str], str]] = []
    if target_root:
        path_rewrites.append((
            re.compile(re.escape(target_root.rstrip("/")) + _TRAILING),
            '"$repro_src"',
        ))
    if slug:
        # Negative lookbehind on `/`: if the prior char is `/`, this is the
        # tail of a longer absolute path the absolute-prefix rule above is
        # expected to own. Otherwise (whitespace, `-I`, `"`, …) it's a
        # standalone slug-relative reference we should rewrite ourselves.
        path_rewrites.append((
            re.compile(r"(?<!/)targets/" + re.escape(slug) + _TRAILING),
            '"$repro_src"',
        ))
    out: list[str] = []
    skip_block = False
    with open(in_path, "r", encoding="utf-8", errors="replace") as f:
        for i, line in enumerate(f, start=1):
            stripped = line.rstrip("\n")
            if i == 1 and stripped.startswith("#!"):
                continue
            if _REWRITE_SET_EU_RE.match(stripped):
                continue
            if _REWRITE_INTERNAL_HEADER_RE.match(stripped):
                continue
            if _REWRITE_VAR_INIT_RE.match(stripped):
                continue
            if _REWRITE_HARNESS_BIN_GUARD_RE.match(stripped):
                skip_block = True
                continue
            if skip_block:
                if _REWRITE_FI_RE.match(stripped):
                    skip_block = False
                continue
            new = _REWRITE_BIN_QUOTED.sub('"$san_bin"', stripped)
            new = _REWRITE_HARDCODED_PATH.sub('"$san_bin"', new)
            for pat, repl in path_rewrites:
                new = pat.sub(repl, new)
            out.append(new + "\n")
    return "".join(out)


# ─── REPORT.md helpers ──────────────────────────────────────────────

# strip_audit_sections — remove the leading h1+table, audit-internal
# `## Reproduction`, auto-appended `## Reproduce` / `## Expected ...`,
# bare-label fields, the auto-Severity bullet, and squash blank-line runs.
# Section-end pseudo-tokens (Data Flow, Patch, ...) end an active
# skip block when encountered as bare-label intros.

_H1_CRASH_RE = re.compile(r"^# CRASH-[A-Z0-9-]+")
_TBL_ROW_RE = re.compile(r"^\| ")
_TBL_SEP_RE = re.compile(r"^\|[-: ]+\|")
_BLANK_RE = re.compile(r"^\s*$")
# Any ATX heading. Used to end an active whole-section skip: the original
# rule only reset on an H2 (`## `), so a narrative the agent placed under an
# H1 (e.g. `# Mechanism`) after a killed section was swallowed whole.
_HEADING_RE = re.compile(r"^#{1,6}\s")
# A stray H1 in the agent body (any `# Heading` that is not the bundle's own
# crash title). Demoted to H2 so it renders as a subsection rather than a
# second top-level heading.
_BODY_H1_RE = re.compile(r"^# (?=\S)")
# A heading the agent wrote that restates a crash id/title (e.g.
# `## CRASH-1: heap-buffer-overflow ...`). The bundle already supplies the
# authoritative `# CRASH-NNNN: ...` title, so the agent's copy is a duplicate
# title — drop the heading line (its body content is kept). The digit after
# `CRASH-` keeps real crash ids (CRASH-1, CRASH-001-3) while leaving ordinary
# hyphenated headings (`## CRASH-resistant design`) untouched.
_BODY_CRASH_TITLE_RE = re.compile(r"^#{1,6}\s+CRASH-\d")
# A fenced code block carrying a sanitizer dump. The bundle re-emits the
# authoritative sanitizer output in its own `## Expected sanitizer output`
# section, so an agent's copy — under any heading, or embedded inside a
# narrative section — is a duplicate. Matched by the SHAPE of a real dump (a
# `<X>Sanitizer:` report line, a `SUMMARY:` line, a numbered stack frame, or a
# UBSan `file:line:col: runtime error:`) so a passing mention of a sanitizer
# in source or prose does not cause a code block to be dropped.
_SANITIZER_DUMP_RE = re.compile(
    r"(?:Address|Leak|Thread|Memory|HWAddress|UndefinedBehavior)Sanitizer:"
    r"|^\s*SUMMARY:\s*\w*Sanitizer"
    r"|^\s*#\d+\s+0x[0-9a-fA-F]+"
    r"|:\d+:\d+:\s+runtime error:",
    re.MULTILINE,
)
# Agents commonly wrap the field table under a `## Fields` heading. The
# auto-generated REPORT.md prepends its own Fields table, so we drop the
# agent's heading + immediately-following table to avoid duplication.
_FIELDS_HEADING_RE = re.compile(r"^#{1,6}\s+Fields\s*$", re.IGNORECASE)
# Whole-section kills. `Expected sanitizer output` / `ASan top frames` are
# auto-appended sections from a prior bundle (idempotent re-strip). A bare
# `Sanitizer output` / `ASan output` is the model's freeform pointer (often
# just "See sanitizer.txt") — redundant once export-repro re-inlines the
# full diagnostic under the canonical `## Expected sanitizer output`, so we
# drop it to avoid two sanitizer sections in the rendered report. Matching
# is case-insensitive on the leaf word so `Sanitizer`/`sanitizer` both go.
# `Severity rationale` is bin/severity's auto-appended section — strip here so
# it gets re-appended at the END of the rebuilt report (after Reproduce) by the
# severity pass the caller runs immediately after; without stripping, it'd sit
# in the body ahead of the sanitizer stack because the scorer ran against the
# previous rebuild. Match the section heading at ANY level (not just `## `):
# agents sometimes write these auto-emitted sections as an H1 (`# Sanitizer
# output`). An H2-only match left the H1 form in the body — a duplicate of the
# harness-appended section — and broke idempotency once demote_body_headings
# turned the survivor into an H2 that a second pass would then kill.
_SECTION_REPRO_BLOCKS_RE = re.compile(
    r"^#{1,6} *(?:Reproduce"
    r"|(?:Expected\s+)?[Ss]anitizer\s+[Oo]utput"
    r"|ASan\s+(?:top\s+frames|[Oo]utput)"
    r"|Severity\s+rationale)(?:\s|$)"
)
_SECTION_REPRODUCTION_HEADER_RE = re.compile(r"^#{1,6} *Reproduction(?:\s|$)")
_BARE_REPRODUCTION_RE = re.compile(r"^Reproduction:\s*$")
_END_SKIP_LABEL_RE = re.compile(
    r"^(?:Data Flow|Patch|Supplemental|Evidence|Boundary|Classification|Summary|Root Cause|Suggested fix|Notes)[: ]"
)
_FULL_ORIGINAL_RE = re.compile(r"^Full original output:")
_BARE_LABEL_RES = (
    re.compile(r"^[Ss]urface:\s"),
    re.compile(r"^[Cc]luster:\s"),
    re.compile(r"^[Dd]edup\s+frames:\s"),
    re.compile(r"^[Cc]luster[Ff]uzz\s+key\s+frames:\s"),
    re.compile(r"^[Bb]oundary:\s"),
    re.compile(r"^[Cc]aller\s+controls:\s"),
    re.compile(r"^[Pp]arameter\s+control:\s"),
    re.compile(r"^[Tt]rusted\s+caller\s+actions:\s"),
    re.compile(r"^[Cc]aller\s+contract:\s"),
    re.compile(r"^[Tt]rigger\s+source:\s"),
    # Location / bug-class fields some agents (especially freeform
    # model-direct reports) restate as loose labels right after the Fields
    # table. They duplicate rows the auto Fields table already emits — Dedup
    # frames carries file:function:line, Primitive carries the bug class — so
    # drop them from the body like the restated fields above, rather than
    # leave them as orphaned `Label: value` lines ahead of the narrative.
    # The value pattern is deliberately tight (a single token for
    # file/function/line, a short class-name run for class) so a narrative
    # sentence that merely begins with one of these words — "File: the parser
    # reads ...", "Class: this is an instance of ..." — is NOT mistaken for a
    # field restatement and dropped.
    re.compile(r"^File:\s+\S+\s*$"),
    re.compile(r"^Function:\s+\S+\s*$"),
    re.compile(r"^Line:\s+\S+\s*$"),
    re.compile(r"^(?:Bug\s+)?[Cc]lass:\s+[\w()\- ]{1,40}\s*$"),
)
_AUTO_SEVERITY_RE = re.compile(r"^-?\s*\*\*Severity\*\*\s*:")
# Kept metadata lines (strip leaves these in the body); skipped, not treated as
# narrative, when deciding whether the narrative already has a heading.
_STRATEGY_LINE_RE = re.compile(r"^(?:Strategy|Advisory):\s", re.IGNORECASE)
# Enrichment blocks (`<!-- enrich:NAME -->...<!-- /enrich:NAME -->`) that
# lib/report_enrich.py prepends to the body. They are harness-owned metadata
# (bin/render-md renders them as the hero card / snippet cards), not agent
# narrative — skipped, not treated as narrative, when placing the heading.
_ENRICH_OPEN_RE = re.compile(r"^<!--\s*enrich:[A-Za-z0-9_-]+\s*-->\s*$")
_ENRICH_CLOSE_RE = re.compile(r"^<!--\s*/enrich:[A-Za-z0-9_-]+\s*-->\s*$")
# An existing `## Summary` heading anywhere in the body. When present, the
# narrative is already headed under Summary, so _ensure_leading_heading must
# not prepend a second one — even if an orphan metadata line (`Linked FIND:`,
# a recon cross-reference) sits above it and would otherwise look like the
# first unheaded narrative line.
_SUMMARY_HEADING_RE = re.compile(r"^#{1,6}\s+Summary\s*$", re.IGNORECASE | re.MULTILINE)


# Prose `## Fix` (or near-variant) sections agents write between Summary
# and the reproducer. Lifted out of the body in build_report_md so they
# can sit at the END of the rebuilt report — after the sanitizer stack
# and Reproduce — alongside the Severity rationale. The
# variants mirror lib/report_enrich.py's `_FIX_SECTION_NAMES`.
# `## Fix Direction` is intentionally excluded — that's the
# advisory-no-patch narrative and load-bearing for downstream TL;DR mining.
_FIX_HEADING_NAMES = ("Fix", "Suggested fix", "Recommended fix", "Proposed fix")
_FIX_HEADING_PATTERN = re.compile(
    r"^##\s+(?:Fix|Suggested\s+fix|Recommended\s+fix|Proposed\s+fix)\s*$.*?(?=^##\s|\Z)",
    re.MULTILINE | re.DOTALL | re.IGNORECASE,
)


def extract_fix_section(text: str) -> tuple[str, str]:
    """Lift a prose `## Fix` (or near-variant) section out of `text`.

    Returns (text_without_fix, fix_section). The section is removed from
    its original position so build_report_md can re-place it at the end
    of the rebuilt report. Idempotent: a second call on the result simply
    returns (text, "") when no Fix heading remains. `## Fix Direction` is
    NOT matched (the heading regex anchors `\\s*$` after the leaf word).
    """
    m = _FIX_HEADING_PATTERN.search(text)
    if m is None:
        return text, ""
    section = m.group(0).rstrip() + "\n"
    without = text[:m.start()] + text[m.end():]
    return without, section


_SUMMARY_SECTION_HEADING_RE = re.compile(r"^#{1,6}\s+Summary\s*$", re.IGNORECASE)


def extract_summary_section(text: str) -> tuple[str, str]:
    """Split the leading `## Summary` section off the front of `text`.

    Returns (summary_head, rest). `summary_head` is everything from the start
    of the body through the end of the `## Summary` section — including any
    leading enrichment blocks that precede the heading — so build_report_md can
    place it ABOVE the Fields table, matching the finding-report layout
    (Title -> Summary -> Fields -> rest). `rest` is the remaining narrative
    (Classification, Root Cause, Data Flow, ...), which stays below Fields.

    No-op (returns ("", text)) when there is no `## Summary`, or when another
    section heading precedes it (only enrichment / blank / non-heading lines may
    sit above Summary for it to lead). Idempotent: a second call on `rest`
    returns ("", rest). The section boundary is the next `##` heading, so `###`
    subsections stay attached to Summary.
    """
    lines = text.splitlines(keepends=True)
    sidx = next((i for i, l in enumerate(lines)
                 if _SUMMARY_SECTION_HEADING_RE.match(l.strip())), None)
    if sidx is None:
        return "", text
    # Summary must lead: nothing but enrichment / blank / non-heading lines
    # may precede it, else moving it would drag an earlier section along.
    if any(l.lstrip().startswith("#") for l in lines[:sidx]):
        return "", text
    eidx = next((i for i in range(sidx + 1, len(lines))
                 if lines[i].lstrip().startswith("## ")), len(lines))
    head = "".join(lines[:eidx]).rstrip() + "\n"
    rest = "".join(lines[eidx:])
    return head, rest


def strip_audit_sections(text: str) -> str:
    out: list[str] = []
    skip = False
    fields_skip = False
    # 0 = haven't seen the H1 yet; 1 = inside the H1's preamble (eat
    # blanks + a `## Fields` heading + the field table); 2 = preamble
    # done.
    ate_h1_table = 0
    blank_run = False
    for raw_line in text.splitlines(keepends=True):
        line_no_nl = raw_line.rstrip("\n")
        # Drop the leading h1 and the field table that follows it. The
        # preamble may interleave blank lines and an optional `## Fields`
        # heading before the actual table — we eat all of it until the
        # first non-blank, non-table, non-Fields-heading line.
        if ate_h1_table == 0 and _H1_CRASH_RE.match(line_no_nl):
            ate_h1_table = 1
            continue
        if ate_h1_table == 1:
            if _BLANK_RE.match(line_no_nl):
                continue
            if _FIELDS_HEADING_RE.match(line_no_nl):
                continue
            if _TBL_ROW_RE.match(line_no_nl):
                continue
            if _TBL_SEP_RE.match(line_no_nl):
                continue
            ate_h1_table = 2  # First real body line — preamble is over.
        # Drop the `## Fields` heading + the table that follows it: the
        # bundle's auto-header already emits a Fields table, so the agent's
        # copy would render as a duplicate. Unlike the whole-block kills
        # below, this eats ONLY the heading and its table lines (blank /
        # row / separator). The first line that is not part of the table
        # ends the skip and is processed normally — so narrative prose the
        # agent placed after the table (under an H1 like `# Mechanism`, or
        # under no heading at all) is preserved rather than swallowed.
        if _FIELDS_HEADING_RE.match(line_no_nl):
            fields_skip = True
            continue
        if fields_skip:
            if (_BLANK_RE.match(line_no_nl)
                    or _TBL_ROW_RE.match(line_no_nl)
                    or _TBL_SEP_RE.match(line_no_nl)):
                continue
            fields_skip = False  # End of the table — fall through.
        # Whole-block kills: these sections are re-appended at the end of
        # the rebuilt bundle, so drop everything up to the next heading.
        if _SECTION_REPRODUCTION_HEADER_RE.match(line_no_nl):
            skip = True
            continue
        if _BARE_REPRODUCTION_RE.match(line_no_nl):
            skip = True
            continue
        if _SECTION_REPRO_BLOCKS_RE.match(line_no_nl):
            skip = True
            continue
        # End an active whole-section skip at the next heading of ANY level
        # (not just H2) or a bare-label section intro.
        if skip and _HEADING_RE.match(line_no_nl):
            skip = False
        if skip and _END_SKIP_LABEL_RE.match(line_no_nl):
            skip = False
        if skip:
            continue
        # Drop a heading that just restates the crash id/title — the bundle
        # already carries the authoritative `# CRASH-NNNN: ...` title. Only
        # the heading line goes; the section's body content stays.
        if _BODY_CRASH_TITLE_RE.match(line_no_nl):
            continue
        if _FULL_ORIGINAL_RE.match(line_no_nl):
            continue
        if any(p.match(line_no_nl) for p in _BARE_LABEL_RES):
            continue
        if _AUTO_SEVERITY_RE.match(line_no_nl):
            continue
        # Squash consecutive blank lines.
        if _BLANK_RE.match(line_no_nl):
            if blank_run:
                continue
            blank_run = True
            out.append(raw_line)
            continue
        blank_run = False
        out.append(raw_line)
    return "".join(out)


def demote_body_headings(text: str) -> str:
    """Demote stray H1 lines (`# Foo` → `## Foo`) in an agent body.

    The bundle supplies the single H1 crash title; any H1 the agent wrote
    in the body (e.g. `# Mechanism`) would otherwise render as a second
    top-level heading and, when its body was stripped, as an empty one.
    Lines inside fenced code blocks are left untouched. Idempotent: an H2
    is never matched, so a second pass is a no-op.
    """
    out: list[str] = []
    in_fence = False
    for raw_line in text.splitlines(keepends=True):
        stripped = raw_line.lstrip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            out.append(raw_line)
            continue
        if not in_fence and _BODY_H1_RE.match(raw_line):
            raw_line = "#" + raw_line  # "# Foo" -> "## Foo"
        out.append(raw_line)
    return "".join(out)


# Sections the bundle re-emits itself — never carry the agent's copy. Used by
# the conservative `recover_agent_prose` fallback (section-based, independent
# of the line-greedy strip so a bug in one cannot silently break the other).
_AUTO_SECTION_RE = re.compile(
    r"^#{1,6}\s+(?:Fields"
    r"|Reproduce|Reproduction"
    r"|(?:Expected\s+)?[Ss]anitizer\s+[Oo]utput"
    r"|ASan\b"
    r"|Severity\s+rationale)\b",
    re.IGNORECASE,
)


def _is_structured_line(stripped: str) -> bool:
    """A non-narrative body line: table row/separator, bare-label field,
    the auto-Severity bullet, or the `Full original output:` pointer."""
    if stripped.startswith("|"):
        return True
    if any(p.match(stripped) for p in _BARE_LABEL_RES):
        return True
    if _AUTO_SEVERITY_RE.match(stripped) or _FULL_ORIGINAL_RE.match(stripped):
        return True
    return False


def _body_has_prose(text: str) -> bool:
    """True if `text` carries narrative — a non-blank line that is not a
    heading, table row, bare-label field, or auto-emitted boilerplate."""
    for raw in text.splitlines():
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if _is_structured_line(stripped):
            continue
        return True
    return False


def recover_agent_prose(text: str) -> str:
    """Conservative fallback recovery of an agent body.

    Drops only the leading crash-title H1 and the known auto-emitted
    sections (Fields, Reproduce/Reproduction, sanitizer output, Severity
    rationale) by heading, plus stray structured lines, keeping
    every other line verbatim. Section-based and deliberately independent of
    `strip_audit_sections` so it can still surface the narrative if that
    line-greedy function ever over-strips.
    """
    out: list[str] = []
    drop = False
    for raw_line in text.splitlines(keepends=True):
        line = raw_line.rstrip("\n")
        if _H1_CRASH_RE.match(line):
            continue
        if _HEADING_RE.match(line):
            drop = bool(_AUTO_SECTION_RE.match(line))
            if drop:
                continue
        if drop:
            continue
        if _is_structured_line(line):
            continue
        out.append(raw_line)
    return "".join(out)


def strip_sanitizer_blocks(text: str) -> str:
    """Drop fenced code blocks whose content is a sanitizer dump.

    The bundle re-emits the authoritative sanitizer output in its own
    `## Expected sanitizer output` section, so an agent's copy — under any
    heading (`## Observed`, `## ASan Evidence`, ...) or embedded inside a
    narrative section — is a duplicate. Matched by content (a sanitizer
    signature inside the fence), not by heading name, so it is robust to
    whatever the agent titled it. A non-sanitizer code block (source, a
    reproduce command) is kept verbatim. The enclosing heading and any
    surrounding prose stay; an emptied heading is dropped by bin/render-md.
    """
    lines = text.splitlines(keepends=True)
    out: list[str] = []
    i, n = 0, len(lines)
    while i < n:
        fence = lines[i].lstrip()[:3]
        if fence in ("```", "~~~"):
            j = i + 1
            while j < n and lines[j].lstrip()[:3] != fence:
                j += 1
            if j >= n:
                # No closing fence — malformed. Keep this line and process the
                # rest normally rather than swallowing the document tail.
                out.append(lines[i])
                i += 1
                continue
            if _SANITIZER_DUMP_RE.search("".join(lines[i + 1:j])):
                i = j + 1                  # drop open fence + content + close fence
                continue
            out.extend(lines[i:j + 1])     # keep the block verbatim
            i = j + 1
            continue
        out.append(lines[i])
        i += 1
    return "".join(out)


def _squash_blank_runs(text: str) -> str:
    """Collapse runs of blank lines to a single blank — block removal can
    leave a double blank where a fenced dump used to sit. Applied once at the
    end so the result is stable on a second render_agent_body pass."""
    out: list[str] = []
    blank = False
    for line in text.splitlines(keepends=True):
        if line.strip() == "":
            if blank:
                continue
            blank = True
        else:
            blank = False
        out.append(line)
    return "".join(out)


def _ensure_leading_heading(text: str) -> str:
    """Guarantee the agent narrative sits under a section heading.

    Once the auto-emitted sections, field restatements, duplicate sanitizer
    dumps and restated crash titles are stripped, a body can lead with bare
    narrative prose — either because the agent wrote no heading, or because the
    only heading it wrote restated the crash title (dropped above). The bundle
    would then render that prose with no section title. Prepend a canonical
    `## Summary` in that case. No-op when the body already leads with a heading
    (of any level), already carries a `## Summary` heading (the narrative is
    headed — a second one would duplicate it), or carries no narrative. The
    kept `Strategy:` metadata line is skipped, not treated as narrative.
    """
    if _SUMMARY_HEADING_RE.search(text):
        return text                              # already headed under Summary
    lines = text.splitlines(keepends=True)
    in_enrich = False
    for idx, raw in enumerate(lines):
        s = raw.strip()
        if _ENRICH_OPEN_RE.match(s):
            in_enrich = True
            continue                          # skip enrich metadata block
        if _ENRICH_CLOSE_RE.match(s):
            in_enrich = False
            continue
        if in_enrich:
            continue
        if not s:
            continue
        if s.startswith("#"):
            return text                      # already under a heading
        if _is_structured_line(s) or _STRATEGY_LINE_RE.match(s):
            continue                          # skip kept metadata (Strategy:, ...)
        # First narrative line, with no heading above it — head it.
        sep = "" if idx == 0 or lines[idx - 1].strip() == "" else "\n"
        lines.insert(idx, sep + "## Summary\n\n")
        return "".join(lines)
    return text                              # no narrative to head


def render_agent_body(body_text: str) -> str:
    """Turn a raw agent report body into the narrative spliced into the
    bundle: strip the auto-emitted sections, drop duplicate sanitizer dumps,
    demote stray H1s, and ensure the narrative sits under a heading. If
    stripping leaves no prose but the original had some, fall back to the
    conservative section-based recovery (independent of the line-greedy strip)
    so the bundle never ships an empty narrative.
    """
    rendered = strip_sanitizer_blocks(strip_audit_sections(body_text))
    if not _body_has_prose(rendered) and _body_has_prose(body_text):
        rendered = strip_sanitizer_blocks(recover_agent_prose(body_text))
    return _ensure_leading_heading(_squash_blank_runs(demote_body_headings(rendered)))


def read_field_from_fields_table(path: Optional[Path], label: str) -> str:
    """Lookup `label` in the first `## Fields` Markdown table in `path`.

    Modern agent reports often place all required fields in a GFM
    table under a `## Fields` heading rather than as bare-label lines.
    This helper walks that table and returns the value cell verbatim
    (without inline markup stripping) or "" if absent.
    """
    if path is None or not path.is_file():
        return ""
    label_lower = label.strip().lower()
    in_section = False
    seen_sep = False
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for raw in f:
            line = raw.rstrip("\n")
            if not in_section:
                if _FIELDS_HEADING_RE.match(line):
                    in_section = True
                continue
            # Inside the Fields section.
            if line.startswith("#"):
                # Next heading ends the section without a match.
                return ""
            if not line.strip():
                if seen_sep:
                    # Blank line after the table closes it.
                    return ""
                continue
            # Parse a single GFM table row: `| key | value |`.
            stripped = line.strip()
            if not (stripped.startswith("|") and stripped.endswith("|")):
                if seen_sep:
                    return ""
                continue
            # Header separator (`|:---|:---|`) — mark and continue.
            if _TBL_SEP_RE.match(line):
                seen_sep = True
                continue
            # Strip the outer pipes and split on the first internal pipe.
            inner = stripped[1:-1]
            parts = inner.split("|", 1)
            if len(parts) != 2:
                continue
            key = parts[0].strip()
            val = parts[1].strip()
            if not seen_sep:
                # Header row (e.g., `| Field | Value |`) — skip.
                continue
            if key.lower() == label_lower:
                return val
    return ""


def read_bare_field(path: Optional[Path], label: str) -> str:
    """Read `^Label: value` or a short `Label:\nvalue` block, falling back
    to a `## Fields` Markdown table when the bare-label form is absent.

    Returns the trimmed value or "" if path is empty / file absent / label
    not found.
    """
    if path is None or not path.is_file():
        return ""
    pattern = re.compile(rf"^{re.escape(label)}:[ \t]+", re.IGNORECASE)
    block_pattern = re.compile(rf"^{re.escape(label)}:[ \t]*$", re.IGNORECASE)
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        lines = list(f)
    for idx, line in enumerate(lines):
        if pattern.match(line):
            line = line.rstrip("\n")
            # Strip "Label:" + leading spaces, plus trailing whitespace.
            m = re.match(r"^[A-Za-z0-9 /_-]+:\s*", line)
            if m:
                line = line[m.end():]
            return line.rstrip()
        if block_pattern.match(line.rstrip("\n")):
            vals: list[str] = []
            for nxt in lines[idx + 1:]:
                stripped = nxt.strip()
                if not stripped:
                    if vals:
                        break
                    continue
                vals.append(stripped)
            return " ".join(vals).rstrip()
    return read_field_from_fields_table(path, label)


def read_llm_sidecar_fields(scan_dirs: list[Path]) -> dict:
    """Reach fields the harness LLM hybrid pass wrote to `.llm_fields.json`.

    The model-direct prompt asks only for a minimal crash report.md
    (file/function/class); the structured reachability fields (Surface /
    Trigger source / Caller controls / Boundary / …) come from this sidecar —
    the same fallback bin/severity already consumes. The bundle build must read
    it too: without it every reach field the report omits collapses to a dash
    and the severity re-score runs on empties. First sidecar in scan order
    wins; a missing or malformed file yields {}. Values are returned verbatim
    (stripped); blanks are dropped so callers can `or`-chain a report value
    ahead of the sidecar.
    """
    sidecar = find_first_in_scan(scan_dirs, ".llm_fields.json")
    if sidecar is None:
        return {}
    try:
        data = json.loads(sidecar.read_text(encoding="utf-8", errors="replace"))
    except (OSError, ValueError):
        return {}
    if not isinstance(data, dict):
        return {}
    return {k: v.strip() for k, v in data.items()
            if isinstance(v, str) and v.strip()}


_STRATEGY_TOKEN_RE = re.compile(r"\b(S[1-8]|REF)\b", re.IGNORECASE)


def normalize_strategy(value: str) -> str:
    """Reduce a free-form Strategy field to its canonical token.

    Accepts agent-written forms like 'S2', 'Strategy 2', 'S2-invariant-negation',
    'S5 (lifetime & state)', or 'REF: pattern-search'. Returns the bare token
    (S1..S8 or REF) so the Fields table and cluster columns stay terse. Falls
    back to the input value when no recognised token is present, and returns
    empty for empty input. The strategy index lives in
    .agents/references/strategies/README.md."""
    if not value:
        return ""
    s = value.strip()
    if not s:
        return ""
    m = _STRATEGY_TOKEN_RE.search(s)
    if not m:
        return s
    token = m.group(1).upper()
    return token


def read_severity_from(path: Optional[Path]) -> str:
    """Return `"Level (CVSS[-*] 4.0: score)"` or just `"Level"` if the Severity line
    exists in `path`; "" otherwise. The colon after the version keeps the score
    from reading as a second version number (`4.0 6.0`).
    """
    if path is None or not path.is_file():
        return ""
    sev_re = re.compile(
        r"^-?\s*\*\*Severity\*\*\s*:\s*(Critical|High|Medium|Low|None|Unknown)"
    )
    score_re = re.compile(
        r"\b(CVSS(?:-[A-Z]+)?)(?:\s+(4\.0))?\s*:?\s*([0-9]+(?:\.[0-9]+)?)(?![0-9./])"
    )
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.rstrip("\n")
            m = sev_re.match(line)
            if m:
                level = m.group(1)
                sm = score_re.search(line)
                if sm:
                    name, version, score = sm.groups()
                    if version:
                        return f"{level} ({name} {version}: {score})"
                    return f"{level} ({name}: {score})"
                return level
    return ""


def read_auto_severity_line(path: Optional[Path]) -> str:
    """Return the existing generated `**Severity**: ...` line minus any
    leading `-` bullet, or "" if absent.
    """
    if path is None or not path.is_file():
        return ""
    sev_re = re.compile(r"^-?\s*\*\*Severity\*\*\s*:.*\((?:auto:|CVSS(?:-[A-Z]+)?\s+4\.0:)")
    leading_re = re.compile(r"^-?\s*")
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.rstrip("\n")
            if sev_re.match(line):
                return leading_re.sub("", line)
    return ""


def read_confidence(report_md: Optional[Path], asan_file: Path) -> str:
    pair_re = re.compile(r"([0-9]+/[0-9]+)")
    if asan_file.is_file():
        cr_re = re.compile(r"CRASH_RATE:\s+([0-9]+/[0-9]+)")
        with open(asan_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                m = cr_re.search(line)
                if m:
                    return m.group(1)
    if report_md is not None and report_md.is_file():
        rate_re = re.compile(
            r"(?:Crash\s+rate|Reproduction\s+rate|Rate):\s+[0-9]+/",
            re.IGNORECASE,
        )
        extract_re = re.compile(r":\s*([0-9]+/[0-9]+)")
        with open(report_md, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                if rate_re.search(line):
                    m = extract_re.search(line)
                    if m:
                        return m.group(1)
        # Fallback: GFM Fields-table cell `| Reproduction rate | 5/5 |`.
        for label in ("Reproduction rate", "Crash rate", "Rate"):
            cell = read_field_from_fields_table(report_md, label)
            if cell:
                m = pair_re.search(cell)
                if m:
                    return m.group(1)
    return "?"


def emit_field(label: str, value: str, why: str = "") -> str:
    val = value or "—"
    if why:
        return f"| {label:<21} | {val} — {why} |\n"
    return f"| {label:<21} | {val} |\n"


# ─── Sanitizer extraction ─────────────────────────────────────────────

SAN_DIAG_START_RE = re.compile(
    r"^(?:==[0-9]+==ERROR: (?:AddressSanitizer|UndefinedBehaviorSanitizer)|"
    r"WARNING: (?:ThreadSanitizer|MemorySanitizer):|"
    r"WARNING: DATA RACE$|"
    r"[^ \t].*:[0-9]+:[0-9]+: runtime error:|"
    r".*UndefinedBehaviorSanitizer:)"
)
SAN_SUMMARY_RE = re.compile(
    r"^SUMMARY: (?:AddressSanitizer|UndefinedBehaviorSanitizer|"
    r"ThreadSanitizer|MemorySanitizer)"
)

def extract_asan_top(asan_file: Path) -> str:
    if not asan_file.is_file():
        return ""
    with open(asan_file, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            if SAN_DIAG_START_RE.match(line):
                return line.rstrip("\n")
    return ""


def extract_asan_summary(asan_file: Path) -> str:
    if not asan_file.is_file():
        return ""
    with open(asan_file, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.rstrip("\n")
            if SAN_SUMMARY_RE.match(line):
                line = demangle(line + "\n").rstrip("\n")
                line = re.sub(r"\s*\([^)]*\+0x[0-9a-fA-F]+\)", "", line)
                return line
    return ""


def extract_dedup_frames(asan_file: Path) -> str:
    if not asan_file.is_file():
        return ""
    text = asan_file.read_text(encoding="utf-8", errors="replace")
    frames = stack_frames.interesting_frames(text, want=3)
    return " -> ".join(frame.display for frame in frames)


def extract_asan_diagnostic(asan_file: Path) -> str:
    """Return the first complete sanitizer diagnostic block.

    The maintainer-facing report should show the real sanitizer view: the
    ERROR line, access primitive (`READ/WRITE of size ...`), every stack
    section the sanitizer prints before SUMMARY, and the SUMMARY line. Stop before the
    shadow-byte dump so REPORT.md stays readable while `sanitizer.txt`
    remains the canonical full log.
    """
    if not asan_file.is_file():
        return ""
    lines: list[str] = []
    with open(asan_file, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            if SAN_DIAG_START_RE.match(line):
                lines = [line.rstrip("\n")]
                continue
            if not lines:
                continue
            lines.append(line.rstrip("\n"))
            if SAN_SUMMARY_RE.match(line):
                return demangle("\n".join(lines) + "\n").rstrip("\n")
            if len(lines) >= 160:
                break
    if not lines:
        return ""
    return demangle("\n".join(lines) + "\n").rstrip("\n")


# ─── Surface inference ──────────────────────────────────────────────
#
# Classify where a crash lives: a maintenance/test tool, the target's
# shipped command-line program, or its public library API. Every signal
# is either structural (path segments — industry-wide layout convention)
# or target-derived (binary names from target.toml, source paths from the
# target tree). No hardcoded per-project list: the identifying names come
# from the target's own config, so any project classifies correctly.

_HARNESS_MAINT_INCLUDE_RE = re.compile(
    r'#include\s+["<](?:[^">]+/)?(?:maint|tools|tests?|examples?)/'
)
_HARNESS_MAINT_DEFINE_RE = re.compile(r"#define\s+main\s+[a-zA-Z_]+_main")
# Any header include (quoted or angle-bracket) — a C harness that includes
# a real header is calling into a library. The maint check above already
# excludes tooling, so a plain header include is a sufficient signal; this
# replaces a former pcre2|libxml|openssl|… project enumeration.
_HARNESS_INCLUDE_RE = re.compile(
    r'#include\s+["<](?:[A-Za-z0-9_.+-]+/)*[A-Za-z][A-Za-z0-9_.+-]*'
    r'\.h(?:pp|xx)?[">]'
)
_FRAME_LINE_RE = re.compile(r"^\s*#[0-9]+")
_FRAME_MAINT_RE = re.compile(r"/(?:maint|tests?|examples?)/")
# Generic prose keywords for a command-line surface. Industry vocabulary,
# not project-specific. Tool *names* are matched separately, derived from
# target.toml — see _target_tool_names.
_REPORT_CLI_KEYWORD_RE = re.compile(
    r"--shell|\bcommand[- ]line\b|\bCLI\b", re.IGNORECASE
)
_REPORT_DEV_SURFACE_RE = re.compile(
    r"(^|[ /])(?:maint|tests?|fuzz|fuzzer|examples?)/|\b(?:test|maint)[- ]tool\b",
    re.IGNORECASE,
)


def _target_tool_names(cfg: object) -> set[str]:
    """Basenames of the executables this target ships, from its target.toml.

    The sanitizer binaries are the instrumented build of the target's own
    program — for a CLI project that basename *is* the tool name
    (`xmlcatalog`, `pcre2test`, …). Deriving it here replaces a hardcoded
    per-project CLI list, so surface inference works for any target.

    Browser targets are excluded: a browser is not a command-line tool and
    its binary name would mis-trip the `cli` classifier. The [runner] bin
    is excluded too — it is usually a generic interpreter (python3, node,
    …), i.e. the harness, not the target's own program.
    """
    names: set[str] = set()
    if cfg is None or str(getattr(cfg, "is_browser", "0")) == "1":
        return names
    for attr in ("asan_bin", "ubsan_bin", "msan_bin", "tsan_bin"):
        raw = (getattr(cfg, attr, "") or "").strip().rstrip("/")
        if not raw:
            continue
        base = os.path.basename(raw)
        if base.lower().endswith(".exe"):
            base = base[:-4]
        if base and not base.startswith("."):
            names.add(base)
    return names


def _names_in_text(names: set[str], text: str) -> bool:
    """True when any of `names` appears as a whole word in `text`."""
    if not names or not text:
        return False
    pattern = r"\b(?:" + "|".join(re.escape(n) for n in sorted(names)) + r")\b"
    return re.search(pattern, text) is not None


def _frames_under_target(frames: list[str], target_root: str) -> bool:
    """True when an ASan frame's source path lies inside the target tree."""
    root = (target_root or "").strip().rstrip("/")
    return bool(root) and any(root in line for line in frames)


def infer_surface(harness_src: Optional[Path], asan_file: Path,
                  cfg: object = None) -> tuple[str, str]:
    tool_names = _target_tool_names(cfg)
    target_root = (getattr(cfg, "target_root", "") or "") if cfg is not None else ""

    if harness_src is not None and harness_src.is_file():
        try:
            text = harness_src.read_text(encoding="utf-8", errors="replace")
        except OSError:
            text = ""
        if _HARNESS_MAINT_INCLUDE_RE.search(text) or _HARNESS_MAINT_DEFINE_RE.search(text):
            return "maint-tool", "harness embeds a maintenance/test program"
        if _HARNESS_INCLUDE_RE.search(text):
            return "library-api", "C harness calls a public library entry point"
    # Fall back to sanitizer.txt frames.
    if asan_file.is_file():
        first_n: list[str] = []
        with open(asan_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.rstrip("\n")
                if _FRAME_LINE_RE.match(line):
                    first_n.append(line)
                    if len(first_n) >= 10:
                        break
        joined = "\n".join(first_n)
        if _FRAME_MAINT_RE.search(joined):
            return "maint-tool", "ASan frames point into maint/ or tests/"
        if _names_in_text(tool_names, joined):
            return "cli", "ASan frames are inside the target's shipped binary"
        if _frames_under_target(first_n, target_root):
            return "library-api", "ASan frames are in the target's library source"
    return "unknown", ""


def adjust_surface_from_report(surface_value: str, surface_reason: str,
                               report_text: str, boundary_value: str,
                               trusted_actions_value: str,
                               cfg: object = None) -> tuple[str, str]:
    """Use the report's real boundary to correct harness-shaped guesses.

    C harnesses often drive shipped command-line tools or embedded tool mains.
    The harness shape alone then looks like `library-api`, but the maintainer
    surface is the CLI named by Boundary/Trusted caller actions. Only override
    on explicit CLI/tool signals so public-library reports that merely mention
    a harness remain library-api. CLI tool names come from target.toml via
    _target_tool_names — no hardcoded per-project list.
    """
    blob = "\n".join([boundary_value or "", trusted_actions_value or "", report_text or ""])
    if _REPORT_DEV_SURFACE_RE.search(blob):
        return "maint-tool", "report boundary points into maintenance/test tooling"
    if _REPORT_CLI_KEYWORD_RE.search(blob) or _names_in_text(_target_tool_names(cfg), blob):
        return "cli", "report boundary is a shipped command-line tool"
    return surface_value, surface_reason


def infer_primitive_label(asan_text: str) -> str:
    if not asan_text:
        return "unclassified"
    lower = asan_text.lower()
    if "memorysanitizer" in lower:
        return "use-of-uninitialized-value"
    if "threadsanitizer" in lower or re.search(r"^warning: data race$", lower, re.MULTILINE):
        return "data-race"
    if "undefinedbehaviorsanitizer" in lower or re.search(r":[0-9]+:[0-9]+: runtime error:", asan_text):
        if "out of bounds" in lower:
            return "ubsan-out-of-bounds"
        if "misaligned" in lower:
            return "ubsan-alignment"
        if "null pointer" in lower:
            return "ubsan-null"
        if "object-size" in lower:
            return "ubsan-object-size"
        if "vptr" in lower:
            return "ubsan-vptr"
        if "pointer overflow" in lower or "pointer-overflow" in lower:
            return "ubsan-pointer-overflow"
        return "undefined-behavior"
    if "attempting double-free" in lower or "double-free" in lower:
        return "double-free"
    if "attempting free on address which was not malloc" in lower or "bad-free" in lower:
        return "bad-free"
    m = re.search(r"AddressSanitizer:\s+([a-zA-Z-]+)", asan_text)
    if not m:
        return "unclassified"
    prim = m.group(1)
    rw = re.search(r"\b(READ|WRITE) of size\s+([0-9]+)", asan_text, re.IGNORECASE)
    if prim in {"BUS", "SEGV"} and re.search(r"wild-addr-(read|write)|high value address", lower):
        if rw:
            return f"wild-address-{rw.group(1).lower()}"
        return "wild-address-read"
    return prim


def _title_func_from_dedup(dedup_frames: str) -> str:
    if not dedup_frames:
        return "target code"
    first = dedup_frames.split(" -> ", 1)[0].strip()
    if not first:
        return "target code"
    # `func path:line` -> func. C++ names can contain spaces in return types,
    # so keep the full prefix before the final source location token.
    m = re.match(r"(?P<func>.+?)\s+\S+:\d+(?::\d+)?$", first)
    if m:
        return m.group("func").strip()
    return first.split()[0]


def _rev_is_pinned(rev: str) -> bool:
    """True when `rev` is a usable upstream ref worth a "clones upstream@<rev>"
    hint — a sha, tag, or branch/HEAD. Sentinels ("norev", "") are not.
    Delegates to the shared sentinel set in target_config."""
    return not target_config.is_unpinned_rev(rev)


def build_report_title(crash_id: str, primitive_label: str, dedup_frames: str,
                       trigger_value: str) -> str:
    # `trigger_value` is intentionally unused in the headline: it is already a
    # Fields-table row ("Trigger source"), and appending "when <trigger>"
    # produced a dangling clause ("... when bytes") whenever the value was a
    # bare noun rather than a phrase. Keep the title a complete sentence.
    primitive = primitive_label or "sanitizer diagnostic"
    func = _title_func_from_dedup(dedup_frames)
    return f"{crash_id}: {primitive} in {func}"


# ─── Top-level driver ───────────────────────────────────────────────

# Forbidden tokens whose presence in a generated bundle file indicates
# that internal audit refs leaked through. The path-prefix half of the
# pattern used to also hardcode /Users|/Volumes|/home — that broke for
# every other layout (Docker /root/work, CI /workspace, NixOS /nix,
# WSL /mnt/...) and overlapped the dynamic cfg-prefix check below.
# We now only look for env-var/identifier tokens that are unambiguously
# audit-internal regardless of where the audit happens to run. Path
# leaks are caught by the cfg.* prefix loop in
# _bundle_text_has_internal_ref AFTER _normalize_bundle_paths has had
# its chance to rewrite known prefixes — so a hit here is a genuine
# bug, not a portability artefact.
_FORBIDDEN_REFS_RE = re.compile(
    r"\b(?:RESULTS_DIR|TARGET_ROOT|TARGET_SLUG|AUDIT_AGENT_NUM|"
    r"HYPOTHESIS_ID|TRIED_INPUTS_LOG|ASAN_OUTPUT_FILE|HITS_LOG_PATH)="
)


def _bundle_text_has_internal_ref(text: str, cfg: target_config.Config) -> bool:
    """True if `text` still contains an audit-private identifier or path.

    Two-stage check:
      1. Env-var-style tokens (RESULTS_DIR=, TARGET_ROOT=, …) that
         shell-source files or templates would carry. These are bugs
         everywhere.
      2. Absolute prefixes from this session's `cfg.results_dir`,
         `cfg.target_root`, `cfg.logdir`. Computed at runtime, so they
         work regardless of host layout. `_normalize_bundle_paths` is
         expected to have rewritten these before the scan; anything
         surviving is a real escape.
    """
    if _FORBIDDEN_REFS_RE.search(text):
        return True
    for raw in (cfg.results_dir, cfg.target_root, cfg.logdir):
        if not raw:
            continue
        try:
            candidates = {raw, str(Path(raw).resolve())}
        except OSError:
            candidates = {raw}
        for candidate in candidates:
            if candidate and candidate not in {"/", "."} and candidate in text:
                return True
    return False


def _normalize_bundle_paths(text: str, cfg: target_config.Config) -> str:
    """Rewrite this session's absolute audit paths to portable form.

    The bundle is a maintainer-facing artefact, so absolute paths into
    the audit workspace are noise at best and disclose host layout at
    worst. We rewrite each configured prefix to a stable relative
    placeholder before the leak scan runs:

      * cfg.target_root → ``targets/<slug>``  (preserves source-file
        structure so frame paths like ``contrib/minizip/zip.c:2225``
        remain navigable from the bundle root)
      * cfg.results_dir → ``''`` (audit-private scratch; strip the
        prefix so e.g. ``…/results/scratch-2/H-xyz.txt`` becomes
        ``scratch-2/H-xyz.txt`` — still a unique handle, no host leak)
      * cfg.logdir      → ``logs``

    Idempotent: text without the configured prefixes is returned
    unchanged. Both the raw and `Path.resolve()` forms are matched
    because symlinked workspaces (common under /var/folders on macOS,
    /tmp on Linux) appear in two flavours inside the same report.
    """
    if not text:
        return text
    slug = (cfg.slug or "target").strip() or "target"

    raw_pairs: list[tuple[str, str]] = []
    for attr, replacement in (
        ("target_root", f"targets/{slug}"),
        ("results_dir", ""),
        ("logdir", "logs"),
    ):
        raw = getattr(cfg, attr, "") or ""
        if not raw:
            continue
        candidates = {raw}
        try:
            candidates.add(str(Path(raw).resolve()))
        except OSError:
            pass
        for cand in candidates:
            if cand and cand not in ("/", "."):
                raw_pairs.append((cand, replacement))

    # Longest prefix first: if target_root is nested under results_dir
    # (unusual but legal) we must not let the shorter results_dir match
    # eat the longer target_root form before it gets a chance.
    raw_pairs.sort(key=lambda kv: len(kv[0]), reverse=True)
    for cand, replacement in raw_pairs:
        text = text.replace(cand, replacement)
    return text


def _normalize_bundle_file(path: Path, cfg: target_config.Config) -> None:
    """Apply _normalize_bundle_paths to a staged file, in place.

    Only rewrites files that decode cleanly as UTF-8 text — binary
    testcases (``input.bin`` and friends) are left untouched because
    naive string replacement on bytes-rendered-as-text would corrupt
    them. Best-effort: I/O errors are silently skipped, since the leak
    scan that runs next will fail loudly if anything important is
    still leaking.
    """
    try:
        raw = path.read_bytes()
    except OSError:
        return
    if b"\x00" in raw[:4096]:
        # Heuristic: a NUL byte inside the first 4 KiB is a strong
        # binary signal. Skip to preserve testcase integrity.
        return
    try:
        text = raw.decode("utf-8")
    except UnicodeDecodeError:
        return
    rewritten = _normalize_bundle_paths(text, cfg)
    if rewritten == text:
        return
    try:
        path.write_text(rewritten, encoding="utf-8")
    except OSError:
        return


def _install_with_exact_case(src: Path, dst: Path) -> None:
    """Copy ``src`` to ``dst`` and guarantee the on-disk entry name is
    exactly ``dst.name``.

    Atomic-write via a same-dir temp file, then ``os.replace`` to the
    final name. The temp file uses a name that does not case-collide
    with ``dst`` or any bundle filename. This sidesteps two Docker
    Desktop / case-insensitive bind-mount quirks observed in practice:
      * ``shutil.copyfile(src, dst)`` when a case-different sibling
        (e.g. lowercase ``report.md``) exists at ``dst.parent`` writes
        through the sibling's dirent (inode-aliased into ``.audit/``
        once the migration step has moved that sibling), leaving the
        bundle root without ``REPORT.md`` at all.
      * ``unlink(sibling)`` followed by ``open(dst, 'wb')`` can fail
        ``ENOENT`` because the bind-mount dirent cache has not made
        the freed name re-creatable yet.
    Writing the new content to a case-unique temp first and finishing
    with ``os.replace`` keeps the create + sibling-removal step atomic
    from the FS's point of view and never relies on the FS letting us
    open a name we just unlinked.
    """
    target_lower = dst.name.lower()
    tmp = dst.parent / f"{dst.name}.installing-{os.getpid()}-{secrets.token_hex(4)}"
    try:
        shutil.copyfile(str(src), str(tmp))
        os.chmod(tmp, 0o644)
        # Remove any case-different sibling so ``os.replace`` produces
        # an entry under the requested case rather than reusing the
        # sibling's name on a case-preserving FS.
        try:
            for entry in os.scandir(dst.parent):
                if entry.name in (tmp.name, dst.name):
                    continue
                if entry.name.lower() != target_lower:
                    continue
                try:
                    os.unlink(entry.path)
                except OSError:
                    pass
        except OSError:
            pass
        os.replace(str(tmp), str(dst))
    except BaseException:
        with contextlib.suppress(OSError):
            os.unlink(tmp)
        raise


def _is_bundle_filename(name: str) -> bool:
    # Note: asan.txt is intentionally NOT in the bundle set — the canonical
    # filename is sanitizer.txt, and any legacy asan.txt left over from an
    # older bundle should migrate into .audit/ on re-export so the root
    # doesn't carry a stale duplicate alongside the fresh sanitizer.txt.
    # Readers still accept asan.txt as a fallback for previously-shipped
    # bundles (lib/crash_artifacts.find_primary_asan, lib/triage.sh,
    # bin/cluster-crashes, bin/severity).
    if name in {"REPORT.md", "REPORT.html", "reproduce.sh", "sanitizer.txt", "msan.txt", "tsan.txt", "ubsan.txt", "harness.c", "harness.cc", "harness.cpp", "harness.cxx", "severity.json"}:
        return True
    if name in {".llm-triage.json", ".llm-confirm.json", ".llm-legit-crash.json",
                ".llm-find-quality.json", ".severity_ok", ".severity_pending",
                ".severity_failed"}:
        return True
    if name.startswith("input."):
        return True
    if name == ".audit":
        return True
    # patch.diff stays at bundle root so a) maintainers see the patch as
    # a standalone file, and b) bin/enrich-report inlines it into the
    # `## Patch` section of REPORT.md / REPORT.html. The filename is
    # fixed in .agents/references/session-rules.md.
    if name == "patch.diff":
        return True
    return False


def write_browser_template(out: Path, *, build_system: str, upstream_url: str,
                           pinned_rev: str, slug: str, san_bin_rel: str,
                           input_name: str, sanitizer: str = "asan",
                           extra_options: str = "", mode: str = "browser",
                           recorded_env_options: str = "",
                           audit_build_script: str = "") -> None:
    meta = sanitizer_meta(sanitizer)
    text = (
        emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel, sanitizer)
        + emit_build(build_system, sanitizer=sanitizer,
                     audit_build_script=audit_build_script)
        + _sub_template(
            BROWSER_RUN,
            __SAN_BIN_REL__=shq(san_bin_rel),
            __INPUT_NAME__=input_name,
            __SANITIZER_LABEL__=meta["label"],
            __MACH_OBJDIR__=meta["mach_objdir"],
            __SANITIZER_ENV_BLOCK__=sanitizer_runtime_env_block(
                sanitizer, extra_options, mode, recorded_env_options
            ),
        )
    )
    out.write_text(text, encoding="utf-8")
    os.chmod(out, 0o755)


def write_js_shell_template(out: Path, *, build_system: str, upstream_url: str,
                            pinned_rev: str, slug: str, san_bin_rel: str,
                            input_name: str, sanitizer: str = "asan",
                            extra_options: str = "", mode: str = "js",
                            recorded_env_options: str = "",
                            audit_build_script: str = "") -> None:
    meta = sanitizer_meta(sanitizer)
    text = (
        emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel, sanitizer)
        + emit_build(build_system, sanitizer=sanitizer,
                     audit_build_script=audit_build_script)
        + _sub_template(
            JS_SHELL_RUN,
            __INPUT_NAME__=input_name,
            __SANITIZER_LABEL__=meta["label"],
            __MACH_OBJDIR__=meta["mach_objdir"],
            __SANITIZER_ENV_BLOCK__=sanitizer_runtime_env_block(
                sanitizer, extra_options, mode, recorded_env_options
            ),
        )
    )
    out.write_text(text, encoding="utf-8")
    os.chmod(out, 0o755)


def write_c_harness_template(out: Path, *, build_system: str, upstream_url: str,
                             pinned_rev: str, slug: str, san_bin_rel: str,
                             san_lib_rel: str, includes_args: str,
                             link_libs: str, input_name: str,
                             link_lib_resolves: str = "",
                             harness_name: str = "harness.c",
                             harness_compiler: str = "clang",
                             sanitizer: str = "asan",
                             extra_options: str = "", mode: str = "generic",
                             recorded_env_options: str = "",
                             audit_build_script: str = "",
                             local_src: str = "",
                             harness_args: str = "") -> None:
    meta = sanitizer_meta(sanitizer)
    if not meta["flag"]:
        die(f"C/C++ harness export for {meta['label']} needs target-specific compiler flags")
    if "FILL_ME" in (san_lib_rel or ""):
        sys.stderr.write(
            f"[export-repro] target.toml {sanitizer}_lib still contains FILL_ME "
            f"({san_lib_rel!r}); reproduce.sh will auto-discover the instrumented "
            f"library the build produces under build-{sanitizer}/. Set "
            f"{sanitizer}_lib in output/<slug>/target.toml to pin a specific "
            f"archive/shared object if discovery picks the wrong one.\n"
        )
    # When a sanitizer library is resolved, embed its directory as both an
    # rpath (Linux DT_RUNPATH / macOS LC_RPATH so the binary self-locates
    # the shared lib) and as LD_LIBRARY_PATH/DYLD_LIBRARY_PATH (fallback
    # for macOS dylib install-names that don't honor rpath, and for older
    # loaders). The rpath flag is harmless for static archives.
    # Resolve $san_lib either from the configured <san>_lib (LIB_RESOLVE) or,
    # when target.toml named none, by discovering the library the build just
    # produced (LIB_DISCOVER). Both leave $san_lib empty for a genuinely
    # header-only target, and the link args below tolerate that.
    if _san_lib_is_unset(san_lib_rel):
        lib_resolve_block = emit_lib_discover(sanitizer)
    else:
        lib_resolve_block = emit_lib_resolve(san_lib_rel, sanitizer)
    # ${san_lib:+...} expands the substitution only when san_lib is set.
    # Both resolve blocks blank san_lib when no archive/shared object is
    # found (header-only case); the link line must then skip the archive and
    # the rpath flag entirely. The shell prunes the empty positional
    # argument, so clang sees a clean command line — no stray "" arg that
    # would be interpreted as "no such file".
    #
    # The env block uses an explicit `if [ -n ... ]; then export …; fi`
    # rather than ${var:+VAR=val} because bash only recognizes a
    # `VAR=val` token as an env-var prefix when it is syntactically
    # apparent before parameter expansion. A `${var:+VAR=val}` that
    # expands to `VAR=val` is treated as a regular word — i.e. bash
    # tries to *run* it as a command and reports "VAR=val: command
    # not found". The explicit `export` block sidesteps that POSIX
    # corner entirely.
    san_lib_arg = ' ${san_lib:+"$san_lib"} ${san_lib_dir:+-Wl,-rpath,"$san_lib_dir"}'
    san_lib_run_env = (
        'if [ -n "$san_lib_dir" ]; then\n'
        '  export LD_LIBRARY_PATH="$san_lib_dir${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"\n'
        '  export DYLD_LIBRARY_PATH="$san_lib_dir${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"\n'
        'fi\n'
    )
    text = (
        emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel,
                      sanitizer, local_src)
        + emit_build(build_system, sanitizer=sanitizer,
                     audit_build_script=audit_build_script)
        + lib_resolve_block
        + link_lib_resolves
        + _sub_template(
            C_HARNESS_RUN,
            __INCLUDES_ARGS__=includes_args,
            __LINK_LIBS__=link_libs,
            # A self-contained harness (constructs its own triggering input)
            # takes no argv; pass the testcase only when one exists. The
            # leading space keeps the run line `… "$build/repro" "$here/x"`
            # spaced correctly while an empty arg collapses cleanly.
            __HARNESS_ARGS__=(harness_args if harness_args else
                              (f' "$here/{input_name}"' if input_name else "")),
            __INPUT_DESC__=(f"$here/{input_name}" if input_name
                            else "self-contained harness (no input file)"),
            __HARNESS_NAME__=harness_name,
            __HARNESS_COMPILER__=harness_compiler,
            __SAN_LIB_ARG__=san_lib_arg,
            __SAN_LIB_RUN_ENV__=san_lib_run_env,
            __SANITIZER_FLAG__=meta["flag"] or "address",
            __SANITIZER_LABEL__=meta["label"],
            __SANITIZER_ENV_BLOCK__=sanitizer_runtime_env_block(
                sanitizer, extra_options, mode, recorded_env_options
            ),
        )
    )
    out.write_text(text, encoding="utf-8")
    os.chmod(out, 0o755)


def write_cli_with_input_template(out: Path, *, build_system: str, upstream_url: str,
                                   pinned_rev: str, slug: str, san_bin_rel: str,
                                   cmake_target: str, input_name: str,
                                   sanitizer: str = "asan",
                                   extra_options: str = "", mode: str = "generic",
                                   recorded_env_options: str = "",
                                   local_src: str = "",
                                   cli_args: str = '"$testcase"',
                                   audit_build_script: str = "") -> None:
    meta = sanitizer_meta(sanitizer)
    if build_system == "swift" and not san_bin_rel:
        if not meta["flag"]:
            die(f"Swift runner does not support sanitizer '{sanitizer}'")
        text = (
            emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel,
                          sanitizer, local_src)
            + _sub_template(
                SWIFT_RUN,
                __INPUT_NAME__=input_name,
                __SANITIZER_LABEL__=meta["label"],
                __SWIFT_SANITIZER__=meta["flag"],
                __SWIFT_EXECUTABLE__=shq(slug),
                __SANITIZER_ENV_BLOCK__=sanitizer_runtime_env_block(
                    sanitizer, extra_options, mode, recorded_env_options
                ),
            )
        )
    else:
        text = (
            emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel,
                          sanitizer, local_src)
            + emit_build(build_system, cmake_target, sanitizer,
                         audit_build_script=audit_build_script)
            + emit_bin_resolve(san_bin_rel, sanitizer)
            + _sub_template(
                CLI_RUN,
                __INPUT_NAME__=input_name,
                __SANITIZER_LABEL__=meta["label"],
                __CLI_ARGS__=cli_args,
                __SANITIZER_ENV_BLOCK__=sanitizer_runtime_env_block(
                    sanitizer, extra_options, mode, recorded_env_options
                ),
            )
        )
    out.write_text(text, encoding="utf-8")
    os.chmod(out, 0o755)


def write_stub_reproduce(out: Path, *, crash_id: str, sanitizer: str,
                         harness_name: str = "", input_name: str = "",
                         reason: str = "") -> None:
    """Last-resort reproduce.sh when no runnable template can be built.

    A bundle is still worth shipping without an automated reproducer: the
    REPORT.md (Fields, inlined sanitizer stack, root-cause prose, captured
    patch) is the maintainer-facing artifact, and the reproducer is a
    convenience. This used to `die()` — dropping the whole bundle — which
    is how model-direct crashes (a self-contained harness with no separate
    testcase, or a pooled crash with no converged build recipe) ended up
    with no REPORT.md at all.

    The stub is a valid shell script that documents what IS known (the
    sibling artifacts, the build hint when a harness is present) and exits
    non-zero so it is never mistaken for a working reproducer. The
    sanitizer label keeps the manual hint accurate per build."""
    meta = sanitizer_meta(sanitizer)
    label = meta["label"]
    lines = [
        "#!/usr/bin/env bash",
        "# Auto-generated stub reproducer — NO runnable template could be",
        f"# determined for {crash_id}" + (f" ({reason})." if reason else "."),
        "# The maintainer-facing artifact is REPORT.md in this directory;",
        f"# sanitizer.txt holds the full {label} diagnostic. Reproduce by hand:",
        "set -euo pipefail",
        "here=\"$(cd \"$(dirname \"$0\")\" && pwd)\"",
        'echo "Artifacts in this bundle:" >&2',
        'ls -1 "$here" >&2',
    ]
    if harness_name:
        lines += [
            'cat >&2 <<EOF',
            f"To reproduce: build {harness_name} against an {label}-instrumented",
            "build of the target library and run it. The harness is self-contained",
            "(it constructs its own triggering input); no separate input file is",
            "needed. See REPORT.md \"Reproduce\"/\"Root cause\" for specifics.",
            "EOF",
        ]
    else:
        lines += [
            'cat >&2 <<EOF',
            "No harness or testcase was captured with this crash. See REPORT.md",
            f"for the root cause and sanitizer.txt for the full {label} stack.",
            "EOF",
        ]
    lines += [
        'echo "stub reproducer: manual reproduction required (see above)" >&2',
        "exit 2",
        "",
    ]
    out.write_text("\n".join(lines), encoding="utf-8")
    os.chmod(out, 0o755)


def write_shell_wrapper_template(out: Path, *, build_system: str, upstream_url: str,
                                  pinned_rev: str, slug: str, san_bin_rel: str,
                                  cmake_target: str, wrapper: Path,
                                  input_name: str = "",
                                  target_root: str = "",
                                  sanitizer: str = "asan",
                                  local_src: str = "",
                                  audit_build_script: str = "") -> None:
    parts = [
        emit_preamble(build_system, upstream_url, pinned_rev, slug, san_bin_rel,
                      sanitizer, local_src),
        emit_build(build_system, cmake_target, sanitizer,
                   audit_build_script=audit_build_script),
    ]
    if san_bin_rel:
        # Legacy CLI-binary wrapper: the inlined body launches `$san_bin`.
        parts.append(emit_bin_resolve(san_bin_rel, sanitizer))
    elif input_name:
        # Self-compiling wrapper (`harness.sh` that compiles upstream sources
        # inline). The preamble already consumed `$1` as the upstream src
        # path, so we override argv to the testcase the wrapper expects.
        # `repro_src` is the rewrite target for audit-side source references
        # — held in a wrapper-safe name because wrappers often reassign `src`.
        parts.append(
            'repro_src="$src"\n'
            'testcase="$(cd "$(dirname "$0")" && pwd)/' + input_name + '"\n'
            'set -- "$testcase"\n'
        )
    parts.append(SHELL_WRAPPER_INTRO)
    parts.append(rewrite_audit_script_body(wrapper, slug=slug, target_root=target_root))
    out.write_text("".join(parts), encoding="utf-8")
    os.chmod(out, 0o755)


# Matches a Fix-Direction-class heading. Accepts both the conventional
# section form (`## Fix Direction` on its own line, body below) and an
# inline form (`## Fix Direction: add the bounds check`) so advisory
# detection never silently misses a prose fix pointer. Advisory-only
# (display metadata), so an occasional over-match on a fix-prose line is
# benign — and only fires when no patch.diff is present.
_FIX_DIRECTION_HEADING_RE = re.compile(
    r"(?im)^[#\s>*\-]*\b(?:Fix\s+Direction|Suggested\s+Fix|Recommended\s+Fix|"
    r"Mitigation|Remediation)\b[ \t]*(?:[:\-–—].*)?$"
)


def detect_advisory_status(report_md: Optional[Path], patch_path: Optional[Path]) -> str:
    """Return ``yes``/``no`` for the Advisory field, or '' if unknown.

    A crash bundle is *advisory* when no patch.diff is attached but the
    agent has explained the fix in prose — either because the fix is
    non-surgical (an ABI-impacting signature change, a removed extern
    symbol) or because no clean diff was captured. Advisory says only
    "fix is prose, not an applyable diff"; the reason lives in the prose.

    The triage pipeline already accepts bundles without patch.diff,
    but downstream maintainers and the LLM confirm-agent benefit from
    an explicit marker that distinguishes "advisory, by design" from
    "agent forgot to capture the patch".

    Decision:
      * patch.diff present (and non-empty) → ``no``
      * patch.diff absent + report has a Fix-Direction-class heading →
        ``yes``
      * patch.diff absent + no such heading → ``''`` (unknown — leaves
        the bundle silent rather than asserting an advisory)
    """
    has_patch = False
    if patch_path is not None and patch_path.is_file():
        try:
            has_patch = patch_path.stat().st_size > 0
        except OSError:
            has_patch = False
    if has_patch:
        return "no"
    if report_md is None or not report_md.is_file():
        return ""
    try:
        body = report_md.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return ""
    if _FIX_DIRECTION_HEADING_RE.search(body):
        return "yes"
    return ""


def build_report_md(*, crash_id: str, primitive_label: str, severity_value: str,
                    surface_value: str, surface_reason: str,
                    trigger_value: str, caller_contract_value: str,
                    boundary_value: str, caller_controls_value: str,
                    parameter_control_value: str,
                    trusted_actions_value: str, confidence_value: str,
                    strategy_value: str,
                    crash_dir: Path, report_md: Optional[Path],
                    asan_top: str, asan_summary: str,
                    dedup_frames: str,
                    asan_expected: str, pinned_rev: str,
                    sanitizer: str = "asan",
                    advisory_value: str = "",
                    local_src: str = "") -> str:
    meta = sanitizer_meta(sanitizer)
    # Compute the agent narrative up front so the `## Summary` section can lead
    # the report — placed ABOVE the Fields table, matching the finding-report
    # layout (Title -> Summary -> Fields -> rest). `fix_section` is lifted to
    # the very end; `summary_head` (enrichment blocks + Summary) goes before
    # Fields; `body_rest` (Classification, Root Cause, Data Flow, ...) stays
    # below Fields. Field extraction and the hero card read by heading/label,
    # not position, so the reorder is layout-only.
    fix_section = ""
    summary_head = ""
    body_rest = "Sanitizer diagnostic discovered during automated QA.\n"
    if report_md is not None and report_md.is_file():
        body_text = report_md.read_text(encoding="utf-8", errors="replace")
        body_stripped = render_agent_body(body_text)
        body_stripped, fix_section = extract_fix_section(body_stripped)
        summary_head, body_rest = extract_summary_section(body_stripped)

    parts: list[str] = []
    parts.append(f"# {build_report_title(crash_id, primitive_label, dedup_frames, trigger_value)}\n")
    parts.append("\n")
    if summary_head:
        parts.append(summary_head)
        parts.append("\n")
    parts.append("## Fields\n")
    parts.append("\n")
    parts.append("| Field                 | Value |\n")
    parts.append("|:----------------------|:------|\n")
    parts.append(emit_field("Primitive", primitive_label))
    parts.append(emit_field("Severity", severity_value))
    if advisory_value:
        parts.append(emit_field(
            "Advisory", advisory_value,
            "no patch.diff — fix described in prose, see Fix Direction"
            if advisory_value == "yes" else ""
        ))
    parts.append(emit_field("Surface", surface_value, surface_reason))
    parts.append(emit_field("Trigger source", trigger_value))
    parts.append(emit_field("Caller contract", caller_contract_value))
    parts.append(emit_field("Boundary", boundary_value))
    parts.append(emit_field("Caller controls", caller_controls_value))
    if parameter_control_value:
        parts.append(emit_field("Parameter control", parameter_control_value))
    parts.append(emit_field("Trusted caller actions", trusted_actions_value))
    parts.append(emit_field("Cluster", "(set by bin/cluster-crashes)"))
    if dedup_frames:
        parts.append(emit_field("Dedup frames", dedup_frames))
    parts.append(emit_field("Reproduction rate", confidence_value))
    parts.append(emit_field("Strategy", strategy_value))
    parts.append("\n")
    # Bare-label block — every label downstream parsers expect.
    parts.append(f"Surface: {surface_value}\n")
    parts.append(f"Trigger source: {trigger_value}\n")
    parts.append(f"Caller contract: {caller_contract_value or 'unspecified'}\n")
    if dedup_frames:
        parts.append(f"Dedup frames: {dedup_frames}\n")
    if boundary_value:
        parts.append(f"Boundary: {boundary_value}\n")
    if caller_controls_value:
        parts.append(f"Caller controls: {caller_controls_value}\n")
    if parameter_control_value:
        parts.append(f"Parameter control: {parameter_control_value}\n")
    if trusted_actions_value:
        parts.append(f"Trusted caller actions: {trusted_actions_value}\n")
    if strategy_value:
        parts.append(f"Strategy: {strategy_value}\n")
    if advisory_value:
        parts.append(f"Advisory: {advisory_value}\n")
    if severity_value == "—":
        parts.append("- **Severity**: TBD\n")
    else:
        auto_line = read_auto_severity_line(crash_dir / "REPORT.md")
        if auto_line:
            parts.append(f"- {auto_line}\n")
        else:
            parts.append(f"- **Severity**: {severity_value}\n")
    parts.append("\n")

    # The narrative below Fields: everything after the Summary section
    # (Classification, Root Cause, Data Flow, ...). The Summary itself was
    # emitted above Fields; the lifted `## Fix` is re-placed at the very end
    # — after Expected sanitizer output and Reproduce, alongside the
    # auto-appended Severity rationale. The triage card carries
    # the verdict; the remediation belongs next to the reference material.
    parts.append(body_rest)
    parts.append("\n")
    parts.append("## Expected sanitizer output\n")
    parts.append("\n")
    parts.append("```\n")
    if asan_expected:
        parts.append(asan_expected + "\n")
    else:
        # Legacy fallback for malformed/truncated logs that only expose
        # isolated sanitizer lines.
        if asan_top:
            parts.append(asan_top + "\n")
        if asan_summary:
            parts.append(asan_summary + "\n")
    parts.append("```\n")
    parts.append("\n")
    if sanitizer == "asan":
        parts.append("Full original output: `sanitizer.txt`.\n")
    else:
        parts.append(f"Full original {meta['label']} output: `sanitizer.txt`.\n")
    parts.append("\n")
    parts.append("## Reproduce\n")
    parts.append("\n")
    parts.append("Run the sibling [reproduce.sh](reproduce.sh):\n")
    parts.append("\n")
    parts.append("```sh\n")
    if _rev_is_pinned(pinned_rev):
        parts.append(
            f"./reproduce.sh                 # clones upstream@{pinned_rev[:12]}, builds/runs with {meta['label']}\n"
        )
        parts.append("./reproduce.sh /path/to/src    # use an existing checkout\n")
    elif local_src:
        # Local-only target audited in place: reproduce.sh resolves the
        # recorded in-place source (targets/<slug>) by walking up to the audit
        # repo root, so the no-argument form works on the audit machine. Keep
        # the path form for a copy of the bundle taken elsewhere.
        parts.append(
            f"./reproduce.sh                 # builds/runs with {meta['label']} against the in-place audit source\n"
        )
        parts.append("./reproduce.sh /path/to/src    # or an existing checkout\n")
    else:
        # No pinned upstream revision and no in-place source recorded. The
        # bundled reproduce.sh cannot clone; point only at the path form so the
        # message stays honest instead of claiming a "clone upstream@norev".
        parts.append(
            f"./reproduce.sh /path/to/src    # builds/runs with {meta['label']} against your checkout\n"
        )
    parts.append("```\n")
    if fix_section:
        parts.append("\n")
        parts.append(fix_section)
    return "".join(parts)


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="bin/export-repro",
        usage="bin/export-repro <CRASH-id> [--out <dir>] [--slug <slug>] [--crash-dir <dir>]",
        add_help=False,
    )
    parser.add_argument("crash_id", nargs="?")
    parser.add_argument("--out")
    parser.add_argument("--slug")
    # Override the default RESULTS_DIR/crashes/<id> path. Used by maintenance
    # passes that regenerate bundles for crashes-rejected/ and
    # crashes-needs-review/ dirs without having to move them.
    parser.add_argument("--crash-dir")
    parser.add_argument("-h", "--help", action="store_true")
    try:
        args = parser.parse_args(argv)
    except SystemExit:
        usage()
        return 2
    if args.help:
        usage()
        return 0
    if not args.crash_id:
        usage()
        return 2

    # Discover the session (slug dir / target.toml). Either via --slug or by
    # walking up from CWD.
    cfg = target_config.Config()
    if args.slug:
        slug_dir = SCRIPT_ROOT / "output" / args.slug
        # Prefer the backend-local output/<slug>/<backend>/results/
        # .session-env over the legacy output/<slug>/.session-env copy,
        # which concurrent backends race on.
        session_dir = target_config.find_slug_session_dir(slug_dir)
        if session_dir is not None:
            env = target_config.read_session_env(session_dir)
            cfg.results_dir = env.get("RESULTS_DIR", "")
            cfg.target_root = env.get("TARGET_ROOT", "")
            cfg.slug = env.get("TARGET_SLUG", "")
            cfg.target_rev = env.get("TARGET_REV", "")
            cfg.session_started = env.get("SESSION_STARTED", "")
            cfg.logdir = env.get("LOGDIR", "")
        elif os.environ.get("RESULTS_DIR") and os.environ.get("TARGET_ROOT"):
            env_slug = os.environ.get("TARGET_SLUG", args.slug)
            if env_slug and env_slug != args.slug:
                die(f"no session-env for slug: {args.slug} (env TARGET_SLUG={env_slug})")
            cfg.results_dir = os.environ.get("RESULTS_DIR", "")
            cfg.target_root = os.environ.get("TARGET_ROOT", "")
            cfg.slug = env_slug or args.slug
            cfg.target_rev = os.environ.get("TARGET_REV", "")
            cfg.session_started = os.environ.get("SESSION_STARTED", "")
            cfg.logdir = os.environ.get("LOGDIR", "")
            cfg.is_browser = os.environ.get("TARGET_IS_BROWSER", os.environ.get("IS_BROWSER_TARGET", "0"))
        else:
            die(f"no session-env for slug: {args.slug}")
        toml_path = slug_dir / "target.toml"
        if toml_path.is_file():
            target_config.load_toml_into(cfg, toml_path)
    else:
        try:
            cfg = target_config.load(os.getcwd())
        except FileNotFoundError:
            die(f"no output/<slug>/.session-env above {os.getcwd()}; use --slug")

    if args.crash_dir:
        crash_dir = Path(args.crash_dir).resolve()
    else:
        crash_dir = Path(cfg.results_dir) / "crashes" / args.crash_id
    if not crash_dir.is_dir():
        die(f"crash dir not found: {crash_dir}")

    out_dir = Path(args.out) if args.out else crash_dir
    out_dir.mkdir(parents=True, exist_ok=True)
    audit_subdir = out_dir / ".audit"

    scan_dirs: list[Path] = []
    if audit_subdir.is_dir():
        scan_dirs.append(audit_subdir)
    scan_dirs.append(crash_dir)

    # ── Locate audit-side artifacts ──────────────────────────────────
    asan_file = crash_artifacts.find_primary_asan(scan_dirs)
    if asan_file is None:
        die(f"no sanitizer output in {crash_dir} (or .audit/)")
    try:
        sanitizer_text = asan_file.read_text(encoding="utf-8", errors="replace")
    except OSError:
        sanitizer_text = ""
    sanitizer = infer_sanitizer_from_text(sanitizer_text)
    run_header = sanitizer_run_header_fields(sanitizer_text)
    run_mode = run_header.get("mode", "")
    recorded_env_options = decode_header_b64(run_header.get("env_options_b64", ""))

    report_md = find_first_in_scan(scan_dirs, "report.md")
    if report_md is None:
        report_md = find_first_in_scan(scan_dirs, "REPORT.md")

    shell_wrapper = find_shell_wrapper(scan_dirs)
    testcase = find_testcase(scan_dirs, crash_dir, audit_subdir)
    # Resolve the harness after the testcase so a source the ASAN_RUN_HEADER
    # names as the input is staged once (as input.*), never also as harness.*.
    harness_src = find_harness(scan_dirs, exclude=testcase)

    # ── Stage outputs in a temp dir ──────────────────────────────────
    stage = Path(tempfile.mkdtemp(prefix="export-repro-", dir=os.environ.get("TMPDIR", "/tmp")))
    try:
        input_name = ""
        if testcase is not None:
            ext = ext_of(testcase.name)
            input_name = f"input.{ext}"
            (stage / input_name).write_bytes(read_testcase_bytes(testcase))
        harness_name = "harness.c"
        harness_compiler = "clang"
        if harness_src is not None:
            suffix = harness_src.suffix.lower()
            if suffix in {".cc", ".cpp", ".cxx"}:
                harness_name = "harness" + suffix
                harness_compiler = "clang++"
            harness_text = strip_internal_headers(harness_src)
            harness_text = rewrite_harness_repo_paths(harness_text)
            (stage / harness_name).write_text(harness_text, encoding="utf-8")
        shutil.copyfile(asan_file, stage / "sanitizer.txt")
        # Candidate patch: agents save it as patch.diff next to
        # report.md. Older bundles still have it under .audit/ because
        # _is_bundle_filename used to demote it; scan_dirs already
        # covers both locations. Stage it so it lands back at the
        # bundle root and bin/enrich-report can inline it into REPORT.md.
        patch_src = find_first_in_scan(scan_dirs, "patch.diff")
        if patch_src is not None:
            shutil.copyfile(patch_src, stage / "patch.diff")

        upstream_url = cfg.upstream_url or "FILL_ME"
        pinned_rev = cfg.target_rev or cfg.pinned_rev or "HEAD"
        slug = cfg.slug or "target"
        cmake_target = cfg.cmake_target or ""
        build_system = cfg.build_system or "cmake"
        san_bin_rel = cfg_sanitizer_bin(cfg, sanitizer) or ""
        san_lib_rel = cfg_sanitizer_lib(cfg, sanitizer) or ""
        if sanitizer == "race" and not san_bin_rel and build_system == "go":
            san_bin_rel = f"{sanitizer_meta(sanitizer)['build_dir']}/repro"
        sanitizer_extra_options = cfg.sanitizer_options.get(sanitizer, "")
        is_browser = cfg.is_browser == "1"
        repro_args = crash_artifacts.find_repro_args(
            scan_dirs,
            bin_names=[Path(san_bin_rel).name] if san_bin_rel else [],
            testcase_name=testcase.name if testcase is not None else "",
        )

        # A local-only / unpinned target cannot be cloned by reproduce.sh (see
        # the clone gate in PREAMBLE_GENERIC). Point it at the in-place source
        # using the same audit-tree-relative placeholder the bundle normalizer
        # uses for source paths (targets/<slug>), so `./reproduce.sh` reproduces
        # in place on the audit machine with no host-absolute path baked in. VCS
        # targets leave this empty and clone from upstream.
        local_src = ""
        if cfg.target_root and (
            target_config.is_placeholder_url(upstream_url)
            or target_config.is_unpinned_rev(pinned_rev)
        ):
            local_src = f"targets/{slug}"

        includes_args = emit_include_args(cfg.includes)
        link_lib_resolves, link_libs = emit_link_libs_with_resolves(cfg.link_libs, sanitizer)

        # If the audit converged on a build recipe via bin/auto-build-script,
        # splice it into reproduce.sh in place of the hardcoded cmake/autotools
        # template. This is the only way the reproducer build is guaranteed to
        # match the audit's build — same script, same flags, same library
        # naming. Absent the file we fall back to the legacy template.
        audit_build_script = ""
        if cfg.target_root:
            _abs = Path(cfg.target_root) / ".audit" / "build.sh"
            # is_file() raises PermissionError when target_root sits under
            # a directory the current user can't stat (e.g. container-
            # authored session-env pointing into /root/... while CI runs
            # as an unprivileged user). Treat any stat error like absence
            # so the generic-template fallback path below kicks in.
            try:
                _exists = _abs.is_file()
            except OSError:
                _exists = False
            if _exists:
                try:
                    audit_build_script = _abs.read_text(encoding="utf-8", errors="replace")
                except OSError:
                    audit_build_script = ""
        # Silent fallback to the generic cmake/autotools/meson template is
        # the failure mode that ate commit 47f0c45 on machines where
        # auto-build-script had not run. Emit a single visible WARN so the
        # operator sees "ah, the audit build never converged a recipe" rather
        # than discovering it weeks later via a maintainer's broken
        # reproduce.sh. Normally bin/audit converges and builds this on first
        # run, so a missing recipe here means that build never completed.
        if not audit_build_script and (build_system or "") in {"cmake", "autotools", "meson"}:
            sys.stderr.write(
                f"[export-repro] WARN: {cfg.target_root or '<target_root unset>'}/.audit/build.sh "
                f"is missing for {build_system} target {cfg.slug!r}; reproduce.sh will use a "
                f"generic {build_system} template that may not include the target-specific "
                f"flags the audit build used. Run 'bin/setup-target {cfg.slug} --build' "
                f"(or rerun the audit, which builds automatically) to converge a working recipe "
                f"via bin/auto-build-script, then rerun the bundle.\n"
            )

        # ── Choose reproduce.sh template ────────────────────────────
        repro_path = stage / "reproduce.sh"
        input_ext_lower = input_name.rsplit(".", 1)[-1].lower() if input_name else ""
        # The stub path emits no build block, so the recipe guard below must
        # skip it; every other branch runs a build and must honor the recipe.
        repro_is_stub = False
        if is_browser:
            if input_ext_lower in ("html", "htm", "xhtml", "svg"):
                write_browser_template(
                    repro_path,
                    build_system=build_system, upstream_url=upstream_url,
                    pinned_rev=pinned_rev, slug=slug,
                    san_bin_rel=san_bin_rel, input_name=input_name,
                    sanitizer=sanitizer, extra_options=sanitizer_extra_options,
                    mode=run_mode or "browser",
                    recorded_env_options=recorded_env_options,
                    audit_build_script=audit_build_script,
                )
            elif input_ext_lower in ("js", "mjs"):
                write_js_shell_template(
                    repro_path,
                    build_system=build_system, upstream_url=upstream_url,
                    pinned_rev=pinned_rev, slug=slug,
                    san_bin_rel=san_bin_rel, input_name=input_name,
                    sanitizer=sanitizer, extra_options=sanitizer_extra_options,
                    mode=run_mode or "js",
                    recorded_env_options=recorded_env_options,
                    audit_build_script=audit_build_script,
                )
            else:
                die(f"browser target {cfg.slug}: unsupported testcase ext '{input_ext_lower}'")
        elif harness_src is not None:
            # A harness drives the build whether or not a separate testcase
            # was captured: a self-contained harness (common for model-direct
            # crashes — it constructs its own triggering input) has
            # input_name == "" and runs with no argv. Previously this branch
            # required `and input_name`, so a self-contained harness fell
            # through to the stub even though a real, runnable reproducer was
            # one compile away.
            harness_cli_args = ""
            if repro_args:
                testcase_shell = f'"$here/{input_name}"' if input_name else ""
                harness_cli_args = " " + " ".join(
                    testcase_shell if a == crash_artifacts.TESTCASE_TOKEN else shq(a)
                    for a in repro_args
                )
            write_c_harness_template(
                repro_path,
                build_system=build_system, upstream_url=upstream_url,
                pinned_rev=pinned_rev, slug=slug,
                san_bin_rel=san_bin_rel, san_lib_rel=san_lib_rel,
                includes_args=includes_args, link_libs=link_libs,
                link_lib_resolves=link_lib_resolves,
                input_name=input_name,
                harness_name=harness_name,
                harness_compiler=harness_compiler,
                sanitizer=sanitizer,
                extra_options=sanitizer_extra_options,
                mode=run_mode or "generic",
                recorded_env_options=recorded_env_options,
                audit_build_script=audit_build_script,
                local_src=local_src,
                harness_args=harness_cli_args,
            )
        elif shell_wrapper is not None:
            write_shell_wrapper_template(
                repro_path,
                build_system=build_system, upstream_url=upstream_url,
                pinned_rev=pinned_rev, slug=slug,
                san_bin_rel=san_bin_rel, cmake_target=cmake_target,
                wrapper=shell_wrapper, input_name=input_name,
                target_root=cfg.target_root or "",
                sanitizer=sanitizer,
                local_src=local_src,
                audit_build_script=audit_build_script,
            )
        elif input_name:
            # Replay the recorded argv when the crash needs non-default flags;
            # {TESTCASE} maps to the staged input, the rest is shell-quoted.
            # Defaults to the bare `"$testcase"` for a flag-less CLI crash.
            cli_args = " ".join(
                '"$testcase"' if a == crash_artifacts.TESTCASE_TOKEN else shq(a)
                for a in repro_args
            ) or '"$testcase"'
            write_cli_with_input_template(
                repro_path,
                build_system=build_system, upstream_url=upstream_url,
                pinned_rev=pinned_rev, slug=slug,
                san_bin_rel=san_bin_rel, cmake_target=cmake_target,
                input_name=input_name, sanitizer=sanitizer,
                extra_options=sanitizer_extra_options,
                mode=run_mode or "generic",
                recorded_env_options=recorded_env_options,
                local_src=local_src, cli_args=cli_args,
                audit_build_script=audit_build_script,
            )
        else:
            # No runnable template (self-contained harness with no separate
            # testcase, browser/CLI input absent, no shell wrapper). Ship a
            # stub reproducer and STILL build REPORT.md — the bundle's value
            # is the report, not the convenience script. Previously this
            # die()'d and dropped the whole bundle, which is why model-direct
            # crashes never got the canonical REPORT.md.
            repro_is_stub = True
            _stub_reason = "self-contained harness, no separate testcase" \
                if harness_src is not None else "no harness/testcase/wrapper captured"
            write_stub_reproduce(
                repro_path, crash_id=args.crash_id, sanitizer=sanitizer,
                harness_name=harness_name if harness_src is not None else "",
                input_name=input_name, reason=_stub_reason,
            )
            sys.stderr.write(
                f"[export-repro] no runnable reproduce.sh template for "
                f"{args.crash_id} ({_stub_reason}); wrote a stub and continued "
                f"with the REPORT.md bundle.\n"
            )

        # ── Guard: the audit recipe must not be silently dropped ─────
        # A converged .audit/build.sh was loaded but the build-emitting
        # template did not inline it (marker absent). That can only mean a
        # writer forgot to thread audit_build_script — the exact regression
        # that shipped guessed builds for every CLI/shell/browser target. It
        # is a code defect, not an operator/data condition, so fail loudly
        # rather than ship a reproduce.sh that rebuilds the wrong binary.
        if (
            audit_build_script
            and not repro_is_stub
            and (build_system or "") in {"cmake", "autotools", "meson"}
            and AUDIT_BUILD_MARKER not in repro_path.read_text(encoding="utf-8")
        ):
            die(
                f"[export-repro] internal error: {cfg.target_root}/.audit/build.sh "
                f"was loaded but reproduce.sh for {args.crash_id} did not inline it "
                f"(build_system={build_system!r}). A reproduce.sh template is not "
                f"threading audit_build_script into emit_build(); fix the writer so "
                f"the reproducer build matches the audit build."
            )

        # ── Build REPORT.md ──────────────────────────────────────────
        asan_top = extract_asan_top(asan_file)
        asan_summary = extract_asan_summary(asan_file)
        dedup_frames = extract_dedup_frames(asan_file)
        asan_expected = extract_asan_diagnostic(asan_file)

        surface_value, surface_reason = infer_surface(harness_src, asan_file, cfg)
        primitive_label = infer_primitive_label("\n".join([asan_top, asan_expected, asan_summary]))

        trigger_value = ""
        boundary_value = ""
        caller_controls_value = ""
        parameter_control_value = ""
        trusted_actions_value = ""
        caller_contract_value = ""
        strategy_value = ""
        report_text = ""
        if report_md is not None:
            report_text = report_md.read_text(encoding="utf-8", errors="replace")
            trigger_value = read_bare_field(report_md, "Trigger source")
            boundary_value = read_bare_field(report_md, "Boundary")
            caller_controls_value = read_bare_field(report_md, "Caller controls")
            parameter_control_value = read_bare_field(report_md, "Parameter control")
            trusted_actions_value = read_bare_field(report_md, "Trusted caller actions")
            caller_contract_value = read_bare_field(report_md, "Caller contract")
            strategy_value = normalize_strategy(read_bare_field(report_md, "Strategy"))
        # Fill any reach field the report itself does not carry from the
        # `.llm_fields.json` sidecar (report value always wins). Model-direct
        # reports keep these only here, so without the fallback the rebuilt
        # REPORT.md dashes them out and the severity re-score loses the
        # call-sequence / contract facts that should temper the score.
        sidecar = read_llm_sidecar_fields(scan_dirs)
        trigger_value = trigger_value or sidecar.get("trigger_source", "")
        boundary_value = boundary_value or sidecar.get("boundary", "")
        caller_controls_value = caller_controls_value or sidecar.get("caller_controls", "")
        parameter_control_value = parameter_control_value or sidecar.get("parameter_control", "")
        trusted_actions_value = trusted_actions_value or sidecar.get("trusted_caller_actions", "")
        caller_contract_value = caller_contract_value or sidecar.get("caller_contract", "")
        # Default to the harness input boundary when nothing named the trigger.
        trigger_value = trigger_value or "bytes"
        surface_value, surface_reason = adjust_surface_from_report(
            surface_value, surface_reason, report_text, boundary_value,
            trusted_actions_value, cfg
        )

        severity_value = "—"
        for cand in (
            crash_dir / "REPORT.md",
            crash_dir / "report.md",
            report_md,
        ):
            v = read_severity_from(cand)
            if v:
                severity_value = v
                break

        confidence_value = read_confidence(report_md, asan_file)

        # Advisory marker: patch.diff is best-effort. When absent + the
        # agent's narrative documents a Fix Direction, the bundle is
        # an "advisory" — the issue ships for human review with the fix
        # as prose rather than an applyable diff (non-surgical fix, or
        # no clean diff captured).
        advisory_value = detect_advisory_status(
            report_md, stage / "patch.diff"
        )

        report_text = build_report_md(
            crash_id=args.crash_id, primitive_label=primitive_label,
            severity_value=severity_value, surface_value=surface_value,
            surface_reason=surface_reason, trigger_value=trigger_value,
            caller_contract_value=caller_contract_value,
            boundary_value=boundary_value,
            caller_controls_value=caller_controls_value,
            parameter_control_value=parameter_control_value,
            trusted_actions_value=trusted_actions_value,
            confidence_value=confidence_value,
            strategy_value=strategy_value,
            crash_dir=crash_dir, report_md=report_md,
            asan_top=asan_top, asan_summary=asan_summary,
            dedup_frames=dedup_frames,
            asan_expected=asan_expected, pinned_rev=pinned_rev,
            sanitizer=sanitizer,
            advisory_value=advisory_value,
            local_src=local_src,
        )
        (stage / "REPORT.md").write_text(report_text, encoding="utf-8")

        # ── Path normalization: rewrite this session's absolute audit
        #    paths to portable relative form *before* the leak scan
        #    runs. The agent's report.md, ASan debug-info, and harness
        #    #include comments all carry $RESULTS_DIR/$TARGET_ROOT
        #    paths verbatim; without rewriting, the leak scan would
        #    reject every bundle on every container layout. After
        #    rewriting, anything the scan still flags is a real escape
        #    that needs an explicit code fix.
        normalize_candidates = [stage / "REPORT.md", stage / "reproduce.sh"]
        normalize_candidates += list(stage.glob("harness.*"))
        normalize_candidates += list(stage.glob("input.*"))
        # Stable dedupe — list.unique-preserve-order.
        _seen: set[str] = set()
        normalize_targets: list[Path] = []
        for c in normalize_candidates:
            key = str(c)
            if key in _seen:
                continue
            _seen.add(key)
            normalize_targets.append(c)
        for f in normalize_targets:
            if f.is_file():
                _normalize_bundle_file(f, cfg)

        # ── Sanity scan: forbidden internal refs ────────────────────
        leaked: list[str] = []
        for f in normalize_targets:
            if not f.is_file():
                continue
            try:
                txt = f.read_text(encoding="utf-8", errors="replace")
            except OSError:
                continue
            if _bundle_text_has_internal_ref(txt, cfg):
                leaked.append(str(f))
        if leaked:
            msg = f"internal refs leaked into: {' '.join(leaked)}"
            if os.environ.get("EXPORT_REPRO_ALLOW_INTERNAL_REFS") == "1":
                sys.stderr.write(f"[export-repro] WARNING: {msg}\n")
            else:
                die(f"{msg}; set EXPORT_REPRO_ALLOW_INTERNAL_REFS=1 only for local debugging")

        # ── Migrate junk into .audit/ ────────────────────────────────
        if out_dir == crash_dir:
            audit_subdir.mkdir(parents=True, exist_ok=True)
            legacy_repro = crash_dir / "repro"
            if legacy_repro.is_dir():
                dest = audit_subdir / "legacy-repro"
                if dest.exists():
                    shutil.rmtree(dest)
                shutil.move(str(legacy_repro), str(dest))
            # Bash uses `shopt -s dotglob nullglob` here so dotfiles are also
            # migrated; mirror that by walking iterdir() (which already lists
            # hidden files) instead of _list_visible_entries.
            for f in sorted(crash_dir.iterdir()):
                if not f.exists():
                    continue
                base = f.name
                # Only the chosen input.<ext> is a bundle file; older
                # bundles may have left input.out / input.bin / ...
                # alongside the correct testcase. Migrate the stragglers
                # so they can't be re-picked by a later find_testcase or
                # confuse the user about which file reproduce.sh runs.
                if base.startswith("input."):
                    if input_name and base == input_name:
                        continue
                else:
                    if _is_bundle_filename(base):
                        continue
                if f.is_dir():
                    continue
                try:
                    shutil.move(str(f), str(audit_subdir / base))
                except OSError:
                    pass

        # ── Install staged files atomically ──────────────────────────
        install_candidates = [
            stage / "REPORT.md",
            stage / "reproduce.sh",
            stage / "sanitizer.txt",
        ]
        install_candidates += list(stage.glob("harness.*"))
        install_candidates.append(stage / "patch.diff")
        for staged in install_candidates:
            if staged.is_file():
                _install_with_exact_case(staged, out_dir / staged.name)
        for staged in stage.glob("input.*"):
            if staged.is_file():
                _install_with_exact_case(staged, out_dir / staged.name)
        repro_dest = out_dir / "reproduce.sh"
        if repro_dest.is_file():
            try:
                os.chmod(repro_dest, 0o755)
            except OSError:
                pass

    finally:
        shutil.rmtree(stage, ignore_errors=True)

    # ── Re-apply severity ────────────────────────────────────────────
    # build_report_md rebuilds REPORT.md from the agent's report.md, which
    # never carries the `## Severity rationale` section written by
    # bin/severity. If a prior run already scored this dir (severity.json
    # present), replay the offline scorer now so the rebuild does not lose
    # the section. Best-effort.
    severity_json = out_dir / "severity.json"
    severity_bin = SCRIPT_DIR / "severity"
    if severity_json.is_file() and severity_json.stat().st_size > 0 \
            and severity_bin.is_file():
        try:
            subprocess.run(
                [sys.executable, str(severity_bin), "--report", str(out_dir)],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                check=False, timeout=30,
            )
        except (OSError, subprocess.SubprocessError):
            pass

    # REPORT.html is rendered by maintain_indexes after severity and
    # cluster post-processing have made their final REPORT.md edits. Rendering
    # here would create a stale pre-severity/pre-cluster HTML sibling.

    # ── Mark this dir as bundled for triage. ─────────────────────────
    promotion_log = audit_subdir / "promotion.log"
    try:
        audit_subdir.mkdir(parents=True, exist_ok=True)
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        with open(promotion_log, "a", encoding="utf-8") as f:
            f.write(
                f"{ts}  exported  CRASH_ID={args.crash_id}  rev={cfg.target_rev or 'unknown'}\n"
            )
    except OSError:
        pass

    sys.stdout.write(f"[export-repro] wrote {out_dir}  (internals → {audit_subdir})\n")
    try:
        for entry in sorted(out_dir.iterdir()):
            if entry.name.startswith("."):
                continue
            sys.stdout.write(entry.name + "\n")
    except OSError:
        pass
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
