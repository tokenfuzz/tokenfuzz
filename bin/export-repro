#!/usr/bin/env python3
"""bin/export-repro — turn a CRASH-NNN-N audit dir into a 4-file
maintainer-facing reproduction bundle.

Usage:
  bin/export-repro <CRASH-id> [--out <dir>] [--slug <slug>]

Produces (replacing any previous content of <out>):
  <out>/REPORT.md           — bug summary, root cause, candidate fix
  <out>/reproduce.sh        — one shell command, no env vars
  <out>/input.<ext>         — testcase bytes (renamed from internal stem)
  <out>/harness.c/.cpp      — present iff the bug uses a C/C++ harness
  <out>/sanitizer.txt       — original full sanitizer output
"""

from __future__ import annotations

import argparse
import base64
import contextlib
import json
import os
import re
import secrets
import shlex
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterable, Optional

# .absolute() not .resolve(): inside a benchmark cell facade bin/ is a
# symlink to the real tree; .resolve() would chase it and make us read
# the wrong output/<slug>/target.toml.
SCRIPT_DIR = Path(__file__).absolute().parent
SCRIPT_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import crash_artifacts  # noqa: E402  (runtime sys.path adjustment)
import stack_frames  # noqa: E402  (runtime sys.path adjustment)
import target_config  # noqa: E402  (runtime sys.path adjustment)


def die(msg: str) -> None:
    sys.stderr.write(f"[export-repro] {msg}\n")
    sys.exit(1)


def usage() -> None:
    sys.stderr.write("Usage: bin/export-repro <CRASH-id> [--out <dir>] [--slug <slug>]\n")


# ─── Helpers ─────────────────────────────────────────────────────────

# Audit-internal header keys probe writes as the leading lines of a script
# testcase or harness. Defined once so the comment-prefixed (harness) and
# bare (testcase) forms below can never drift apart.
_AUDIT_HEADER_KEYS = "TARGET|HYPOTHESIS-ID|CATEGORY|CARD-ID|MODE|HARNESS|PROPERTY"

# Comment-prefixed form, for stripping headers from harness *source*
# (`// TARGET: …`, `# TARGET: …`, `<!-- TARGET: … -->`). Prefix is optional
# so bare headers are caught too.
_INTERNAL_HEADER_RE = re.compile(
    rf"^\s*(?:(?://|<!--|#)\s*)?(?:{_AUDIT_HEADER_KEYS}):"
)

# Bare form, for script *testcases*: probe strips only un-prefixed header
# lines (after an optional shebang), so the export mirrors that exactly.
_TESTCASE_HEADER_RE = re.compile(rf"^[ \t]*(?:{_AUDIT_HEADER_KEYS}):[ \t]*")

# Extensions probe treats as scripts whose leading header lines are stripped
# before execution (bin/probe _probe_prepare_exec_testcase). Kept in sync with
# that list so the exported bytes match the bytes probe actually ran.
_SCRIPT_HEADER_EXTS = frozenset({
    "js", "mjs", "cjs", "ts", "tsx", "jsx", "py", "rb", "php",
    "pl", "pm", "r", "R", "sh", "bash", "zsh", "kts",
})


def strip_internal_headers(path: Path) -> str:
    """Drop the first ≤20 lines that look like an internal `// TAG: …` header."""
    out: list[str] = []
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for i, line in enumerate(f, start=1):
            if i <= 20 and _INTERNAL_HEADER_RE.match(line):
                continue
            out.append(line)
    return "".join(out)


# `_INCLUDE_DIRECTIVE_RE` matches a single C/C++ #include directive, in
# either quoted (`#include "..."`) or angle-bracket (`#include <...>`) form.
# We keep the surrounding punctuation in `open`/`close` so the rewriter can
# substitute just the path without disturbing the syntax around it.
_INCLUDE_DIRECTIVE_RE = re.compile(
    r"""
    ^                                # anchor at line start (MULTILINE below)
    (?P<open>   \s* \# \s* include \s* [<"] )
    (?P<path>   [^>"\n]+ )
    (?P<close>  [>"] )
    """,
    re.MULTILINE | re.VERBOSE,
)

# `_AUDIT_REPO_PATH_RE` matches an #include path that embeds the audit
# machine's project-root layout — anything ending in
# `.../{targets|output}/<slug>/<rest>`. The `inner` group captures `<rest>`
# so the rewriter can re-emit just that bundle-local part. Slug-agnostic
# by design: any audit's target slug fits, at any nested depth above.
_AUDIT_REPO_PATH_RE = re.compile(
    r"""
    ^
    (?:.*/)?                         # optional leading path the agent baked in
    (?:targets|output) /             # the giveaway segment
    [^/]+ /                          # the per-target slug
    (?P<inner> .+ )                  # what should remain in the bundle
    $
    """,
    re.VERBOSE,
)


def rewrite_harness_repo_paths(text: str) -> str:
    """Strip audit-machine repo prefixes from `#include` paths in `text`.

    Agents occasionally bake `#include "targets/<slug>/foo.h"` (or the
    equivalent `output/<slug>/...`) into harnesses because the path
    resolved from the audit machine's project root via clang's
    cwd-fallback. The exported reproducer runs against a fresh upstream
    clone at `$src` — same file, different path — so the literal include
    misses. This rewriter strips the `targets|output/<slug>/` prefix; the
    bundle's `-I "$src"` baseline (see `emit_include_args`) then resolves
    the remaining in-source path.

    Best-effort: untouched if no prefix matches. A stripped path that
    still doesn't exist in the fresh clone fails with a clearer
    `file not found: foo.h` than the repo-rooted form gave before.
    """
    def replace(match: re.Match[str]) -> str:
        open_punct = match.group("open")
        path = match.group("path")
        close_punct = match.group("close")
        prefix_match = _AUDIT_REPO_PATH_RE.match(path)
        if prefix_match is None:
            return match.group(0)  # path has no repo prefix — leave it alone
        bundle_path = prefix_match.group("inner")
        return f"{open_punct}{bundle_path}{close_punct}"

    return _INCLUDE_DIRECTIVE_RE.sub(replace, text)


def read_testcase_bytes(path: Path) -> bytes:
    """Read testcase bytes, mirroring probe's script-header execution view."""
    data = path.read_bytes()
    if b"\x00" in data:
        return data
    try:
        text = data.decode("utf-8")
    except UnicodeDecodeError:
        return data
    if path.suffix.lstrip(".") not in _SCRIPT_HEADER_EXTS:
        return data
    lines = text.splitlines(keepends=True)
    if not any(_TESTCASE_HEADER_RE.match(line) for line in lines[:16]):
        return data
    out: list[str] = []
    for i, line in enumerate(lines, start=1):
        if i == 1 and line.startswith("#!"):
            out.append(line)
            continue
        if _TESTCASE_HEADER_RE.match(line):
            continue
        out.append(line)
    return "".join(out).encode("utf-8")


def ext_of(basename: str) -> str:
    b = basename.lower()
    for suf, ext in (
        (".html", "html"),
        (".htm", "htm"),
        (".xhtml", "xhtml"),
        (".svg", "svg"),
        (".js", "js"),
        (".mjs", "js"),
        (".xml", "xml"),
        (".cat", "cat"),
        (".json", "json"),
        (".dat", "dat"),
    ):
        if b.endswith(suf):
            return ext
    if "." in basename:
        ext = basename.rsplit(".", 1)[1].lower()
        if re.fullmatch(r"[a-z0-9]{1,24}", ext):
            return ext
    return "bin"


def shq(value: str) -> str:
    """Return a shell literal safe to splice into generated bash."""
    return shlex.quote(value)


def shdq_text(value: str) -> str:
    """Return text safe inside a generated double-quoted shell string."""
    return value.replace("\\", "\\\\").replace('"', '\\"').replace("$", "\\$").replace("`", "\\`")


def safe_slug(value: str) -> str:
    """Return a conservative path component for auto-clone directories."""
    slug = value or "target"
    if re.fullmatch(r"[A-Za-z0-9._-]{1,80}", slug) and slug not in {".", ".."}:
        return slug
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "-", slug).strip(".-")
    if not cleaned or cleaned in {".", ".."}:
        cleaned = "target"
    return cleaned[:80]


