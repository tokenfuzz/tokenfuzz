#!/usr/bin/env python3
"""Breadth-first, parallel source review for audit queue seeding."""

from __future__ import annotations

import argparse
import concurrent.futures
import json
import os
import random
import re
import shutil
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path

SCRIPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import llm_invoke
import recon_report
import recon_slicer
import target_config
from prompt_render import render_template
from triage_validate import validate_finding

_CANDIDATE_RE = re.compile(r'^\{.*"id"\s*:\s*"REC(?:ON)?-')


def log(message: str) -> None:
    print(f"[{time.strftime('%H:%M:%S')}] [recon] {message}", flush=True)


def _positive(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("must be a positive integer") from exc
    if parsed < 1:
        raise argparse.ArgumentTypeError("must be >= 1")
    return parsed


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="audit-recon",
        description="Run parallel confirmation-pass discovery over a target tree.",
    )
    parser.add_argument("--target", required=True, help="target slug under targets/")
    parser.add_argument("--target-path")
    parser.add_argument(
        "--backend", required=True,
        choices=("claude", "codex", "gemini", "grok", "oss"),
    )
    parser.add_argument("--model", default="")
    parser.add_argument("--experiment", default="")
    parser.add_argument("--concurrency", type=_positive, default=4)
    parser.add_argument("--out")
    parser.add_argument("--report")
    parser.add_argument("--timeout", type=_positive, default=1800)
    parser.add_argument("--validate", choices=("off", "confirmed", "all"), default="all")
    parser.add_argument("--scope", choices=("auto", "all", "since", "path"), default="auto")
    parser.add_argument("--path", dest="path_scope", default="")
    parser.add_argument("--recon-lookback", type=_positive, default=365)
    parser.add_argument("--no-reroll", action="store_true")
    return parser


def _sanitize_experiment(raw: str) -> str:
    value = re.sub(r"[^a-z0-9._-]+", "-", raw.lower()).strip("-")
    if not value:
        raise ValueError("experiment name resolved to empty string")
    return value


def _git(target: Path, *args: str) -> str:
    completed = subprocess.run(
        ["git", "-C", str(target), *args], text=True,
        stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
    )
    return completed.stdout.strip() if completed.returncode == 0 else ""


def _is_ancestor(target: Path, older: str, newer: str) -> bool:
    return subprocess.run(
        ["git", "-C", str(target), "merge-base", "--is-ancestor", older, newer],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False,
    ).returncode == 0


def _load_target_config(target: Path, output_root: Path, base_root: Path) -> target_config.Config:
    config = target_config.Config(target_root=str(target))
    candidates = (output_root / "target.toml", base_root / "target.toml", target / "target.toml")
    for candidate in candidates:
        if not candidate.is_file():
            continue
        target_config.load_toml_into(config, candidate)
        break
    if not config.attacker_controls:
        config.attacker_controls = ["bytes"]
    return config


def _resolve_since_scope(target: Path, lookback_days: int, checkpoint: Path) -> tuple[str, str]:
    if target_config.detect_repo_type(target) != "git" or not _git(target, "rev-parse", "HEAD"):
        log(f"WARN: --scope since but {target} is not a git repo; falling back to --scope all")
        return "all", ""
    head = _git(target, "rev-parse", "HEAD")
    lookback = _git(target, "rev-list", "-1", f"--before={lookback_days} days ago", "HEAD")
    if not lookback:
        roots = _git(target, "rev-list", "--max-parents=0", "HEAD").splitlines()
        lookback = roots[-1] if roots else ""
    lookback_full = _git(target, "rev-parse", f"{lookback}^{{commit}}") if lookback else ""
    if not lookback or not lookback_full:
        log("WARN: could not resolve a lookback ref; falling back to --scope all")
        return "all", ""
    if lookback_full == head:
        log("Recon scope=since: lookback window covers the entire history -> scope=all")
        return "all", ""
    changed_since = lookback
    try:
        saved = checkpoint.read_text(encoding="utf-8").strip()
    except OSError:
        saved = ""
    if (
        saved and _git(target, "cat-file", "-e", f"{saved}^{{commit}}") == ""
        and _is_ancestor(target, saved, "HEAD")
        and _is_ancestor(target, lookback, saved)
    ):
        # cat-file -e has no stdout; a zero status needs an explicit check.
        exists = subprocess.run(
            ["git", "-C", str(target), "cat-file", "-e", f"{saved}^{{commit}}"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False,
        ).returncode == 0
        if exists:
            changed_since = saved
    return "since", changed_since


def _source_files(target: Path, scope: str, path_scope: str, changed_since: str) -> tuple[Path, list[Path]]:
    source_root = recon_slicer.find_source_root(target)
    if scope == "path":
        scoped = (source_root / path_scope).resolve()
        if not scoped.is_dir():
            scoped = (target / path_scope).resolve()
        if not scoped.is_dir():
            raise ValueError(f"--path subtree does not exist: {scoped}")
        source_root = scoped
    if scope == "since":
        return source_root, recon_slicer.changed_source_files(target, source_root, changed_since)
    return source_root, recon_slicer.collect_source_files(source_root, target)


def _write_slices(source_root: Path, files: list[Path], count: int, seed: int, directory: Path) -> list[Path]:
    for old in directory.glob("slice-*.txt"):
        old.unlink()
    recon_slicer.write_slices(recon_slicer.partition(source_root, files, count, seed), directory)
    return sorted(directory.glob("slice-*.txt"))


def build_recon_prompt(
    target_slug: str,
    attacker_controls: str,
    slice_name: str,
    slice_file: Path,
    timeout_secs: int,
) -> str:
    files = "".join(f"- {line}\n" for line in slice_file.read_text(encoding="utf-8").splitlines())
    scope_block = (
        "## Scope\n\nFocus on these files. You may read one level of caller "
        "(the public API entry point) outside the list when it helps trace a "
        "finding, but do not wander the rest of the tree.\n\n" + files
    )
    return render_template(
        "audit_recon.md.j2",
        {
            "goal_framing": render_template("audit_goal_framing.md.j2", {}),
            "bug_contract": render_template("audit_bug_contract.md.j2", {}),
            "target_slug": target_slug,
            "attacker_controls": attacker_controls or "bytes",
            "scope_block": scope_block,
            "slice_name": slice_name,
            "timeout_secs": str(timeout_secs),
        },
    )


def candidate_rows(text: str) -> tuple[list[dict], int]:
    rows: list[dict] = []
    malformed = 0
    for line in text.splitlines():
        if not _CANDIDATE_RE.search(line):
            continue
        try:
            value = json.loads(line)
        except ValueError:
            malformed += 1
            continue
        if isinstance(value, dict):
            rows.append(value)
        else:
            malformed += 1
    return rows, malformed


@dataclass
class SliceResult:
    name: str
    log: Path
    rows: list[dict]
    malformed: int


def _run_slice(
    *,
    name: str,
    slice_file: Path,
    target_slug: str,
    attacker_controls: str,
    target_path: Path,
    backend: str,
    model: str,
    timeout_secs: int,
    logdir: Path,
    raw_dir: Path,
) -> SliceResult:
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    log_path = logdir / f"recon_{stamp}_{name}.log"
    raw_path = raw_dir / f"recon_{stamp}_{name}.raw"
    prompt = build_recon_prompt(
        target_slug, attacker_controls, name, slice_file, timeout_secs
    )
    add_dirs = str(target_path)
    if target_path != SCRIPT_ROOT:
        add_dirs += f",{SCRIPT_ROOT}"
    combined = ""
    final_rows: list[dict] = []
    total_malformed = 0
    for attempt in (1, 2):
        rc = llm_invoke.run_agent_prompt(
            backend, prompt, timeout_secs, raw_path, model=model,
            max_turns=80, add_dirs=add_dirs, cwd=target_path,
        )
        try:
            extracted = llm_invoke.extract_text(backend, str(raw_path))
        except (OSError, ValueError):
            extracted = raw_path.read_text(encoding="utf-8", errors="replace") if raw_path.exists() else ""
        combined += extracted + "\n"
        rows, malformed = candidate_rows(extracted)
        final_rows.extend(rows)
        total_malformed += malformed
        fatal = rc == 124 or llm_invoke.transient_tail(str(raw_path))
        if final_rows and not fatal:
            break
        if attempt == 1:
            reason = "cut off by a transient provider error" if fatal else "yielded 0 usable candidates"
            log(f"WARN: recon agent for {name} {reason}; retrying once")
            time.sleep(random.uniform(3, 7))
        else:
            log(f"WARN: recon agent for {name} still incomplete after retry; keeping gathered output")
    log_path.write_text(combined, encoding="utf-8")
    return SliceResult(name, log_path, final_rows, total_malformed)


def _counts(rows: list[dict]) -> tuple[int, int, int]:
    confirmed = sum(str(row.get("confidence", "")).startswith("CONFIRMED-") for row in rows)
    needs = sum(row.get("confidence") == "NEEDS-VERIFICATION" for row in rows)
    clean = sum(row.get("confidence") == "AUDIT-CLEAN" for row in rows)
    return confirmed, needs, clean


def _run_pass(
    slice_files: list[Path], pass_label: str, concurrency: int, **options
) -> list[SliceResult]:
    with concurrent.futures.ThreadPoolExecutor(max_workers=concurrency) as pool:
        jobs = []
        for slice_file in slice_files:
            name = slice_file.stem
            if pass_label:
                name = f"{pass_label}-{name}"
            log(f"Launching agent for {name} ({options['backend']})")
            jobs.append(pool.submit(_run_slice, name=name, slice_file=slice_file, **options))
        log(f"Waiting on {len(jobs)} parallel recon agent(s) (timeout={options['timeout_secs']}s each)")
        results = [job.result() for job in jobs]
    log(f"All recon agents finished{f' ({pass_label})' if pass_label else ''}")
    return results


def _run_python(*args: str, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        [sys.executable, *args], input=input_text, text=True,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False,
    )


def _validate(
    output_path: Path,
    results_dir: Path,
    raw_dir: Path,
    target_path: Path,
    backend: str,
    model: str,
    mode: str,
    timeout_secs: int,
) -> tuple[int, int, int]:
    triage_dir = results_dir / ".recon-triage"
    triage_dir.mkdir(parents=True, exist_ok=True)
    for old in triage_dir.glob("s3-*.tsv"):
        old.unlink()
    reps = triage_dir / "reps.jsonl"
    clusters = triage_dir / "clusters.json"
    passthrough = triage_dir / "passthrough.jsonl"
    verdicts = triage_dir / "verdicts.json"
    stage3 = triage_dir / "stage3.tsv"
    validated = output_path.with_name(f"{output_path.stem}.validated.jsonl")
    command = str(SCRIPT_ROOT / "lib" / "recon_triage.py")
    clustered = _run_python(
        command, "cluster", "--in", str(output_path), "--reps", str(reps),
        "--clusters", str(clusters), "--passthrough", str(passthrough),
        "--validate-mode", mode,
    )
    if clustered.returncode:
        log(f"WARN: recon_triage cluster failed: {clustered.stderr.strip()}")
        return 0, 0, 0
    n_reps = sum(1 for line in reps.read_text(encoding="utf-8").splitlines() if line.strip())
    total = sum(1 for line in output_path.read_text(encoding="utf-8").splitlines() if line.strip())
    log(f"Recon triage: {total} hypothesis line(s) -> {n_reps} representative cluster(s) after dedup")
    if not n_reps:
        return 0, 0, 0

    raw = raw_dir / f"recon_batch_triage_{datetime.now().strftime('%Y%m%d_%H%M%S')}.raw"
    budget = max(timeout_secs, 1800)
    prompt = render_template(
        "recon_batch_triage.md.j2",
        {"target_path": str(target_path), "reps_jsonl": reps.read_text(encoding="utf-8")},
    )
    rc = llm_invoke.run_agent_prompt(
        backend, prompt, budget, raw, model=model, max_turns=120,
        add_dirs=str(target_path), cwd=target_path,
    )
    if rc:
        log("WARN: batched triage agent exited non-zero; un-triaged reps fall back to deep verify")
    try:
        triage_text = llm_invoke.extract_text(backend, str(raw))
    except (OSError, ValueError):
        triage_text = ""
    parsed = _run_python(command, "parse-batch", "--reps", str(reps), "--out", str(verdicts), input_text=triage_text)
    if parsed.returncode:
        log(f"WARN: recon_triage parse-batch failed: {parsed.stderr.strip()}")

    maximum = int(os.environ.get("RECON_TRIAGE_MAX_DEEP", "24"))
    survivor_run = _run_python(command, "survivors", "--verdicts", str(verdicts), "--limit", str(maximum))
    survivor_ids = [line for line in survivor_run.stdout.splitlines() if line]
    rep_rows = {
        row["id"]: row
        for line in reps.read_text(encoding="utf-8").splitlines()
        if line.strip() and isinstance((row := json.loads(line)), dict) and row.get("id")
    }
    for fid in survivor_ids:
        finding_dir = results_dir / "recon" / fid
        finding_dir.mkdir(parents=True, exist_ok=True)
        finding_json = finding_dir / "finding.json"
        if not finding_json.exists() and fid in rep_rows:
            finding_json.write_text(json.dumps(rep_rows[fid], ensure_ascii=False) + "\n", encoding="utf-8")

    parallel = max(1, int(os.environ.get("RECON_TRIAGE_PARALLEL", "6")))
    def validate_one(fid: str) -> str:
        result = validate_finding(
            results_dir / "recon" / fid / "finding.json", target_path,
            results_dir, backend=backend, model=model, votes=1,
        )
        return f"{fid}\t{result.verdict}\t{result.summary()}\n"

    with concurrent.futures.ThreadPoolExecutor(max_workers=parallel) as pool:
        stage_lines = list(pool.map(validate_one, survivor_ids))
    stage3.write_text("".join(stage_lines), encoding="utf-8")
    log(f"Recon triage: {len(survivor_ids)} survivor(s) deep-verified by one independent validator each")

    finalized = _run_python(
        command, "finalize", "--reps", str(reps), "--passthrough", str(passthrough),
        "--verdicts", str(verdicts), "--stage3", str(stage3), "--out", str(validated),
    )
    if finalized.returncode or not validated.exists() or not validated.stat().st_size:
        log("WARN: recon_triage finalize failed; hypotheses left unvalidated")
        return 0, 0, 0
    shutil.move(validated, output_path)
    try:
        promoted, rejected, uncertain = map(int, finalized.stdout.split()[:3])
    except (ValueError, IndexError):
        promoted = rejected = uncertain = 0
    recon_root = results_dir / "recon"
    if recon_root.is_dir():
        for directory in recon_report.discover_recon_dirs(recon_root):
            recon_report.write_report(directory)
    return promoted, rejected, uncertain


def _write_report(path: Path, slug: str, backend: str, timeout_secs: int, slices: int, rows: list[dict]) -> None:
    confirmed, needs, clean = _counts(rows)
    lines = [
        f"# {slug} - recon findings ({datetime.now().astimezone().strftime('%Y-%m-%d %H:%M %Z')})",
        "",
        f"Slices: {slices}  |  Backend: {backend}  |  Per-slice timeout: {timeout_secs}s",
        "",
        f"Confirmed: {confirmed}  |  Needs-verification: {needs}  |  Audited-clean: {clean}",
        "",
        "---", "",
    ]
    findings = [row for row in rows if row.get("confidence") not in (None, "AUDIT-CLEAN")]
    if findings:
        lines += ["## Findings", ""]
        for row in findings:
            lines += [
                f"### {row.get('id', 'RECON-???')} - {row.get('title', '(no title)')}", "",
                f"- **Confidence**: {row.get('confidence', '?')}",
                f"- **Class**: {row.get('class', '?')}",
                f"- **File:line**: `{row.get('file', '?')}:{row.get('line', 0)}` in `{row.get('function', '?')}`",
            ]
            for label, key in (("Notes", "notes"), ("Input shape", "input_shape"), ("Primitive", "primitive"), ("Falsification", "falsification"), ("Validator", "validator_verdict")):
                if row.get(key):
                    lines.append(f"- **{label}**: {row[key]}")
            if row.get("reach_path"):
                lines.append(f"- **Reach path**: {' -> '.join(map(str, row['reach_path']))}")
            if row.get("guards_passed"):
                lines.append("- **Guards passed**:")
                lines.extend(f"  - {guard}" for guard in row["guards_passed"])
            lines += ["", "---", ""]
    clean_rows = [row for row in rows if row.get("confidence") == "AUDIT-CLEAN"]
    if clean_rows:
        lines += ["## Slices audited clean", ""]
        lines.extend(f"- **{row.get('slice', '?')}**: {row.get('notes', '')}" for row in clean_rows)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    if args.scope == "path" and not args.path_scope:
        build_parser().error("--scope path requires --path <subdir>")
    if args.path_scope:
        args.scope = "path"
    llm_invoke.apply_memory_policy()
    target_path = Path(args.target_path or SCRIPT_ROOT / "targets" / args.target).resolve()
    if not target_path.is_dir():
        print(f"FATAL: target path does not exist: {target_path}", file=sys.stderr)
        return 2
    try:
        suffix = f"-{_sanitize_experiment(args.experiment)}" if args.experiment else ""
    except ValueError as exc:
        print(f"FATAL: {exc}", file=sys.stderr)
        return 2
    output_root = SCRIPT_ROOT / "output" / f"{args.target}{suffix}"
    base_root = SCRIPT_ROOT / "output" / args.target
    results_dir = output_root / args.backend / "results"
    logdir = output_root / args.backend / "logs"
    out_path = Path(args.out).expanduser() if args.out else results_dir / "recon-hypotheses.jsonl"
    report_path = Path(args.report).expanduser() if args.report else results_dir / "recon-findings.md"
    if out_path.is_dir():
        out_path /= "recon-hypotheses.jsonl"
    if report_path.is_dir():
        report_path /= "recon-findings.md"
    if args.out:
        results_dir = out_path.parent.resolve()
        out_path = results_dir / out_path.name
        report_path = report_path.resolve() if args.report else results_dir / "recon-findings.md"
        logdir = results_dir.parent / "logs" if results_dir.name == "results" else results_dir / "logs"
    raw_dir = logdir / ".raw"
    for directory in (results_dir, logdir, raw_dir, out_path.parent, report_path.parent):
        directory.mkdir(parents=True, exist_ok=True)
    os.environ["LOGDIR"] = str(logdir)
    try:
        llm_invoke.memory_env(args.backend)
    except OSError as exc:
        print(f"FATAL: cannot isolate backend memory: {exc}", file=sys.stderr)
        return 1

    config = _load_target_config(target_path, output_root, base_root)
    checkpoint = results_dir / ".recon-checkpoint"
    scope = args.scope
    threshold = int(os.environ.get("RECON_SCOPE_AUTO_THRESHOLD", "500"))
    if scope == "auto":
        source_count = recon_slicer.count_source_files(target_path)
        scope = "all" if source_count <= threshold else "since"
        log(f"Auto-scope: {source_count} source file(s), threshold={threshold} -> scope={scope}")
    changed_since = ""
    if scope == "since":
        scope, changed_since = _resolve_since_scope(target_path, args.recon_lookback, checkpoint)

    log(f"Recon discovery: target={args.target} path={target_path} backend={args.backend} scope={scope}")
    log(f"  concurrency={args.concurrency}")
    log(f"Output: hypotheses={out_path} report={report_path}")
    try:
        source_root, files = _source_files(target_path, scope, args.path_scope, changed_since)
    except (OSError, ValueError) as exc:
        print(f"FATAL: {exc}", file=sys.stderr)
        return 3

    def checkpoint_head() -> None:
        head = _git(target_path, "rev-parse", "HEAD")
        if head:
            checkpoint.write_text(head + "\n", encoding="utf-8")

    if scope == "since" and not files:
        out_path.write_text("", encoding="utf-8")
        report_path.write_text(
            f"# {args.target} - recon findings ({datetime.now().astimezone().strftime('%Y-%m-%d %H:%M %Z')})\n\n"
            f"Scope: since {changed_since}  |  no source files changed - recon is a no-op.\n",
            encoding="utf-8",
        )
        checkpoint_head()
        log("Done (empty change set).")
        return 0
    if not files:
        print(f"FATAL: no source files found under {source_root}", file=sys.stderr)
        return 3

    root_findings = SCRIPT_ROOT / "findings.jsonl"
    root_findings_preexisted = root_findings.exists()
    temp_root = Path(tempfile.mkdtemp(prefix="recon-slices."))
    try:
        slice_files = _write_slices(source_root, files, args.concurrency, 0, temp_root)
        if not slice_files:
            print("FATAL: no slices produced", file=sys.stderr)
            return 3
        log(f"Sliced {args.target} into {len(slice_files)} file group(s)")
        options = dict(
            target_slug=args.target, attacker_controls=config.attacker_controls_csv(),
            target_path=target_path, backend=args.backend, model=args.model,
            timeout_secs=args.timeout, logdir=logdir, raw_dir=raw_dir,
        )
        results = _run_pass(slice_files, "", args.concurrency, **options)
        first_rows = [row for result in results for row in result.rows]
        confirmed, needs, clean = _counts(first_rows)
        log(f"Pass 1 results: confirmed={confirmed} needs-verify={needs} audit-clean={clean}")
        if not args.no_reroll and not confirmed and not needs and clean:
            log("All slices returned AUDIT-CLEAN. Re-rolling once with seed=1 partition")
            slice_files = _write_slices(source_root, files, args.concurrency, 1, temp_root)
            rerolled = _run_pass(slice_files, "reroll", args.concurrency, **options)
            results.extend(rerolled)

        rows = [row for result in results for row in result.rows]
        malformed = sum(result.malformed for result in results)
        out_path.write_text(
            "".join(json.dumps(row, ensure_ascii=False) + "\n" for row in rows),
            encoding="utf-8",
        )
        if malformed:
            log(f"WARN: dropped {malformed} candidate JSONL line(s) that failed JSON parsing")
        poisoned = not rows and malformed > 0
        confirmed, needs, clean = _counts(rows)
        log(f"Recon results: confirmed={confirmed} needs-verify={needs} audit-clean={clean} (total {len(rows)} line(s))")
        if args.validate != "off" and out_path.stat().st_size:
            promoted, rejected, uncertain = _validate(
                out_path, results_dir, raw_dir, target_path, args.backend,
                args.model, args.validate, args.timeout,
            )
            log(
                "Validator review complete: "
                f"{promoted + rejected + uncertain} representative(s) reviewed - "
                f"{promoted} promoted, {rejected} rejected, {uncertain} uncertain."
            )
            rows = [json.loads(line) for line in out_path.read_text(encoding="utf-8").splitlines() if line]
        elif args.validate != "off":
            log(f"WARN: no hypotheses to validate (mode={args.validate})")
        _write_report(report_path, args.target, args.backend, args.timeout, len(results), rows)
        log(f"Report written: {report_path}")
        if poisoned:
            log("Done (with POISONED output; checkpoint not advanced).")
            return 5
        checkpoint_head()
        log("Done.")
        return 0
    finally:
        if not root_findings_preexisted and root_findings.exists():
            destination = raw_dir / f"recon_stray_findings_{datetime.now().strftime('%Y%m%d_%H%M%S')}.jsonl"
            shutil.move(root_findings, destination)
            log("WARN: quarantined stray repo-root findings.jsonl from recon agent")
        shutil.rmtree(temp_root, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
