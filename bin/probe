#!/usr/bin/env python3
"""Coverage-gated sanitizer and differential testcase runner."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Sequence

ROOT = Path(__file__).resolve().parent.parent
BIN_DIR = ROOT / "bin"
LIB_DIR = ROOT / "lib"
sys.path.insert(0, str(LIB_DIR))

import build_routes
import crash_bundle
import languages
import target_config
import verdict as verdict_lib
from file_tools import capture_command
from sanitizer_helpers import file_contains
from probe_helpers import _nonnegative_int

VALID_MODES = {"auto", "browser", "js", "generic", "js-diff"}
VALID_SANITIZERS = {"asan", "ubsan", "msan", "tsan", "race", "runner"}
MODE_MATRIX = {
    "asan": {"browser", "js", "generic", "js-diff"},
    "ubsan": {"browser", "js", "generic", "js-diff"},
    "msan": {"js", "generic"},
    "tsan": {"js", "generic"},
    "race": {"generic"},
    "runner": {"generic"},
}
COMPILE_SANITIZERS = {"asan": "address", "ubsan": "undefined", "msan": "memory", "tsan": "thread"}
SCRIPT_EXTENSIONS = {"js", "mjs", "cjs", "ts", "tsx", "jsx", "py", "rb", "php", "pl", "pm", "r", "sh", "bash", "zsh", "kts"}
HEADER_RE = {
    "target": re.compile(r"^[^A-Za-z]*TARGET:\s*(.+?)\s*(?:-->|\*/)?\s*$", re.M),
    "hypothesis": re.compile(r"HYPOTHESIS-ID:\s*([^\s>*]+)"),
    "card": re.compile(r"CARD-ID:\s*([^\s>*]+)"),
    "mode": re.compile(r"^[^A-Za-z]*MODE:\s*([A-Za-z0-9_-]+)", re.M),
    "harness": re.compile(r"^[^A-Za-z]*HARNESS:\s*([^\s>*]+)", re.M),
}
BARE_METADATA = re.compile(r"^\s*(TARGET|HYPOTHESIS-ID|CARD-ID|CATEGORY|MODE|HARNESS|PROPERTY):\s*")
HELP = """Usage:
  bin/probe [--confirm] [--dry-run] [--mode auto|browser|js|generic|js-diff] \\
            [--want REGEX] testcase [-- harness-args...]

Required testcase headers:
  TARGET: <file[:function[:line]]>
  HYPOTHESIS-ID: H<n>
  CATEGORY: bounds|lifetime|type|size|uninit|state

Optional testcase headers:
  MODE: auto|browser|js|generic|js-diff
  HARNESS: harness.c
  CARD-ID: <id>

PROBE_SANITIZER=asan|ubsan|msan|tsan|race|runner overrides target.toml.
--confirm runs five times; --dry-run resolves and prints the command only.
"""


def parse_args(argv: Sequence[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(add_help=False, usage=argparse.SUPPRESS)
    parser.add_argument("--mode", default="auto")
    parser.add_argument("--confirm", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--want", default="")
    parser.add_argument("-h", "--help", action="store_true")
    parser.add_argument("testcase", nargs="?")
    parser.add_argument("args", nargs=argparse.REMAINDER)
    try:
        args = parser.parse_args(argv)
    except SystemExit:
        print(HELP, file=sys.stderr)
        raise
    if args.help:
        print(HELP)
        raise SystemExit(0)
    if not args.testcase:
        print(HELP, file=sys.stderr)
        raise SystemExit(2)
    if args.mode not in VALID_MODES:
        raise ValueError(f"invalid mode: {args.mode}")
    if args.want == "auto":
        args.want = ""
    if args.args and args.args[0] == "--":
        args.args.pop(0)
    return args


def path_under(root: Path, path: Path) -> bool:
    try:
        return os.path.commonpath((root.resolve(), path.resolve())) == str(root.resolve())
    except ValueError:
        return False


def load_config(testcase: Path) -> target_config.Config:
    try:
        cfg = target_config.load(testcase)
    except (FileNotFoundError, ValueError):
        results = os.environ.get("RESULTS_DIR", "")
        target_root = os.environ.get("TARGET_ROOT", "")
        if not results or not target_root:
            raise RuntimeError(
                f"could not locate output/<slug>/<backend>/results/.session-env above {testcase}; "
                "run `bin/audit --target <slug>` first"
            )
        cfg = target_config.Config(
            results_dir=results,
            target_root=target_root,
            slug=os.environ.get("TARGET_SLUG", ""),
            target_rev=os.environ.get("TARGET_REV", ""),
            logdir=os.environ.get("LOGDIR", ""),
        )
        toml_path = Path(results).resolve().parent.parent / "target.toml"
        if toml_path.is_file():
            target_config.load_toml_into(cfg, toml_path)
        elif not cfg.sanitizers_enabled:
            cfg.sanitizers_enabled.append("asan")
    overrides = {
        "asan_bin": "TARGET_ASAN_BIN", "asan_lib": "TARGET_ASAN_LIB",
        "ubsan_bin": "TARGET_UBSAN_BIN", "ubsan_lib": "TARGET_UBSAN_LIB",
        "msan_bin": "TARGET_MSAN_BIN", "msan_lib": "TARGET_MSAN_LIB",
        "tsan_bin": "TARGET_TSAN_BIN", "tsan_lib": "TARGET_TSAN_LIB",
        "runner_bin": "TARGET_RUNNER_BIN",
    }
    for attribute, variable in overrides.items():
        if variable in os.environ:
            setattr(cfg, attribute, os.environ[variable])
    return cfg


def parse_header(testcase: Path) -> dict[str, str]:
    with testcase.open("rb") as stream:
        data = stream.read(16384)
    text = "".join(chr(byte) for byte in data if byte in (9, 10) or 32 <= byte <= 126)
    text = "\n".join(text.splitlines()[:16])
    result: dict[str, str] = {}
    for name, pattern in HEADER_RE.items():
        match = pattern.search(text)
        result[name] = match.group(1).strip() if match else ""
    return result


def derive_want(target: str) -> str:
    if ":" in target:
        without_line = target.rsplit(":", 1)[0]
        _, separator, function = without_line.partition(":")
        if separator and function:
            return re.escape(function)
    filename = Path(target.split(":", 1)[0]).name
    return re.escape(filename)


def feature_disabled_marker(path: Path) -> str:
    overlap = ""
    try:
        with path.open(encoding="utf-8", errors="replace") as stream:
            while chunk := stream.read(64 * 1024):
                text = overlap + chunk
                if match := build_routes.FEATURE_DISABLED_RE.search(text):
                    return match.group(0)
                overlap = text[-4096:]
    except OSError:
        pass
    return ""


def prepare_exec_testcase(testcase: Path, config: target_config.Config, agent: str) -> Path:
    extension = testcase.suffix.lstrip(".")
    if extension not in SCRIPT_EXTENSIONS:
        return testcase
    with testcase.open(errors="replace") as stream:
        header_lines = [stream.readline() for _ in range(16)]
    if not any(BARE_METADATA.match(line) for line in header_lines):
        return testcase
    digest_hash = hashlib.sha1()
    with testcase.open("rb") as stream:
        while chunk := stream.read(1024 * 1024):
            digest_hash.update(chunk)
    digest = digest_hash.hexdigest()
    destination_dir = Path(config.results_dir) / f"scratch-{agent}" / ".probe-exec"
    destination_dir.mkdir(parents=True, exist_ok=True)
    destination = destination_dir / f"{testcase.stem}.{digest}.exec.{extension}"
    with testcase.open(errors="replace") as source, destination.open("w") as output:
        for index, line in enumerate(source):
            if index == 0 and line.startswith("#!"):
                output.write(line)
            elif not BARE_METADATA.match(line):
                output.write(line)
    destination.chmod(testcase.stat().st_mode & 0o777)
    return destination


def resolve_executable(value: str, config: target_config.Config) -> str:
    return shutil.which(value) or (value if os.access(value, os.X_OK) else config.resolve_path(value))


def expand_runner(value: str, testcase: Path, sanitizer_name: str, config: target_config.Config) -> str:
    swift = {"asan": "address", "ubsan": "undefined", "tsan": "thread"}.get(sanitizer_name)
    if "{SWIFT_SANITIZER}" in value and swift is None:
        raise ValueError(f"Swift runner does not support sanitizer '{sanitizer_name}'")
    replacements = {
        "{TESTCASE}": str(testcase), "{SANITIZER}": sanitizer_name,
        "{SWIFT_SANITIZER}": swift or "", "{TARGET_ROOT}": config.target_root,
        "{RESULTS_DIR}": config.results_dir, "{TARGET_SLUG}": config.slug,
    }
    for token, replacement in replacements.items():
        value = value.replace(token, replacement)
    return value


def stat_key(path: str) -> str:
    try:
        stat = Path(path).stat()
        return f"{int(stat.st_mtime)}:{stat.st_size}"
    except OSError:
        return ""


class HarnessBuilder:
    def __init__(self, probe: "Probe", source: Path):
        self.probe = probe
        self.source = source
        self.dispatch = languages.probe_dispatch(source.suffix)
        if self.dispatch is None:
            raise ValueError(f"HARNESS source has unsupported extension: {source}")

    def build(self) -> tuple[str, list[str], str]:
        kind = self.dispatch["build_kind"]
        if kind == "interpret":
            override = os.environ.get(self.dispatch["interpreter_env"], "")
            binary = override or self.dispatch["interpreter_default"]
            return binary, [*self.dispatch["interpreter_preargs"], str(self.source)], kind
        compiler = os.environ.get(self.dispatch["compiler_env"], "") or self.dispatch["compiler_default"]
        flags = shlex.split(os.environ.get(self.dispatch["flags_env"], ""))
        cache = Path(self.probe.config.results_dir) / f"scratch-{self.probe.agent}" / ".harness-cache"
        cache.mkdir(parents=True, exist_ok=True)
        sanitizer_lib = self._sanitizer_lib() if kind == "cc" else ""
        identity = "\n".join((
            "schema=4", f"source={hashlib.sha1(self.source.read_bytes()).hexdigest()}",
            f"compiler={shutil.which(compiler) or compiler}", f"compiler_stat={stat_key(shutil.which(compiler) or compiler)}",
            f"kind={kind}", f"flags={flags}", f"sanitizer={self.probe.sanitizer}",
            f"library={sanitizer_lib}", f"library_stat={stat_key(sanitizer_lib)}",
            f"includes={self.probe.config.includes}", f"defines={self.probe.config.defines}",
            f"links={self.probe.config.link_libs}", f"ldflags={os.environ.get('LDFLAGS', '')}",
        ))
        digest = hashlib.sha1(identity.encode()).hexdigest()
        binary = cache / f"{self.source.name}.{digest}.bin"
        failed_log = cache / f"{self.source.name}.{digest}.build.log"
        lock = cache / f"{self.source.name}.{digest}.lock"
        if os.access(binary, os.X_OK):
            return str(binary), [], kind
        if failed_log.is_file() and failed_log.stat().st_size:
            self._show_failure(failed_log, cached=True)
        self._acquire(lock, binary, failed_log)
        try:
            if os.access(binary, os.X_OK):
                return str(binary), [], kind
            if failed_log.is_file() and failed_log.stat().st_size:
                self._show_failure(failed_log)
            command = self._command(kind, compiler, flags, binary, sanitizer_lib)
            completed = subprocess.run(command, capture_output=True, check=False)
            if completed.returncode:
                failed_log.write_bytes(completed.stderr + completed.stdout)
                binary.unlink(missing_ok=True)
                self._show_failure(failed_log)
            failed_log.unlink(missing_ok=True)
            print(f"[probe] built harness: {binary}")
            return str(binary), [], kind
        finally:
            (lock / "owner").unlink(missing_ok=True)
            try:
                lock.rmdir()
            except OSError:
                pass

    def _sanitizer_lib(self) -> str:
        raw = self.probe.config.sanitizer_lib(self.probe.sanitizer)
        library = self.probe.config.resolve_path(raw) if raw else ""
        if self.probe.sanitizer == "asan" and not library:
            raise ValueError("target.toml asan_lib missing")
        if library and not Path(library).is_file():
            if self.probe.sanitizer == "asan" or os.environ.get("PROBE_REQUIRE_SANITIZER_LIB") == "1":
                raise ValueError(f"target.toml {self.probe.sanitizer}_lib missing: {library}")
            print(
                f"[probe] WARN: target.toml {self.probe.sanitizer}_lib missing ({library}); "
                f"building with -fsanitize={COMPILE_SANITIZERS[self.probe.sanitizer]} only",
                file=sys.stderr,
            )
            return ""
        return library

    def _command(self, kind: str, compiler: str, flags: list[str], binary: Path, library: str) -> list[str]:
        if kind == "cc":
            sanitizer_flag = COMPILE_SANITIZERS.get(self.probe.sanitizer)
            if not sanitizer_flag:
                raise ValueError(f"compiled C/C++ HARNESS does not support sanitizer: {self.probe.sanitizer}")
            includes = [value for path in self.probe.config.includes for value in ("-I", self.probe.config.resolve_path(path))]
            library_args = [library] if library else []
            if library and Path(library).parent != Path("."):
                library_args.append(f"-Wl,-rpath,{Path(library).parent}")
            return [
                compiler, f"-fsanitize={sanitizer_flag}", "-g1", "-O0", *flags,
                *self.probe.config.defines, *includes, str(self.source), *library_args,
                *self.probe.config.link_libs, *shlex.split(os.environ.get("LDFLAGS", "")), "-o", str(binary),
            ]
        if kind == "rust":
            return [compiler, "-C", "debuginfo=1", "-C", "opt-level=0", *flags, "-o", str(binary), str(self.source)]
        if kind == "go":
            return [compiler, "build", "-o", str(binary), *flags, str(self.source)]
        if kind == "swift":
            return [compiler, "-gline-tables-only", "-O0", *flags, "-o", str(binary), str(self.source)]
        if kind == "kotlin":
            jar = Path(str(binary) + ".jar")
            command = [compiler, *flags, str(self.source), "-include-runtime", "-d", str(jar)]
            completed = subprocess.run(command, capture_output=True, check=False)
            if completed.returncode:
                raise subprocess.CalledProcessError(completed.returncode, command, completed.stdout, completed.stderr)
            binary.write_text(
                "#!/usr/bin/env python3\nimport os,sys\nos.execvp(" + repr(os.environ.get("JAVA", "java")) + ", [" + repr(os.environ.get("JAVA", "java")) + ", '-jar', " + repr(str(jar)) + ", *sys.argv[1:]])\n"
            )
            binary.chmod(0o755)
            return ["true"]
        raise ValueError(f"unknown build kind: {kind}")

    def _acquire(self, lock: Path, binary: Path, failed: Path) -> None:
        timeout = int(os.environ.get("PROBE_HARNESS_BUILD_LOCK_TIMEOUT", "600"))
        started = time.monotonic()
        while True:
            try:
                lock.mkdir()
                (lock / "owner").write_text(f"pid={os.getpid()}\nstarted={dt.datetime.now().astimezone().isoformat()}\n")
                return
            except FileExistsError:
                if failed.is_file() and failed.stat().st_size:
                    self._show_failure(failed, cached=True)
                if self._stale(lock):
                    stolen = lock.with_name(f"{lock.name}.stale.{os.getpid()}")
                    try:
                        lock.rename(stolen)
                        shutil.rmtree(stolen, ignore_errors=True)
                        print(f"[probe] reaped stale harness build lock: {lock}", file=sys.stderr)
                    except OSError:
                        pass
                if time.monotonic() - started >= timeout:
                    raise RuntimeError(f"timed out waiting for harness build lock: {lock}")
                time.sleep(0.05)

    def _stale(self, lock: Path) -> bool:
        owner = lock / "owner"
        if owner.is_file():
            match = re.search(r"^pid=([0-9]+)", owner.read_text(errors="ignore"), re.M)
            if match:
                try:
                    os.kill(int(match.group(1)), 0)
                    return False
                except ProcessLookupError:
                    return True
                except PermissionError:
                    return False
        grace = int(os.environ.get("PROBE_HARNESS_LOCK_STALE_MIN", "5")) * 60
        return grace <= 0 or time.time() - lock.stat().st_mtime > grace

    def _show_failure(self, path: Path, *, cached: bool = False) -> None:
        data = path.read_bytes()
        head = _nonnegative_int(os.environ.get("PROBE_BUILD_LOG_HEAD_BYTES", "8192"), 8192)
        tail = _nonnegative_int(os.environ.get("PROBE_BUILD_LOG_TAIL_BYTES", "8192"), 8192)
        prefix = "cached harness build failure" if cached else "harness build failed"
        print(f"[probe] {prefix}: {self.source}", file=sys.stderr)
        print(f"[probe] full compiler log: {path}", file=sys.stderr)
        if len(data) <= head + tail + 256:
            sys.stderr.buffer.write(data)
        else:
            sys.stderr.buffer.write(data[:head])
            print(f"\n[probe] compiler log elided {len(data) - head - tail} bytes; full log: {path}", file=sys.stderr)
            sys.stderr.buffer.write(data[-tail:])
        raise RuntimeError("harness build failed")


class Probe:
    def __init__(self, args: argparse.Namespace):
        self.args = args
        self.testcase = self._resolve_testcase(Path(args.testcase))
        self.config = load_config(self.testcase)
        self.testcase = self.testcase.resolve()
        self._validate_location()
        self.agent = self._agent_number()
        self.header = parse_header(self.testcase)
        self.mode = self._mode()
        self.output = self.testcase.with_suffix(".asan.txt") if self.testcase.suffix else Path(str(self.testcase) + ".asan.txt")
        self.exec_testcase = prepare_exec_testcase(self.testcase, self.config, self.agent)
        self.want = args.want or derive_want(self.header["target"])
        self.card = self.header["card"] or self._card_from_state()
        self.sanitizer = self._sanitizer()
        self.harness_source: Path | None = None
        self.build_kind = ""
        self.environment = self._environment()
        self.command = self._command()

    def _resolve_testcase(self, testcase: Path) -> Path:
        relative = str(testcase)[2:] if str(testcase).startswith("./") else str(testcase)
        if re.match(r"^scratch-[0-9]+/", relative) and os.environ.get("RESULTS_DIR"):
            result_path = Path(os.environ["RESULTS_DIR"]) / relative
            if Path(relative).is_file() and result_path.is_file() and Path(relative).resolve() != result_path.resolve():
                raise ValueError(f"ambiguous scratch path: cwd {relative} exists, but probe would use {result_path}")
            testcase = result_path
        if not testcase.is_file():
            raise ValueError(f"testcase not found: {testcase}")
        return testcase

    def _validate_location(self) -> None:
        if os.environ.get("PROBE_ALLOW_EXTERNAL_TESTCASE") == "1":
            return
        results = Path(self.config.results_dir).resolve()
        if not path_under(results, self.testcase):
            raise ValueError(f"testcase must live under RESULTS_DIR/scratch-N: {self.testcase}")
        relative = self.testcase.relative_to(results)
        if not relative.parts or not re.fullmatch(r"scratch-[0-9]+", relative.parts[0]):
            raise ValueError(f"testcase must live under RESULTS_DIR/scratch-N: {self.testcase}")

    def _agent_number(self) -> str:
        match = re.search(r"/scratch-([0-9]+)/", str(self.testcase))
        return match.group(1) if match else "1"

    def _mode(self) -> str:
        mode = self.args.mode
        if mode == "auto" and self.header["mode"]:
            mode = self.header["mode"]
        if mode == "auto":
            if self.testcase.suffix.lower() in {".html", ".htm", ".xhtml", ".svg"}:
                mode = "browser"
            elif self.testcase.suffix.lower() in {".js", ".mjs"}:
                mode = "js" if self.config.is_browser != "0" else "generic"
            else:
                mode = "generic"
        if mode not in VALID_MODES - {"auto"}:
            raise ValueError(f"invalid mode: {mode}")
        return mode

    def _card_from_state(self) -> str:
        hypothesis = self.header["hypothesis"]
        state = Path(self.config.results_dir) / "state/hypotheses.jsonl"
        if not hypothesis or not state.is_file():
            return ""
        card = ""
        for line in state.read_text(errors="replace").splitlines():
            try:
                row = json.loads(line)
            except json.JSONDecodeError:
                continue
            if row.get("id") == hypothesis:
                card = str(row.get("card_id", ""))
        return card

    def _sanitizer(self) -> str:
        selected = os.environ.get("PROBE_SANITIZER", "").lower()
        if not selected:
            selected = "runner" if self.config.sanitizers_explicitly_disabled else (self.config.sanitizers_enabled[0] if self.config.sanitizers_enabled else "asan")
        if selected not in VALID_SANITIZERS:
            raise ValueError(f"unsupported sanitizer: {selected}")
        if selected != "runner":
            if self.config.sanitizers_explicitly_disabled:
                raise ValueError("target.toml has [sanitizer].enabled = []; use PROBE_SANITIZER=runner or enable a sanitizer")
            if selected not in self.config.sanitizers_enabled and os.environ.get("PROBE_ALLOW_DISABLED_SANITIZER") != "1":
                raise ValueError(f"sanitizer '{selected}' is not enabled for this target; enabled sanitizers: {self.config.sanitizers_enabled_csv()}")
        if self.mode not in MODE_MATRIX[selected]:
            raise ValueError(f"sanitizer '{selected}' does not support mode '{self.mode}'")
        return selected

    def _environment(self) -> dict[str, str]:
        environment = dict(os.environ)
        environment.update({
            "RESULTS_DIR": self.config.results_dir, "TARGET_ROOT": self.config.target_root,
            "TARGET_SLUG": self.config.slug, "TARGET_REV": self.config.target_rev,
            "LOGDIR": self.config.logdir, "AUDIT_AGENT_NUM": self.agent,
            "TRIED_INPUTS_LOG": str(Path(self.config.results_dir) / f"tried-inputs-{self.agent}.log"),
            "HITS_LOG_PATH": str(Path(self.config.results_dir) / f"hits-{self.agent}.log"),
            "ASAN_OUTPUT_FILE": str(self.output), "PROBE_SANITIZER_SELECTED": self.sanitizer,
            "SANITIZER_RUNS": "5" if self.args.confirm else environment.get("SANITIZER_RUNS", "1"),
        })
        if self.header["hypothesis"]:
            environment["HYPOTHESIS_ID"] = self.header["hypothesis"]
        if self.header["target"]:
            environment["TARGET"] = self.header["target"]
        if self.want:
            environment["WANT"] = self.want
        if self.exec_testcase != self.testcase:
            environment["ASAN_RECORDED_TESTCASE"] = str(self.testcase)
        return environment

    def _command(self) -> list[str]:
        override = ""
        preargs: list[str] = []
        harness = self.header["harness"]
        if harness:
            raw = Path(harness)
            if os.environ.get("PROBE_ALLOW_EXTERNAL_HARNESS") != "1" and (raw.is_absolute() or ".." in raw.parts):
                raise ValueError(f"HARNESS must stay under the testcase directory: {harness}")
            source = (self.testcase.parent / raw).resolve()
            if not source.is_file():
                raise ValueError(f"HARNESS source not found: {source}")
            if os.environ.get("PROBE_ALLOW_EXTERNAL_HARNESS") != "1" and not path_under(self.testcase.parent, source):
                raise ValueError(f"HARNESS resolves outside testcase directory: {harness}")
            self.harness_source = source
            override, preargs, self.build_kind = HarnessBuilder(self, source).build()
            self.mode = "generic"
        elif self.mode == "generic" and self.exec_testcase.suffix.lower() in {".ts", ".tsx"} and self._can_use_runner():
            if Path(self.config.runner_bin).name == "node":
                ts_node = Path(self.config.target_root) / "node_modules/.bin/ts-node"
                found = str(ts_node) if os.access(ts_node, os.X_OK) else shutil.which("ts-node") or ""
                if found:
                    override = found
                    preargs = ["--transpile-only", "--skip-project", "--compiler-options", '{"module":"CommonJS","moduleResolution":"node","target":"ES2022","ignoreDeprecations":"6.0"}']
        if self.mode == "js-diff":
            runner = BIN_DIR / ("run-asan" if self.sanitizer == "asan" else "run-ubsan")
            return [str(runner), "js-diff", str(self.exec_testcase), *self.args.args]
        if self.mode in {"browser", "js"}:
            return [str(BIN_DIR / "run-sanitizer-multi"), self.sanitizer, self.mode, str(self.exec_testcase), *self.args.args]

        uses_runner = False
        raw_bin = self.config.sanitizer_bin(self.sanitizer)
        if override:
            binary = override
        elif raw_bin:
            binary = self.config.resolve_path(raw_bin)
        elif self.config.runner_bin:
            binary = resolve_executable(self.config.runner_bin, self.config)
            uses_runner = True
        else:
            binary = ""
        env_name = f"{self.sanitizer.upper()}_GENERIC_BIN" if self.sanitizer in {"asan", "ubsan", "msan", "tsan"} else "ASAN_GENERIC_BIN"
        if binary:
            self.environment[env_name] = binary
        if self.sanitizer in {"runner", "race"}:
            self.environment["ASAN_GENERIC_DISABLE_OPTIONS"] = "1"
        generic_args: list[str] = []
        skip = False
        if not harness and not preargs and uses_runner and self.config.runner_args:
            generic_args = [expand_runner(value, self.exec_testcase, self.sanitizer, self.config) for value in self.config.runner_args]
            skip = any("{TESTCASE}" in value for value in self.config.runner_args)
            if not skip:
                generic_args.append(str(self.exec_testcase))
                skip = True
        elif preargs:
            generic_args = [*preargs, str(self.exec_testcase)]
            skip = True
        elif self.exec_testcase != self.testcase:
            generic_args = [str(self.exec_testcase)]
            skip = True
        self.environment["ASAN_GENERIC_SKIP_TESTCASE"] = "1" if skip else "0"
        self.environment["SANITIZER_GENERIC_SKIP_TESTCASE"] = "1" if skip else "0"
        return [
            str(BIN_DIR / "run-sanitizer-multi"), self.sanitizer, "generic",
            str(self.exec_testcase), *generic_args, *self.args.args,
        ]

    def _can_use_runner(self) -> bool:
        return bool(self.config.runner_bin and (self.sanitizer in {"runner", "race"} or not self.config.sanitizer_bin(self.sanitizer)))

    def dry_run(self) -> int:
        print(
            f"[probe] mode={self.mode} sanitizer={self.sanitizer} asan_output={self.output} "
            f"target={self.header['target']} hypothesis={self.header['hypothesis']} "
            f"want={self.want} card={self.card}"
        )
        if self.exec_testcase != self.testcase:
            print(f"[probe] exec_testcase={self.exec_testcase} original_testcase={self.testcase}")
        print(f"[probe] command: {shlex.join(self.command)}")
        return 0

    def execute(self) -> int:
        confirmation = " confirm=1" if self.args.confirm else ""
        print(f"[probe] mode={self.mode} testcase={self.testcase} asan_output={self.output}{confirmation}")
        if self.mode == "js-diff":
            with capture_command(
                self.command, merge_stderr=True, env=self.environment
            ) as completed:
                self.output.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(completed.stdout, self.output)
                with completed.stdout.open("rb") as source:
                    shutil.copyfileobj(source, sys.stdout.buffer, 1024 * 1024)
        else:
            completed = subprocess.run(self.command, env=self.environment, check=False)
        result = completed.returncode
        probe_verdict = self._classify(result)
        result, probe_verdict = self._auto_route(result, probe_verdict)
        self._cap_output()
        print(f"[probe] verdict={probe_verdict}")
        self._record_state(probe_verdict)
        self._file_crash(probe_verdict)
        return result

    def _classify(self, returncode: int) -> str:
        if self.output.is_file() and self.output.stat().st_size:
            if verdict_lib.file_has_crash(self.output, tuple(self.config.runner_crash_patterns)):
                return "CRASH"
            if file_contains(self.output, b"DIFFERENTIAL: outputs DIFFER"):
                return "DIFF"
            if verdict_lib.file_is_clean(self.output):
                return "CLEAN"
            return "NO_EXEC"
        return "CLEAN" if returncode == 0 else "NO_EXEC"

    def _auto_route(self, returncode: int, current: str) -> tuple[int, str]:
        binary = self.environment.get("ASAN_GENERIC_BIN", "")
        if os.environ.get("PROBE_AUTO_ROUTE", "1") == "0" or self.mode != "generic" or self.sanitizer != "asan" or current in {"CRASH", "DIFF"} or not binary or not self.output.is_file():
            return returncode, current
        feature = feature_disabled_marker(self.output)
        if not feature:
            return returncode, current
        keys = ([f"card:{self.card}"] if self.card else []) + ([f"file:{self.header['target'].split(':')[0]}"] if self.header["target"] else [])
        candidates: list[str] = []
        cached = build_routes.lookup_route(Path(self.config.results_dir), *keys) if keys else ""
        if cached:
            candidates.append(cached)
        candidates.extend(str(candidate.binary) for candidate in build_routes.enumerate_sibling_builds(Path(self.config.target_root), Path(binary)) if str(candidate.binary) != cached)
        for candidate in candidates:
            if not os.access(candidate, os.X_OK):
                continue
            environment = {**self.environment, "ASAN_GENERIC_BIN": candidate}
            with capture_command(
                self.command, merge_stderr=True, env=environment
            ) as completed:
                if feature_disabled_marker(completed.stdout):
                    continue
                shutil.copy2(completed.stdout, self.output)
                routed = self._classify(completed.returncode)
            print(f"[probe] ROUTED: feature='{feature}' canonical='{binary}' -> '{candidate}' verdict={routed}")
            for key in keys:
                build_routes.record_route(Path(self.config.results_dir), key=key, binary=candidate, feature=feature, canonical_binary=binary)
            return completed.returncode, routed
        print(f"[probe] ROUTE_MISS: feature='{feature}' canonical='{binary}' - no sibling build exercised this feature")
        return returncode, current

    def _cap_output(self) -> None:
        if not self.output.is_file() or not self.output.stat().st_size:
            return
        maximum = _nonnegative_int(os.environ.get("PROBE_ASAN_OUTPUT_MAX_BYTES", "8388608"), 8388608)
        head = _nonnegative_int(os.environ.get("PROBE_ASAN_OUTPUT_HEAD_BYTES", "262144"), 262144)
        tail = _nonnegative_int(os.environ.get("PROBE_ASAN_OUTPUT_TAIL_BYTES", "262144"), 262144)
        size = self.output.stat().st_size
        if maximum and size > maximum:
            marker = (
                f"[probe] ASAN_OUTPUT_FILE truncated for storage after verdict classification: original_size_bytes={size} max_bytes={maximum}\n"
                f"[probe] showing first {head} byte(s) and last {tail} byte(s); rerun with PROBE_ASAN_OUTPUT_MAX_BYTES=0 to preserve full output.\n"
            ).encode()
            fd, temporary_name = tempfile.mkstemp(
                prefix=f".{self.output.name}.", dir=self.output.parent
            )
            try:
                with os.fdopen(fd, "wb") as target, self.output.open("rb") as source:
                    target.write(marker)
                    target.write(source.read(head))
                    target.write(b"\n[probe] ... middle omitted from oversized ASan output ...\n")
                    source.seek(max(0, size - tail))
                    shutil.copyfileobj(source, target, 1024 * 1024)
                os.replace(temporary_name, self.output)
            except BaseException:
                Path(temporary_name).unlink(missing_ok=True)
                raise

    def _state_command(self, *args: str) -> None:
        state = BIN_DIR / "state"
        if not os.access(state, os.X_OK):
            return
        subprocess.run([
            str(state), "--results-dir", self.config.results_dir, "--target-path", self.config.target_root,
            "--target-slug", self.config.slug, *args,
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)

    def _record_state(self, probe_verdict: str) -> None:
        hypothesis = self.header["hypothesis"]
        if not hypothesis:
            return
        self._state_command(
            "add-run", "--agent", self.agent, "--hypothesis-id", hypothesis, "--card-id", self.card,
            "--mode", self.mode, "--testcase", str(self.testcase),
            "--testcase-sha1", hashlib.sha1(self.testcase.read_bytes()).hexdigest(),
            "--asan-output", str(self.output), "--verdict", probe_verdict,
            "--sanitizer-runs", self.environment["SANITIZER_RUNS"],
        )
        if probe_verdict == "CRASH" and self.sanitizer != "runner":
            self._state_command("update-hyp", "--id", hypothesis, "--status", "CRASH", "--note", "bin/probe observed sanitizer diagnostic")
            if self.card:
                self._state_command("update-card", "--card-id", self.card, "--status", "crash")
        elif probe_verdict == "CRASH":
            self._state_command(
                "add-note", "--agent", self.agent, "--hypothesis-id", hypothesis,
                "--card-id", self.card, "--kind", "decision",
                "--text", "bin/probe observed runner diagnostic in findings-only mode; keep hypothesis/card active until a FIND report or explicit discard closes it",
            )

    def _file_crash(self, probe_verdict: str) -> None:
        runs = int(self.environment["SANITIZER_RUNS"])
        if not crash_bundle.should_file(probe_verdict, self.sanitizer, runs):
            return
        if self.harness_source and self.build_kind == "interpret":
            print(f"[probe] WARNING: crash confirmed but auto-file skipped for interpreted HARNESS. File it under {self.config.results_dir}/crashes/.", file=sys.stderr)
            return
        strategy_path = Path(self.config.results_dir) / "state" / f"strategy-{self.agent}"
        strategy = strategy_path.read_text().strip().upper() if strategy_path.is_file() else ""
        if not re.fullmatch(r"S[1-8]|REF", strategy):
            strategy = ""
        try:
            status, crash_id = crash_bundle.materialize(
                self.config.results_dir, self.agent, self.testcase, self.output,
                self.sanitizer, self.mode, harness=self.harness_source, args=self.args.args,
                target=self.header["target"], hypothesis=self.header["hypothesis"],
                card=self.card, strategy=strategy,
            )
        except OSError as exc:
            print(f"[probe] WARNING: crash confirmed but bundle could not be created: {exc}", file=sys.stderr)
            return
        if status == "FILED":
            print(f"[probe] CRASH FILED: {self.config.results_dir}/crashes/{crash_id} - reproducer + sanitizer.txt copied in; enrich report.md there")
            if self.header["hypothesis"]:
                self._state_command(
                    "add-note", "--agent", self.agent,
                    "--hypothesis-id", self.header["hypothesis"],
                    "--card-id", self.card, "--kind", "decision",
                    "--text", f"bin/probe filed {crash_id} at crashes/{crash_id}",
                )
        else:
            print(f"[probe] CRASH already filed (identical reproducer): {self.config.results_dir}/crashes/{crash_id}")


def main(argv: Sequence[str] | None = None) -> int:
    try:
        args = parse_args(sys.argv[1:] if argv is None else argv)
        probe = Probe(args)
        return probe.dry_run() if args.dry_run else probe.execute()
    except (ValueError, RuntimeError, OSError, subprocess.CalledProcessError) as exc:
        print(f"[probe] {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
