#!/bin/bash
# ASan multi-run wrapper — default is 5 runs, ASAN_RUNS overrides.
# Runs run-asan repeatedly and aggregates crash results.
# Timing-dependent bugs (UAFs, races) may not crash on every run.
# Usage: bin/run-asan-multi <mode> <testcase> [extra args...]
# Output: per-run results + summary line "CRASH_RATE: <crashes>/<RUNS>"
#
# All output is also appended to $ASAN_OUTPUT_FILE if set (for agents
# piping to their scratch dir).

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RUNS="${ASAN_RUNS:-5}"

if [ -r "$SCRIPT_DIR/../lib/platform.sh" ]; then
  # shellcheck source=../lib/platform.sh
  source "$SCRIPT_DIR/../lib/platform.sh"
else
  audit_sha1() {
    if command -v shasum >/dev/null 2>&1; then
      shasum -a 1 "$@"
    elif command -v sha1sum >/dev/null 2>&1; then
      sha1sum "$@"
    else
      cksum "$@"
    fi
  }
fi

# Optional: shared head+tail+spill cap for crash output that runs to hundreds
# of KB (stack-overflow with thousands of repeated frames; UBSan cascades).
# When sourced, _digest_asan routes crash-path output through the helper if
# size exceeds the threshold. Soft dep: legacy "no truncation on crash"
# behavior kicks in if the lib is absent.
if [ -r "$SCRIPT_DIR/../lib/output_cap.sh" ]; then
  # shellcheck source=../lib/output_cap.sh
  . "$SCRIPT_DIR/../lib/output_cap.sh"
fi

# bin/probe sets ASAN_OUTPUT_FILE to <testcase>.asan.txt and is the normal
# entry point. If callers invoke run-asan-multi directly without it, derive
# the same default from the testcase argument so the artifact still lands
# in a predictable place. ASAN_OUTPUT_FILE_OPTIONAL=1 disables file output
# entirely (smoke tests, preflight).
if [ -z "${ASAN_OUTPUT_FILE:-}" ] && [ -z "${ASAN_OUTPUT_FILE_OPTIONAL:-}" ]; then
    _tc="${2:-}"
    if [ -n "$_tc" ]; then
        ASAN_OUTPUT_FILE="${_tc%.*}.asan.txt"
    else
        echo "[run-asan-multi] ERROR: cannot derive ASAN_OUTPUT_FILE — pass a testcase or use bin/probe." >&2
        exit 2
    fi
fi
OUTPUT_FILE="${ASAN_OUTPUT_FILE:-}"

# Seed the output file with a deterministic header the audit harness
# can grep to count VERIFIED runs (see count_verified_asan_runs in
# bin/audit). This protects against agents creating empty
# .asan.txt files as shortcut credits.
if [ -n "$OUTPUT_FILE" ]; then
    mkdir -p "$(dirname "$OUTPUT_FILE")" 2>/dev/null || true
    _asan_env_options_b64=""
    if [ -n "${ASAN_OPTIONS:-}" ]; then
        _asan_env_options_b64="$(
            python3 - "${ASAN_OPTIONS}" <<'PY'
import base64
import sys
print(base64.b64encode(sys.argv[1].encode()).decode())
PY
        )"
    fi
    {
        echo "ASAN_RUN_HEADER: sanitizer=asan runs=$RUNS mode=${1:-?} testcase=${ASAN_RECORDED_TESTCASE:-${2:-?}} env_options_b64=$_asan_env_options_b64 started=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    } > "$OUTPUT_FILE"
fi

# ── Auto coverage-gate: if WANT is set and bin/hits exists, run a cheap
# coverage check BEFORE spending ASan budget. Only a real MISSED verdict
# skips ASan. Coverage build/tool/execution failures continue ungated so
# a broken coverage build cannot suppress a sanitizer diagnostic.
# Set SKIP_COVERAGE_GATE=1 to bypass (used by enforce_asan_for_orphans).
coverage_mode="${1:-browser}"
if [ -n "${WANT:-}" ] && [ -z "${SKIP_COVERAGE_GATE:-}" ] && [ -x "$SCRIPT_DIR/hits" ] \
   && { [ "$coverage_mode" = "browser" ] || [ "$coverage_mode" = "js" ]; }; then
  coverage_testcase="${2:-}"
  coverage_timeout="${HITS_TIMEOUT:-${COV_TIMEOUT:-20}}"
  if [ -n "$coverage_testcase" ] && [ -f "$coverage_testcase" ]; then
    coverage_args=(--testcase "$coverage_testcase" --want "$WANT" --mode "$coverage_mode" --timeout "$coverage_timeout")
    [ -n "${HITS_LOG_PATH:-}" ] && coverage_args+=(--log "$HITS_LOG_PATH")
    coverage_output="$(mktemp "${TMPDIR:-/tmp}/asan5x-cov-XXXXXXXX")"
    "$SCRIPT_DIR/hits" "${coverage_args[@]}" > "$coverage_output" 2>&1
    cov_rc=$?
    if [ "$cov_rc" -ne 0 ]; then
      cat "$coverage_output"
      if [ "$cov_rc" -eq 1 ]; then
        # MISSED — print the closest frame and skip ASan entirely.
        _closest="$(grep -m1 '^MISSED' "$coverage_output" | sed 's/^MISSED — closest reached: //' | head -c 200)"
        [ -z "$_closest" ] && _closest="$(grep -m1 '^EXEC_FAIL\|^NO_COVERAGE' "$coverage_output" | head -c 200)"
        rm -f "$coverage_output"
        # Record the miss in tried-inputs
        if [ -n "${TRIED_INPUTS_LOG:-}" ] && [ -n "$coverage_testcase" ]; then
          mkdir -p "$(dirname "$TRIED_INPUTS_LOG")" 2>/dev/null || true
          _tc_hash="?"
          _tc_hash="$(audit_sha1 "$coverage_testcase" 2>/dev/null | awk '{print $1}')"
          printf '%s verdict=NO_HIT mode=%s testcase=%s hash=%s hypothesis=%s target=%s closest=%q\n' \
            "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$coverage_mode" "$coverage_testcase" \
            "${_tc_hash:0:12}" "${HYPOTHESIS_ID:-?}" "${TARGET:-?}" \
            "${_closest:-<none>}" \
            >> "$TRIED_INPUTS_LOG"
        fi
        if [ -n "$OUTPUT_FILE" ]; then
          echo "COVERAGE_GATE: MISSED — ASan skipped. Revise testcase (closest: ${_closest:-<none>})" >> "$OUTPUT_FILE"
        fi
        echo "[run-asan-multi] COVERAGE GATE: MISSED — ASan skipped. Revise testcase (closest: ${_closest:-<none>})"
        exit 1
      fi

      cov_label="COVERAGE_ENV_FAIL"
      [ "$cov_rc" -eq 3 ] && cov_label="COVERAGE_EXEC_FAIL"
      _closest="$(grep -m1 '^EXEC_FAIL\|^NO_COVERAGE' "$coverage_output" | head -c 200)"
      [ -z "$_closest" ] && _closest="hits exited $cov_rc"
      export HITS_VERDICT="$cov_label"
      if [ -n "$OUTPUT_FILE" ]; then
        echo "COVERAGE_GATE: ${cov_label} — ASan proceeding ungated (hits rc=${cov_rc}; ${_closest})" >> "$OUTPUT_FILE"
      fi
      echo "[run-asan-multi] COVERAGE GATE: ${cov_label} — proceeding to ASan ungated (hits rc=${cov_rc}; ${_closest})"
      rm -f "$coverage_output"
    fi
    if [ "$cov_rc" -eq 0 ]; then
      # HIT — print verdict and continue to ASan runs below
      cat "$coverage_output"
      export CLOSEST_FRAME="$(grep -m1 '^HIT:' "$coverage_output" | sed 's/^HIT: //' | head -c 200)"
      export HITS_VERDICT="HIT"
      rm -f "$coverage_output"
      echo "[run-asan-multi] COVERAGE GATE: HIT — proceeding to ASan"
    fi
  fi
fi

# Validate: mode is required, testcase file should exist when provided.
if [ $# -lt 1 ]; then
  echo "[run-asan-multi] ERROR: mode argument required." >&2
  echo "  Usage: bin/run-asan-multi <mode> <testcase> [extra args...]" >&2
  exit 2
fi
if [ $# -ge 2 ] && [ ! -f "${2}" ]; then
  echo "[run-asan-multi] ERROR: testcase not found: ${2}" >&2
  exit 2
fi

crashes=0
executions=0
diff_divergences=0

# Tee to output file if requested
_out() {
  if [ -n "$OUTPUT_FILE" ]; then
    echo "$@" | tee -a "$OUTPUT_FILE"
  else
    echo "$@"
  fi
}

# Emit one address-stable signature line per top interesting frame for $1's
# ASan output. Empty stdout + exit 0 = no parseable crash (clean run or
# non-ASan failure). Non-zero exit = python3 itself failed (broken module,
# unreadable file, etc.) — caller MUST treat that as "unknown" and fall
# back to full digest, NOT as "matches run 1". Stable across runs because
# addresses, alloc tags, and thread ids are stripped — see
# lib/stack_frames.py crash_signature().
_run_signature() {
  python3 "$_STACK_FRAMES_PY" --signature "$1" 2>/dev/null
}

# Resolve the helper once; fall back to full-digest behavior on every run if
# python3 isn't reachable or the module file is missing (e.g. test harness
# that copies bin/run-asan-multi into an isolated mock dir without lib/).
_STACK_FRAMES_PY="$SCRIPT_DIR/../lib/stack_frames.py"
_can_dedupe=0
if command -v python3 >/dev/null 2>&1 && [ -f "$_STACK_FRAMES_PY" ]; then
  _can_dedupe=1
fi

# Track signature of run 1 so we can short-circuit duplicate output for
# matching reruns. Empty signature with `_run1_sig_ok=1` is a meaningful
# "no crash" answer; `_run1_sig_ok=0` means we never got a clean reading
# (parse error / missing python) — comparison must NOT match in that case.
# `_seen_run1` distinguishes "not yet captured" from "captured empty".
_run1_sig=""
_run1_sig_ok=0
_run1_crashed=0
_seen_run1=0

# Filter known-noise lines out of stdout while leaving $OUTPUT_FILE byte-identical.
# Filtered patterns are universally diagnostic-only in the Firefox-headless ASan
# build: framebuffer warnings on every clean run, the shadow-bytes hex block on
# every crash. On clean runs whose total exceeds head+tail, keep first
# ASAN_DIGEST_HEAD + last ASAN_DIGEST_TAIL lines and elide the middle, pointing
# at OUTPUT_FILE for the full trace. Crash runs are never truncated. Set
# ASAN_NO_DIGEST=1 to disable both filtering and truncation. Set
# ASAN_DIGEST_HEAD=0 or ASAN_DIGEST_TAIL=0 to disable truncation only.
_digest_asan() {
  local f="$1"
  if [ -n "${ASAN_NO_DIGEST:-}" ]; then cat "$f"; return; fi

  local digest_head="${ASAN_DIGEST_HEAD:-80}"
  local digest_tail="${ASAN_DIGEST_TAIL:-120}"

  # Single-pass noise filter (drops headless/framebuffer chatter, elides shadow
  # bytes block on crashes). Same awk used for both crash and clean paths.
  local filtered_tmp
  filtered_tmp=$(mktemp "${TMPDIR:-/tmp}/asan-digest-XXXXXXXX")
  # The skip flag elides the shadow-bytes block. Under halt_on_error=0
  # (ASAN_OPTS_FUZZ), one run can emit multiple ASan reports — without the
  # explicit reset on the next ==N==ERROR header, skip stays latched after
  # the first shadow block and the second crash's ERROR/stack/SUMMARY are
  # silently consumed by `skip { next }` until the final ABORTING.
  awk -v outfile="${OUTPUT_FILE:-}" '
    /^\*\*\* You are running in headless mode\./ { next }
    /^Crash Annotation GraphicsCriticalError:.*RenderCompositorSWGL failed mapping default framebuffer/ { next }
    /^==[0-9]+==ERROR:/ { skip = 0 }
    /^Shadow bytes around the buggy address:/ {
      msg = "[Shadow bytes block elided"
      if (outfile != "") msg = msg " — see " outfile
      print msg "]"
      skip = 1
      next
    }
    skip && /^==[0-9]+==ABORTING/ { skip = 0; print; next }
    skip { next }
    { print }
  ' "$f" > "$filtered_tmp"

  # Crash detection runs against the raw input (not the filtered tmp) so a
  # marker that the awk filter ever drops still gates the truncation path.
  # This is deliberately NOT lib/verdict.sh's classifier: this regex gates
  # output digest-truncation, not the audit verdict, so it is tuned for
  # that job — it adds ^==NN==ABORTING and a bare "runtime error:" (an
  # aborted/UBSan run should not be truncated) and omits the language-
  # runtime fatals verdict.sh carries. Keep the two independent.
  local has_crash=0
  if grep -qE 'ERROR: AddressSanitizer|AddressSanitizer:DEADLYSIGNAL|CRASH DETECTED|Hit MOZ_CRASH\(|^==[0-9]+==ABORTING|runtime error:' "$f" 2>/dev/null; then
    has_crash=1
  fi

  # Crash path: historically passed through verbatim ("crash runs are never
  # truncated"). That meant a stack-overflow with ~10K identical frames
  # could emit 200+ KB, which then poisoned every later turn's cached
  # transcript. Route through cap_output_file when (a) the helper is loaded
  # and (b) the filtered output is past OUTCAP_MAX_BYTES. The helper keeps
  # the ERROR header + first ~150 frames + SUMMARY + ABORTING (head 24 KB,
  # tail 20 KB), spills the full text to disk, and leaves $OUTPUT_FILE
  # untouched — the full trace is always recoverable from the .asan.txt
  # file plus the spill.
  if [ "$has_crash" -eq 1 ] || [ "$digest_head" -le 0 ] || [ "$digest_tail" -le 0 ]; then
    if [ "$has_crash" -eq 1 ] \
       && declare -F cap_output_file >/dev/null 2>&1 \
       && [ "${OUTCAP_MAX_BYTES:-51200}" -gt 0 ]; then
      local _filtered_bytes
      _filtered_bytes=$(wc -c < "$filtered_tmp" 2>/dev/null | tr -d ' ')
      _filtered_bytes=${_filtered_bytes:-0}
      if [ "$_filtered_bytes" -gt "${OUTCAP_MAX_BYTES:-51200}" ]; then
        cap_output_file "$filtered_tmp" asan-crash
        rm -f "$filtered_tmp"
        return
      fi
    fi
    cat "$filtered_tmp"
    rm -f "$filtered_tmp"
    return
  fi

  local total
  total=$(wc -l < "$filtered_tmp" 2>/dev/null | tr -d ' ')
  total=${total:-0}
  if [ "$total" -le $((digest_head + digest_tail)) ]; then
    cat "$filtered_tmp"
    rm -f "$filtered_tmp"
    return
  fi

  local elided=$((total - digest_head - digest_tail))
  head -n "$digest_head" "$filtered_tmp"
  if [ -n "${OUTPUT_FILE:-}" ]; then
    printf '[run-asan-multi] DIGEST: clean run, %d middle line(s) elided (showing first %d + last %d) — full output in %s. Override: ASAN_DIGEST_HEAD/ASAN_DIGEST_TAIL or ASAN_NO_DIGEST=1.\n' \
      "$elided" "$digest_head" "$digest_tail" "$OUTPUT_FILE"
  else
    printf '[run-asan-multi] DIGEST: clean run, %d middle line(s) elided (showing first %d + last %d). Override: ASAN_DIGEST_HEAD/ASAN_DIGEST_TAIL or ASAN_NO_DIGEST=1.\n' \
      "$elided" "$digest_head" "$digest_tail"
  fi
  tail -n "$digest_tail" "$filtered_tmp"
  rm -f "$filtered_tmp"
}

# Budget accounting — when the audit harness sets ASAN_RUN_COUNTER_FILE and
# ASAN_RUN_BUDGET, increment a per-iteration run counter (each invocation
# = one logical "exploration block," regardless of RUNS). Print a budget
# line the agent can see so it can self-throttle. Enforcement is soft:
# we do NOT refuse to run when over budget — the signal is enough; hard
# blocking would corrupt in-flight testcases.
if [ -n "${ASAN_RUN_COUNTER_FILE:-}" ]; then
  mkdir -p "$(dirname "$ASAN_RUN_COUNTER_FILE")" 2>/dev/null || true
  prev_budget=0
  if [ -f "$ASAN_RUN_COUNTER_FILE" ]; then
    prev_budget=$(cat "$ASAN_RUN_COUNTER_FILE" 2>/dev/null || echo 0)
    prev_budget=${prev_budget//[^0-9]/}
    : "${prev_budget:=0}"
  fi
  cur_budget=$((prev_budget + 1))
  printf '%s' "$cur_budget" > "$ASAN_RUN_COUNTER_FILE"
  if [ -n "${ASAN_RUN_BUDGET:-}" ] && [ "$ASAN_RUN_BUDGET" -gt 0 ] 2>/dev/null; then
    _out "[run-asan-multi] BUDGET: ${cur_budget}/${ASAN_RUN_BUDGET} ASan invocations used this iteration"
    if [ "$cur_budget" -gt "$ASAN_RUN_BUDGET" ]; then
      _out "[run-asan-multi] BUDGET: EXCEEDED — stop opening new hypotheses; wrap up the current one and exit"
    fi
  else
    _out "[run-asan-multi] BUDGET: ${cur_budget} ASan invocation(s) this iteration"
  fi
fi

for i in $(seq 1 "$RUNS"); do
  _out "=== Run $i/$RUNS ==="
  run_tmp="$(mktemp "${TMPDIR:-/tmp}/asan-5x-run-XXXXXXXX")"
  "$SCRIPT_DIR/run-asan" "$@" >"$run_tmp" 2>&1 || true

  if [ -n "$OUTPUT_FILE" ]; then
    cat "$run_tmp" >> "$OUTPUT_FILE"
  fi

  # Check for crash. Browser mode emits an explicit marker, but xpcshell
  # currently only emits the raw ASan report, so count either form.
  this_crashed=0
  if grep -q "CRASH DETECTED" "$run_tmp" || grep -qE 'ERROR: AddressSanitizer|Hit MOZ_CRASH\(' "$run_tmp"; then
    crashes=$((crashes + 1))
    this_crashed=1
  fi
  # Check for wrapper-issued post-run execution evidence. Do not trust raw
  # TESTCASE_EXECUTED from testcase stdout; it can be printed before an early
  # non-ASan failure and would poison CLEAN accounting.
  if grep -Eq '^\[run-asan\] (browser|js|xpcshell|generic) EXECUTION VERIFIED \(post-run' "$run_tmp"; then
    executions=$((executions + 1))
  fi

  # Compute address-stable crash signature so reruns can be summarized
  # against run 1 instead of re-emitting full ~50 KB stacks. ASan output
  # is ~50 KB per crash run, so 5× would otherwise put 200–300 KB into the
  # agent's transcript on every `--confirm`. The dedup only fires when
  # (a) we got a clean signature reading from BOTH this run and run 1,
  # (b) crash status matches run 1, AND (c) the top-3 interesting frames
  # match. Divergent reruns still get a full digest because they actually
  # carry new information.
  #
  # If python3 itself fails (broken stack_frames.py, missing python),
  # `this_sig_ok=0` and we fail-closed by emitting the full digest — never
  # treat a parsing failure as "matches run 1", because that would silently
  # hide real divergence behind a misleading VERIFIED line on stdout while
  # the raw $OUTPUT_FILE truth remains hidden from the agent's transcript.
  #
  # Set ASAN_NO_DIGEST=1 to disable. _can_dedupe=0 (python3 unavailable or
  # lib/stack_frames.py missing — e.g. isolated test harnesses) also keeps
  # the original full-digest-every-run behavior.
  this_sig=""
  this_sig_ok=0
  if [ "$_can_dedupe" -eq 1 ]; then
    if this_sig=$(_run_signature "$run_tmp"); then
      this_sig_ok=1
    fi
  fi

  if [ "$_seen_run1" -eq 0 ]; then
    # Run 1: full digest, capture baseline.
    _digest_asan "$run_tmp"
    _run1_sig="$this_sig"
    _run1_sig_ok="$this_sig_ok"
    _run1_crashed="$this_crashed"
    _seen_run1=1
  elif [ "$_can_dedupe" -eq 0 ] || [ -n "${ASAN_NO_DIGEST:-}" ]; then
    # Dedup unavailable or user opted out — emit unconditionally.
    _digest_asan "$run_tmp"
  elif [ "$this_sig_ok" -eq 0 ] || [ "$_run1_sig_ok" -eq 0 ]; then
    # Either run had a parsing failure — fail closed with full digest.
    _digest_asan "$run_tmp"
  elif [ "$this_crashed" = "$_run1_crashed" ] && [ "$this_sig" = "$_run1_sig" ]; then
    # Matches run 1 — short summary instead of dumping the full stack again.
    if [ "$this_crashed" = "1" ]; then
      # Show the first stable frame so the agent can eyeball the match.
      _first_frame=$(printf '%s\n' "$_run1_sig" | head -n 1)
      _out "[run-asan-multi] Run ${i}/${RUNS}: VERIFIED — same crash signature as run 1 (${_first_frame})"
    else
      _out "[run-asan-multi] Run ${i}/${RUNS}: VERIFIED — clean (matches run 1)"
    fi
  else
    # Divergent — full digest. The divergence itself is information
    # (timing-dependent UAF, intermittent OOB, JIT correctness flake, …).
    if [ "$this_crashed" = "1" ] && [ "$_run1_crashed" = "0" ]; then
      _out "[run-asan-multi] Run ${i}/${RUNS}: DIVERGED — crashed where run 1 was clean"
    elif [ "$this_crashed" = "0" ] && [ "$_run1_crashed" = "1" ]; then
      _out "[run-asan-multi] Run ${i}/${RUNS}: DIVERGED — clean where run 1 crashed"
    else
      _out "[run-asan-multi] Run ${i}/${RUNS}: DIVERGED — different crash signature than run 1"
    fi
    _digest_asan "$run_tmp"
  fi

  rm -f "$run_tmp"
  _out ""
done

_out "=== SUMMARY ==="
_out "CRASH_RATE: ${crashes}/${RUNS}"
_out "[run-asan-multi] EXECUTION_RATE: ${executions}/${RUNS}"

# ── Auto-differential testing (Strategy S4 baked in) ──────────────
# For js and xpcshell modes, automatically run a differential check
# (--ion-eager vs --no-ion) on every testcase. This catches JIT value
# corruption that ASan cannot see. Costs ~2 extra js shell invocations
# (~1s each) — negligible compared to the ASan run itself.
diff_mode="${1:-}"
diff_testcase="${2:-}"
if [ "$diff_mode" = "js" -o "$diff_mode" = "xpcshell" ] \
   && [ -n "$diff_testcase" ] && [ -f "$diff_testcase" ] \
   && [ "$crashes" -eq 0 ] \
   && [ "$executions" -gt 0 ]; then
  _out ""
  _out "=== AUTO-DIFFERENTIAL (--ion-eager vs --no-ion) ==="
  _diff_tmp="$(mktemp "${TMPDIR:-/tmp}/asan-5x-diff-XXXXXXXX")"
  "$SCRIPT_DIR/run-asan" js-diff "$diff_testcase" >"$_diff_tmp" 2>&1 || true
  # Check for divergence
  if grep -q "outputs DIFFER" "$_diff_tmp" 2>/dev/null; then
    _out "[run-asan-multi] AUTO-DIFF: DIVERGENCE DETECTED — potential JIT correctness issue"
    [ -n "$OUTPUT_FILE" ] && cat "$_diff_tmp" >> "$OUTPUT_FILE"
    _digest_asan "$_diff_tmp"
    diff_divergences=$((diff_divergences + 1))
  elif grep -q "ERROR: AddressSanitizer" "$_diff_tmp" 2>/dev/null; then
    _out "[run-asan-multi] AUTO-DIFF: ASan crash in differential mode!"
    [ -n "$OUTPUT_FILE" ] && cat "$_diff_tmp" >> "$OUTPUT_FILE"
    _digest_asan "$_diff_tmp"
    crashes=$((crashes + 1))
  else
    _out "[run-asan-multi] AUTO-DIFF: outputs match (no JIT divergence)"
  fi
  rm -f "$_diff_tmp"
fi

# Append-only memory of every testcase this agent has run. Keyed on
# (testcase, mode) so the agent can check `grep -F <tc>` before
# rewriting a variant it already tried and got the same verdict. Log
# survives context compression. Caller sets TRIED_INPUTS_LOG to the
# per-agent path; bin/audit provides it in agent env.
if [ -n "${TRIED_INPUTS_LOG:-}" ]; then
  mkdir -p "$(dirname "$TRIED_INPUTS_LOG")" 2>/dev/null || true
  verdict="CLEAN"
  [ "$crashes" -gt 0 ] && verdict="CRASH"
  [ "$crashes" -eq 0 ] && [ "$diff_divergences" -gt 0 ] && verdict="DIFF"
  [ "$crashes" -eq 0 ] && [ "$executions" -eq 0 ] && verdict="NO_EXEC"
  # Hash the testcase bytes so the agent can tell a literal rerun apart
  # from a textual variant even if the path is the same.
  tc_hash="?"
  if [ -f "${2:-/dev/null}" ]; then
    tc_hash="$(audit_sha1 "$2" 2>/dev/null | awk '{print $1}')"
  fi
  # Extra fields (hypothesis/target/closest_frame) let post-compression
  # log reads decide without reopening the testcase.
  printf '%s verdict=%s mode=%s testcase=%s hash=%s runs=%d crashes=%d execs=%d hypothesis=%s target=%q closest=%q hits_verdict=%s\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$verdict" "${1:-?}" "${2:-?}" \
    "${tc_hash:0:12}" "$RUNS" "$crashes" "$executions" \
    "${HYPOTHESIS_ID:-?}" "${TARGET:-?}" "${CLOSEST_FRAME:-<none>}" \
    "${HITS_VERDICT:-?}" \
    >> "$TRIED_INPUTS_LOG"
fi

if [ "$crashes" -gt 0 ]; then
  _out "[run-asan-multi] CRASHES FOUND: ${crashes}/${RUNS} runs crashed"
  exit 1
elif [ "$diff_divergences" -gt 0 ]; then
  _out "[run-asan-multi] DIFFERENTIAL FINDING: ${diff_divergences} divergent js-diff check(s)"
  exit 1
elif [ "$executions" -eq 0 ]; then
  _out "[run-asan-multi] WARNING: testcase may not have executed in any run"
  exit 2
else
  _out "[run-asan-multi] NO CRASHES in ${RUNS} runs (${executions} executed successfully)"
fi
