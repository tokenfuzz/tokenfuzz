#!/usr/bin/env python3
"""Run ripgrep with audit-log exclusions and bounded stdout."""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))
from file_tools import cap_output_bytes
from command_tools import find_executable


def error(message: str) -> int:
    print(f"[rg-safe] {message}", file=sys.stderr)
    return 2


def real_rg() -> str | None:
    wrapper = Path(
        os.environ.get("AGENT_WRAPPERS_PATH", str(ROOT / "lib" / "wrappers"))
    ).resolve()
    return find_executable("rg", skip=(wrapper,))


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    byte_value = os.environ.get("RG_BYTES")
    include_logs = os.environ.get("RG_INCLUDE_LOGS", "0") == "1"
    passthrough: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg in ("--no-cap", "--no-cap-bytes"):
            byte_value = "0"
        elif arg == "--cap-bytes":
            if index + 1 >= len(args):
                return error("--cap-bytes needs a value")
            index += 1
            byte_value = args[index]
        elif arg.startswith("--cap-bytes="):
            byte_value = arg.split("=", 1)[1]
        elif arg == "--include-logs":
            include_logs = True
        elif arg == "--":
            passthrough.extend(args[index:])
            break
        else:
            passthrough.append(arg)
        index += 1

    if byte_value is not None and not byte_value.isdigit():
        return error(f"non-numeric --cap-bytes: {byte_value}")
    executable = real_rg()
    if not executable:
        return error("rg (ripgrep) not found in PATH")

    prefix = ["--glob", "!**/.git/**", "--glob", "!**/.hg/**"]
    if not include_logs:
        prefix.extend(("--glob", "!**/output/**/logs/**"))
    completed = subprocess.run([executable, *prefix, *passthrough], stdout=subprocess.PIPE)
    output = completed.stdout
    cap_env = None
    if byte_value is not None:
        byte_cap = int(byte_value)
        cap_env = dict(os.environ)
        cap_env["OUTCAP_MAX_BYTES"] = str(byte_cap)
        cap_env["OUTCAP_HEAD_BYTES"] = str(byte_cap * 3 // 5)
        cap_env["OUTCAP_TAIL_BYTES"] = str(byte_cap * 2 // 5)
    try:
        output = cap_output_bytes(output, "rg-safe", cap_env)
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 2
    sys.stdout.buffer.write(output)
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
