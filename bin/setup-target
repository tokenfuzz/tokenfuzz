#!/usr/bin/env bash
# Clone or update a target checkout under targets/<target>, then seed
# output/<target>/target.toml for the audit harness.
set -euo pipefail

SCRIPT_ROOT="${AUDIT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$SCRIPT_ROOT/lib/target_config.sh"

usage() {
  cat <<'EOF'
Usage:
  bin/setup-target <target> [repo URL] [options]

Options:
  --repo-type <auto|git|hg>
                           Source repo type (default: auto)
  --ref <ref>             Branch, tag, bookmark, or revision to check out
  --no-update             When a repo URL/ref is supplied, do not pull/fetch an existing checkout
  --force, --force-config
                           Regenerate output/<target>/target.toml and overwrite
                           LLM-suggested [threat_model] / [s6_peers] sections
  --bootstrap             Prepare the checkout for auditing. Runs whichever of these
                            apply to the detected build system:
                              * Language build (python: setup.py build_ext --inplace;
                                rust: cargo build; go: go build ./...; swift: swift
                                build; npm: npm install; php: composer install;
                                ruby: bundle install).
                              * Sanitizer build recipe convergence for C/C++ targets
                                (cmake / autotools / meson) — calls bin/auto-build-script
                                to discover a working ASan build and writes the validated
                                script to targets/<target>/.audit/build.sh. bin/export-repro
                                later inlines this script verbatim into each reproduce.sh
                                so maintainers get the same build the audit used.
                            Skips each step silently when its inputs are absent
                            (no manifest, no LLM backend, no recognised C/C++
                            build system, recipe already exists).
  --no-llm-config         Skip LLM-backed target.toml enrichment
  -h, --help              Show this help

Examples:
  bin/setup-target pcre2 https://github.com/PCRE2Project/pcre2
  bin/setup-target pcre2
  bin/setup-target firefox https://hg.mozilla.org/mozilla-unified --repo-type hg
  bin/setup-target oss-python-pyyaml --bootstrap
EOF
}

log() {
  printf '[setup-target] %s\n' "$*"
}

die() {
  printf '[setup-target] FATAL: %s\n' "$*" >&2
  exit 1
}

TARGET_NAME=""
REPO_URL=""
REPO_TYPE="auto"
REF=""
NO_UPDATE=0
FORCE_CONFIG=0
FORCE_CONFIG_FLAG=""
RUN_BOOTSTRAP=0
RUN_LLM_CONFIG=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo-type)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      REPO_TYPE="$2"; shift 2 ;;
    --repo-type=*)
      REPO_TYPE="${1#--repo-type=}"; shift ;;
    --ref)
      [ "$#" -ge 2 ] || die "--ref requires a value"
      REF="$2"; shift 2 ;;
    --ref=*)
      REF="${1#--ref=}"; shift ;;
    --no-update)
      NO_UPDATE=1; shift ;;
    --force|--force-config)
      FORCE_CONFIG=1
      FORCE_CONFIG_FLAG="$1"
      shift ;;
    --bootstrap)
      RUN_BOOTSTRAP=1; shift ;;
    --no-llm-config)
      RUN_LLM_CONFIG=0; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --*)
      die "unknown option: $1" ;;
    *)
      if [ -z "$TARGET_NAME" ]; then
        TARGET_NAME="$1"
      elif [ -z "$REPO_URL" ]; then
        REPO_URL="$1"
      else
        die "unexpected argument: $1"
      fi
      shift ;;
  esac
done

[ -n "$TARGET_NAME" ] || { usage >&2; exit 1; }
case "$TARGET_NAME" in
  *[!A-Za-z0-9._-]*|'') die "target must contain only letters, numbers, dot, underscore, or dash" ;;
esac
case "$REPO_TYPE" in auto|git|hg) ;; *) die "--repo-type must be auto, git, or hg" ;; esac

TARGET_ROOT="$SCRIPT_ROOT/targets/$TARGET_NAME"
CONFIG_DIR="$SCRIPT_ROOT/output/$TARGET_NAME"
TARGET_TOML="$CONFIG_DIR/target.toml"

detect_repo_type() {
  local root="$1" url="${2:-}"
  if [ -d "$root" ]; then
    target_detect_repo_type "$root"
    return
  fi
  if [ -n "$url" ]; then
    if [ -d "$url" ]; then
      local url_type
      url_type="$(target_detect_repo_type "$url")"
      if [ "$url_type" != "none" ]; then
        printf '%s\n' "$url_type"; return
      fi
    fi
    case "$url" in
      *hg.mozilla.org*|hg:*|*.hg) printf 'hg\n'; return ;;
    esac
  fi
  printf 'git\n'
}

git_dirty() {
  [ -n "$(git -C "$1" status --porcelain 2>/dev/null)" ]
}

hg_dirty() {
  [ -n "$(hg --cwd "$1" status 2>/dev/null)" ]
}

clone_target() {
  local repo_type="$1"
  [ -n "$REPO_URL" ] || die "targets/$TARGET_NAME does not exist; pass a repo URL to clone it"
  mkdir -p "$SCRIPT_ROOT/targets"
  case "$repo_type" in
    git)
      log "Cloning git source into targets/$TARGET_NAME"
      git clone "$REPO_URL" "$TARGET_ROOT"
      if [ -n "$REF" ]; then
        git -C "$TARGET_ROOT" checkout "$REF"
      fi
      ;;
    hg)
      log "Cloning hg source into targets/$TARGET_NAME"
      if [ -n "$REF" ]; then
        hg clone -u "$REF" "$REPO_URL" "$TARGET_ROOT"
      else
        hg clone "$REPO_URL" "$TARGET_ROOT"
      fi
      ;;
  esac
}

sync_git() {
  if git_dirty "$TARGET_ROOT"; then
    log "targets/$TARGET_NAME has local changes; leaving source checkout untouched"
    return
  fi
  log "Fetching git updates for targets/$TARGET_NAME"
  if [ -n "$REF" ]; then
    git -C "$TARGET_ROOT" fetch --tags origin "$REF" || git -C "$TARGET_ROOT" fetch --tags origin
    git -C "$TARGET_ROOT" checkout "$REF"
  else
    git -C "$TARGET_ROOT" fetch --tags origin
  fi
  if git -C "$TARGET_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    git -C "$TARGET_ROOT" pull --ff-only
  else
    log "No upstream tracking branch; fetched updates without changing HEAD"
  fi
}

sync_hg() {
  if hg_dirty "$TARGET_ROOT"; then
    log "targets/$TARGET_NAME has local changes; leaving source checkout untouched"
    return
  fi
  log "Pulling hg updates for targets/$TARGET_NAME"
  hg --cwd "$TARGET_ROOT" pull
  if [ -n "$REF" ]; then
    hg --cwd "$TARGET_ROOT" update -r "$REF"
  else
    hg --cwd "$TARGET_ROOT" update
  fi
}

if [ -d "$TARGET_ROOT" ]; then
  DETECTED_REPO_TYPE="$(detect_repo_type "$TARGET_ROOT" "$REPO_URL")"
  [ "$REPO_TYPE" = "auto" ] || [ "$REPO_TYPE" = "$DETECTED_REPO_TYPE" ] || \
    die "targets/$TARGET_NAME is $DETECTED_REPO_TYPE, not $REPO_TYPE"
  if [ "$DETECTED_REPO_TYPE" = "none" ]; then
    if [ -n "$REPO_URL" ] || [ -n "$REF" ]; then
      log "Using existing targets/$TARGET_NAME as a plain source tree (no VCS metadata; repo URL/ref ignored)"
    else
      log "Using existing targets/$TARGET_NAME as a plain source tree"
    fi
  elif [ "$NO_UPDATE" -eq 1 ] || { [ -z "$REPO_URL" ] && [ -z "$REF" ]; }; then
    log "Using existing targets/$TARGET_NAME without updating"
  elif [ "$DETECTED_REPO_TYPE" = "git" ]; then
    sync_git
  else
    sync_hg
  fi
else
  DETECTED_REPO_TYPE="$([ "$REPO_TYPE" = "auto" ] && detect_repo_type "$TARGET_ROOT" "$REPO_URL" || printf '%s\n' "$REPO_TYPE")"
  clone_target "$DETECTED_REPO_TYPE"
fi

mkdir -p "$CONFIG_DIR"
# Reviewed configs are preserved by default. The harness only re-seeds when:
#   * the file is missing (fresh target),
#   * the operator passed --force / --force-config,
#   * unfilled FILL_ME placeholders remain from a prior seed, OR
#   * the file no longer parses as TOML (e.g. an aborted hand-edit).
# In every other case we leave the operator's edits alone — docs/reference/
# target-toml.md promises that `bin/setup-target <slug>` may safely be run
# against an updated checkout without rewriting reviewed config.
CONFIG_REASON=""
if [ ! -f "$TARGET_TOML" ]; then
  CONFIG_REASON="missing"
elif [ "$FORCE_CONFIG" -ne 0 ]; then
  CONFIG_REASON="requested"
elif grep -q 'FILL_ME' "$TARGET_TOML" 2>/dev/null; then
  CONFIG_REASON="placeholders"
elif ! SCRIPT_ROOT="$SCRIPT_ROOT" python3 - "$TARGET_TOML" <<'PY' >/dev/null 2>&1
import os, sys
from pathlib import Path
sys.path.insert(0, str(Path(os.environ["SCRIPT_ROOT"]) / "lib"))
from target_config import Config, load_toml_into  # noqa: E402
load_toml_into(Config(), Path(sys.argv[1]))
PY
then
  CONFIG_REASON="invalid"
fi

if [ -z "$CONFIG_REASON" ]; then
  log "Keeping reviewed output/$TARGET_NAME/target.toml (pass --force to regenerate)"
else
  case "$CONFIG_REASON" in
    missing) log "Seeding output/$TARGET_NAME/target.toml" ;;
    placeholders) log "Refreshing output/$TARGET_NAME/target.toml because generated placeholders remain" ;;
    invalid) log "Refreshing output/$TARGET_NAME/target.toml because it no longer parses as TOML" ;;
    requested) log "Regenerating output/$TARGET_NAME/target.toml (${FORCE_CONFIG_FLAG:-"--force"})" ;;
  esac
  target_seed_toml "$TARGET_ROOT" "$TARGET_TOML" "$REPO_URL"
fi

append_unique_backend() {
  local candidate="$1"
  case "$candidate" in claude|codex|gemini|oss) ;; *) return 0 ;; esac
  case " $LLM_BACKEND_CANDIDATES " in
    *" $candidate "*) return 0 ;;
  esac
  LLM_BACKEND_CANDIDATES="${LLM_BACKEND_CANDIDATES:+$LLM_BACKEND_CANDIDATES }$candidate"
}

build_llm_backend_candidates() {
  LLM_BACKEND_CANDIDATES=""
  local requested="${ACTIVE_BACKEND:-${BACKEND:-${AUDIT_BACKEND:-}}}"
  if [ -n "$requested" ] && [ "$requested" != "all" ]; then
    append_unique_backend "$requested"
  fi
  append_unique_backend claude
  append_unique_backend codex
  append_unique_backend gemini
  if [ "$requested" = "oss" ] || [ -n "${MODEL:-${AUDIT_MODEL:-${CODEX_OSS_MODEL_DEFAULT:-}}}" ]; then
    append_unique_backend oss
  fi
}

run_llm_config_bootstrap() {
  [ -n "$CONFIG_REASON" ] || return 0
  if [ "$RUN_LLM_CONFIG" -eq 0 ]; then
    log "LLM config bootstrap skipped (--no-llm-config)"
    return 0
  fi
  if [ "${AUDIT_NEW_TARGET_BOOTSTRAP:-1}" = "0" ]; then
    log "LLM config bootstrap skipped (AUDIT_NEW_TARGET_BOOTSTRAP=0)"
    return 0
  fi
  if [ "${LLM_DECIDE_DISABLE:-0}" = "1" ]; then
    log "LLM config bootstrap skipped (LLM_DECIDE_DISABLE=1)"
    return 0
  fi

  build_llm_backend_candidates
  if [ -z "$LLM_BACKEND_CANDIDATES" ]; then
    log "LLM config bootstrap skipped (no candidate backends)"
    return 0
  fi

  # Translate a helper name into the section + invocation it owns, so
  # the rotation summary can point operators at the right hand-edit. Two
  # callers today; the case statement is the single source of truth.
  helper_section() {
    case "$1" in
      suggest-threat-model) printf '%s\n' "[threat_model]" ;;
      suggest-peers)        printf '%s\n' "[s6_peers]" ;;
      *)                    printf '%s\n' "<section>" ;;
    esac
  }

  local helper backend rc success helper_args
  local -a attempts
  local next_backend section
  for helper in suggest-threat-model suggest-peers; do
    [ -x "$SCRIPT_ROOT/bin/$helper" ] || continue
    success=0
    attempts=()
    helper_args=("$TARGET_NAME" --apply)
    if [ "$helper" = "suggest-threat-model" ]; then
      # setup-target has just written the deterministic seed, so replacing
      # that generated default is safe. Existing operator-curated configs can
      # still be protected by running the helper directly without --force.
      helper_args+=("--force")
    elif [ "$FORCE_CONFIG" -ne 0 ]; then
      helper_args+=("--force")
    fi
    # Convert space-separated candidate string into a positional list so
    # we can name the next backend in the per-attempt rotation log.
    # shellcheck disable=SC2206  # word-splitting is intentional
    local -a candidates=($LLM_BACKEND_CANDIDATES)
    local i
    for (( i=0; i<${#candidates[@]}; i++ )); do
      backend="${candidates[$i]}"
      next_backend="${candidates[$((i+1))]:-}"
      rc=0
      # LLM_BOOTSTRAP_QUIET=1 silences the helper's own per-attempt
      # warning; this rotation log is the authoritative narrator.
      SCRIPT_ROOT="$SCRIPT_ROOT" ACTIVE_BACKEND="$backend" BACKEND="$backend" \
        LLM_BOOTSTRAP_QUIET=1 \
        "$SCRIPT_ROOT/bin/$helper" "${helper_args[@]}" || rc=$?
      case "$rc" in
        0)
          log "config bootstrap: $helper succeeded on backend=$backend — updated output/$TARGET_NAME/target.toml"
          success=1
          break
          ;;
        4)
          log "config bootstrap: $helper kept the existing curated section on backend=$backend — rerun setup-target with --force to overwrite"
          success=1
          break
          ;;
        *)
          attempts+=("$backend(rc=$rc)")
          if [ -n "$next_backend" ]; then
            log "config bootstrap: $helper returned rc=$rc on backend=$backend — retrying with backend=$next_backend"
          else
            log "config bootstrap: $helper returned rc=$rc on backend=$backend — no remaining backends"
          fi
          ;;
      esac
    done
    if [ "$success" -eq 0 ]; then
      section="$(helper_section "$helper")"
      log "config bootstrap: $helper could not generate $section after trying [${attempts[*]}] — hand-edit output/$TARGET_NAME/target.toml or fix backend credentials and rerun 'bin/$helper $TARGET_NAME --apply' (see lib/llm_decide.log for call telemetry)"
    fi
  done
}

run_llm_config_bootstrap

python3 "$SCRIPT_ROOT/lib/target_config.py" parse-toml "$TARGET_TOML" >/dev/null || \
  die "target config does not parse: $TARGET_TOML"

REV="$(target_detect_rev "$TARGET_ROOT" || true)"
log "Source: $TARGET_ROOT"
log "Config: $TARGET_TOML"
[ -n "$REV" ] && log "Revision: $REV"

# Auto-bootstrap when the source tree carries ABI-mismatched Python
# extensions. Generic — `lib/languages.py stale-python-extensions`
# scans the checkout for `*.cpython-<tag>-*.so` files whose tag does
# not match the active interpreter, ignoring bases that already have a
# matching-tag sibling. This catches the pyyaml-style failure where a
# prebuilt cp39 `.so` blocks every C-side card under cp314 without
# anything in setup-target's path being target-specific.
if [ "$RUN_BOOTSTRAP" -eq 0 ] && [ -d "$TARGET_ROOT" ]; then
  STALE_PY_EXTS="$(python3 "$SCRIPT_ROOT/lib/languages.py" \
                     stale-python-extensions "$TARGET_ROOT" 2>/dev/null || true)"
  if [ -n "$STALE_PY_EXTS" ]; then
    STALE_COUNT="$(printf '%s\n' "$STALE_PY_EXTS" | wc -l | tr -d ' ')"
    log "ABI mismatch: ${STALE_COUNT} Python extension(s) built for a non-active interpreter — forcing --bootstrap"
    log "  first stale: $(printf '%s\n' "$STALE_PY_EXTS" | head -1)"
    RUN_BOOTSTRAP=1
  fi
fi

# Read build_system out of the freshly-written target.toml. Used by
# both the language-bootstrap step below and the sanitizer build-recipe
# convergence step further down — keep this read at top scope so both
# can see it.
BUILD_SYSTEM="$(python3 - "$SCRIPT_ROOT" "$TARGET_TOML" <<'PY'
import sys
from pathlib import Path
sys.path.insert(0, str(Path(sys.argv[1]) / "lib"))
import target_config as tc
parsed = tc.parse_toml(Path(sys.argv[2]))
bs = parsed.get("build_system", "")
print(bs if isinstance(bs, str) else "")
PY
)"

# Optional language-specific bootstrap. Asks the language registry for
# the full plan (commands, last-command fallback alternatives, env, and
# maintained fuzz backends) for the detected build_system. The plan is
# release-mode: NDEBUG / -O2 / -c release / --release flow through
# `sanitizer_env`, with no debug asserts that produce noise rather than
# security signal. All output is tee'd to TARGET_ROOT/.audit/bootstrap.log
# so failures are diagnosable; the actual recipe that worked is
# persisted to TARGET_ROOT/.audit/bootstrap.sh for reproducible reruns.
if [ "$RUN_BOOTSTRAP" -eq 1 ]; then
  if [ -z "$BUILD_SYSTEM" ]; then
    log "bootstrap: skipped (no build_system in $TARGET_TOML)"
  else
    LANG_NAME="$(python3 "$SCRIPT_ROOT/lib/languages.py" supports-build-system "$BUILD_SYSTEM" 2>/dev/null || true)"
    if [ -z "$LANG_NAME" ]; then
      log "bootstrap: skipped (build_system='$BUILD_SYSTEM' is not registered in lib/languages.py)"
    else
      BOOTSTRAP_PLAN="$(python3 "$SCRIPT_ROOT/lib/languages.py" bootstrap-plan \
                          "$BUILD_SYSTEM" "$TARGET_ROOT" 2>/dev/null || echo '{}')"
      # Surface maintained fuzz backends up front so the operator
      # sees what's auditable for this target. Empty tuple = no
      # first-class instrumentation; we say so honestly rather
      # than pretending.
      FUZZ_BACKENDS="$(printf '%s' "$BOOTSTRAP_PLAN" | python3 -c \
        'import json,sys; p=json.load(sys.stdin); print(" ".join(p.get("fuzz_backends") or []))')"
      if [ -n "$FUZZ_BACKENDS" ]; then
        log "bootstrap: fuzz backends for $LANG_NAME: $FUZZ_BACKENDS"
      else
        log "bootstrap: fuzz backends for $LANG_NAME: (none registered — no maintained toolchain)"
      fi
      CMD_COUNT="$(printf '%s' "$BOOTSTRAP_PLAN" | python3 -c \
        'import json,sys; print(len(json.load(sys.stdin).get("cmds") or []))')"
      if [ "$CMD_COUNT" -eq 0 ]; then
        log "bootstrap: skipped ($LANG_NAME has no bootstrap commands, or required manifest is absent in $TARGET_ROOT)"
      else
        log "bootstrap: running $CMD_COUNT $LANG_NAME release-mode command(s) in $TARGET_ROOT"
        mkdir -p "$TARGET_ROOT/.audit"
        BOOTSTRAP_LOG="$TARGET_ROOT/.audit/bootstrap.log"
        BOOTSTRAP_SH="$TARGET_ROOT/.audit/bootstrap.sh"
        # The executor below honours the no-shell-expansion contract
        # (argv lists, never `bash -c "$cmd"`) and writes a final
        # bootstrap.sh that maintainers can rerun verbatim.
        if ! BOOTSTRAP_LOG="$BOOTSTRAP_LOG" BOOTSTRAP_SH="$BOOTSTRAP_SH" \
             python3 - "$TARGET_ROOT" "$BOOTSTRAP_PLAN" <<'PY'
import json, os, subprocess, sys, shlex
target_root, plan_json = sys.argv[1], sys.argv[2]
plan = json.loads(plan_json)
cmds: list[list[str]] = plan.get("cmds") or []
alternatives: list[list[str]] = plan.get("alternatives") or []
env_pairs: list[list[str]] = plan.get("env") or []

log_path = os.environ["BOOTSTRAP_LOG"]
sh_path = os.environ["BOOTSTRAP_SH"]

env = os.environ.copy()
for k, v in env_pairs:
    env[k] = v

# Open the bootstrap log once and tee each subprocess into it AND
# this process's stdout, so the operator sees failures inline and
# also has a forensic record under .audit/bootstrap.log.
recipe_lines: list[str] = [
    "#!/usr/bin/env bash",
    "# Auto-generated by bin/setup-target --bootstrap. Reproduces the",
    "# release-mode sanitizer build that the audit harness ran against.",
    "set -euo pipefail",
    f'cd "$(dirname "$0")/.."',  # .audit/bootstrap.sh → target root
]
for k, v in env_pairs:
    recipe_lines.append(f"export {k}={shlex.quote(v)}")

def run(argv: list[str]) -> int:
    msg = f"[setup-target] bootstrap: {' '.join(shlex.quote(a) for a in argv)}\n"
    sys.stdout.write(msg); sys.stdout.flush()
    with open(log_path, "a") as logf:
        logf.write(msg)
        logf.flush()
        proc = subprocess.run(
            argv, cwd=target_root, env=env,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
        )
        logf.write(proc.stdout or "")
    # Echo last 40 lines to stdout so the operator sees the failure
    # without having to cat the file.
    if proc.returncode != 0:
        tail = (proc.stdout or "").splitlines()[-40:]
        for line in tail:
            sys.stdout.write(line + "\n")
    else:
        # Show only the summary line on success to keep stdout quiet
        # but informative. Full output is in bootstrap.log.
        last = (proc.stdout or "").rstrip().splitlines()[-1:] or [""]
        if last[0]:
            sys.stdout.write("    " + last[0] + "\n")
    return proc.returncode

# Run each command in order. For the LAST command in `cmds`, if it
# fails, walk the `alternatives` list before giving up. This is the
# npm "ci → install → install --legacy-peer-deps" chain expressed
# generically: alternatives apply to the final step because
# upstream-style commands (pip install + setup.py, or npm ci) are
# already sequenced inside cmds.
final_idx = len(cmds) - 1
for i, cmd in enumerate(cmds):
    rc = run(cmd)
    if rc == 0:
        recipe_lines.append(" ".join(shlex.quote(a) for a in cmd))
        continue
    if i == final_idx and alternatives:
        # The primary final command failed; try each alternative.
        succeeded = False
        for alt in alternatives:
            sys.stdout.write(
                f"[setup-target] bootstrap: primary failed (rc={rc}); trying alternative\n"
            )
            rc = run(alt)
            if rc == 0:
                recipe_lines.append(" ".join(shlex.quote(a) for a in alt))
                succeeded = True
                break
        if not succeeded:
            sys.stderr.write(
                f"[setup-target] bootstrap: all alternatives exhausted (rc={rc}); aborting\n"
            )
            sys.exit(rc)
    else:
        sys.stderr.write(
            f"[setup-target] bootstrap: command failed (rc={rc}); aborting bootstrap\n"
        )
        sys.exit(rc)

# Persist the recipe that worked so reruns and bin/export-repro are
# bit-identical.
with open(sh_path, "w") as fh:
    fh.write("\n".join(recipe_lines) + "\n")
os.chmod(sh_path, 0o755)
sys.stdout.write(f"[setup-target] bootstrap: wrote {sh_path}\n")
PY
        then
          die "bootstrap failed for $TARGET_NAME (see $TARGET_ROOT/.audit/bootstrap.log)"
        fi
        log "bootstrap: completed (log: $TARGET_ROOT/.audit/bootstrap.log, recipe: $TARGET_ROOT/.audit/bootstrap.sh)"
      fi
    fi
  fi
fi

# Sanitizer build-recipe convergence. C/C++ targets need a working ASan
# build script at targets/<slug>/.audit/build.sh so:
#   * bin/export-repro can inline it into each reproduce.sh (the recipe
#     bug fixed in commit 47f0c45 — without this file, reproduce.sh
#     silently falls back to a generic cmake template missing the
#     target-specific flags an audit actually needed),
#   * the maintainer running reproduce.sh and the operator running the
#     audit get a bit-identical build by construction.
#
# bin/auto-build-script discovers the recipe via an LLM-driven
# convergence loop. It needs the same LLM backend run_llm_config_bootstrap
# uses, so we reuse that gating. The call is part of --bootstrap; if the
# operator did not pass --bootstrap and the recipe is missing, we log a
# one-line hint so the next setup-target run includes it.
NATIVE_BUILD_SYSTEM=0
case "${BUILD_SYSTEM:-}" in
  cmake|autotools|meson) NATIVE_BUILD_SYSTEM=1 ;;
esac

AUDIT_BUILD_SH="$TARGET_ROOT/.audit/build.sh"

if [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ "$RUN_BOOTSTRAP" -eq 1 ]; then
  if [ -f "$AUDIT_BUILD_SH" ] && [ "$FORCE_CONFIG" -eq 0 ]; then
    log "bootstrap: keeping existing $AUDIT_BUILD_SH (pass --force to regenerate)"
  elif [ ! -x "$SCRIPT_ROOT/bin/auto-build-script" ]; then
    log "bootstrap: bin/auto-build-script not executable; skipping sanitizer build convergence"
  else
    build_llm_backend_candidates
    if [ -z "$LLM_BACKEND_CANDIDATES" ]; then
      log "bootstrap: no LLM backend configured; skipping sanitizer build convergence (set up a backend and rerun with --bootstrap)"
    else
      log "bootstrap: converging ASan build recipe via bin/auto-build-script (this may take a few minutes and one or more LLM revisions)"
      success=0
      # shellcheck disable=SC2206  # word-splitting is intentional
      _abs_candidates=($LLM_BACKEND_CANDIDATES)
      _abs_attempts=()
      _abs_i=0
      for backend in "${_abs_candidates[@]}"; do
        next_backend="${_abs_candidates[$((_abs_i+1))]:-}"
        _abs_i=$((_abs_i+1))
        rc=0
        SCRIPT_ROOT="$SCRIPT_ROOT" ACTIVE_BACKEND="$backend" BACKEND="$backend" \
          "$SCRIPT_ROOT/bin/auto-build-script" \
            --src "$TARGET_ROOT" \
            --out "$AUDIT_BUILD_SH" \
            --sanitizer asan || rc=$?
        if [ "$rc" -eq 0 ]; then
          log "bootstrap: auto-build-script succeeded on backend=$backend — wrote $AUDIT_BUILD_SH"
          success=1
          break
        fi
        _abs_attempts+=("$backend(rc=$rc)")
        if [ -n "$next_backend" ]; then
          log "bootstrap: auto-build-script returned rc=$rc on backend=$backend — retrying with backend=$next_backend"
        else
          log "bootstrap: auto-build-script returned rc=$rc on backend=$backend — no remaining backends"
        fi
      done
      if [ "$success" -eq 0 ]; then
        log "bootstrap: auto-build-script did not converge after trying [${_abs_attempts[*]}] — rerun with --bootstrap once the upstream build error visible above is resolvable, or write $AUDIT_BUILD_SH by hand"
      fi
    fi
  fi
elif [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ ! -f "$AUDIT_BUILD_SH" ]; then
  log "hint: $TARGET_NAME is a $BUILD_SYSTEM target with no $AUDIT_BUILD_SH; rerun with --bootstrap to converge an ASan build recipe (without it, reproduce.sh falls back to a generic cmake template that may miss target-specific flags)"
fi

# Materialize the canonical sanitizer build and record the library it
# produces, so --bootstrap is self-sufficient (recipe + build + filled
# config). auto-build-script validates the recipe in a throwaway scratch
# dir, so on a fresh target targets/<slug>/build-asan never exists, and the
# early config seed — which must run before any build, to supply
# build_system — could not detect <san>_lib and left it a commented
# FILL_ME. Build once into the canonical dir with the converged recipe,
# then patch the detected library fields into target.toml in place, leaving
# the LLM-curated sections untouched. (reproduce.sh self-discovers the
# library at run time regardless; this just makes the config accurate for
# the model-direct prompt recipe and bin/probe.)
if [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ "$RUN_BOOTSTRAP" -eq 1 ] && [ -f "$AUDIT_BUILD_SH" ]; then
  ASAN_BUILD_DIR="$TARGET_ROOT/build-asan${AUDIT_BUILD_SUFFIX:-}"
  if [ ! -d "$ASAN_BUILD_DIR" ]; then
    log "bootstrap: materializing canonical ASan build ($ASAN_BUILD_DIR) for library detection"
    mkdir -p "$TARGET_ROOT/.audit"
    if "$AUDIT_BUILD_SH" "$TARGET_ROOT" "$ASAN_BUILD_DIR" \
         >> "$TARGET_ROOT/.audit/build-materialize.log" 2>&1; then
      log "bootstrap: canonical ASan build complete"
    else
      log "bootstrap: canonical ASan build failed (see $TARGET_ROOT/.audit/build-materialize.log); reproduce.sh still self-discovers the library at run time"
    fi
  fi
  if [ "$(python3 "$SCRIPT_ROOT/lib/target_config.py" refresh-libs "$TARGET_ROOT" "$TARGET_TOML" 2>/dev/null)" = "changed" ]; then
    log "bootstrap: filled <san>_lib in $TARGET_TOML from the canonical build"
  fi
fi

cat <<EOF

Next steps:
  1. Review output/$TARGET_NAME/target.toml and edit only unresolved or target-specific fields.
  2. Smoke-test with: bin/audit --target $TARGET_NAME --backend <claude|codex|gemini|oss> 1
EOF
