#!/usr/bin/env python3
"""Clone or update a target and seed its audit configuration."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path

SCRIPT_ROOT = Path(os.environ.get("AUDIT_ROOT", Path(__file__).resolve().parent.parent)).resolve()
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import build_materialize
import languages
import target_config

RESERVED = {"output", "benchmark"}
NATIVE_SYSTEMS = {"cmake", "autotools", "meson"}


def log(message: str) -> None:
    print(f"[setup-target] {message}")


def run(command: list[str], *, cwd: Path | None = None, check: bool = True, env=None) -> subprocess.CompletedProcess:
    return subprocess.run(command, cwd=cwd, check=check, env=env)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=__doc__,
        epilog="Examples: setup-target pcre2 https://github.com/PCRE2Project/pcre2; setup-target myparser ~/code/myparser",
    )
    parser.add_argument("target")
    parser.add_argument("source", nargs="?", default="")
    parser.add_argument("--repo-type", choices=("auto", "git", "hg"), default="auto")
    parser.add_argument("--ref", default="")
    parser.add_argument("--no-update", action="store_true")
    parser.add_argument("--force", action="store_true")
    parser.add_argument("--build", action="store_true")
    parser.add_argument("--no-llm-config", action="store_true")
    return parser.parse_args(argv)


def validate_target(name: str) -> None:
    if name.startswith("/") or name.endswith("/") or "//" in name:
        raise ValueError("target name must not start or end with '/' or contain empty components")
    for component in name.split("/"):
        if component in {"", ".", ".."} or component.startswith("."):
            raise ValueError("each target path component must be a plain name")
        if component in RESERVED:
            raise ValueError(f"'{component}' is a reserved directory name and cannot be a target path component")
        if not re.fullmatch(r"[A-Za-z0-9._-]+", component):
            raise ValueError("target components may contain only letters, numbers, dot, underscore, or dash")


class Setup:
    def __init__(self, args: argparse.Namespace):
        validate_target(args.target)
        self.args = args
        self.name = args.target
        self.source = args.source
        self.target_root = SCRIPT_ROOT / "targets" / self.name
        self.config_dir = SCRIPT_ROOT / "output" / self.name
        self.toml = self.config_dir / "target.toml"
        self.seeded_full = False

    def detect_type(self, root: Path | None = None) -> str:
        candidate = root or self.target_root
        if candidate.is_dir():
            detected = target_config.detect_repo_type(candidate)
            if detected != "none" or root is not None:
                return detected
        if self.source:
            source_path = Path(self.source).expanduser()
            if source_path.is_dir():
                detected = target_config.detect_repo_type(source_path)
                if detected != "none":
                    return detected
            if "hg.mozilla.org" in self.source or self.source.startswith("hg:") or self.source.endswith(".hg"):
                return "hg"
        return "git"

    def prepare_source(self) -> None:
        if self.target_root.is_dir():
            detected = self.detect_type(self.target_root)
            if self.args.repo_type != "auto" and self.args.repo_type != detected:
                raise ValueError(f"targets/{self.name} is {detected}, not {self.args.repo_type}")
            if detected == "none":
                if self.source or self.args.ref:
                    log(f"Using existing targets/{self.name} as a plain source tree (no VCS metadata; repo URL/ref ignored)")
                else:
                    log(f"Using existing targets/{self.name} as a plain source tree")
                self.source = ""
            elif self.args.no_update or (not self.source and not self.args.ref):
                log(f"Using existing targets/{self.name} without updating")
            elif detected == "git":
                self.sync_git()
            else:
                self.sync_hg()
            return
        source_path = Path(self.source).expanduser() if self.source else None
        if source_path and source_path.is_dir() and target_config.detect_repo_type(source_path) == "none":
            if self.args.repo_type != "auto":
                raise ValueError(f"{self.source} is a plain source tree, not a {self.args.repo_type} repo; omit --repo-type to symlink it")
            self.link_target(source_path)
            self.source = ""
            return
        if not self.source:
            raise ValueError(f"targets/{self.name} does not exist; pass a repo URL to clone it")
        repo_type = self.args.repo_type if self.args.repo_type != "auto" else self.detect_type()
        self.clone(repo_type)

    def link_target(self, source: Path) -> None:
        destination = source.resolve()
        self.target_root.parent.mkdir(parents=True, exist_ok=True)
        if self.target_root.is_symlink():
            log(f"Re-pointing targets/{self.name} -> {destination}")
            self.target_root.unlink()
        elif self.target_root.exists():
            raise ValueError(f"targets/{self.name} already exists and is not a symlink")
        self.target_root.symlink_to(destination, target_is_directory=True)
        log(f"Symlinking targets/{self.name} -> {destination} (local non-VCS source; not cloned, pulled, or fetched)")

    def clone(self, repo_type: str) -> None:
        self.target_root.parent.mkdir(parents=True, exist_ok=True)
        log(f"Cloning {repo_type} source into targets/{self.name}")
        if repo_type == "git":
            run(["git", "clone", self.source, str(self.target_root)])
            if self.args.ref:
                run(["git", "-C", str(self.target_root), "checkout", self.args.ref])
        else:
            command = ["hg", "clone"]
            if self.args.ref:
                command.extend(("-u", self.args.ref))
            run([*command, self.source, str(self.target_root)])

    def sync_git(self) -> None:
        dirty = subprocess.run(["git", "-C", str(self.target_root), "status", "--porcelain"], capture_output=True, text=True).stdout
        if dirty:
            log(f"targets/{self.name} has local changes; leaving source checkout untouched")
            return
        log(f"Fetching git updates for targets/{self.name}")
        if self.args.ref:
            fetched = subprocess.run(["git", "-C", str(self.target_root), "fetch", "--tags", "origin", self.args.ref])
            if fetched.returncode:
                run(["git", "-C", str(self.target_root), "fetch", "--tags", "origin"])
            run(["git", "-C", str(self.target_root), "checkout", self.args.ref])
        else:
            run(["git", "-C", str(self.target_root), "fetch", "--tags", "origin"])
        upstream = subprocess.run(["git", "-C", str(self.target_root), "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if upstream.returncode == 0:
            run(["git", "-C", str(self.target_root), "pull", "--ff-only"])
        else:
            log("No upstream tracking branch; fetched updates without changing HEAD")

    def sync_hg(self) -> None:
        dirty = subprocess.run(["hg", "--cwd", str(self.target_root), "status"], capture_output=True, text=True).stdout
        if dirty:
            log(f"targets/{self.name} has local changes; leaving source checkout untouched")
            return
        log(f"Pulling hg updates for targets/{self.name}")
        run(["hg", "--cwd", str(self.target_root), "pull"])
        command = ["hg", "--cwd", str(self.target_root), "update"]
        if self.args.ref:
            command.extend(("-r", self.args.ref))
        run(command)

    def seed_config(self) -> None:
        self.config_dir.mkdir(parents=True, exist_ok=True)
        if not self.toml.is_file():
            reason = "missing"
        elif self.args.force:
            reason = "requested"
        elif target_config.config_has_live_placeholder(self.toml):
            reason = "placeholders"
        else:
            try:
                target_config.parse_toml(self.toml)
                reason = ""
            except Exception:
                reason = "invalid"
        if self.args.build and reason == "placeholders":
            log(f"Keeping output/{self.name}/target.toml as-is (--build does not re-seed; run 'bin/setup-target {self.name}' without --build to refresh placeholders)")
            reason = ""
        if not reason:
            log(f"Keeping reviewed output/{self.name}/target.toml (pass --force to regenerate)")
            return
        if reason == "placeholders":
            log(f"Refreshing output/{self.name}/target.toml to fill placeholders (preserving curated [threat_model] / [s6_peers])")
            target_config.seed_toml(self.target_root, self.toml, self.source, preserve_curated=True)
            return
        if reason == "missing":
            log(f"Seeding output/{self.name}/target.toml")
        elif reason == "invalid":
            log(f"Refreshing output/{self.name}/target.toml because it no longer parses as TOML")
        else:
            log(f"Regenerating output/{self.name}/target.toml (--force)")
        target_config.seed_toml(self.target_root, self.toml, self.source)
        self.seeded_full = True

    def backend_candidates(self) -> list[str]:
        requested = os.environ.get("ACTIVE_BACKEND", os.environ.get("BACKEND", os.environ.get("AUDIT_BACKEND", "")))
        result: list[str] = []
        for candidate in ([requested] if requested and requested != "all" else []) + ["claude", "codex", "gemini", "grok"]:
            if candidate and candidate not in result:
                result.append(candidate)
        if requested == "oss" or os.environ.get("MODEL", os.environ.get("AUDIT_MODEL", "")):
            result.append("oss")
        return result

    def run_config_helper(self, helper: str, helper_args: list[str]) -> None:
        executable = SCRIPT_ROOT / "bin" / helper
        if not os.access(executable, os.X_OK):
            return
        candidates = self.backend_candidates()
        for index, backend in enumerate(candidates):
            environment = {
                **os.environ, "SCRIPT_ROOT": str(SCRIPT_ROOT),
                "ACTIVE_BACKEND": backend, "BACKEND": backend,
                "LLM_BOOTSTRAP_QUIET": "1",
            }
            completed = subprocess.run(
                [str(executable), *helper_args], env=environment
            )
            if completed.returncode == 0:
                log(
                    f"config bootstrap: {helper} succeeded on "
                    f"backend={backend} - updated output/{self.name}/target.toml"
                )
                return
            if completed.returncode == 4:
                log(
                    f"config bootstrap: {helper} kept the existing curated "
                    f"section on backend={backend}"
                )
                return
            next_backend = candidates[index + 1] if index + 1 < len(candidates) else ""
            if next_backend:
                log(
                    f"config bootstrap: {helper} returned "
                    f"rc={completed.returncode} on backend={backend} - "
                    f"retrying with backend={next_backend}"
                )
            else:
                log(
                    f"config bootstrap: {helper} returned "
                    f"rc={completed.returncode} on backend={backend} - "
                    "no remaining backends"
                )

    def llm_bootstrap(self) -> None:
        if not self.seeded_full:
            return
        if self.args.no_llm_config or os.environ.get("AUDIT_NEW_TARGET_BOOTSTRAP", "1") == "0" or os.environ.get("LLM_DECIDE_DISABLE", "0") == "1":
            return
        for helper in ("suggest-threat-model", "suggest-peers"):
            helper_args = [self.name, "--apply"]
            if helper == "suggest-threat-model" or self.args.force:
                helper_args.append("--force")
            self.run_config_helper(helper, helper_args)

    def runner_bootstrap(self) -> None:
        """Derive native CLI argv after the sanitizer build is selectable."""
        if (
            self.args.no_llm_config
            or os.environ.get("AUDIT_NEW_TARGET_BOOTSTRAP", "1") == "0"
            or os.environ.get("LLM_DECIDE_DISABLE", "0") == "1"
        ):
            return
        config = target_config.Config(target_root=str(self.target_root))
        target_config.load_toml_into(config, self.toml)
        if (
            config.is_browser == "1" or config.build_system not in NATIVE_SYSTEMS
            or config.runner_bin
            or (config.runner_args and not self.args.force)
        ):
            return
        if config.first_executable_sanitizer() is None:
            return
        helper_args = [self.name, "--apply"]
        if self.args.force:
            helper_args.append("--force")
        self.run_config_helper("suggest-runner", helper_args)

    def language_build(self, config: target_config.Config) -> None:
        if not self.args.build:
            stale = languages.stale_python_extensions(self.target_root)
            if stale:
                log(f"ABI mismatch: {len(stale)} Python extension(s) built for a non-active interpreter - forcing a build")
                self.args.build = True
        if not self.args.build or not config.build_system:
            return
        language = languages.for_build_system(config.build_system)
        if not language:
            log(f"bootstrap: skipped (build_system='{config.build_system}' is not registered in lib/languages.py)")
            return
        plan = languages.bootstrap_plan_for_target(self.target_root, config.build_system)
        if not plan.get("cmds"):
            return
        audit_dir = self.target_root / ".audit"
        status = languages.execute_bootstrap_plan(self.target_root, plan, audit_dir / "bootstrap.log", audit_dir / "bootstrap.sh")
        if status:
            raise RuntimeError(f"bootstrap failed for {self.name} (see {audit_dir / 'bootstrap.log'})")

    def sanitizer_build_artifact_present(
        self,
        config: target_config.Config,
        sanitizer_name: str,
        build_dir: Path,
    ) -> bool:
        """Verify a recipe produced a selectable artifact in its clean tree."""
        for kind, configured in (
            ("bin", config.sanitizer_bin(sanitizer_name)),
            ("lib", config.sanitizer_lib(sanitizer_name)),
        ):
            if not configured or "FILL_ME" in configured:
                continue
            try:
                path = Path(config.resolve_path(configured))
                path.resolve().relative_to(build_dir.resolve())
            except (OSError, ValueError):
                continue
            if kind == "bin" and path.is_file() and os.access(path, os.X_OK):
                return True
            if kind == "lib" and path.is_file():
                return True
        detected_bin, detected_lib = \
            target_config.detect_sanitizer_build_artifacts(
                self.target_root, sanitizer_name
            )
        return bool(detected_bin or detected_lib)

    def sanitizer_builds(self, config: target_config.Config) -> None:
        audit_dir = self.target_root / ".audit"
        # Native C/C++ trees converge a .audit/build.sh through auto-build-script;
        # a language target (cargo/go/pip) opts into a sanitizer build only by
        # shipping a hand-authored .audit/build.sh (or build-<san>.sh) recipe.
        # With neither a native build system nor such a recipe there is nothing
        # to materialize.
        recipes = ["build.sh", *(f"build-{s}.sh" for s in ("ubsan", "msan", "tsan"))]
        has_recipe = any((audit_dir / name).is_file() for name in recipes)
        if config.build_system not in NATIVE_SYSTEMS and not has_recipe:
            return
        if config.sanitizers_explicitly_disabled:
            sanitizers = []
        else:
            sanitizers = ["asan", *(
                name for name in config.sanitizers_enabled if name != "asan"
            )]
        if self.args.build:
            candidates = self.backend_candidates()
            auto_builder = SCRIPT_ROOT / "bin/auto-build-script"
            for sanitizer_name in sanitizers:
                if sanitizer_name not in {"asan", "ubsan", "msan", "tsan"}:
                    continue
                recipe = audit_dir / ("build.sh" if sanitizer_name == "asan" else f"build-{sanitizer_name}.sh")
                candidate_dir = audit_dir / "build-candidates"
                candidate = candidate_dir / f"{recipe.name}.{os.getpid()}"
                candidate.unlink(missing_ok=True)
                generated = False
                if recipe.is_file() and not self.args.force:
                    log(f"bootstrap: keeping existing {recipe} (pass --force to regenerate)")
                elif os.access(auto_builder, os.X_OK) and candidates:
                    candidate_dir.mkdir(parents=True, exist_ok=True)
                    for backend in candidates:
                        environment = {**os.environ, "SCRIPT_ROOT": str(SCRIPT_ROOT), "ACTIVE_BACKEND": backend, "BACKEND": backend}
                        completed = subprocess.run([
                            str(auto_builder), "--src", str(self.target_root), "--out", str(candidate), "--sanitizer", sanitizer_name,
                        ], env=environment)
                        if completed.returncode == 0:
                            generated = True
                            log(f"bootstrap: auto-build-script ({sanitizer_name}) succeeded on backend={backend} - validating candidate")
                            break
                active_recipe = candidate if generated else recipe
                if not active_recipe.is_file():
                    continue
                build_dir = self.target_root / f"build-{sanitizer_name}{os.environ.get('AUDIT_BUILD_SUFFIX', '')}"
                freshness = target_config.build_freshness(
                    self.target_root, sanitizer_name, recipe_path=recipe
                )
                if freshness != "fresh" or self.args.force:
                    log(f"bootstrap: materializing {sanitizer_name} build into {build_dir} (source is {freshness}; compiling so <san>_bin/<san>_lib can be detected; a few minutes)")
                    audit_dir.mkdir(parents=True, exist_ok=True)
                    # A committed or hand-authored recipe may lose its executable
                    # bit. Restore only owner-execute; do not broaden its access.
                    active_recipe.chmod(active_recipe.stat().st_mode | 0o100)
                    result = build_materialize.materialize(
                        self.target_root,
                        sanitizer_name,
                        active_recipe,
                        recipe,
                        lambda tree: self.sanitizer_build_artifact_present(
                            config, sanitizer_name, tree
                        ),
                        force=self.args.force,
                    )
                    if result.status == "built":
                        log(f"bootstrap: {sanitizer_name} build complete")
                    else:
                        if result.status == "fresh":
                            candidate.unlink(missing_ok=True)
                            continue
                        log(
                            f"bootstrap: {sanitizer_name} clean build failed "
                            f"({result.reason}; see {result.log_path})"
                        )
                        # Existing recipes used to get only one materialization
                        # attempt. A clean failure is the evidence needed for a
                        # bounded repair loop; keep the old recipe/build until a
                        # revised candidate passes both scratch and canonical
                        # validation.
                        if (
                            not self.args.no_llm_config
                            and os.environ.get("LLM_DECIDE_DISABLE", "0") != "1"
                            and os.access(auto_builder, os.X_OK)
                            and candidates
                            and result.log_path is not None
                        ):
                            candidate_dir.mkdir(parents=True, exist_ok=True)
                            repaired = candidate_dir / f"{recipe.name}.{os.getpid()}.repaired"
                            repaired.unlink(missing_ok=True)
                            environment = {
                                **os.environ,
                                "SCRIPT_ROOT": str(SCRIPT_ROOT),
                                "ACTIVE_BACKEND": candidates[0],
                                "BACKEND": candidates[0],
                            }
                            completed = subprocess.run([
                                str(auto_builder), "--src", str(self.target_root),
                                "--out", str(repaired), "--sanitizer", sanitizer_name,
                                "--repair-from", str(active_recipe),
                                "--failure-log", str(result.log_path),
                                "--max-iters", "3",
                            ], env=environment, check=False)
                            if completed.returncode == 0 and repaired.is_file():
                                repaired_result = build_materialize.materialize(
                                    self.target_root,
                                    sanitizer_name,
                                    repaired,
                                    recipe,
                                    lambda tree: self.sanitizer_build_artifact_present(
                                        config, sanitizer_name, tree
                                    ),
                                    force=self.args.force,
                                )
                                if repaired_result.status == "built":
                                    log(
                                        f"bootstrap: repaired {sanitizer_name} "
                                        "recipe after clean-build failure"
                                    )
                                else:
                                    repaired.unlink(missing_ok=True)
                            else:
                                repaired.unlink(missing_ok=True)
                        candidate.unlink(missing_ok=True)
                elif generated:
                    # A concurrent materializer may have made the old recipe
                    # fresh while this candidate was generated. Do not replace
                    # that recipe without validating this candidate against the
                    # canonical tree.
                    candidate.unlink(missing_ok=True)
        elif sanitizers and not (audit_dir / "build.sh").is_file():
            log(f"hint: {self.name} is a {config.build_system} target with no {audit_dir / 'build.sh'} yet; bin/audit builds it automatically")
        if target_config.refresh_detected_build_fields(self.target_root, self.toml):
            log(f"Refreshed <san>_bin/<san>_lib in {self.toml} from build trees on disk")

        # Keep build-asan as the regular control, then materialize cached ASan
        # alternates. Alternate failure is intentionally additive/fail-open.
        build_configs_command = SCRIPT_ROOT / "bin" / "build-configs"
        if self.args.build and config.build_configs and os.access(build_configs_command, os.X_OK):
            candidates = self.backend_candidates()
            command = [
                str(build_configs_command),
                "--target-path", str(self.target_root),
                "--target-toml", str(self.toml), "--all",
            ]
            if candidates:
                command += ["--backend", candidates[0]]
            if self.args.force:
                command.append("--force")
            environment = os.environ.copy()
            if candidates:
                environment.update(ACTIVE_BACKEND=candidates[0], BACKEND=candidates[0])
            completed = subprocess.run(command, env=environment, check=False)
            if completed.returncode:
                log("bootstrap: alternate build configurations could not be prepared; primary build is unaffected")

    def execute(self) -> int:
        self.prepare_source()
        self.seed_config()
        self.llm_bootstrap()
        target_config.parse_toml(self.toml)
        revision = target_config.detect_rev(self.target_root)
        log(f"Source: {self.target_root}")
        log(f"Config: {self.toml}")
        if revision:
            log(f"Revision: {revision}")
        config = target_config.Config(target_root=str(self.target_root))
        target_config.load_toml_into(config, self.toml)
        self.language_build(config)
        self.sanitizer_builds(config)
        self.runner_bootstrap()
        print(f"\nNext steps:\n  1. Review output/{self.name}/target.toml.\n  2. Smoke-test with: bin/audit --target {self.name} --backend <claude|codex|gemini|grok|oss> 1")
        return 0


def main(argv: list[str] | None = None) -> int:
    try:
        return Setup(parse_args(sys.argv[1:] if argv is None else argv)).execute()
    except (ValueError, RuntimeError, OSError, subprocess.CalledProcessError) as exc:
        print(f"[setup-target] FATAL: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
