#!/usr/bin/env bash
# Clone or update a target checkout under targets/<target>, then seed
# output/<target>/target.toml for the audit harness.
set -euo pipefail

SCRIPT_ROOT="${AUDIT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$SCRIPT_ROOT/lib/target_config.sh"
source "$SCRIPT_ROOT/lib/platform.sh"

usage() {
  cat <<'EOF'
Usage:
  bin/setup-target <target> [repo URL | local source dir] [options]

The second argument may be a remote repo URL or a path to a local source
directory:
  * a remote URL — or a local directory that is its own git/hg checkout — is
    cloned into targets/<target> as an isolated checkout;
  * a local directory with no VCS metadata is symlinked into targets/<target>
    instead (never copied, pulled, or fetched) and seeds a local-only "no VCS"
    target (upstream_url = FILL_ME, pinned_rev = norev), so the generated
    reproduce.sh asks for a checkout path rather than trying to clone.

Options:
  --repo-type <auto|git|hg>
                           Source repo type (default: auto)
  --ref <ref>             Branch, tag, bookmark, or revision to check out
  --no-update             When a repo URL/ref is supplied, do not pull/fetch an existing checkout
  --force, --force-config
                           Regenerate output/<target>/target.toml and overwrite
                           LLM-suggested [threat_model] / [s6_peers] sections
  --build                 Optional: build the checkout now instead of letting the
                            first `bin/audit` build it lazily. setup-target does NOT
                            build by default — bin/audit (and bin/benchmark, which
                            runs through it) (re)builds a missing or stale native
                            ASan tree automatically at audit time, fail-open. Pass
                            --build only to pre-warm or verify the build up front.
                            Runs whichever of these apply to the detected build system:
                              * Language build (python: setup.py build_ext --inplace;
                                rust: cargo build; go: go build ./...; swift: swift
                                build; npm: npm install; php: composer install;
                                ruby: bundle install).
                              * Sanitizer build recipe convergence for C/C++ targets
                                (cmake / autotools / meson) — calls bin/auto-build-script
                                for each sanitizer in [sanitizer].enabled and writes the
                                validated script to targets/<target>/.audit/build.sh (ASan)
                                or .audit/build-<san>.sh, then materializes each build-<san>
                                tree. ASan is required; extra sanitizers are best-effort.
                                bin/export-repro later inlines the ASan script verbatim into
                                each reproduce.sh so maintainers get the same build.
                            Skips each step silently when its inputs are absent
                            (no manifest, no LLM backend, no recognised C/C++
                            build system, recipe already exists).
  --no-llm-config         Skip LLM-backed target.toml enrichment
  -h, --help              Show this help

Examples:
  bin/setup-target pcre2 https://github.com/PCRE2Project/pcre2
  bin/setup-target pcre2
  bin/setup-target firefox https://hg.mozilla.org/mozilla-unified --repo-type hg
  bin/setup-target myparser ~/code/myparser
  bin/setup-target oss-python-pyyaml --build
EOF
}

log() {
  printf '[setup-target] %s\n' "$*"
}

die() {
  printf '[setup-target] FATAL: %s\n' "$*" >&2
  exit 1
}

TARGET_NAME=""
REPO_URL=""
REPO_TYPE="auto"
REF=""
NO_UPDATE=0
FORCE_CONFIG=0
FORCE_CONFIG_FLAG=""
RUN_BUILD=0
RUN_LLM_CONFIG=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo-type)
      [ "$#" -ge 2 ] || die "$1 requires a value"
      REPO_TYPE="$2"; shift 2 ;;
    --repo-type=*)
      REPO_TYPE="${1#--repo-type=}"; shift ;;
    --ref)
      [ "$#" -ge 2 ] || die "--ref requires a value"
      REF="$2"; shift 2 ;;
    --ref=*)
      REF="${1#--ref=}"; shift ;;
    --no-update)
      NO_UPDATE=1; shift ;;
    --force|--force-config)
      FORCE_CONFIG=1
      FORCE_CONFIG_FLAG="$1"
      shift ;;
    --build)
      RUN_BUILD=1; shift ;;
    --no-llm-config)
      RUN_LLM_CONFIG=0; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --*)
      die "unknown option: $1" ;;
    *)
      if [ -z "$TARGET_NAME" ]; then
        TARGET_NAME="$1"
      elif [ -z "$REPO_URL" ]; then
        REPO_URL="$1"
      else
        die "unexpected argument: $1"
      fi
      shift ;;
  esac
done

[ -n "$TARGET_NAME" ] || { usage >&2; exit 1; }
# A target name is a relative path under targets/, so a nested target such as
# samples/sample-ruby is allowed. Each '/'-separated component must be a plain
# name (letters, numbers, dot, underscore, dash); reject anything that could
# escape the tree (absolute, empty, '.'/'..', hidden, or doubled slashes).
case "$TARGET_NAME" in
  /*|*/) die "target name must not start or end with '/'" ;;
  *//*) die "target name must not contain an empty path component ('//')" ;;
esac
_tn="$TARGET_NAME"
while :; do
  _comp="${_tn%%/*}"
  case "$_comp" in
    ''|.|..|.*) die "each target path component must be a plain name (no '.', '..', or leading dot)" ;;
    *[!A-Za-z0-9._-]*) die "target components may contain only letters, numbers, dot, underscore, or dash" ;;
    # 'output'/'benchmark' are harness-reserved directory names: target-root
    # enumeration (lib/target_config.iter_target_roots) treats a nested output/
    # as a benchmark repo-root facade boundary and skips the top-level benchmark
    # artifact tree, so a target named with either component would be silently
    # un-enumerable. Reject them here to keep that invariant sound.
    output|benchmark) die "'$_comp' is a reserved directory name and cannot be a target path component" ;;
  esac
  [ "$_tn" = "$_comp" ] && break
  _tn="${_tn#*/}"
done
unset _tn _comp
case "$REPO_TYPE" in auto|git|hg) ;; *) die "--repo-type must be auto, git, or hg" ;; esac

TARGET_ROOT="$SCRIPT_ROOT/targets/$TARGET_NAME"
CONFIG_DIR="$SCRIPT_ROOT/output/$TARGET_NAME"
TARGET_TOML="$CONFIG_DIR/target.toml"

detect_repo_type() {
  local root="$1" url="${2:-}"
  if [ -d "$root" ]; then
    target_detect_repo_type "$root"
    return
  fi
  if [ -n "$url" ]; then
    if [ -d "$url" ]; then
      local url_type
      url_type="$(target_detect_repo_type "$url")"
      if [ "$url_type" != "none" ]; then
        printf '%s\n' "$url_type"; return
      fi
    fi
    case "$url" in
      *hg.mozilla.org*|hg:*|*.hg) printf 'hg\n'; return ;;
    esac
  fi
  printf 'git\n'
}

git_dirty() {
  [ -n "$(git -C "$1" status --porcelain 2>/dev/null)" ]
}

hg_dirty() {
  [ -n "$(hg --cwd "$1" status 2>/dev/null)" ]
}

# Point targets/<target> at an existing local non-VCS directory via symlink
# instead of cloning. Used when the source argument is a plain source tree (no
# .git / .hg) the operator wants audited in place: it is never copied, pulled,
# or fetched, and seeds a local-only "no VCS" target. A local directory that is
# its own git/hg checkout goes through clone_target instead.
link_target() {
  local src="$1" dest
  dest="$(cd "$src" 2>/dev/null && pwd)" || die "source directory not found: $src"
  [ -d "$dest" ] || die "source is not a directory: $dest"
  mkdir -p "$(dirname "$TARGET_ROOT")"
  if [ -L "$TARGET_ROOT" ]; then
    log "Re-pointing targets/$TARGET_NAME -> $dest"
    rm -f "$TARGET_ROOT"
  elif [ -e "$TARGET_ROOT" ]; then
    die "targets/$TARGET_NAME already exists and is not a symlink; remove it first to symlink a different source"
  fi
  ln -s "$dest" "$TARGET_ROOT"
  log "Symlinking targets/$TARGET_NAME -> $dest (local non-VCS source; not cloned, pulled, or fetched)"
}

clone_target() {
  local repo_type="$1"
  [ -n "$REPO_URL" ] || die "targets/$TARGET_NAME does not exist; pass a repo URL to clone it"
  mkdir -p "$(dirname "$TARGET_ROOT")"
  case "$repo_type" in
    git)
      log "Cloning git source into targets/$TARGET_NAME"
      git clone "$REPO_URL" "$TARGET_ROOT"
      if [ -n "$REF" ]; then
        git -C "$TARGET_ROOT" checkout "$REF"
      fi
      ;;
    hg)
      log "Cloning hg source into targets/$TARGET_NAME"
      if [ -n "$REF" ]; then
        hg clone -u "$REF" "$REPO_URL" "$TARGET_ROOT"
      else
        hg clone "$REPO_URL" "$TARGET_ROOT"
      fi
      ;;
  esac
}

sync_git() {
  if git_dirty "$TARGET_ROOT"; then
    log "targets/$TARGET_NAME has local changes; leaving source checkout untouched"
    return
  fi
  log "Fetching git updates for targets/$TARGET_NAME"
  if [ -n "$REF" ]; then
    git -C "$TARGET_ROOT" fetch --tags origin "$REF" || git -C "$TARGET_ROOT" fetch --tags origin
    git -C "$TARGET_ROOT" checkout "$REF"
  else
    git -C "$TARGET_ROOT" fetch --tags origin
  fi
  if git -C "$TARGET_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    git -C "$TARGET_ROOT" pull --ff-only
  else
    log "No upstream tracking branch; fetched updates without changing HEAD"
  fi
}

sync_hg() {
  if hg_dirty "$TARGET_ROOT"; then
    log "targets/$TARGET_NAME has local changes; leaving source checkout untouched"
    return
  fi
  log "Pulling hg updates for targets/$TARGET_NAME"
  hg --cwd "$TARGET_ROOT" pull
  if [ -n "$REF" ]; then
    hg --cwd "$TARGET_ROOT" update -r "$REF"
  else
    hg --cwd "$TARGET_ROOT" update
  fi
}

if [ -d "$TARGET_ROOT" ]; then
  DETECTED_REPO_TYPE="$(detect_repo_type "$TARGET_ROOT" "$REPO_URL")"
  [ "$REPO_TYPE" = "auto" ] || [ "$REPO_TYPE" = "$DETECTED_REPO_TYPE" ] || \
    die "targets/$TARGET_NAME is $DETECTED_REPO_TYPE, not $REPO_TYPE"
  if [ "$DETECTED_REPO_TYPE" = "none" ]; then
    if [ -n "$REPO_URL" ] || [ -n "$REF" ]; then
      log "Using existing targets/$TARGET_NAME as a plain source tree (no VCS metadata; repo URL/ref ignored)"
    else
      log "Using existing targets/$TARGET_NAME as a plain source tree"
    fi
    # The tree has no VCS to clone from, so an ignored URL must not be recorded
    # as the upstream — that would produce dishonest export-repro metadata and
    # point reproduce.sh at the wrong source. Seed introspection records a
    # local-only (FILL_ME / norev) target instead.
    REPO_URL=""
  elif [ "$NO_UPDATE" -eq 1 ] || { [ -z "$REPO_URL" ] && [ -z "$REF" ]; }; then
    log "Using existing targets/$TARGET_NAME without updating"
  elif [ "$DETECTED_REPO_TYPE" = "git" ]; then
    sync_git
  else
    sync_hg
  fi
elif [ -n "$REPO_URL" ] && [ -d "$REPO_URL" ] && \
     [ "$(target_detect_repo_type "$REPO_URL")" = "none" ]; then
  # The source argument is a local directory with no VCS metadata. An explicit
  # --repo-type git|hg contradicts that, so fail clearly rather than silently
  # symlinking (mirrors the type-mismatch check for existing checkouts above).
  [ "$REPO_TYPE" = "auto" ] || \
    die "$REPO_URL is a plain source tree, not a $REPO_TYPE repo; omit --repo-type to symlink it"
  # Symlink it in place rather than failing on `git clone <plain dir>`; seed
  # introspection (REPO_URL cleared) then records a local-only no-VCS target.
  link_target "$REPO_URL"
  REPO_URL=""
else
  DETECTED_REPO_TYPE="$([ "$REPO_TYPE" = "auto" ] && detect_repo_type "$TARGET_ROOT" "$REPO_URL" || printf '%s\n' "$REPO_TYPE")"
  clone_target "$DETECTED_REPO_TYPE"
fi

mkdir -p "$CONFIG_DIR"
# Reviewed configs are preserved by default. The harness only re-seeds when:
#   * the file is missing (fresh target),
#   * the operator passed --force / --force-config,
#   * an ACTIVE (uncommented) field still holds an unresolved FILL_ME
#     placeholder a re-seed could fill, OR
#   * the file no longer parses as TOML (e.g. an aborted hand-edit).
# In every other case we leave the operator's edits alone — docs/reference/
# target-toml.md promises that `bin/setup-target <slug>` may safely be run
# against an updated checkout without rewriting reviewed config. A bare grep
# for FILL_ME cannot do this: the seed always leaves commented FILL_ME example
# lines, and a local-only target keeps upstream_url = "FILL_ME" as its steady
# state, so grep would re-seed (and wipe edits) on every rerun. The structured
# check parses the TOML and ignores both — see target_config.config-needs-reseed.
#
# The placeholder re-seed is non-destructive: it carries the curated
# [threat_model]/[s6_peers] forward (target_seed_toml_preserving), so filling
# one unrelated FILL_ME cannot discard a hand/LLM-curated threat model or peer
# set. A full re-seed (missing/invalid/--force) regenerates everything.
CONFIG_REASON=""
if [ ! -f "$TARGET_TOML" ]; then
  CONFIG_REASON="missing"
elif [ "$FORCE_CONFIG" -ne 0 ]; then
  CONFIG_REASON="requested"
elif python3 "$SCRIPT_ROOT/lib/target_config.py" config-needs-reseed "$TARGET_TOML" >/dev/null 2>&1; then
  CONFIG_REASON="placeholders"
elif ! SCRIPT_ROOT="$SCRIPT_ROOT" python3 - "$TARGET_TOML" <<'PY' >/dev/null 2>&1
import os, sys
from pathlib import Path
sys.path.insert(0, str(Path(os.environ["SCRIPT_ROOT"]) / "lib"))
from target_config import Config, load_toml_into  # noqa: E402
load_toml_into(Config(), Path(sys.argv[1]))
PY
then
  CONFIG_REASON="invalid"
fi

# A --build invocation is "build what's already set up" and must not rewrite a
# config that still parses. The placeholder re-seed does a full template
# rewrite that discards curated [threat_model]/[s6_peers] (and then the LLM
# bootstrap regenerates them) — fine when an operator runs plain setup-target
# to refresh config, but bin/audit and bin/benchmark shell `setup-target
# --build` at preflight to (re)build lazily, and must never clobber a reviewed
# target.toml as a side effect of an audit. A missing/invalid config still
# seeds (a fresh --build target needs build_system); --force still wins.
if [ "$RUN_BUILD" -eq 1 ] && [ "$CONFIG_REASON" = "placeholders" ]; then
  log "Keeping output/$TARGET_NAME/target.toml as-is (--build does not re-seed; run 'bin/setup-target $TARGET_NAME' without --build to refresh placeholders)"
  CONFIG_REASON=""
fi

# RUN_LLM_AFTER_SEED gates the threat-model/peers LLM bootstrap below. It is
# set only when a FULL re-seed (missing/invalid/--force) wrote the deterministic
# defaults — those are safe for the bootstrap to replace with --force. The
# placeholder refresh deliberately leaves it 0: that path PRESERVES the curated
# [threat_model]/[s6_peers], so running the bootstrap (which forces an
# overwrite) would clobber exactly the sections we just protected.
RUN_LLM_AFTER_SEED=0
if [ -z "$CONFIG_REASON" ]; then
  log "Keeping reviewed output/$TARGET_NAME/target.toml (pass --force to regenerate)"
elif [ "$CONFIG_REASON" = "placeholders" ]; then
  # Surgical refresh: re-render the template (re-detecting metadata, re-emitting
  # build-field placeholders as comments) to clear the stale FILL_ME, but carry
  # the curated [threat_model]/[s6_peers] forward. Filling one unrelated
  # placeholder must never discard a hand/LLM-curated threat model or peer set.
  log "Refreshing output/$TARGET_NAME/target.toml to fill placeholders (preserving curated [threat_model] / [s6_peers])"
  target_seed_toml_preserving "$TARGET_ROOT" "$TARGET_TOML" "$REPO_URL"
else
  case "$CONFIG_REASON" in
    missing) log "Seeding output/$TARGET_NAME/target.toml" ;;
    invalid) log "Refreshing output/$TARGET_NAME/target.toml because it no longer parses as TOML" ;;
    requested) log "Regenerating output/$TARGET_NAME/target.toml (${FORCE_CONFIG_FLAG:-"--force"})" ;;
  esac
  target_seed_toml "$TARGET_ROOT" "$TARGET_TOML" "$REPO_URL"
  RUN_LLM_AFTER_SEED=1
fi

append_unique_backend() {
  local candidate="$1"
  case "$candidate" in claude|codex|gemini|oss) ;; *) return 0 ;; esac
  case " $LLM_BACKEND_CANDIDATES " in
    *" $candidate "*) return 0 ;;
  esac
  LLM_BACKEND_CANDIDATES="${LLM_BACKEND_CANDIDATES:+$LLM_BACKEND_CANDIDATES }$candidate"
}

build_llm_backend_candidates() {
  LLM_BACKEND_CANDIDATES=""
  local requested="${ACTIVE_BACKEND:-${BACKEND:-${AUDIT_BACKEND:-}}}"
  if [ -n "$requested" ] && [ "$requested" != "all" ]; then
    append_unique_backend "$requested"
  fi
  append_unique_backend claude
  append_unique_backend codex
  append_unique_backend gemini
  if [ "$requested" = "oss" ] || [ -n "${MODEL:-${AUDIT_MODEL:-}}" ]; then
    append_unique_backend oss
  fi
}

run_llm_config_bootstrap() {
  # Only after a full re-seed (missing/invalid/--force). A placeholder refresh
  # preserves curated [threat_model]/[s6_peers], so it leaves this 0 to avoid a
  # --force overwrite of the sections it just protected.
  [ "$RUN_LLM_AFTER_SEED" -eq 1 ] || return 0
  if [ "$RUN_LLM_CONFIG" -eq 0 ]; then
    log "LLM config bootstrap skipped (--no-llm-config)"
    return 0
  fi
  if [ "${AUDIT_NEW_TARGET_BOOTSTRAP:-1}" = "0" ]; then
    log "LLM config bootstrap skipped (AUDIT_NEW_TARGET_BOOTSTRAP=0)"
    return 0
  fi
  if [ "${LLM_DECIDE_DISABLE:-0}" = "1" ]; then
    log "LLM config bootstrap skipped (LLM_DECIDE_DISABLE=1)"
    return 0
  fi

  build_llm_backend_candidates
  if [ -z "$LLM_BACKEND_CANDIDATES" ]; then
    log "LLM config bootstrap skipped (no candidate backends)"
    return 0
  fi

  # Translate a helper name into the section + invocation it owns, so
  # the rotation summary can point operators at the right hand-edit. Two
  # callers today; the case statement is the single source of truth.
  helper_section() {
    case "$1" in
      suggest-threat-model) printf '%s\n' "[threat_model]" ;;
      suggest-peers)        printf '%s\n' "[s6_peers]" ;;
      *)                    printf '%s\n' "<section>" ;;
    esac
  }

  local helper backend rc success helper_args
  local -a attempts
  local next_backend section
  for helper in suggest-threat-model suggest-peers; do
    [ -x "$SCRIPT_ROOT/bin/$helper" ] || continue
    success=0
    attempts=()
    helper_args=("$TARGET_NAME" --apply)
    if [ "$helper" = "suggest-threat-model" ]; then
      # setup-target has just written the deterministic seed, so replacing
      # that generated default is safe. Existing operator-curated configs can
      # still be protected by running the helper directly without --force.
      helper_args+=("--force")
    elif [ "$FORCE_CONFIG" -ne 0 ]; then
      helper_args+=("--force")
    fi
    # Convert space-separated candidate string into a positional list so
    # we can name the next backend in the per-attempt rotation log.
    # shellcheck disable=SC2206  # word-splitting is intentional
    local -a candidates=($LLM_BACKEND_CANDIDATES)
    local i
    for (( i=0; i<${#candidates[@]}; i++ )); do
      backend="${candidates[$i]}"
      next_backend="${candidates[$((i+1))]:-}"
      rc=0
      # LLM_BOOTSTRAP_QUIET=1 silences the helper's own per-attempt
      # warning; this rotation log is the authoritative narrator.
      SCRIPT_ROOT="$SCRIPT_ROOT" ACTIVE_BACKEND="$backend" BACKEND="$backend" \
        LLM_BOOTSTRAP_QUIET=1 \
        "$SCRIPT_ROOT/bin/$helper" "${helper_args[@]}" || rc=$?
      case "$rc" in
        0)
          log "config bootstrap: $helper succeeded on backend=$backend — updated output/$TARGET_NAME/target.toml"
          success=1
          break
          ;;
        4)
          log "config bootstrap: $helper kept the existing curated section on backend=$backend — rerun setup-target with --force to overwrite"
          success=1
          break
          ;;
        *)
          attempts+=("$backend(rc=$rc)")
          if [ -n "$next_backend" ]; then
            log "config bootstrap: $helper returned rc=$rc on backend=$backend — retrying with backend=$next_backend"
          else
            log "config bootstrap: $helper returned rc=$rc on backend=$backend — no remaining backends"
          fi
          ;;
      esac
    done
    if [ "$success" -eq 0 ]; then
      section="$(helper_section "$helper")"
      log "config bootstrap: $helper could not generate $section after trying [${attempts[*]}] — hand-edit output/$TARGET_NAME/target.toml or fix backend credentials and rerun 'bin/$helper $TARGET_NAME --apply' (see lib/llm_decide.log for call telemetry)"
    fi
  done
}

run_llm_config_bootstrap

python3 "$SCRIPT_ROOT/lib/target_config.py" parse-toml "$TARGET_TOML" >/dev/null || \
  die "target config does not parse: $TARGET_TOML"

REV="$(target_detect_rev "$TARGET_ROOT" || true)"
log "Source: $TARGET_ROOT"
log "Config: $TARGET_TOML"
[ -n "$REV" ] && log "Revision: $REV"

# Auto-bootstrap when the source tree carries ABI-mismatched Python
# extensions. Generic — `lib/languages.py stale-python-extensions`
# scans the checkout for `*.cpython-<tag>-*.so` files whose tag does
# not match the active interpreter, ignoring bases that already have a
# matching-tag sibling. This catches the pyyaml-style failure where a
# prebuilt cp39 `.so` blocks every C-side card under cp314 without
# anything in setup-target's path being target-specific.
if [ "$RUN_BUILD" -eq 0 ] && [ -d "$TARGET_ROOT" ]; then
  STALE_PY_EXTS="$(python3 "$SCRIPT_ROOT/lib/languages.py" \
                     stale-python-extensions "$TARGET_ROOT" 2>/dev/null || true)"
  if [ -n "$STALE_PY_EXTS" ]; then
    STALE_COUNT="$(printf '%s\n' "$STALE_PY_EXTS" | wc -l | tr -d ' ')"
    log "ABI mismatch: ${STALE_COUNT} Python extension(s) built for a non-active interpreter — forcing a build"
    log "  first stale: $(printf '%s\n' "$STALE_PY_EXTS" | head -1)"
    RUN_BUILD=1
  fi
fi

# Read build_system out of the freshly-written target.toml. Used by
# both the language-bootstrap step below and the sanitizer build-recipe
# convergence step further down — keep this read at top scope so both
# can see it.
BUILD_SYSTEM="$(python3 - "$SCRIPT_ROOT" "$TARGET_TOML" <<'PY'
import sys
from pathlib import Path
sys.path.insert(0, str(Path(sys.argv[1]) / "lib"))
import target_config as tc
parsed = tc.parse_toml(Path(sys.argv[2]))
bs = parsed.get("build_system", "")
print(bs if isinstance(bs, str) else "")
PY
)"

# Optional language-specific bootstrap. Asks the language registry for
# the full plan (commands, last-command fallback alternatives, env, and
# maintained fuzz backends) for the detected build_system. The plan is
# release-mode: NDEBUG / -O2 / -c release / --release flow through
# `sanitizer_env`, with no debug asserts that produce noise rather than
# security signal. All output is tee'd to TARGET_ROOT/.audit/bootstrap.log
# so failures are diagnosable; the actual recipe that worked is
# persisted to TARGET_ROOT/.audit/bootstrap.sh for reproducible reruns.
if [ "$RUN_BUILD" -eq 1 ]; then
  if [ -z "$BUILD_SYSTEM" ]; then
    log "bootstrap: skipped (no build_system in $TARGET_TOML)"
  else
    LANG_NAME="$(python3 "$SCRIPT_ROOT/lib/languages.py" supports-build-system "$BUILD_SYSTEM" 2>/dev/null || true)"
    if [ -z "$LANG_NAME" ]; then
      log "bootstrap: skipped (build_system='$BUILD_SYSTEM' is not registered in lib/languages.py)"
    else
      BOOTSTRAP_PLAN="$(python3 "$SCRIPT_ROOT/lib/languages.py" bootstrap-plan \
                          "$BUILD_SYSTEM" "$TARGET_ROOT" 2>/dev/null || echo '{}')"
      # Surface maintained fuzz backends up front so the operator
      # sees what's auditable for this target. Empty tuple = no
      # first-class instrumentation; we say so honestly rather
      # than pretending.
      FUZZ_BACKENDS="$(printf '%s' "$BOOTSTRAP_PLAN" | python3 -c \
        'import json,sys; p=json.load(sys.stdin); print(" ".join(p.get("fuzz_backends") or []))')"
      if [ -n "$FUZZ_BACKENDS" ]; then
        log "bootstrap: fuzz backends for $LANG_NAME: $FUZZ_BACKENDS"
      else
        log "bootstrap: fuzz backends for $LANG_NAME: (none registered — no maintained toolchain)"
      fi
      CMD_COUNT="$(printf '%s' "$BOOTSTRAP_PLAN" | python3 -c \
        'import json,sys; print(len(json.load(sys.stdin).get("cmds") or []))')"
      if [ "$CMD_COUNT" -eq 0 ]; then
        log "bootstrap: skipped ($LANG_NAME has no bootstrap commands, or required manifest is absent in $TARGET_ROOT)"
      else
        log "bootstrap: running $CMD_COUNT $LANG_NAME release-mode command(s) in $TARGET_ROOT"
        mkdir -p "$TARGET_ROOT/.audit"
        BOOTSTRAP_LOG="$TARGET_ROOT/.audit/bootstrap.log"
        BOOTSTRAP_SH="$TARGET_ROOT/.audit/bootstrap.sh"
        # The executor below honours the no-shell-expansion contract
        # (argv lists, never `bash -c "$cmd"`) and writes a final
        # bootstrap.sh that maintainers can rerun verbatim.
        if ! BOOTSTRAP_LOG="$BOOTSTRAP_LOG" BOOTSTRAP_SH="$BOOTSTRAP_SH" \
             python3 - "$TARGET_ROOT" "$BOOTSTRAP_PLAN" <<'PY'
import json, os, subprocess, sys, shlex
target_root, plan_json = sys.argv[1], sys.argv[2]
plan = json.loads(plan_json)
cmds: list[list[str]] = plan.get("cmds") or []
alternatives: list[list[str]] = plan.get("alternatives") or []
env_pairs: list[list[str]] = plan.get("env") or []

log_path = os.environ["BOOTSTRAP_LOG"]
sh_path = os.environ["BOOTSTRAP_SH"]

env = os.environ.copy()
for k, v in env_pairs:
    env[k] = v

# Open the bootstrap log once and tee each subprocess into it AND
# this process's stdout, so the operator sees failures inline and
# also has a forensic record under .audit/bootstrap.log.
recipe_lines: list[str] = [
    "#!/usr/bin/env bash",
    "# Auto-generated by bin/setup-target --build. Reproduces the",
    "# release-mode sanitizer build that the audit harness ran against.",
    "set -euo pipefail",
    f'cd "$(dirname "$0")/.."',  # .audit/bootstrap.sh → target root
]
for k, v in env_pairs:
    recipe_lines.append(f"export {k}={shlex.quote(v)}")

def run(argv: list[str]) -> int:
    msg = f"[setup-target] bootstrap: {' '.join(shlex.quote(a) for a in argv)}\n"
    sys.stdout.write(msg); sys.stdout.flush()
    with open(log_path, "a") as logf:
        logf.write(msg)
        logf.flush()
        proc = subprocess.run(
            argv, cwd=target_root, env=env,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
        )
        logf.write(proc.stdout or "")
    # Echo last 40 lines to stdout so the operator sees the failure
    # without having to cat the file.
    if proc.returncode != 0:
        tail = (proc.stdout or "").splitlines()[-40:]
        for line in tail:
            sys.stdout.write(line + "\n")
    else:
        # Show only the summary line on success to keep stdout quiet
        # but informative. Full output is in bootstrap.log.
        last = (proc.stdout or "").rstrip().splitlines()[-1:] or [""]
        if last[0]:
            sys.stdout.write("    " + last[0] + "\n")
    return proc.returncode

# Run each command in order. For the LAST command in `cmds`, if it
# fails, walk the `alternatives` list before giving up. This is the
# npm "ci → install → install --legacy-peer-deps" chain expressed
# generically: alternatives apply to the final step because
# upstream-style commands (pip install + setup.py, or npm ci) are
# already sequenced inside cmds.
final_idx = len(cmds) - 1
for i, cmd in enumerate(cmds):
    rc = run(cmd)
    if rc == 0:
        recipe_lines.append(" ".join(shlex.quote(a) for a in cmd))
        continue
    if i == final_idx and alternatives:
        # The primary final command failed; try each alternative.
        succeeded = False
        for alt in alternatives:
            sys.stdout.write(
                f"[setup-target] bootstrap: primary failed (rc={rc}); trying alternative\n"
            )
            rc = run(alt)
            if rc == 0:
                recipe_lines.append(" ".join(shlex.quote(a) for a in alt))
                succeeded = True
                break
        if not succeeded:
            sys.stderr.write(
                f"[setup-target] bootstrap: all alternatives exhausted (rc={rc}); aborting\n"
            )
            sys.exit(rc)
    else:
        sys.stderr.write(
            f"[setup-target] bootstrap: command failed (rc={rc}); aborting bootstrap\n"
        )
        sys.exit(rc)

# Persist the recipe that worked so reruns and bin/export-repro are
# bit-identical.
with open(sh_path, "w") as fh:
    fh.write("\n".join(recipe_lines) + "\n")
os.chmod(sh_path, 0o755)
sys.stdout.write(f"[setup-target] bootstrap: wrote {sh_path}\n")
PY
        then
          die "bootstrap failed for $TARGET_NAME (see $TARGET_ROOT/.audit/bootstrap.log)"
        fi
        log "bootstrap: completed (log: $TARGET_ROOT/.audit/bootstrap.log, recipe: $TARGET_ROOT/.audit/bootstrap.sh)"
      fi
    fi
  fi
fi

# Sanitizer build-recipe convergence. C/C++ targets need a working ASan
# build script at targets/<slug>/.audit/build.sh so:
#   * bin/export-repro can inline it into each reproduce.sh (the recipe
#     bug fixed in commit 47f0c45 — without this file, reproduce.sh
#     silently falls back to a generic cmake template missing the
#     target-specific flags an audit actually needed),
#   * the maintainer running reproduce.sh and the operator running the
#     audit get a bit-identical build by construction.
#
# bin/auto-build-script discovers the recipe via an LLM-driven
# convergence loop. It needs the same LLM backend run_llm_config_bootstrap
# uses, so we reuse that gating. The call is part of --build; if the
# operator did not pass --build and the recipe is missing, we log a
# one-line hint so the next setup-target run includes it.
NATIVE_BUILD_SYSTEM=0
case "${BUILD_SYSTEM:-}" in
  cmake|autotools|meson) NATIVE_BUILD_SYSTEM=1 ;;
esac

AUDIT_BUILD_SH="$TARGET_ROOT/.audit/build.sh"

# Which sanitizers to converge a recipe + build for. ASan is the canonical,
# always-required build (reproduce.sh, export-repro, and the model-direct
# prompt all assume targets/<slug>/build-asan). Every *additional* sanitizer
# listed in [sanitizer].enabled gets a best-effort per-sanitizer recipe and
# build tree so a later `PROBE_SANITIZER=<san>` run has something to execute;
# a non-ASan build that fails to converge warns but never blocks ASan or the
# rest of setup. auto-build-script only understands the clang -fsanitize
# families, so we limit the loop to those — `race` (Go) and bare `runner`
# targets are not native C/C++ builds and are handled elsewhere.
BOOTSTRAP_SANITIZERS="$(python3 - "$SCRIPT_ROOT" "$TARGET_TOML" <<'PY'
import sys
from pathlib import Path
sys.path.insert(0, str(Path(sys.argv[1]) / "lib"))
import target_config as tc
parsed = tc.parse_toml(Path(sys.argv[2]))
san = parsed.get("sanitizer")
enabled = san.get("enabled") if isinstance(san, dict) else None
if not isinstance(enabled, list) or not enabled:
    enabled = ["asan"]
supported = ("asan", "ubsan", "msan", "tsan")
ordered = []
# ASan first (required), then the rest in declared order, deduped.
for s in ["asan"] + [str(x).lower() for x in enabled]:
    if s in supported and s not in ordered:
        ordered.append(s)
print(" ".join(ordered))
PY
)"
[ -n "$BOOTSTRAP_SANITIZERS" ] || BOOTSTRAP_SANITIZERS="asan"

# Recipe path for a sanitizer. ASan keeps the canonical .audit/build.sh
# (reproduce.sh and export-repro inline that exact path); the others use a
# sibling .audit/build-<san>.sh so each carries its own -fsanitize flags.
_recipe_path_for() {
  case "$1" in
    asan) printf '%s\n' "$AUDIT_BUILD_SH" ;;
    *)    printf '%s\n' "$TARGET_ROOT/.audit/build-$1.sh" ;;
  esac
}

if [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ "$RUN_BUILD" -eq 1 ]; then
  if [ ! -x "$SCRIPT_ROOT/bin/auto-build-script" ]; then
    log "bootstrap: bin/auto-build-script not executable; skipping sanitizer build convergence"
  else
    build_llm_backend_candidates
    for san in $BOOTSTRAP_SANITIZERS; do
      recipe="$(_recipe_path_for "$san")"
      if [ -f "$recipe" ] && [ "$FORCE_CONFIG" -eq 0 ]; then
        log "bootstrap: keeping existing $recipe (pass --force to regenerate)"
        continue
      fi
      if [ -z "$LLM_BACKEND_CANDIDATES" ]; then
        log "bootstrap: no LLM backend configured; skipping $san build convergence (set up a backend and rerun with --build)"
        continue
      fi
      log "bootstrap: converging $san build recipe via bin/auto-build-script (this may take a few minutes and one or more LLM revisions)"
      success=0
      # shellcheck disable=SC2206  # word-splitting is intentional
      _abs_candidates=($LLM_BACKEND_CANDIDATES)
      _abs_attempts=()
      _abs_i=0
      for backend in "${_abs_candidates[@]}"; do
        next_backend="${_abs_candidates[$((_abs_i+1))]:-}"
        _abs_i=$((_abs_i+1))
        rc=0
        SCRIPT_ROOT="$SCRIPT_ROOT" ACTIVE_BACKEND="$backend" BACKEND="$backend" \
          "$SCRIPT_ROOT/bin/auto-build-script" \
            --src "$TARGET_ROOT" \
            --out "$recipe" \
            --sanitizer "$san" || rc=$?
        if [ "$rc" -eq 0 ]; then
          log "bootstrap: auto-build-script ($san) succeeded on backend=$backend — wrote $recipe"
          success=1
          break
        fi
        _abs_attempts+=("$backend(rc=$rc)")
        if [ -n "$next_backend" ]; then
          log "bootstrap: auto-build-script ($san) returned rc=$rc on backend=$backend — retrying with backend=$next_backend"
        else
          log "bootstrap: auto-build-script ($san) returned rc=$rc on backend=$backend — no remaining backends"
        fi
      done
      if [ "$success" -eq 0 ]; then
        if [ "$san" = asan ]; then
          log "bootstrap: auto-build-script did not converge after trying [${_abs_attempts[*]}] — rerun with --build once the upstream build error visible above is resolvable, or write $recipe by hand"
        else
          log "bootstrap: auto-build-script ($san) did not converge after trying [${_abs_attempts[*]}] — $san is best-effort, ASan is unaffected; resolve the build error above and rerun, or write $recipe by hand"
        fi
      fi
    done
  fi
elif [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ ! -f "$AUDIT_BUILD_SH" ]; then
  log "hint: $TARGET_NAME is a $BUILD_SYSTEM target with no $AUDIT_BUILD_SH yet; bin/audit converges an ASan build recipe and builds it automatically on first run (pass --build here to do it now instead)"
fi

# Materialize each enabled sanitizer's build and record the binary/library
# it produces, so --build is self-sufficient (recipe + build + filled
# config). auto-build-script validates the recipe in a throwaway scratch
# dir, so on a fresh target targets/<slug>/build-<san> never exists, and the
# early config seed — which must run before any build, to supply
# build_system — could not detect <san>_bin/<san>_lib and left them
# commented FILL_ME. Build once per sanitizer into its canonical dir with the
# converged recipe, then patch every detected field into target.toml in place
# (refresh-build-fields already loops over asan/ubsan/msan/tsan), leaving the
# LLM-curated sections untouched. (reproduce.sh self-discovers the library at
# run time regardless; this makes the config accurate for the model-direct
# prompt recipe, bin/run-asan, and bin/probe.) ASan is required; a failed
# non-ASan build warns but does not abort setup.
#
# Build when the tree is missing OR stale (a source pull/edit since the last
# build), then stamp it. The freshness probe + stamp are the same ones
# bin/audit and bin/benchmark use to (re)build lazily, so a manual --build and
# an audit-time build converge on identical state. A re-run of the recipe over
# an existing build-<san> is an incremental rebuild (cmake/make pick up only
# changed sources); we do not wipe the tree.
if [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && [ "$RUN_BUILD" -eq 1 ]; then
  for san in $BOOTSTRAP_SANITIZERS; do
    recipe="$(_recipe_path_for "$san")"
    [ -f "$recipe" ] || continue
    SAN_BUILD_DIR="$TARGET_ROOT/build-$san${AUDIT_BUILD_SUFFIX:-}"
    freshness="$(python3 "$SCRIPT_ROOT/lib/target_config.py" \
                   build-freshness "$TARGET_ROOT" "$san" 2>/dev/null || echo missing)"
    # Build unless the tree is confirmed fresh — missing/stale (and any
    # unexpected value) all (re)build, erring toward a harmless incremental
    # recipe re-run rather than skipping and leaving a stale binary.
    if [ "$freshness" != fresh ]; then
      log "bootstrap: materializing $san build into $SAN_BUILD_DIR (source is $freshness; compiling so <san>_bin/<san>_lib can be detected; a few minutes)"
      mkdir -p "$TARGET_ROOT/.audit"
      if "$recipe" "$TARGET_ROOT" "$SAN_BUILD_DIR" \
           >> "$TARGET_ROOT/.audit/build-materialize.log" 2>&1; then
        python3 "$SCRIPT_ROOT/lib/target_config.py" \
          build-write-stamp "$TARGET_ROOT" "$san" 2>/dev/null || true
        log "bootstrap: $san build complete"
      elif [ "$san" = asan ]; then
        log "bootstrap: canonical ASan build failed (see $TARGET_ROOT/.audit/build-materialize.log); reproduce.sh still self-discovers the library at run time"
      else
        log "bootstrap: $san build failed (see $TARGET_ROOT/.audit/build-materialize.log); $san is best-effort, ASan is unaffected"
      fi
    fi
    # macOS: bake each built dylib/exe debug map into a self-contained .dSYM so
    # the audit's offline symbolizer (which prefers llvm-symbolizer, and
    # llvm-symbolizer cannot follow a Mach-O debug map) resolves library crash
    # frames to file:line. Run for any existing build dir, not just a fresh
    # rebuild, so an already-fresh build is repaired without recompiling.
    # Idempotent (skips up-to-date .dSYMs); best-effort; no-op on Linux. Done in
    # the materialization path, not the recipe, so it covers existing
    # .audit/build.sh files without regeneration and survives LLM revisions.
    audit_make_dsyms "$SAN_BUILD_DIR" \
      >> "$TARGET_ROOT/.audit/build-materialize.log" 2>&1 || true
  done
fi

# Re-detect <san>_bin/<san>_lib from whatever build trees are on disk and patch
# them into target.toml in place. This is a surgical line edit, not a re-seed,
# so curated sections survive — which is why it runs on every native rerun, not
# just --build: it is how the documented "build, then rerun setup-target to
# re-inspect" flow fills the fields the pre-build seed had to leave commented.
# A no-op when no build exists yet.
if [ "$NATIVE_BUILD_SYSTEM" -eq 1 ] && \
   [ "$(python3 "$SCRIPT_ROOT/lib/target_config.py" refresh-build-fields "$TARGET_ROOT" "$TARGET_TOML" 2>/dev/null)" = "changed" ]; then
  log "Refreshed <san>_bin/<san>_lib in $TARGET_TOML from build trees on disk"
fi

cat <<EOF

Next steps:
  1. Review output/$TARGET_NAME/target.toml and edit only unresolved or target-specific fields.
  2. Smoke-test with: bin/audit --target $TARGET_NAME --backend <claude|codex|gemini|oss> 1
EOF
