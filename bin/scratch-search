#!/usr/bin/env python3
"""Search audit scratch, corpus, crash, and finding artifacts by section."""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))
from command_tools import find_executable
from file_tools import clipped_prefix_bytes


USAGE = """scratch-search — search across all audit artifacts under $RESULTS_DIR.

Usage:
  bin/scratch-search [options] PATTERN

Options:
  --section A,B,...   restrict to named sections (default: all)
  --lines             show matching file:line:body output
  --files-only        list paths only (default)
  --include-asan      include sanitizer sidecars
  --include-logs      include *.log / *.log.raw
  --cap N             per-section line cap (default 40)
  --cap-bytes N       per-section byte cap (default 8192)
  -i / -w / -F / -e / --glob   pass through to rg
"""


def fail(message: str, *, usage: bool = False) -> int:
    print(f"[scratch-search] {message}", file=sys.stderr)
    if usage:
        print(USAGE, file=sys.stderr, end="")
    return 2


def parse_args(argv: list[str]) -> tuple[dict[str, object], int]:
    options: dict[str, object] = {
        "pattern": "",
        "section": "",
        "files_only": True,
        "include_asan": False,
        "include_logs": False,
        "cap_lines": "40",
        "cap_bytes": "8192",
        "rg_args": [],
    }
    index = 0
    while index < len(argv):
        arg = argv[index]
        value_options = {
            "--section": "section",
            "--cap": "cap_lines",
            "--cap-bytes": "cap_bytes",
        }
        if arg in value_options:
            if index + 1 >= len(argv):
                return options, fail(f"{arg} needs a value")
            index += 1
            options[value_options[arg]] = argv[index]
        elif arg.startswith("--section="):
            options["section"] = arg.split("=", 1)[1]
        elif arg.startswith("--cap-bytes="):
            options["cap_bytes"] = arg.split("=", 1)[1]
        elif arg.startswith("--cap="):
            options["cap_lines"] = arg.split("=", 1)[1]
        elif arg == "--lines":
            options["files_only"] = False
        elif arg in ("--files-only", "-l"):
            options["files_only"] = True
        elif arg == "--include-asan":
            options["include_asan"] = True
        elif arg == "--include-logs":
            options["include_logs"] = True
        elif arg in ("-h", "--help"):
            print(USAGE, end="")
            return options, 3
        elif arg in (
            "-i",
            "--ignore-case",
            "-w",
            "--word-regexp",
            "-F",
            "--fixed-strings",
            "--smart-case",
            "-S",
        ):
            options["rg_args"].append(arg)  # type: ignore[union-attr]
        elif arg in ("-e", "--regexp", "--glob", "-g"):
            if index + 1 >= len(argv):
                return options, fail(f"{arg} needs a value")
            options["rg_args"].extend((arg, argv[index + 1]))  # type: ignore[union-attr]
            index += 1
        elif arg == "--":
            if index + 1 >= len(argv):
                return options, fail("PATTERN is required", usage=True)
            options["pattern"] = argv[index + 1]
            options["rg_args"].extend(argv[index + 2 :])  # type: ignore[union-attr]
            break
        elif arg.startswith("-"):
            return options, fail(f"unknown option: {arg}", usage=True)
        elif not options["pattern"]:
            options["pattern"] = arg
        else:
            options["rg_args"].append(arg)  # type: ignore[union-attr]
        index += 1
    return options, 0


def section_paths(results: Path, requested: str) -> list[tuple[str, Path]]:
    sections = [(path.name, path) for path in sorted(results.glob("scratch-*")) if path.is_dir()]
    sections.extend(
        (name, results / name)
        for name in ("corpus", "crashes", "crashes-rejected", "findings", "findings-rejected")
        if (results / name).is_dir()
    )
    if requested:
        allowed = set(requested.split(","))
        sections = [section for section in sections if section[0] in allowed]
    return sections


def relative_lines(data: bytes, results: Path) -> bytes:
    prefix = (str(results) + os.sep).encode()
    rendered = []
    for line in data.splitlines(keepends=True):
        if line.startswith(prefix):
            line = line[len(prefix) :]
        rendered.append(b"    " + line)
    return b"".join(rendered)


def emit_section(
    rg: str,
    label: str,
    path: Path,
    results: Path,
    options: dict[str, object],
    exclusions: list[str],
) -> bool:
    files_only = bool(options["files_only"])
    if files_only:
        mode = ["--files-with-matches", "--no-heading", "--color", "never"]
    else:
        mode = [
            "--no-heading",
            "--line-number",
            "--color",
            "never",
            "--max-columns",
            "200",
            "--max-columns-preview",
        ]
    command = [
        rg,
        *mode,
        *exclusions,
        *options["rg_args"],  # type: ignore[misc]
        "--",
        str(options["pattern"]),
        str(path),
    ]
    completed = subprocess.run(
        command, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL
    )
    raw = completed.stdout
    lines = raw.splitlines(keepends=True)
    total_lines = len(lines)
    if files_only:
        total_files = total_lines
    else:
        total_files = len({line.split(b":", 1)[0] for line in lines if line})
    if completed.returncode == 2 or total_lines == 0:
        print(f"[{label}] no matches")
        return False

    file_word = "file" if total_files == 1 else "files"
    match_word = "match" if total_lines == 1 else "matches"
    if files_only:
        print(f"[{label}] {total_files} {file_word}")
    else:
        print(f"[{label}] {total_lines} {match_word} in {total_files} {file_word}")
    sys.stdout.flush()

    cap_lines = int(options["cap_lines"])
    cap_bytes = int(options["cap_bytes"])
    line_capped = cap_lines > 0 and total_lines > cap_lines
    selected = b"".join(lines[:cap_lines] if line_capped else lines)
    selected = relative_lines(selected, results)
    byte_capped = len(selected) > cap_bytes
    if byte_capped:
        selected = clipped_prefix_bytes(selected, cap_bytes)
    sys.stdout.buffer.write(selected)
    sys.stdout.flush()

    if line_capped or byte_capped:
        remaining = max(0, total_lines - cap_lines)
        if files_only:
            print(
                f"    [{remaining} more files in this section. Re-run with narrower "
                f"PATTERN or --lines --section {label} for match bodies.]"
            )
        else:
            print(
                f"    [{remaining} more matches in this section. Re-run with narrower "
                "PATTERN, higher --cap, or default files-only mode to widen path inventory.]"
            )
    elif files_only:
        print(
            f"    [paths only. Re-run with --lines --section {label} for match bodies.]"
        )
    return True


def main(argv: list[str] | None = None) -> int:
    options, status = parse_args(list(sys.argv[1:] if argv is None else argv))
    if status == 3:
        return 0
    if status:
        return status
    if not options["pattern"]:
        return fail("PATTERN is required", usage=True)
    if not str(options["cap_lines"]).isdigit() or not str(options["cap_bytes"]).isdigit():
        return fail("--cap / --cap-bytes must be numeric")

    results_value = os.environ.get("RESULTS_DIR", "")
    if not results_value:
        return fail("RESULTS_DIR not set (run inside an audit session, or export it)")
    results = Path(results_value)
    if not results.is_dir():
        return fail(f"RESULTS_DIR not a directory: {results}")
    wrapper = Path(
        os.environ.get("AGENT_WRAPPERS_PATH", str(ROOT / "lib" / "wrappers"))
    ).resolve()
    rg = find_executable("rg", skip=(wrapper,))
    if not rg:
        return fail("ripgrep (rg) is required")

    sections = section_paths(results, str(options["section"]))
    if not sections:
        print(
            f"[scratch-search] no sections to search (RESULTS_DIR={results}, "
            f"filter='{options['section'] or 'none'}')",
            file=sys.stderr,
        )
        return 1

    exclusions: list[str] = []
    if not options["include_asan"]:
        for pattern in (
            "!**/*.asan.txt",
            "!**/*.ubsan.txt",
            "!**/asan_output*.txt",
            "!**/asan-output*.txt",
        ):
            exclusions.extend(("--glob", pattern))
    if not options["include_logs"]:
        for pattern in ("!**/*.log", "!**/*.log.raw"):
            exclusions.extend(("--glob", pattern))
    for pattern in (
        "!**/.harness-cache/**",
        "!**/*.o",
        "!**/*.a",
        "!**/*.so",
        "!**/*.dylib",
        "!**/*.dSYM/**",
    ):
        exclusions.extend(("--glob", pattern))

    matched = False
    for label, path in sections:
        matched |= emit_section(rg, label, path, results, options, exclusions)
    return 0 if matched else 1


if __name__ == "__main__":
    raise SystemExit(main())
