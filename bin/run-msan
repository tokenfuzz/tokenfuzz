#!/bin/bash
# MemorySanitizer execution wrapper.
# Supports: generic, js, fuzz, fuzz-repro, fuzz-js
#
# Usage: bin/run-msan <mode> <testcase> [args...]
#
# Mode taxonomy:
#   generic          Target CLI or probe-built HARNESS executable. This is the
#                    normal non-browser path used by bin/probe.
#   js               Standalone JS shell (`dist/bin/js`) running a script.
#                    This is normal JS-engine execution, not libFuzzer.
#   fuzz             Standalone libFuzzer target over a corpus. Uses
#                    halt_on_error=0 so a fuzzing session can keep collecting.
#   fuzz-repro       One existing fuzzer crash file, rerun with halt_on_error=1
#                    for a clean single diagnostic.
#   fuzz-js          Standalone SpiderMonkey fuzz-tests binary for JS engine
#                    fuzzers such as Wasm/RegExp/StructuredClone. Different
#                    harness ABI and artifact flow from `js`.
#
# The per-mode dispatch is shared with bin/run-tsan via lib/sanitizer_run.sh;
# this script only declares the MSan-specific option strings and timeouts.
#
# MSan detects reads of uninitialized memory. It is the second-highest-signal
# sanitizer after ASan but requires that *every* dependency in the program
# (including libc++) be MSan-instrumented — interceptor gaps cause noise.
# Self-contained libraries (libxml2, pcre2, libpng, …) are good MSan targets;
# browsers are not, which is why no browser/xpcshell modes are wired here.
#
# Reads target paths and per-target suppressions from output/<slug>/target.toml.
#
# Timeout env vars (all optional):
#   MSAN_TIMEOUT             — overrides js/generic defaults
#   FUZZ_MSAN_TIMEOUT        — fuzz-mode timeout (default 600)
#   MSAN_FUZZ_REPRO_TIMEOUT  — fuzz-repro timeout (default 20)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$REPO_ROOT/lib/timeout.sh"
# shellcheck source=../lib/target_config.sh
source "$REPO_ROOT/lib/target_config.sh"
# shellcheck source=../lib/sanitizer.sh
source "$REPO_ROOT/lib/sanitizer.sh"
# shellcheck source=../lib/sanitizer_run.sh
source "$REPO_ROOT/lib/sanitizer_run.sh"

_probe_path="${2:-$PWD}"
target_load "$_probe_path" 2>/dev/null || true

sanitizer_prepare_runtime_env msan
sanitizer_warn_if_disabled msan

command -v python3 &>/dev/null || { echo "[run-msan] FATAL: python3 is required" >&2; exit 1; }

MSAN_BUILD_DIR="$(sanitizer_build_dir msan)"

JS_TIMEOUT="${MSAN_TIMEOUT:-10}"
FUZZ_TIMEOUT="${FUZZ_MSAN_TIMEOUT:-600}"
FUZZ_REPRO_TIMEOUT="${MSAN_FUZZ_REPRO_TIMEOUT:-20}"
GENERIC_TIMEOUT="${MSAN_TIMEOUT:-15}"

# Per-mode option strings come from lib/sanitizer_options.conf via
# sanitizer_options_for (lib/sanitizer.sh) — the single source of truth
# shared with bin/export-repro. Do not re-hardcode option strings here.
MSAN_OPTS_FULL="$(sanitizer_options_for msan full)"
MSAN_OPTS_JS="$(sanitizer_options_for msan js)"
MSAN_OPTS_FUZZ="$(sanitizer_options_for msan fuzz)"
MSAN_OPTS_FUZZ_REPRO="$(sanitizer_options_for msan fuzz-repro)"

# Append target.toml [sanitizer].msan_suppressions / msan_options. MSan
# suppressions are how operators silence reads through uninstrumented
# dependencies pending a full clean rebuild.
MSAN_OPTS_FULL="$(sanitizer_compose_options msan "$MSAN_OPTS_FULL")"
MSAN_OPTS_JS="$(sanitizer_compose_options msan "$MSAN_OPTS_JS")"
MSAN_OPTS_FUZZ="$(sanitizer_compose_options msan "$MSAN_OPTS_FUZZ")"
MSAN_OPTS_FUZZ_REPRO="$(sanitizer_compose_options msan "$MSAN_OPTS_FUZZ_REPRO")"

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 {generic|js|fuzz|fuzz-repro|fuzz-js} [args...]"
    exit 1
fi

MODE="$1"; shift
rc=0

case "$MODE" in
    generic)
        sanitizer_run_generic msan "$MSAN_OPTS_FULL" "$GENERIC_TIMEOUT" "$@" || rc=$?
        ;;
    js)
        sanitizer_run_js msan "$MSAN_OPTS_JS" "$JS_TIMEOUT" "$@" || rc=$?
        ;;
    fuzz)
        sanitizer_run_fuzz msan "$MSAN_OPTS_FUZZ" "$FUZZ_TIMEOUT" "$@" || rc=$?
        ;;
    fuzz-repro)
        sanitizer_run_fuzz_repro msan "$MSAN_OPTS_FUZZ_REPRO" "$FUZZ_REPRO_TIMEOUT" "$@" || rc=$?
        ;;
    fuzz-js)
        sanitizer_run_fuzz_js msan "$MSAN_OPTS_FUZZ" "$FUZZ_TIMEOUT" "$@" || rc=$?
        ;;
    *)
        echo "Usage: $0 {generic|js|fuzz|fuzz-repro|fuzz-js} [args...]"
        exit 1
        ;;
esac

exit "$rc"
