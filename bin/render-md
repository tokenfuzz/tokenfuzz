#!/usr/bin/env python3
"""bin/render-md — pad markdown table cells and emit a stylish HTML sibling.

Two outputs from one tool, both deterministic and idempotent:

  1. The markdown file is rewritten in place with each GFM table padded
     to the widest cell per column (alignment markers — `:--`, `--:`,
     `:--:` — are honoured). This makes `cat INDEX.md` actually align.

  2. With `--html` (or `--html-sibling`) a self-contained HTML file is
     emitted next to the input. The template is single-file (no external
     CSS/JS, no network), so the user can open `file:///.../INDEX.html`
     in any browser and have a fully styled, clickable view.

The HTML carries a few touches that earn the "stylish" label without
adding dependencies:

  * **Severity badges**: cells whose text matches Critical / High /
    Medium / Low get a pill-shaped colour-coded label (red, orange,
    yellow, green) so the eye lands on the worst rows first.
  * **Surface chips**: library-api / cli / maint-tool render as small
    chips so QA can scan input surface at a glance.
  * **Cluster ids**: monospace + light background so they read like the
    code references they are.
  * **Sticky table headers**: long INDEX.md tables stay scannable when
    you scroll.
  * **Auto link rewrite**: `[…](foo.md)` is rewritten to `…/foo.html` in
    the HTML output so cross-document links land on the styled sibling.

Markdown features supported (this is not a general renderer — only what
INDEX.md / CLUSTERS.md / REPORT.md actually use):

    # / ## / ### headings, paragraphs, GFM tables (with alignment markers),
    inline links [text](url), inline `code`, **bold**, _italic_, fenced
    ```code blocks```.

Anything outside the set above passes through inside `<p>...</p>`.
"""
from __future__ import annotations

import argparse
import html
import re
import sys
from pathlib import Path

SCRIPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import stack_frames  # noqa: E402


# ─── Markdown table parsing + padding ─────────────────────────────────────


_TABLE_ROW_RE = re.compile(r"^\s*\|.*\|\s*$")
_TABLE_SEP_RE = re.compile(r"^\s*\|?\s*:?-+:?\s*(\|\s*:?-+:?\s*)+\|?\s*$")


def _split_row(raw: str) -> list[str]:
    s = raw.strip()
    if s.startswith("|"):
        s = s[1:]
    if s.endswith("|"):
        s = s[:-1]
    return [c.strip() for c in s.split("|")]


def _alignment_from_sep(sep_row: str) -> list[str]:
    out: list[str] = []
    for cell in _split_row(sep_row):
        c = cell.strip()
        starts = c.startswith(":")
        ends = c.endswith(":")
        if starts and ends:
            out.append("center")
        elif ends:
            out.append("right")
        elif starts:
            out.append("left")
        else:
            out.append("none")
    return out


def _pad_cell(text: str, width: int, align: str) -> str:
    pad = max(0, width - len(text))
    if align == "right":
        return " " * pad + text
    if align == "center":
        left = pad // 2
        right = pad - left
        return " " * left + text + " " * right
    return text + " " * pad


def _pad_table(header: str, sep: str, body: list[str]) -> list[str]:
    cols_h = _split_row(header)
    cols_sep = _split_row(sep)
    rows = [_split_row(r) for r in body]
    if rows:
        n = max(len(cols_h), len(cols_sep), *(len(r) for r in rows))
    else:
        n = max(len(cols_h), len(cols_sep))
    cols_h += [""] * (n - len(cols_h))
    cols_sep += [""] * (n - len(cols_sep))
    rows = [r + [""] * (n - len(r)) for r in rows]

    align = _alignment_from_sep(sep)
    align += ["none"] * (n - len(align))

    widths = [len(cols_h[i]) for i in range(n)]
    for r in rows:
        for i in range(n):
            widths[i] = max(widths[i], len(r[i]))

    sep_cells: list[str] = []
    for i in range(n):
        a = align[i]
        bar_w = max(widths[i], 3)
        if a == "left":
            sep_cells.append(":" + "-" * (bar_w - 1))
        elif a == "right":
            sep_cells.append("-" * (bar_w - 1) + ":")
        elif a == "center":
            sep_cells.append(":" + "-" * (bar_w - 2) + ":")
        else:
            sep_cells.append("-" * bar_w)

    def emit(cells: list[str]) -> str:
        out = []
        for i, c in enumerate(cells):
            a = align[i]
            out.append(_pad_cell(c, widths[i], a if a != "none" else "left"))
        return "| " + " | ".join(out) + " |"

    lines = [emit(cols_h)]
    lines.append("| " + " | ".join(sep_cells) + " |")
    for r in rows:
        lines.append(emit(r))
    return lines


def pad_markdown_tables(text: str) -> str:
    lines = text.splitlines()
    out: list[str] = []
    i = 0
    while i < len(lines):
        line = lines[i]
        nxt = lines[i + 1] if i + 1 < len(lines) else ""
        if _TABLE_ROW_RE.match(line) and _TABLE_SEP_RE.match(nxt):
            header = line
            sep = nxt
            body: list[str] = []
            j = i + 2
            while j < len(lines) and _TABLE_ROW_RE.match(lines[j]):
                body.append(lines[j])
                j += 1
            out.extend(_pad_table(header, sep, body))
            i = j
            continue
        out.append(line)
        i += 1
    if text.endswith("\n"):
        return "\n".join(out) + "\n"
    return "\n".join(out)


# ─── Markdown → HTML (single file, no external assets) ─────────────────────


