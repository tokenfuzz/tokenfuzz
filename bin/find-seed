#!/usr/bin/env python3
"""Locate in-tree testcases likely to exercise a target file or function."""

from __future__ import annotations

import argparse
import fnmatch
import hashlib
import os
import re
import sys
import tempfile
from pathlib import Path


SCRIPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))


SEED_GLOBS = (
    "*.html", "*.htm", "*.xhtml", "*.svg", "*.xml",
    "*.json", "*.yaml", "*.yml", "*.toml", "*.ini", "*.cfg",
    "*.proto", "*.fbs", "*.pem", "*.cer", "*.crt", "*.der",
    "*.conf", "*.input", "*.dat", "*.bin",
    "*.js", "*.mjs", "*.ts", "*.tsx", "*.py", "*.rb", "*.go",
    "*.rs", "*.java", "*.kt", "*.kts", "*.pl", "*.pm", "*.php",
    "*.swift", "*.ml", "*.r", "*.clj", "*.cljs", "*.sh", "*.bash",
    "test*", "*_test*", "*_spec*", "spec_*",
)
DISCOVERY_GLOBS = SEED_GLOBS + (
    "*.css", "*.raw", "test*", "crash-*", "oom-*", "slow-unit-*",
    "*.dict", "*.expect*", "*.golden", "*.R",
)
PRUNE_NAMES = {
    "_build", "dist", ".git", ".hg", "doc", "docs", "man", "man3",
    "CMakeFiles", "node_modules", "venv", ".venv", "__pycache__",
    "target", ".gradle", ".cargo", "vendor", "third_party",
}
STRONG_NAMES = {
    "test", "tests", "testdata", "test_data", "test-data", "fuzz",
    "corpus", "crashtests", "seed", "seeds", "samples", "inputs",
    "regression", "regressions", "spec", "specs", "fixtures", "fixture",
    "examples", "example", "sample", "cases",
}
PARENT_NAMES = {
    "test", "tests", "fuzz", "testdata", "corpus", "crashtests",
    "inputs", "spec", "specs", "fixtures", "examples",
}


def matches_any(name: str, patterns: tuple[str, ...]) -> bool:
    lower = name.lower()
    return any(fnmatch.fnmatch(lower, pattern.lower()) for pattern in patterns)


def pruned(name: str) -> bool:
    return (
        name in PRUNE_NAMES
        or name.startswith(("build-", "obj-"))
        or name.endswith(("-install", ".dSYM"))
    )


def discover_seed_roots(root: Path) -> list[Path]:
    scored = []
    root_depth = len(root.parts)
    for directory, dirnames, filenames in os.walk(root):
        path = Path(directory)
        depth = len(path.parts) - root_depth
        dirnames[:] = [] if depth >= 5 else [name for name in dirnames if not pruned(name)]
        count = sum(1 for name in filenames if matches_any(name, DISCOVERY_GLOBS))
        name = path.name.lower()
        bonus = 10 if name in STRONG_NAMES else 4 if re.search(
            r"test|fuzz|corpus|crashtest|seed|spec|fixture", name
        ) else 0
        if path.parent.name.lower() in PARENT_NAMES:
            bonus += 4
        score = count + bonus * 3
        if score >= 12:
            scored.append((score, path))
    scored.sort(key=lambda row: (-row[0], str(row[1])))
    return [path for _score, path in scored[:25]]


def parse_size(value: str) -> int:
    match = re.fullmatch(r"(\d+)([KMG]?)", value.strip(), re.IGNORECASE)
    if not match:
        raise ValueError(value)
    multiplier = {"": 1, "K": 1024, "M": 1024**2, "G": 1024**3}[match.group(2).upper()]
    return int(match.group(1)) * multiplier


def resolve_target_root() -> Path | None:
    configured = os.environ.get("TARGET_ROOT", "")
    if not configured:
        return None
    path = Path(configured).expanduser()
    return path.resolve() if path.is_dir() else None


def cached_roots(root: Path) -> list[Path]:
    cache_dir = Path(os.environ.get("RESULTS_DIR") or os.environ.get("TMPDIR") or "/tmp")
    override = cache_dir / ".seed-roots"
    digest = hashlib.sha1(str(root).encode()).hexdigest()
    automatic = cache_dir / f".seed-roots.{digest}"
    cache = override if override.exists() and override.stat().st_size > 0 else automatic
    if cache == automatic and (
        not automatic.exists()
        or automatic.stat().st_size == 0
        or root.stat().st_mtime > automatic.stat().st_mtime
    ):
        cache_dir.mkdir(parents=True, exist_ok=True)
        roots = discover_seed_roots(root)
        if roots:
            temporary = None
            try:
                with tempfile.NamedTemporaryFile(
                    mode="w", encoding="utf-8", dir=cache_dir,
                    prefix=f".{automatic.name}.", suffix=".tmp", delete=False,
                ) as output:
                    temporary = Path(output.name)
                    output.write("".join(f"{path}\n" for path in roots))
                os.replace(temporary, automatic)
            finally:
                if temporary is not None:
                    temporary.unlink(missing_ok=True)
        cache = automatic
    if not cache.exists():
        return []
    return [
        path for line in cache.read_text(encoding="utf-8", errors="replace").splitlines()
        if (path := Path(line)).is_dir()
    ]


def candidate_files(roots: list[Path], max_bytes: int):
    seen = set()
    for root in roots:
        for directory, dirnames, filenames in os.walk(root):
            dirnames[:] = [name for name in dirnames if not pruned(name)]
            for filename in filenames:
                if not matches_any(filename, SEED_GLOBS):
                    continue
                path = Path(directory) / filename
                try:
                    if path.stat().st_size > max_bytes:
                        continue
                except OSError:
                    continue
                key = str(path)
                if key not in seen:
                    seen.add(key)
                    yield path


def first_context(path: Path, pattern: re.Pattern[str]) -> str:
    try:
        with path.open(encoding="utf-8", errors="replace") as source:
            for line in source:
                if pattern.search(line):
                    return line.rstrip("\n")[:160]
    except OSError:
        pass
    return "<no-ctx>"


def main() -> int:
    parser = argparse.ArgumentParser(prog="find-seed", description=__doc__)
    parser.add_argument("spec", nargs="?")
    parser.add_argument("max_results", nargs="?", type=int, default=15)
    args = parser.parse_args()
    if not args.spec:
        parser.print_help()
        return 0
    root = resolve_target_root()
    if root is None or not root.is_dir():
        print(
            "[find-seed] TARGET_ROOT not set or not a directory "
            "(run inside an audit session, or export TARGET_ROOT)", file=sys.stderr
        )
        return 2
    file_part, separator, function = args.spec.partition(":")
    stem = Path(file_part).stem
    roots = cached_roots(root)
    if not roots:
        print(
            f"[find-seed] no seed-corpus roots found under {root} - writing from "
            "scratch is fine, seeds are a bootstrap aid, not a requirement",
            file=sys.stderr,
        )
        return 1
    try:
        max_bytes = parse_size(os.environ.get("FIND_SEED_MAX_FILESIZE", "64M"))
    except ValueError:
        max_bytes = 64 * 1024 * 1024
    function_re = re.compile(rf"\b{re.escape(function)}\b", re.IGNORECASE) if separator else None
    stem_re = re.compile(rf"\b{re.escape(stem)}\b", re.IGNORECASE)
    ranked: list[tuple[str, Path, str]] = []
    for path in candidate_files(roots, max_bytes):
        if function_re and first_context(path, function_re) != "<no-ctx>":
            ranked.append(("FUNC", path, first_context(path, function_re)))
        elif first_context(path, stem_re) != "<no-ctx>":
            ranked.append(("STEM", path, first_context(path, stem_re)))
        elif stem.lower() in path.name.lower() or (function and function.lower() in path.name.lower()):
            ranked.append(("NAME", path, "(filename match)"))
    if not ranked:
        print(f"[find-seed] no seeds matched {args.spec} under {root} (writing from scratch is fine)", file=sys.stderr)
        return 1
    order = {"FUNC": 0, "STEM": 1, "NAME": 2}
    ranked.sort(key=lambda row: (order[row[0]], str(row[1])))
    for rank, path, context in ranked[: max(0, args.max_results)]:
        print(f"{rank}\t{path}\t{context}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
