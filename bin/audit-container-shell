#!/usr/bin/env python3
"""Build and enter the disposable TokenFuzz audit container."""

from __future__ import annotations

import argparse
import os
import platform
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path


HELP = r'''Usage:
  bin/audit-container-shell [options]

Reuses the local audit-cli-shell Docker image, mounts this repository at /root/work,
and opens an interactive shell. It does not run bin/audit.
Each container starts logged out; pass --forward-credentials or log in inside.

Options:
  --image <image>       Base image (default: node:lts-bookworm)
  --tag <name>          Image tag (default: audit-cli-shell:latest)
  --runtime <name>      Container CLI; only docker is supported
  --gvisor              Equivalent to --docker-runtime runsc
  --docker-runtime <name>
  --workdir <path>      Container work directory (default: /root/work)
  --env-file <path>     Docker environment file
  --forward-credentials Forward selected host credentials and Google config
  --rebuild             Build or refresh the image
  --dry-run             Print commands without executing them

The image includes Claude Code, Codex, Antigravity CLI (`agy`), Google Gemini
CLI, and Grok Build. Host ~/.claude, ~/.codex, ~/.gemini, and ~/.grok are never
mounted. `IS_SANDBOX=1` is set because the container is the sandbox boundary
for Claude's dangerously-skip-permissions mode.

Authenticating the CLIs:
  # codex login
  # claude
  # agy
  # grok login
Then confirm auth; if a command hangs, press Ctrl+C:
  # codex login status
  # claude -p "Reply exactly: tokenfuzz-claude-auth-ok"
  # agy -p "Reply exactly: tokenfuzz-gemini-auth-ok"
  # grok -p "Reply exactly: tokenfuzz-grok-auth-ok"

Run from /root/work:
  ./bin/audit --backend <backend> --target <target-name> [--model <model>]
'''


DOCKERFILE = r'''ARG BASE_IMAGE=node:lts-bookworm
FROM ${BASE_IMAGE}

ARG CLAUDE_NPM_SPEC=@anthropic-ai/claude-code@latest
ARG CODEX_NPM_SPEC=@openai/codex@latest
ARG GEMINI_CLI_NPM_SPEC=@google/gemini-cli@latest
ARG AGY_INSTALL_URL=https://antigravity.google/cli/install.sh
ARG GROK_INSTALL_URL=https://x.ai/cli/install.sh

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
  if ! command -v node >/dev/null 2>&1 || ! command -v npm >/dev/null 2>&1 || ! command -v curl >/dev/null 2>&1; then \
    if command -v apt-get >/dev/null 2>&1; then \
      apt-get update; apt-get install -y --no-install-recommends nodejs npm curl ca-certificates; rm -rf /var/lib/apt/lists/*; \
    elif command -v dnf >/dev/null 2>&1; then \
      dnf install -y nodejs npm curl ca-certificates; dnf clean all; \
    elif command -v microdnf >/dev/null 2>&1; then \
      microdnf install -y nodejs npm curl ca-certificates; microdnf clean all; \
    elif command -v yum >/dev/null 2>&1; then \
      yum install -y nodejs npm curl ca-certificates; yum clean all; \
    else echo "No supported package manager found" >&2; exit 2; fi; \
  fi
RUN npm install -g "${CLAUDE_NPM_SPEC}" "${CODEX_NPM_SPEC}" "${GEMINI_CLI_NPM_SPEC}" && npm cache clean --force
RUN curl -fsSL "${AGY_INSTALL_URL}" | bash
RUN curl -fsSL "${GROK_INSTALL_URL}" -o /tmp/grok-install.sh && bash /tmp/grok-install.sh && rm -f /tmp/grok-install.sh
ENV PATH="/root/.grok/bin:${PATH}"

RUN cat >/usr/local/bin/audit-container-entry <<'ENTRY' && chmod +x /usr/local/bin/audit-container-entry
#!/usr/bin/env bash
set -euo pipefail
workdir="${AUDIT_CONTAINER_WORKDIR:-/root/work}"
cd "$workdir"
export AUDIT_ROOT="$workdir"
if [ "${AUDIT_CONTAINER_INSTALL_DEPS:-1}" != "0" ]; then
  [ -f "$workdir/tests/run-tests.sh" ] || { echo "FATAL: missing $workdir/tests/run-tests.sh" >&2; exit 2; }
  bash "$workdir/tests/run-tests.sh" --install-container-deps
fi
if [ -t 1 ]; then
  cat <<'BANNER'
Audit container shell
Log in with: codex login, claude, agy, or grok login.
Then run ./bin/audit --backend <backend> --target <target-name> [--model <model>]
BANNER
fi
exec "${SHELL:-/bin/bash}" -l
ENTRY
WORKDIR /root/work
ENTRYPOINT ["/usr/local/bin/audit-container-entry"]
'''


CREDENTIAL_NAMES = (
    "ANTHROPIC_API_KEY", "CLAUDE_CODE_OAUTH_TOKEN", "OPENAI_API_KEY",
    "GEMINI_API_KEY", "USE_GEMINI_CLI", "GOOGLE_API_KEY", "XAI_API_KEY",
    "GOOGLE_CLOUD_PROJECT", "GOOGLE_CLOUD_QUOTA_PROJECT",
)


def log(message: str) -> None:
    print(f"[audit-container-shell] {message}", file=sys.stderr)


def fatal(message: str) -> "NoReturn":
    print(f"[audit-container-shell] FATAL: {message}", file=sys.stderr)
    raise SystemExit(1)


class Parser(argparse.ArgumentParser):
    def error(self, message: str) -> "NoReturn":
        if message.startswith("unrecognized arguments: "):
            value = message.removeprefix("unrecognized arguments: ").split()[0]
            fatal(f"unknown option: {value}" if value.startswith("--") else f"unexpected argument: {value}")
        fatal(message)


def parse_args() -> argparse.Namespace:
    parser = Parser(add_help=False)
    parser.add_argument("--image", dest="base_image", default="node:lts-bookworm")
    parser.add_argument("--tag", default="audit-cli-shell:latest")
    parser.add_argument("--runtime", default=os.environ.get("CONTAINER_RUNTIME", "docker"))
    parser.add_argument("--gvisor", action="store_true")
    parser.add_argument("--docker-runtime", default=os.environ.get("AUDIT_DOCKER_RUNTIME", ""))
    parser.add_argument("--workdir", default="/root/work")
    parser.add_argument("--env-file", default="")
    parser.add_argument("--forward-credentials", action="store_true", default=os.environ.get("AUDIT_FORWARD_CREDENTIALS", "0") == "1")
    parser.add_argument("--rebuild", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("-h", "--help", action="store_true")
    args = parser.parse_args()
    if args.help:
        print(HELP)
        raise SystemExit(0)
    if args.gvisor:
        args.docker_runtime = "runsc"
    if args.base_image == "ubuntu":
        args.base_image = "ubuntu:latest"
    elif args.base_image == "fedora":
        args.base_image = "fedora:latest"
    if args.runtime != "docker":
        fatal("--runtime must be docker")
    if not args.workdir:
        fatal("--workdir must not be empty")
    return args


def run(command: list[str], **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(command, **kwargs)


def runtime_status(runtime: str) -> int:
    if not shutil.which(runtime):
        return 1
    return 0 if run([runtime, "info"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0 else 2


def host_os() -> str:
    uname = shutil.which("uname")
    if uname:
        result = run([uname, "-s"], stdout=subprocess.PIPE, text=True)
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    return platform.system()


def try_start(runtime: str) -> bool:
    system = host_os()
    if runtime == "docker" and system == "Darwin":
        if Path("/Applications/Docker.app").is_dir():
            log("Attempting to start Docker Desktop: open -a Docker")
            return run(["open", "-a", "Docker"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0
        if shutil.which("colima"):
            log("Attempting to start Colima: colima start")
            subprocess.Popen(["colima", "start"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
    if runtime == "docker" and system == "Linux" and shutil.which("systemctl"):
        log("Attempting to start docker: systemctl --user start docker")
        return run(["systemctl", "--user", "start", "docker"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0
    return False


def ensure_runtime(runtime: str) -> None:
    status = runtime_status(runtime)
    if status == 2 and os.environ.get("AUDIT_CONTAINER_AUTO_START", "1") != "0":
        log(f"{runtime} daemon not reachable; attempting auto-start (set AUDIT_CONTAINER_AUTO_START=0 to disable)")
        if try_start(runtime):
            timeout = int(os.environ.get("AUDIT_CONTAINER_START_TIMEOUT", "60"))
            for elapsed in range(0, timeout, 2):
                if runtime_status(runtime) == 0:
                    log(f"{runtime} daemon is now reachable (after {elapsed}s)")
                    return
                time.sleep(2)
        status = 2
    if status == 1:
        fatal(f"{runtime} not installed")
    if status == 2:
        hint = "start Docker Desktop or run `colima start`" if host_os() == "Darwin" else "start the daemon (e.g. `sudo systemctl start docker`)"
        fatal(f"{runtime} installed but daemon not reachable ({hint})")


def command_text(command: list[str]) -> str:
    return shlex.join(command)


def add_credentials(command: list[str], forward: bool) -> None:
    home_text = os.environ.get("HOME", "")
    home = Path(home_text)
    if forward:
        forwarded = []
        for name in CREDENTIAL_NAMES:
            if os.environ.get(name):
                command.extend(("-e", name))
                forwarded.append(name)
        adc = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS", "")
        adc_forwarded = bool(adc and Path(adc).is_file())
        if adc_forwarded:
            command.extend(("-v", f"{adc}:/root/.config/audit-google-application-credentials.json:ro"))
            command.extend(("-e", "GOOGLE_APPLICATION_CREDENTIALS=/root/.config/audit-google-application-credentials.json"))
        gcloud = home / ".config" / "gcloud"
        gcloud_forwarded = gcloud.is_dir()
        if gcloud_forwarded:
            gcloud_text = f"{home_text}/.config/gcloud"
            command.extend(("-v", f"{gcloud_text}:/root/.config/gcloud:ro"))
        if forwarded:
            log("Forwarding host env vars: " + " ".join(forwarded))
        if adc_forwarded:
            log(f"Mounting GOOGLE_APPLICATION_CREDENTIALS read-only: {adc} -> /root/.config/audit-google-application-credentials.json")
        if gcloud_forwarded:
            log(f"Mounting Google Cloud config read-only: {gcloud_text} -> /root/.config/gcloud")
        if not forwarded and not adc_forwarded and not gcloud_forwarded:
            log("--forward-credentials set but no host credential env vars or Google config found to forward; log in inside the container")
        log("Note: host CLI credential directories (~/.claude, ~/.codex, ~/.gemini, ~/.grok) are not mounted; --forward-credentials only forwards env vars and Google config")
    else:
        log("No host CLI credential directories mounted; log in inside the container or use --forward-credentials / --env-file")


def main() -> int:
    args = parse_args()
    root_text = os.environ.get("AUDIT_ROOT", str(Path(__file__).resolve().parent.parent))
    root = Path(root_text)
    if not root.is_dir():
        fatal(f"repository root does not exist: {root}")
    if not args.dry_run:
        ensure_runtime(args.runtime)
        if not args.rebuild and run([args.runtime, "image", "inspect", args.tag], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
            fatal(f"image {args.tag} does not exist locally; run with --rebuild to build it")

    dockerfile_path: Path | None = None
    try:
        if args.rebuild:
            if args.dry_run:
                dockerfile = "<generated Dockerfile>"
            else:
                handle = tempfile.NamedTemporaryFile("w", prefix="audit-cli-shell.Dockerfile.", delete=False)
                handle.write(DOCKERFILE)
                handle.close()
                dockerfile_path = Path(handle.name)
                dockerfile = str(dockerfile_path)
            build = [
                args.runtime, "build", "--pull", "-t", args.tag,
                "--build-arg", f"BASE_IMAGE={args.base_image}",
                "--build-arg", f"CLAUDE_NPM_SPEC={os.environ.get('CLAUDE_NPM_SPEC', '@anthropic-ai/claude-code@latest')}",
                "--build-arg", f"CODEX_NPM_SPEC={os.environ.get('CODEX_NPM_SPEC', '@openai/codex@latest')}",
                "--build-arg", f"GEMINI_CLI_NPM_SPEC={os.environ.get('GEMINI_CLI_NPM_SPEC', '@google/gemini-cli@latest')}",
                "--build-arg", f"AGY_INSTALL_URL={os.environ.get('AGY_INSTALL_URL', 'https://antigravity.google/cli/install.sh')}",
                "--build-arg", f"GROK_INSTALL_URL={os.environ.get('GROK_INSTALL_URL', 'https://x.ai/cli/install.sh')}",
                "-f", dockerfile, root_text,
            ]
            if args.dry_run:
                log("build command:\n" + command_text(build))
            elif run(build).returncode != 0:
                return 1

        command = [args.runtime, "run", "--rm", "-it"]
        if args.docker_runtime:
            command.extend(("--runtime", args.docker_runtime))
            log(f"Using Docker OCI runtime: {args.docker_runtime}")
        if os.environ.get("AUDIT_CONTAINER_NO_NEW_PRIVS", "1") != "0":
            command.extend(("--security-opt", "no-new-privileges"))
        command.extend(("-v", f"{root_text}:{args.workdir}", "-w", args.workdir))
        command.extend(("-e", f"AUDIT_CONTAINER_WORKDIR={args.workdir}", "-e", "GEMINI_CLI_TRUST_WORKSPACE=true", "-e", "IS_SANDBOX=1"))
        suffix = os.environ.get("AUDIT_BUILD_SUFFIX", "")
        if suffix:
            command.extend(("-e", f"AUDIT_BUILD_SUFFIX={suffix}"))
            log(f"Forwarding AUDIT_BUILD_SUFFIX={suffix} from host")
        elif not args.dry_run:
            result = run([args.runtime, "image", "inspect", args.tag, "--format", "{{.Id}}"], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
            image_id = result.stdout.strip().removeprefix("sha256:")[:12]
            if image_id:
                command.extend(("-e", f"AUDIT_BUILD_SUFFIX=-{image_id}"))
        if args.env_file:
            if not Path(args.env_file).is_file():
                fatal(f"--env-file does not exist: {args.env_file}")
            command.extend(("--env-file", args.env_file))
        add_credentials(command, args.forward_credentials)
        command.append(args.tag)
        if args.dry_run:
            log("run command:\n" + command_text(command))
            return 0
        log(f"Opening container shell at {args.workdir}")
        return run(command).returncode
    finally:
        if dockerfile_path is not None:
            dockerfile_path.unlink(missing_ok=True)


if __name__ == "__main__":
    raise SystemExit(main())
