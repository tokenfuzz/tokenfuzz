#!/usr/bin/env python3
"""Clear per-backend logs while preserving log directories and .gitkeep files."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

TOOL = "cleanup_logs"
DEFAULT_BACKENDS = "claude,codex,gemini,grok,oss"
REPO_ROOT = Path(__file__).absolute().parent.parent
sys.path.insert(0, str(REPO_ROOT / "lib"))

from cleanup import (  # noqa: E402
    CleanupArgumentParser,
    args_before_double_dash,
    clear_log_tree,
    count_removable_logs,
    parse_csv,
    path_is_under,
    resolve_output_root,
    target_slugs,
    valid_component,
    valid_slug,
)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = CleanupArgumentParser(
        prog=TOOL,
        tool=TOOL,
        description=(
            "Clear output/<target>/<backend>/logs for selected targets and backends. "
            "The logs directories and all .gitkeep entries are preserved."
        ),
    )
    parser.add_argument("-n", "--dry-run", action="store_true")
    parser.add_argument("-q", "--quiet", action="store_true")
    parser.set_defaults(backends=DEFAULT_BACKENDS)
    parser.add_argument("--backends", dest="backends", default=argparse.SUPPRESS)
    parser.add_argument("--backend", dest="backends", default=argparse.SUPPRESS)
    parser.add_argument("--target", action="append", default=[])
    parser.add_argument("--output-root", default="")
    parser.add_argument("positionals", nargs="*", help=argparse.SUPPRESS)
    args = parser.parse_args(args_before_double_dash(argv))
    if args.positionals:
        parser.exit(2, f"[{TOOL}] unexpected positional arg: {args.positionals[0]}\n")
    return args


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    output_root = resolve_output_root(args.output_root, REPO_ROOT)
    if output_root is None:
        raw_root = Path(args.output_root) if args.output_root else REPO_ROOT / "output"
        print(f"[{TOOL}] output root not found: {raw_root}", file=sys.stderr)
        return 2

    backends = parse_csv(args.backends)
    if not backends:
        print(f"[{TOOL}] no backends to clear", file=sys.stderr)
        return 2

    targets = target_slugs(output_root, args.target)
    if not targets:
        if not args.quiet:
            print(f"[{TOOL}] no targets under {output_root}")
        return 0

    cleared = 0
    skipped = 0
    failed = 0
    for target in targets:
        if not valid_slug(target):
            print(f"[{TOOL}] invalid target component: '{target}'", file=sys.stderr)
            failed += 1
            continue
        for backend in backends:
            if not valid_component(backend):
                print(
                    f"[{TOOL}] invalid backend component for {target}: '{backend}'",
                    file=sys.stderr,
                )
                failed += 1
                continue

            logdir = output_root.joinpath(*target.split("/"), backend, "logs")
            if not logdir.is_dir():
                skipped += 1
                continue
            try:
                resolved = logdir.resolve(strict=True)
            except OSError:
                skipped += 1
                continue
            if resolved.name != "logs":
                print(f"[{TOOL}] refusing to clean unexpected path: '{resolved}'", file=sys.stderr)
                failed += 1
                continue
            if not path_is_under(output_root, resolved):
                print(
                    f"[{TOOL}] refusing to clean path outside output root: '{resolved}'",
                    file=sys.stderr,
                )
                failed += 1
                continue

            if args.dry_run:
                try:
                    count, _protected = count_removable_logs(resolved)
                except OSError:
                    print(f"[{TOOL}] failed to inspect {resolved}", file=sys.stderr)
                    failed += 1
                    continue
                print(f"[dry-run] {resolved}: {count} entries")
                continue

            removed, success, _protected = clear_log_tree(resolved)
            if not success:
                print(f"[{TOOL}] failed to clear {resolved}", file=sys.stderr)
                failed += 1
                continue
            if not args.quiet:
                if removed:
                    print(f"{resolved}: cleared {removed} entries")
                else:
                    print(f"{resolved}: already empty")
            cleared += 1

    if not args.dry_run and not args.quiet:
        print(f"cleared={cleared} skipped={skipped} failed={failed}")
    return 1 if failed else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
