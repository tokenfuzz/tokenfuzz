#!/usr/bin/env python3
"""Repeat a sanitizer runner and emit one normalized execution verdict."""

from __future__ import annotations

import base64
import datetime as dt
import hashlib
import os
import re
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
LIB_DIR = Path(os.environ.get("SCRIPT_ROOT", SCRIPT_DIR.parent)) / "lib"
sys.path.insert(0, str(LIB_DIR))

from file_tools import cap_output_bytes
from verdict import CRASH_PATTERNS

VALID_SANITIZERS = {"asan", "ubsan", "msan", "tsan", "race", "runner"}
RUNNERS = {
    "asan": "run-asan", "race": "run-asan", "runner": "run-asan",
    "ubsan": "run-ubsan", "msan": "run-msan", "tsan": "run-tsan",
}
OPTION_NAMES = {
    "asan": "ASAN_OPTIONS", "ubsan": "UBSAN_OPTIONS",
    "msan": "MSAN_OPTIONS", "tsan": "TSAN_OPTIONS",
}
CRASH_RE = re.compile("|".join(CRASH_PATTERNS), re.MULTILINE)
EXEC_VERIFIED_RE = re.compile(
    r"^\[run-(?:asan|ubsan|msan|tsan)\] "
    r"(?:browser|js|xpcshell|generic) EXECUTION VERIFIED \(post-run|"
    r"^\[run-ubsan\] EXECUTION VERIFIED:",
    re.MULTILINE,
)
EXEC_INCONCLUSIVE_RE = re.compile(
    r"^\[run-(?:asan|ubsan|msan|tsan)\] "
    r"(?:browser|js|xpcshell|generic) EXECUTION INCONCLUSIVE \(post-run",
    re.MULTILINE,
)
DIGEST_CRASH_RE = re.compile(
    r"ERROR: AddressSanitizer|AddressSanitizer:DEADLYSIGNAL|CRASH DETECTED|"
    r"Hit MOZ_CRASH\(|^==[0-9]+==ABORTING|runtime error:",
    re.MULTILINE,
)


def _integer_env(name: str, default: int) -> int:
    value = os.environ.get(name, str(default))
    try:
        return int(value)
    except ValueError:
        print(
            f"[run-sanitizer-multi] WARN: {name} must be an integer; using {default} (got {value!r})",
            file=sys.stderr,
        )
        return default


@dataclass(frozen=True)
class Outcome:
    crashed: bool
    executed: bool
    succeeded: bool
    signature: tuple[str, ...] | None


class MultiRun:
    def __init__(self, sanitizer: str, args: list[str]):
        self.sanitizer = sanitizer
        self.args = args
        self.runs = int(os.environ.get("SANITIZER_RUNS", "5"))
        self.child = SCRIPT_DIR / RUNNERS[sanitizer]
        self.header = "ASAN_RUN_HEADER" if sanitizer == "asan" else "SANITIZER_RUN_HEADER"
        self.output_display = os.environ.get("SAN_OUTPUT_FILE", os.environ.get("ASAN_OUTPUT_FILE", ""))
        self.output_file = self._output_file()
        if not self.output_display and self.output_file:
            self.output_display = str(self.output_file)
        self.no_digest = bool(os.environ.get("SANITIZER_NO_DIGEST"))
        self.digest_head = _integer_env("SANITIZER_DIGEST_HEAD", 80)
        self.digest_tail = _integer_env("SANITIZER_DIGEST_TAIL", 120)
        sibling_frames = SCRIPT_DIR.parent / "lib" / "stack_frames.py"
        self.stack_frames = sibling_frames if sibling_frames.is_file() else LIB_DIR / "stack_frames.py"
        self.crashes = 0
        self.executions = 0
        self.successes = 0
        self.diff_divergences = 0

    def _output_file(self) -> Path | None:
        configured = os.environ.get("SAN_OUTPUT_FILE", os.environ.get("ASAN_OUTPUT_FILE", ""))
        if configured:
            return Path(configured)
        optional = os.environ.get("SAN_OUTPUT_FILE_OPTIONAL", os.environ.get("ASAN_OUTPUT_FILE_OPTIONAL", ""))
        if optional:
            return None
        testcase = self.args[1] if len(self.args) > 1 else ""
        if not testcase:
            raise ValueError("cannot derive output file - pass a testcase or use bin/probe")
        path = Path(testcase)
        return path.with_suffix(".asan.txt") if path.suffix else Path(f"{path}.asan.txt")

    def emit(self, message: str = "") -> None:
        print(message)
        if self.output_file:
            with self.output_file.open("a", encoding="utf-8") as stream:
                stream.write(message + "\n")

    def seed_output(self) -> None:
        if not self.output_file:
            return
        self.output_file.parent.mkdir(parents=True, exist_ok=True)
        option_name = OPTION_NAMES.get(self.sanitizer, "")
        option_value = os.environ.get(option_name, "") if option_name else ""
        encoded = base64.b64encode(option_value.encode()).decode() if option_value else ""
        testcase = os.environ.get(
            "SANITIZER_RECORDED_TESTCASE",
            os.environ.get("ASAN_RECORDED_TESTCASE", self.args[1] if len(self.args) > 1 else "?"),
        )
        started = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        self.output_file.write_text(
            f"{self.header}: sanitizer={self.sanitizer} runs={self.runs} "
            f"mode={self.args[0] if self.args else '?'} testcase={testcase} "
            f"env_options_b64={encoded} started={started}\n"
        )

    def coverage_gate(self) -> int | None:
        mode = self.args[0] if self.args else "browser"
        if not os.environ.get("WANT") or os.environ.get("SKIP_COVERAGE_GATE") or mode not in {"browser", "js"}:
            return None
        hits = SCRIPT_DIR / "hits"
        testcase = self.args[1] if len(self.args) > 1 else ""
        if not os.access(hits, os.X_OK) or not testcase or not Path(testcase).is_file():
            return None
        command = [
            str(hits), "--testcase", testcase, "--want", os.environ["WANT"],
            "--mode", mode, "--timeout", os.environ.get("HITS_TIMEOUT", os.environ.get("COV_TIMEOUT", "20")),
        ]
        if os.environ.get("HITS_LOG_PATH"):
            command.extend(("--log", os.environ["HITS_LOG_PATH"]))
        completed = subprocess.run(command, capture_output=True, text=True, check=False)
        output = completed.stdout + completed.stderr
        print(output, end="")
        closest_match = re.search(r"^(?:MISSED . closest reached: |EXEC_FAIL|NO_COVERAGE:? ?)(.*)$", output, re.MULTILINE)
        closest = (closest_match.group(1) if closest_match else f"hits exited {completed.returncode}")[:200]
        if completed.returncode == 1:
            self.emit(f"COVERAGE_GATE: MISSED - ASan skipped. Revise testcase (closest: {closest or '<none>'})")
            self._record_coverage_miss(testcase, mode, closest)
            print(f"[run-sanitizer-multi] COVERAGE GATE: MISSED - ASan skipped. Revise testcase (closest: {closest or '<none>'})")
            return 1
        if completed.returncode:
            label = "COVERAGE_EXEC_FAIL" if completed.returncode == 3 else "COVERAGE_ENV_FAIL"
            os.environ["HITS_VERDICT"] = label
            self.emit(f"COVERAGE_GATE: {label} - ASan proceeding ungated (hits rc={completed.returncode}; {closest})")
            print(f"[run-sanitizer-multi] COVERAGE GATE: {label} - proceeding to ASan ungated (hits rc={completed.returncode}; {closest})")
        else:
            hit = re.search(r"^HIT: (.*)$", output, re.MULTILINE)
            os.environ["CLOSEST_FRAME"] = (hit.group(1) if hit else "")[:200]
            os.environ["HITS_VERDICT"] = "HIT"
            print("[run-sanitizer-multi] COVERAGE GATE: HIT - proceeding to ASan")
        return None

    def _record_coverage_miss(self, testcase: str, mode: str, closest: str) -> None:
        log = os.environ.get("TRIED_INPUTS_LOG")
        if not log:
            return
        destination = Path(log)
        destination.parent.mkdir(parents=True, exist_ok=True)
        digest = hashlib.sha1(Path(testcase).read_bytes()).hexdigest()[:12]
        with destination.open("a") as stream:
            stream.write(
                f"{now()} verdict=NO_HIT mode={mode} testcase={testcase} hash={digest} "
                f"hypothesis={os.environ.get('HYPOTHESIS_ID', '?')} "
                f"target={os.environ.get('TARGET', '?')} closest={closest or '<none>'}\n"
            )

    def account_budget(self) -> None:
        counter_name = os.environ.get("SANITIZER_RUN_COUNTER_FILE", "")
        if not counter_name:
            return
        counter = Path(counter_name)
        counter.parent.mkdir(parents=True, exist_ok=True)
        previous_text = counter.read_text(errors="ignore") if counter.is_file() else ""
        digits = "".join(ch for ch in previous_text if ch.isdigit())
        current = int(digits or 0) + 1
        counter.write_text(str(current))
        budget_text = os.environ.get("SANITIZER_RUN_BUDGET", "")
        budget = int(budget_text) if budget_text.isdigit() else 0
        if budget:
            self.emit(f"[run-sanitizer-multi] BUDGET: {current}/{budget} sanitizer invocations used this iteration")
            if current > budget:
                self.emit("[run-sanitizer-multi] BUDGET: EXCEEDED - stop opening new hypotheses; wrap up the current one and exit")
        else:
            self.emit(f"[run-sanitizer-multi] BUDGET: {current} sanitizer invocation(s) this iteration")

    def classify(self, data: bytes) -> Outcome:
        text = data.decode(errors="replace")
        crashed = CRASH_RE.search(text) is not None
        succeeded = EXEC_VERIFIED_RE.search(text) is not None
        executed = succeeded or EXEC_INCONCLUSIVE_RE.search(text) is not None or crashed
        signature = self._signature(data)
        return Outcome(crashed, executed, succeeded, signature)

    def _signature(self, data: bytes) -> tuple[str, ...] | None:
        if not self.stack_frames.is_file():
            return None
        with tempfile.NamedTemporaryFile() as report:
            report.write(data)
            report.flush()
            completed = subprocess.run(
                [sys.executable, str(self.stack_frames), "--signature", report.name],
                capture_output=True,
                text=True,
                check=False,
            )
        if completed.returncode:
            return None
        return tuple(completed.stdout.splitlines())

    def digest(self, data: bytes) -> bytes:
        if self.no_digest:
            return data
        lines = data.decode(errors="replace").splitlines(keepends=True)
        filtered: list[str] = []
        skip_shadow = False
        for line in lines:
            if line.startswith("*** You are running in headless mode.") or (
                line.startswith("Crash Annotation GraphicsCriticalError:")
                and "RenderCompositorSWGL failed mapping default framebuffer" in line
            ):
                continue
            if re.match(r"^==[0-9]+==ERROR:", line):
                skip_shadow = False
            if line.startswith("Shadow bytes around the buggy address:"):
                suffix = f" - see {self.output_display}" if self.output_file else ""
                filtered.append(f"[Shadow bytes block elided{suffix}]\n")
                skip_shadow = True
                continue
            if skip_shadow and re.match(r"^==[0-9]+==ABORTING", line):
                skip_shadow = False
                filtered.append(line)
                continue
            if not skip_shadow:
                filtered.append(line)
        result = "".join(filtered).encode()
        if DIGEST_CRASH_RE.search(data.decode(errors="replace")):
            try:
                return cap_output_bytes(result, "asan-crash")
            except ValueError:
                return result
        head = self.digest_head
        tail = self.digest_tail
        if head <= 0 or tail <= 0 or len(filtered) <= head + tail:
            return result
        elided = len(filtered) - head - tail
        location = f" - full output in {self.output_display}" if self.output_file else ""
        marker = (
            f"[run-sanitizer-multi] DIGEST: clean run, {elided} middle line(s) elided "
            f"(showing first {head} + last {tail}){location}. Override: "
            "SANITIZER_DIGEST_HEAD/SANITIZER_DIGEST_TAIL or SANITIZER_NO_DIGEST=1.\n"
        )
        return "".join(filtered[:head] + [marker] + filtered[-tail:]).encode()

    def append_raw(self, data: bytes) -> None:
        if self.output_file:
            with self.output_file.open("ab") as stream:
                stream.write(data)

    def run_repetitions(self) -> None:
        baseline: Outcome | None = None
        for index in range(1, self.runs + 1):
            self.emit(f"=== Run {index}/{self.runs} ===")
            completed = subprocess.run([str(self.child), *self.args], capture_output=True, check=False)
            data = completed.stdout + completed.stderr
            self.append_raw(data)
            outcome = self.classify(data)
            self.crashes += int(outcome.crashed)
            self.executions += int(outcome.executed)
            self.successes += int(outcome.succeeded)
            if baseline is None:
                sys.stdout.flush()
                sys.stdout.buffer.write(self.digest(data))
                baseline = outcome
            elif outcome.signature is None or baseline.signature is None:
                sys.stdout.flush()
                sys.stdout.buffer.write(self.digest(data))
            elif self.no_digest or outcome != baseline:
                if outcome != baseline:
                    if outcome.crashed and not baseline.crashed:
                        self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: DIVERGED - crashed where run 1 was clean")
                    elif not outcome.crashed and baseline.crashed:
                        self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: DIVERGED - clean where run 1 crashed")
                    else:
                        self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: DIVERGED - result differs from run 1")
                sys.stdout.flush()
                sys.stdout.buffer.write(self.digest(data))
            elif outcome.crashed:
                first = outcome.signature[0] if outcome.signature else "no stable frame"
                self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: VERIFIED — same crash signature as run 1 ({first})")
            elif outcome.succeeded:
                self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: VERIFIED - clean (matches run 1)")
            elif outcome.executed:
                self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: REPEATED - execution failed (matches run 1)")
            else:
                self.emit(f"[run-sanitizer-multi] Run {index}/{self.runs}: REPEATED - no execution evidence (matches run 1)")
            self.emit()

    def auto_diff(self) -> None:
        mode = self.args[0] if self.args else ""
        testcase = self.args[1] if len(self.args) > 1 else ""
        if self.sanitizer != "asan" or mode not in {"js", "xpcshell"} or not Path(testcase).is_file() or self.crashes or not self.executions:
            return
        self.emit("\n=== AUTO-DIFFERENTIAL (--ion-eager vs --no-ion) ===")
        completed = subprocess.run([str(SCRIPT_DIR / "run-asan"), "js-diff", testcase], capture_output=True, check=False)
        data = completed.stdout + completed.stderr
        if b"outputs DIFFER" in data:
            self.emit("[run-sanitizer-multi] AUTO-DIFF: DIVERGENCE DETECTED - potential JIT correctness issue")
            self.append_raw(data)
            sys.stdout.buffer.write(self.digest(data))
            self.diff_divergences += 1
        elif b"ERROR: AddressSanitizer" in data:
            self.emit("[run-sanitizer-multi] AUTO-DIFF: ASan crash in differential mode!")
            self.append_raw(data)
            sys.stdout.buffer.write(self.digest(data))
            self.crashes += 1
        else:
            self.emit("[run-sanitizer-multi] AUTO-DIFF: outputs match (no JIT divergence)")

    def record_tried(self) -> None:
        configured = os.environ.get("TRIED_INPUTS_LOG")
        if not configured:
            return
        testcase = self.args[1] if len(self.args) > 1 else ""
        digest = hashlib.sha1(Path(testcase).read_bytes()).hexdigest()[:12] if Path(testcase).is_file() else "?"
        verdict = "CRASH" if self.crashes else "DIFF" if self.diff_divergences else "NO_EXEC" if not self.executions else "EXEC_FAIL" if not self.successes else "CLEAN"
        destination = Path(configured)
        destination.parent.mkdir(parents=True, exist_ok=True)
        with destination.open("a") as stream:
            stream.write(
                f"{now()} verdict={verdict} mode={self.args[0] if self.args else '?'} testcase={testcase or '?'} "
                f"hash={digest} runs={self.runs} crashes={self.crashes} execs={self.executions} "
                f"hypothesis={os.environ.get('HYPOTHESIS_ID', '?')} target={os.environ.get('TARGET', '?')} "
                f"closest={os.environ.get('CLOSEST_FRAME', '<none>')} hits_verdict={os.environ.get('HITS_VERDICT', '?')}\n"
            )

    def finish(self) -> int:
        self.emit("=== SUMMARY ===")
        self.emit(f"CRASH_RATE: {self.crashes}/{self.runs}")
        self.emit(f"[run-sanitizer-multi] EXECUTION_RATE: {self.executions}/{self.runs}")
        self.emit(f"[run-sanitizer-multi] SUCCESS_RATE: {self.successes}/{self.runs}")
        self.auto_diff()
        self.record_tried()
        if self.crashes:
            self.emit(f"[run-sanitizer-multi] CRASHES FOUND: {self.crashes}/{self.runs} runs crashed")
            return 1
        if self.diff_divergences:
            self.emit(f"[run-sanitizer-multi] DIFFERENTIAL FINDING: {self.diff_divergences} divergent js-diff check(s)")
            return 1
        if not self.executions:
            self.emit("[run-sanitizer-multi] WARNING: testcase may not have executed in any run")
            return 2
        if not self.successes:
            self.emit(f"[run-sanitizer-multi] EXECUTION FAILED in {self.runs} runs ({self.executions} reached target, 0 completed cleanly)")
            return 1
        self.emit(f"[run-sanitizer-multi] NO CRASHES in {self.runs} runs ({self.successes} completed cleanly, {self.executions} reached target)")
        return 0


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def main(argv: list[str]) -> int:
    if not argv:
        print("[run-sanitizer-multi] ERROR: sanitizer argument required.", file=sys.stderr)
        return 2
    sanitizer_name, *args = argv
    if sanitizer_name not in VALID_SANITIZERS:
        print(f"[run-sanitizer-multi] ERROR: unknown sanitizer '{sanitizer_name}' (want asan|ubsan|msan|tsan|race|runner).", file=sys.stderr)
        return 2
    if not args:
        print("[run-sanitizer-multi] ERROR: mode argument required.", file=sys.stderr)
        return 2
    if len(args) >= 2 and not Path(args[1]).is_file():
        print(f"[run-sanitizer-multi] ERROR: testcase not found: {args[1]}", file=sys.stderr)
        return 2
    try:
        run = MultiRun(sanitizer_name, args)
    except (ValueError, OSError) as exc:
        print(f"[run-sanitizer-multi] ERROR: {exc}", file=sys.stderr)
        return 2
    run.seed_output()
    coverage_status = run.coverage_gate()
    if coverage_status is not None:
        return coverage_status
    run.account_budget()
    run.run_repetitions()
    return run.finish()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
