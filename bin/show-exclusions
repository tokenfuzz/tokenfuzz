#!/usr/bin/env python3
"""Show active, confirmed, rejected, and infrastructure-noise results."""

from __future__ import annotations

import os
import re
import stat
import sys
from pathlib import Path

REASON_RE = re.compile(r"^(?:#\s*)?reason:\s*(.*)$", re.IGNORECASE)
REJECTION_FILES = (
    "REJECTION.md",
    "rejection.md",
    ".rejection",
    ".audit/REJECTION.md",
    ".audit/rejection.md",
)


def is_directory(path: Path) -> bool:
    try:
        return path.is_dir()
    except OSError:
        return False


def directories(parent: Path, prefix: str) -> list[Path]:
    try:
        entries = list(parent.iterdir())
    except OSError:
        return []
    return sorted(
        (entry for entry in entries if entry.name.startswith(prefix) and is_directory(entry)),
        key=lambda entry: os.fsencode(entry.name),
    )


def reason_from_file(path: Path) -> str:
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return ""
    for line in lines:
        match = REASON_RE.fullmatch(line.strip())
        if match and match.group(1):
            return match.group(1)
    for line in lines:
        stripped = line.strip()
        if stripped and not stripped.startswith("#"):
            return stripped
    return ""


def rejection_reason(directory: Path) -> str:
    reason = reason_from_file(directory / ".autodiscard")
    if reason:
        return reason
    for relative in REJECTION_FILES:
        reason = reason_from_file(directory / relative)
        if reason:
            return reason
    return "(no rejection reason found)"


def noise_files(root: Path) -> list[Path]:
    if not root.is_dir():
        return []
    files: list[Path] = []
    for current, _directories, names in os.walk(root, followlinks=False):
        current_path = Path(current)
        try:
            relative_parent = current_path.relative_to(root)
        except ValueError:
            continue
        if "shutdown-noise" not in relative_parent.parts:
            continue
        for name in names:
            path = current_path / name
            try:
                if stat.S_ISREG(path.lstat().st_mode):
                    files.append(path)
            except OSError:
                continue
    return sorted(files, key=lambda path: os.fsencode(str(path)))


def report(results_arg: str) -> str:
    results = Path(results_arg)
    crashes = directories(results / "crashes", "CRASH-")
    findings = directories(results / "findings", "FIND-")
    rejected = directories(results / "crashes-rejected", "CRASH-")
    noise = noise_files(results / "fuzz-crashes")

    lines = [f"=== Exclusion report: {results_arg} ===", ""]
    lines.append("--- Active crash candidates (pending triage/security review) ---")
    lines.extend(f"  {entry.name}" for entry in crashes)
    if not crashes:
        lines.append("  (none)")
    lines.extend(["", "--- Confirmed findings ---"])
    lines.extend(f"  {entry.name}" for entry in findings)
    if not findings:
        lines.append("  (none)")
    lines.extend(["", "--- Rejected crash candidates (excluded from active results) ---"])
    lines.extend(
        f"  {entry.name:<24}  {rejection_reason(entry)}" for entry in rejected
    )
    if not rejected:
        lines.append("  (none)")
    lines.extend(["", "--- Fuzz-crash infrastructure noise (shutdown-noise/) ---"])
    lines.extend(f"  {path.relative_to(results)}" for path in noise)
    if not noise:
        lines.append("  (none)")
    lines.extend(
        [
            "",
            "--- Summary ---",
            f"  active crashes:      {len(crashes)}",
            f"  confirmed findings:  {len(findings)}",
            f"  rejected crashes:    {len(rejected)}",
            f"  fuzz noise moved:    {len(noise)}",
        ]
    )
    return "\n".join(lines) + "\n"


def main(argv: list[str]) -> int:
    if not argv or not Path(argv[0]).is_dir():
        print(f"usage: {sys.argv[0]} <results_dir>", file=sys.stderr)
        print(f"  e.g.  {sys.argv[0]} output/firefox/codex/results", file=sys.stderr)
        return 2
    sys.stdout.write(report(argv[0]))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
