#!/bin/bash
# show-exclusions — single-pane debug view of which audit results were kept
# vs. excluded, and why. Read-only — never modifies state.
#
# Usage:
#   bin/show-exclusions <results_dir>
#   bin/show-exclusions output/firefox/codex/results
#
# Produces four sections:
#   1. Active crash candidates      (crashes/CRASH-*)
#   2. Confirmed findings          (findings/FIND-*)
#   3. Rejected crash candidates   (crashes-rejected/CRASH-* with reason)
#   4. Fuzz-crash noise            (shutdown-noise/ entries moved by run-asan)
#
# Exit code: 0 always (this is a report, not a gate).

set -uo pipefail

RESULTS_DIR="${1:-}"
if [ -z "$RESULTS_DIR" ] || [ ! -d "$RESULTS_DIR" ]; then
  echo "usage: $0 <results_dir>" >&2
  echo "  e.g.  $0 output/firefox/codex/results" >&2
  exit 2
fi

crashes=0
findings=0
rejected=0
noise=0

rejection_reason() {
  local d="$1"
  local reason=""

  if [ -f "$d/.autodiscard" ]; then
    reason=$(sed -nE 's/^# Reason:[[:space:]]*(.*)$/\1/p' "$d/.autodiscard" 2>/dev/null | head -1)
    [ -n "$reason" ] || reason=$(grep -v '^#' "$d/.autodiscard" 2>/dev/null | head -1)
  fi

  if [ -z "$reason" ]; then
    local f
    for f in "$d/REJECTION.md" "$d/rejection.md" "$d/.rejection" "$d/.audit/REJECTION.md" "$d/.audit/rejection.md"; do
      [ -f "$f" ] || continue
      reason=$(sed -nE 's/^# Reason:[[:space:]]*(.*)$/\1/p; s/^[Rr]eason:[[:space:]]*(.*)$/\1/p' "$f" 2>/dev/null | head -1)
      [ -n "$reason" ] || reason=$(grep -vE '^[[:space:]]*(#|$)' "$f" 2>/dev/null | head -1)
      [ -n "$reason" ] && break
    done
  fi

  [ -n "$reason" ] || reason="(no rejection reason found)"
  printf '%s\n' "$reason"
}

echo "=== Exclusion report: $RESULTS_DIR ==="
echo ""

echo "--- Active crash candidates (pending triage/security review) ---"
for d in "$RESULTS_DIR"/crashes/CRASH-*/; do
  [ -d "$d" ] || continue
  crashes=$((crashes + 1))
  printf '  %s\n' "$(basename "$d")"
done
[ "$crashes" -eq 0 ] && echo "  (none)"
echo ""

echo "--- Confirmed findings ---"
for d in "$RESULTS_DIR"/findings/FIND-*/; do
  [ -d "$d" ] || continue
  findings=$((findings + 1))
  printf '  %s\n' "$(basename "$d")"
done
[ "$findings" -eq 0 ] && echo "  (none)"
echo ""

echo "--- Rejected crash candidates (excluded from active results) ---"
for d in "$RESULTS_DIR"/crashes-rejected/CRASH-*/; do
  [ -d "$d" ] || continue
  rejected=$((rejected + 1))
  id=$(basename "$d")
  reason=$(rejection_reason "$d")
  printf '  %-24s  %s\n' "$id" "$reason"
done
[ "$rejected" -eq 0 ] && echo "  (none)"
echo ""

echo "--- Fuzz-crash infrastructure noise (shutdown-noise/) ---"
if [ -d "$RESULTS_DIR/fuzz-crashes" ]; then
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    noise=$((noise + 1))
    printf '  %s\n' "${f#$RESULTS_DIR/}"
  done < <(find "$RESULTS_DIR/fuzz-crashes" -type f -path '*/shutdown-noise/*' 2>/dev/null | sort)
fi
[ "$noise" -eq 0 ] && echo "  (none)"
echo ""

echo "--- Summary ---"
printf '  active crashes:      %d\n' "$crashes"
printf '  confirmed findings:  %d\n' "$findings"
printf '  rejected crashes:    %d\n' "$rejected"
printf '  fuzz noise moved:    %d\n' "$noise"
