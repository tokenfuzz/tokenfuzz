#!/usr/bin/env python3
"""bin/auto-build-script — converge on a sanitizer build recipe via LLM.

POC for the "ship one validated recipe per audit" model. Given an
upstream source tree and a sanitizer label, this tool:

  1. Detects the build system from on-disk manifests (CMakeLists.txt
     → cmake; configure.ac → autotools; meson.build → meson) and
     emits an initial vanilla recipe targeting that system.
  2. Runs the recipe against a scratch build dir.
  3. On non-zero exit (or missing expected artifact), feeds the tail
     of the build log + the current script to the LLM and asks for a
     revised COMPLETE script. Re-runs.
  4. Iterates up to --max-iters times. Writes the first working
     script to --out, prints its path on stdout.

The output script's contract is fixed: it takes argv `<src-dir>
<build-dir>` and on success produces a sanitizer-instrumented build
under <build-dir>. The contract is what bin/export-repro embeds into
reproduce.sh.

Why the LLM is invoked at AUDIT TIME, not at reproduce time:
  * Operator pays for the tokens, not maintainers.
  * The converged script is deterministic — every maintainer running
    reproduce.sh gets bit-identical behaviour.
  * No LLM-emitted shell ever runs on an upstream maintainer's box.

Safety rails before any LLM-emitted script runs:
  * No absolute paths to host-private locations ($HOME, /Users/,
    /home/, /private/).
  * No `sudo`, `curl|sh`, `wget|sh`, `eval`.
  * Argv-1 / argv-2 contract preserved.
  * Script kept under a small length cap.

Usage:
  bin/auto-build-script --src targets/<slug> --sanitizer asan \\
                        --out targets/<slug>/.audit/build.sh   \\
                        [--max-iters 5] [--scratch /tmp/...]
"""
from __future__ import annotations

import argparse
import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path

SCRIPT_DIR = Path(__file__).absolute().parent
SCRIPT_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import build_config  # noqa: E402
from llm_decide import llm_decide  # noqa: E402
from prompt_render import render_template  # noqa: E402


_BUILD_LOG_TAIL_BYTES = 4_000
_README_EXCERPT_BYTES = 2_000
_MAX_SCRIPT_LEN = 8_000

# Anything matching these substrings in an LLM-proposed script is a
# rejection. The intent is to block obviously-host-private state and
# trust-violating constructs from being executed by the audit loop.
_FORBIDDEN_SUBSTRINGS = (
    "sudo ",
    "sudo\t",
    "curl ", "wget ",
    "$HOME", "${HOME}",
    "/Users/", "/home/", "/private/",
    "rm -rf /",
    "> /etc/", ">/etc/",
    "/dev/tcp/",
    " eval ", "\teval ",
    "`curl", "$(curl",
    "`wget", "$(wget",
)

_REQUIRED_SUBSTRINGS = (
    "-fsanitize=",
    "$1",
    "$2",
)


def die(msg: str, rc: int = 2) -> None:
    sys.stderr.write(f"[auto-build-script] {msg}\n")
    sys.exit(rc)


def info(msg: str) -> None:
    sys.stderr.write(f"[auto-build-script] {msg}\n")
    sys.stderr.flush()


def detect_build_system(src: Path) -> str:
    if (src / "CMakeLists.txt").is_file():
        return "cmake"
    if (src / "meson.build").is_file():
        return "meson"
    if (src / "configure.ac").is_file() or (src / "configure").is_file():
        return "autotools"
    if (src / "Makefile").is_file() or (src / "GNUmakefile").is_file():
        return "make"
    return ""


# Release-mode sanitizer recipes. The audit cares about real
# security bugs, not debug-only invariant asserts that fire as
# noise — so every initial recipe explicitly:
#   * disables NDEBUG-gated asserts (defensive checks, internal
#     invariants) by passing -DNDEBUG / -Db_ndebug=true,
#   * uses -O2 (matches what distros ship and what OSS-Fuzz uses;
#     -O1 was the prior default and produced visibly different
#     crash signatures vs. shipped binaries),
#   * uses -g1 (line tables only) for symbolised stack traces. Line
#     tables carry function + file:line, which is all crash
#     symbolization and clustering need, at a fraction of full -g's
#     DWARF; less debug info also symbolizes faster, which matters on
#     macOS where slow in-process symbolization can truncate a report
#     under the run timeout. -g1 is the portable spelling (clang and
#     gcc both accept it; clang treats it as -gline-tables-only),
#     whereas -gline-tables-only is clang-only.
#   * keeps -fno-omit-frame-pointer for accurate ASan backtraces.
# CMAKE_BUILD_TYPE=Release applies the same NDEBUG/-O2 baseline at
# the CMake level for projects that read the type and not raw
# C_FLAGS.
_INITIAL_CMAKE = """\
#!/usr/bin/env bash
set -eu
src="$1"; build="$2"
mkdir -p "$build"
rm -f "$build/CMakeCache.txt"
rm -rf "$build/CMakeFiles"
cmake -S "$src" -B "$build" \\
    -DCMAKE_BUILD_TYPE=Release \\
    -DCMAKE_C_COMPILER="${CC:-clang}" \\
    -DCMAKE_CXX_COMPILER="${CXX:-clang++}" \\
    -DCMAKE_C_FLAGS="-O2 -g1 -DNDEBUG -fsanitize=__SAN__ -fno-omit-frame-pointer" \\
    -DCMAKE_CXX_FLAGS="-O2 -g1 -DNDEBUG -fsanitize=__SAN__ -fno-omit-frame-pointer" \\
    -DCMAKE_EXE_LINKER_FLAGS="-fsanitize=__SAN__" \\
    -DCMAKE_SHARED_LINKER_FLAGS="-fsanitize=__SAN__"__EXTRA_ARGS__
cmake --build "$build" -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 2)"
"""

_INITIAL_AUTOTOOLS = """\
#!/usr/bin/env bash
set -eu
src="$1"; build="$2"
mkdir -p "$build"
( cd "$src" && [ -x ./configure ] || { [ -x ./autogen.sh ] && ./autogen.sh; } )
# Keep debug symbols in the linked binary. Some configure scripts strip by
# default, which drops the symbol table and (on macOS) the Mach-O debug map,
# so sanitizer stacks lose file:line despite -g1. Pass --disable-stripping
# only when this configure advertises it, so a hand-written configure that
# errors on unknown options is unaffected.
strip_opt=""
case "$(cd "$build" && "$src/configure" --help 2>/dev/null || true)" in
    *--disable-stripping*) strip_opt="--disable-stripping" ;;
esac
( cd "$build" && \\
    CC="${CC:-clang}" \\
    CXX="${CXX:-clang++}" \\
    CFLAGS="-O2 -g1 -DNDEBUG -fsanitize=__SAN__ -fno-omit-frame-pointer" \\
    CXXFLAGS="-O2 -g1 -DNDEBUG -fsanitize=__SAN__ -fno-omit-frame-pointer" \\
    LDFLAGS="-fsanitize=__SAN__" \\
    "$src/configure" $strip_opt__EXTRA_ARGS__ )
( cd "$build" && make -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 2)" )
"""

_INITIAL_MESON = """\
#!/usr/bin/env bash
set -eu
src="$1"; build="$2"
mkdir -p "$build"
meson setup --reconfigure "$build" "$src" \\
    --buildtype=release \\
    -Db_sanitize=__SAN_MESON__ -Db_ndebug=true \\
    -Dc_args="-g1 -fno-omit-frame-pointer" \\
    -Dcpp_args="-g1 -fno-omit-frame-pointer"__EXTRA_ARGS__
meson compile -C "$build"
"""


_SAN_TO_CC_FLAG = {
    "asan": "address",
    "ubsan": "undefined",
    "msan": "memory",
    "tsan": "thread",
}


def _format_extra_args(flags) -> str:
    return "" if not flags else " " + " ".join(shlex.quote(flag) for flag in flags)


def initial_script(build_system: str, sanitizer: str, extra_flags=()) -> str:
    cc_flag = _SAN_TO_CC_FLAG.get(sanitizer, sanitizer)
    extra = _format_extra_args(extra_flags)
    if build_system == "cmake":
        template = _INITIAL_CMAKE
    if build_system == "autotools":
        template = _INITIAL_AUTOTOOLS
    elif build_system == "meson":
        template = _INITIAL_MESON.replace("__SAN_MESON__", cc_flag)
    elif build_system != "cmake":
        die(f"no initial recipe for build system: {build_system!r}")
        return ""  # unreachable
    return template.replace("__SAN__", cc_flag).replace("__EXTRA_ARGS__", extra)


def run_script(script_path: Path, src: Path, build: Path,
               timeout_secs: int) -> tuple[int, str]:
    """Return (exit_code, captured_stdout_stderr_text)."""
    proc = subprocess.run(
        ["bash", str(script_path), str(src), str(build)],
        capture_output=True, text=True, timeout=timeout_secs,
    )
    return proc.returncode, (proc.stdout + proc.stderr)


build_produced_artifacts = build_config.produced_artifacts


# Matches bash's "command not found" diagnostics. Examples this catches:
#   /tmp/.../build.candidate.sh: line 7: cmake: command not found
#   cmake: command not found
#   sh: 1: cmake: not found
# The captured group is the binary name. Path-shaped matches (anything
# containing '/') are filtered downstream so we don't mistake a missing
# file path inside a configure log for a missing tool.
_COMMAND_NOT_FOUND_RE = re.compile(
    r"(?:^|: )([A-Za-z0-9_.+-]+): (?:command )?not found",
    re.MULTILINE,
)


def detect_missing_commands(log: str) -> list[str]:
    """Return the distinct binary names bash reported as 'not found' in
    ``log``. The caller uses a non-empty return value to short-circuit
    the LLM revision loop: the recipe shipped in reproduce.sh cannot
    install packages (the safety rails block sudo / apt / curl|sh), so a
    missing toolchain is unrecoverable through LLM iteration and the
    user needs an actionable diagnostic instead of N wasted LLM calls.
    """
    seen: list[str] = []
    for m in _COMMAND_NOT_FOUND_RE.finditer(log):
        cmd = m.group(1).strip()
        if not cmd or "/" in cmd or cmd in seen:
            continue
        seen.append(cmd)
    return seen


def validate_proposed_script(script: str) -> tuple[bool, str]:
    if not isinstance(script, str):
        return False, "not a string"
    if len(script) > _MAX_SCRIPT_LEN:
        return False, f"script too long: {len(script)} > {_MAX_SCRIPT_LEN}"
    lo = script.lower()
    if not lo.startswith(("#!/usr/bin/env bash", "#!/bin/bash", "#!/usr/bin/bash")):
        return False, "missing bash shebang"
    for needle in _REQUIRED_SUBSTRINGS:
        if needle not in script:
            return False, f"missing required token: {needle!r}"
    for bad in _FORBIDDEN_SUBSTRINGS:
        if bad in script:
            return False, f"contains forbidden token: {bad!r}"
    return True, ""


def read_readme_excerpt(src: Path) -> str:
    for name in ("README.md", "README.rst", "README", "README.txt"):
        p = src / name
        if p.is_file():
            try:
                txt = p.read_text("utf-8", errors="replace")
            except OSError:
                continue
            return txt[:_README_EXCERPT_BYTES]
    return ""


def ask_llm_for_revision(*, slug: str, build_system: str, sanitizer: str,
                         current_script: str, build_log: str,
                         readme_excerpt: str,
                         timeout_secs: int) -> str | None:
    readme_block = ""
    if readme_excerpt:
        readme_block = (
            "Upstream README build-instructions excerpt (truncated):\n"
            "```\n"
            f"{readme_excerpt}\n"
            "```"
        )
    prompt = render_template("auto_build_script.md.j2", {
        "slug": slug,
        "build_system": build_system,
        "sanitizer": sanitizer,
        "current_script": current_script,
        "build_log": build_log[-_BUILD_LOG_TAIL_BYTES:],
        "upstream_readme_block": readme_block,
    })
    obj = llm_decide("build-script-converge", "script", prompt,
                    timeout=timeout_secs)
    if not isinstance(obj, dict):
        return None
    script = obj.get("script")
    if not isinstance(script, str):
        return None
    return script.strip() + "\n"


# A widened recipe is an alternate build, never a replacement for the primary
# recipe. The caller opts in with --widen-from after the primary has already
# converged, so the extra cost is at most two model decisions and candidate builds.
_FEATURE_OPTIONS_MAX_BYTES = 8_000
_CMAKE_OPTION_RE = re.compile(
    r"\b(?:[A-Za-z_][A-Za-z0-9_]*_option|option|cmake_dependent_option)"
    r"\s*\(\s*\"?([A-Za-z_][A-Za-z0-9_]*)",
    re.IGNORECASE,
)
_CMAKE_CACHE_BOOL_RE = re.compile(
    r"\bset\s*\(\s*\"?([A-Za-z_][A-Za-z0-9_]*)\"?\s+[^)]*\bCACHE\s+BOOL\b",
    re.IGNORECASE,
)
_MESON_OPTION_RE = re.compile(
    r"\boption\s*\(\s*['\"]([^'\"]+)", re.IGNORECASE,
)
_AUTOTOOLS_OPTION_RE = re.compile(r"--[A-Za-z0-9][A-Za-z0-9_-]*")
_NON_SURFACE_OPTION_RE = re.compile(
    r"(?:^|_)(?:TESTS?|BENCH(?:MARKS?)?|EXAMPLES?|DOCS?|FUZZ(?:ERS?|ING)?|"
    r"INSTALL|PACKAGE|CONTRIB|FRAMEWORK|SCCACHE|CCACHE|COVERAGE|REPRODUCIBLE)(?:_|$)"
    r"|^(?:DEFAULT|BOTH)_LIBRAR(?:Y|IES)$"
    r"|(?:^|_)(?:BUILD_)?(?:SHARED|STATIC|PROGRAMS?|TOOLS?)(?:_|$)"
    r"|(?:^|_)PROGRAMS?_LINK(?:_|$)"
    r"|(?:^|_)(?:MULTITHREADED_)?COMPILATION(?:_|$)",
    re.IGNORECASE,
)


def is_surface_option(name: str) -> bool:
    """Keep shipped code choices; drop build/test/link-topology controls."""
    normalized = re.sub(r"[^A-Za-z0-9]+", "_", name).strip("_")
    return bool(normalized) and not _NON_SURFACE_OPTION_RE.search(normalized)


def collect_feature_options(src: Path, build_system: str) -> str:
    """Return bounded, build-system-advertised option context."""
    try:
        if build_system == "cmake":
            names: list[str] = []
            seen: set[str] = set()
            candidates: list[Path] = []
            # CMake projects commonly keep their real entry point under a
            # source directory named build/cmake (zstd is one example), so
            # pruning every "build" directory would miss advertised options.
            # Walk only four source levels and exclude known generated trees.
            for dirpath, dirnames, filenames in os.walk(src):
                directory = Path(dirpath)
                depth = len(directory.relative_to(src).parts)
                dirnames[:] = sorted(
                    name for name in dirnames
                    if name not in {".git", ".hg", ".audit", "node_modules", "__pycache__"}
                    and not re.match(r"^build-(?:asan|ubsan|msan|tsan)(?:[-+].*)?$", name)
                )
                if depth >= 4:
                    dirnames[:] = []
                for filename in sorted(filenames):
                    if filename == "CMakeLists.txt" or filename.endswith(".cmake"):
                        candidates.append(directory / filename)
                        if len(candidates) >= 200:
                            break
                if len(candidates) >= 200:
                    break
            for path in candidates[:200]:
                if not path.is_file():
                    continue
                text = path.read_text(encoding="utf-8", errors="replace")
                for regex in (_CMAKE_OPTION_RE, _CMAKE_CACHE_BOOL_RE):
                    for match in regex.finditer(text):
                        name = match.group(1)
                        if name not in seen and is_surface_option(name):
                            seen.add(name)
                            names.append(name)
            return "\n".join(names)[:_FEATURE_OPTIONS_MAX_BYTES]
        if build_system == "meson":
            for name in ("meson.options", "meson_options.txt"):
                path = src / name
                if path.is_file():
                    # Preserve types, defaults, choices, and descriptions. The
                    # model needs those semantics to distinguish shipped
                    # features from dependencies and build-only controls.
                    return path.read_text(
                        encoding="utf-8", errors="replace"
                    )[:_FEATURE_OPTIONS_MAX_BYTES]
            return ""
        if build_system == "autotools":
            configure = src / "configure"
            if not (configure.is_file() and os.access(configure, os.X_OK)):
                return ""
            completed = subprocess.run(
                [str(configure), "--help"], cwd=src, capture_output=True,
                text=True, timeout=30, check=False,
            )
            # Autoconf-compatible frontends are not uniform: modern SQLite
            # advertises shipped features as bare flags such as `--fts5` and
            # `--rtree`, while FFmpeg uses `--enable-*`. Keep the bounded help
            # text and let the model reason from descriptions instead of
            # encoding a target-specific option grammar here.
            return completed.stdout[:_FEATURE_OPTIONS_MAX_BYTES]
    except (OSError, subprocess.TimeoutExpired):
        return ""
    return ""


_RELEASE_MARKERS = (
    "-DNDEBUG", "CMAKE_BUILD_TYPE=Release", "b_ndebug=true",
    "--buildtype=release", "buildtype=release",
)
_BASELINE_MUST_KEEP = ("-g1", "-fno-omit-frame-pointer")
_OPT_RE = re.compile(r"-O(?:[0-3sgz]|fast)\b")


def widened_preserves_baseline(baseline: str, widened: str) -> tuple[bool, str]:
    sanitizer = re.search(r"-fsanitize=[A-Za-z,]+", baseline)
    if sanitizer and sanitizer.group(0) not in widened:
        return False, f"dropped {sanitizer.group(0)}"
    if any(value in baseline for value in _RELEASE_MARKERS) and not any(
        value in widened for value in _RELEASE_MARKERS
    ):
        return False, "dropped release mode"
    optimization = _OPT_RE.findall(baseline)
    if optimization and optimization[-1] not in widened:
        return False, f"dropped optimization level {optimization[-1]}"
    for token in _BASELINE_MUST_KEEP:
        if token in baseline and token not in widened:
            return False, f"dropped {token}"
    return True, ""


def widened_adds_advertised_option(
    baseline: str, widened: str, feature_options: str, build_system: str,
) -> bool:
    if baseline.strip() == widened.strip():
        return False
    if build_system == "cmake":
        names = feature_options.splitlines()
    elif build_system == "meson":
        names = [
            name for name in _MESON_OPTION_RE.findall(feature_options)
            if is_surface_option(name)
        ]
    else:
        names = [
            name for name in _AUTOTOOLS_OPTION_RE.findall(feature_options)
            if is_surface_option(name)
        ]
    baseline_lower = baseline.lower()
    widened_lower = widened.lower()
    return any(
        name.strip() and name.lower() not in baseline_lower and name.lower() in widened_lower
        for name in names
    )


def widened_enables_non_surface_option(
    baseline: str, widened: str, build_system: str,
) -> str:
    """Name a newly enabled test/topology option, or return an empty string."""
    if build_system in {"cmake", "meson"}:
        for name, value in re.findall(
            r"-D([A-Za-z0-9_-]+)\s*=\s*([^\s\\]+)", widened
        ):
            setting = f"-D{name}={value}"
            if (
                setting not in baseline
                and not is_surface_option(name)
                and value.lower() not in {"false", "disabled", "off", "no", "0"}
            ):
                return name
        return ""
    baseline_options = set(_AUTOTOOLS_OPTION_RE.findall(baseline))
    for option in _AUTOTOOLS_OPTION_RE.findall(widened):
        if (
            option not in baseline_options
            and option.startswith(("--enable-", "--with-"))
            and not is_surface_option(option)
        ):
            return option
    return ""


def widened_disables_advertised_option(
    baseline: str, widened: str, feature_options: str, build_system: str,
) -> str:
    """Name a newly disabled shipped option, or return an empty string."""
    if build_system == "cmake":
        for name in feature_options.splitlines():
            if not name.strip():
                continue
            disabled = re.compile(
                rf"-D{re.escape(name)}\s*=\s*(?:OFF|FALSE|NO|0)(?:\s|$)",
                re.IGNORECASE,
            )
            if disabled.search(widened) and not disabled.search(baseline):
                return name
        return ""
    if build_system == "meson":
        names = _MESON_OPTION_RE.findall(feature_options)
        for name in names:
            disabled = re.compile(
                rf"-D{re.escape(name)}\s*=\s*(?:false|disabled|off|no|0)(?:\s|$)",
                re.IGNORECASE,
            )
            if disabled.search(widened) and not disabled.search(baseline):
                return name
        return ""
    for option in re.findall(r"--(?:disable|without)-[A-Za-z0-9_-]+", widened):
        if option not in baseline:
            return option
    return ""


def ask_llm_for_widened(
    *, slug: str, build_system: str, sanitizer: str, baseline_script: str,
    feature_options: str, readme_excerpt: str, timeout_secs: int,
    current_script: str = "", build_log: str = "",
) -> str | None:
    feedback_block = ""
    if current_script:
        feedback_block = (
            "The previous widened candidate failed. Revise it rather than "
            "returning the unchanged primary recipe.\n\n"
            "Previous widened candidate:\n"
            "```bash\n"
            f"{current_script}\n"
            "```\n\n"
            "Failure or harness-validation feedback:\n"
            "```\n"
            f"{build_log[-_BUILD_LOG_TAIL_BYTES:]}\n"
            "```"
        )
    prompt = render_template("auto_build_widen_features.md.j2", {
        "slug": slug,
        "build_system": build_system,
        "sanitizer": sanitizer,
        "baseline_script": baseline_script,
        "feature_options": feature_options,
        "readme_excerpt": readme_excerpt,
        "feedback_block": feedback_block,
    })
    result = llm_decide("build-script-widen-features", "script", prompt, timeout=timeout_secs)
    script = result.get("script") if isinstance(result, dict) else None
    return script.strip() + "\n" if isinstance(script, str) else None


def _widen_candidate_rejection(
    baseline_script: str, script: str, options: str, build_system: str,
) -> str:
    non_surface = widened_enables_non_surface_option(
        baseline_script, script, build_system
    )
    if non_surface:
        return f"candidate enables non-shipping build surface ({non_surface})"
    if not widened_adds_advertised_option(
        baseline_script, script, options, build_system
    ):
        return "candidate adds no advertised build option"
    disabled = widened_disables_advertised_option(
        baseline_script, script, options, build_system
    )
    if disabled:
        return f"candidate disables primary surface ({disabled})"
    ok, reason = validate_proposed_script(script)
    if ok:
        ok, reason = widened_preserves_baseline(baseline_script, script)
    return "" if ok else reason


def widen_features(
    *, slug: str, build_system: str, sanitizer: str, baseline_script: str,
    src: Path, scratch: Path, readme_excerpt: str, build_timeout_secs: int,
    llm_timeout_secs: int, max_iters: int = 2,
) -> str | None:
    options = collect_feature_options(src, build_system)
    if not options.strip():
        info("widen: no advertised build options found; keeping primary-only coverage")
        return ""
    script = ask_llm_for_widened(
        slug=slug, build_system=build_system, sanitizer=sanitizer,
        baseline_script=baseline_script, feature_options=options,
        readme_excerpt=readme_excerpt, timeout_secs=llm_timeout_secs,
    )
    if script is None:
        decision_log = os.environ.get("LLM_DECIDE_LOG") or (
            f"{os.environ.get('LOGDIR') or '/tmp'}/llm-decisions.log"
        )
        info(
            "widen: model did not return a usable recipe "
            f"(timeout/backend/JSON failure; see {decision_log})"
        )
        return None
    for iteration in range(1, max_iters + 1):
        rejection = _widen_candidate_rejection(
            baseline_script, script, options, build_system
        )
        if rejection:
            log = f"[harness validation] {rejection}\n"
            info(f"widen: iteration {iteration} rejected: {rejection}")
        else:
            candidate = scratch / "widen.candidate.sh"
            candidate.write_text(script, encoding="utf-8")
            candidate.chmod(0o755)
            build = scratch / f"widen-build-{iteration}"
            shutil.rmtree(build, ignore_errors=True)
            build.mkdir(parents=True)
            started = time.time()
            try:
                returncode, log = run_script(
                    candidate, src, build, build_timeout_secs
                )
            except subprocess.TimeoutExpired:
                returncode, log = 124, "[timeout]\n"
            produced = returncode == 0 and build_produced_artifacts(build)
            (scratch / f"widen-build-{iteration}.log").write_text(
                log, encoding="utf-8", errors="replace"
            )
            info(
                f"widen: iteration {iteration} rc={returncode} "
                f"elapsed={time.time() - started:.1f}s produced_artifacts={produced}"
            )
            if produced:
                return script
        if iteration == max_iters:
            break
        revised = ask_llm_for_widened(
            slug=slug, build_system=build_system, sanitizer=sanitizer,
            baseline_script=baseline_script, feature_options=options,
            current_script=script, build_log=log,
            readme_excerpt=readme_excerpt, timeout_secs=llm_timeout_secs,
        )
        if revised is None or revised.strip() == script.strip():
            break
        script = revised
    return None


def write_recipe(out: Path, script: str, provenance: str) -> None:
    body = script.split("\n", 1)[1] if script.startswith("#!") and "\n" in script else script
    out.write_text(
        "#!/usr/bin/env bash\n"
        "# AUTO-GENERATED by bin/auto-build-script.\n"
        f"# {provenance}\n"
        "# Contract: argv = <src-dir> <build-dir>. Idempotent. Deterministic.\n"
        + body,
        encoding="utf-8",
    )
    out.chmod(0o755)


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("--src", required=True, help="upstream source tree")
    ap.add_argument("--sanitizer", default="asan",
                    help="asan|ubsan|msan|tsan (default asan)")
    ap.add_argument("--out", required=True,
                    help="path to write the validated build script")
    ap.add_argument("--scratch", default="",
                    help="scratch build dir (default: a tempdir)")
    ap.add_argument("--max-iters", type=int, default=5)
    ap.add_argument("--build-timeout-secs", type=int, default=900)
    ap.add_argument("--llm-timeout-secs", type=int, default=60)
    ap.add_argument("--keep-scratch", action="store_true")
    ap.add_argument(
        "--extra-flag", action="append", default=[],
        help="ordered configure/setup argument for a named build configuration (repeatable)",
    )
    ap.add_argument(
        "--widen-from", default="", metavar="RECIPE",
        help="create a feature-widened alternate from an existing working recipe",
    )
    args = ap.parse_args(argv)

    # Keep arguments as an ordered argv vector. Quoting happens only when they
    # are embedded in the generated shell recipe.
    build_config.validate_flags(args.extra_flag)
    if args.widen_from and args.extra_flag:
        die("--widen-from and --extra-flag are mutually exclusive")

    src = Path(args.src).expanduser().absolute()
    if not src.is_dir():
        die(f"source tree not found: {src}")

    out = Path(args.out).expanduser().absolute()
    out.parent.mkdir(parents=True, exist_ok=True)

    scratch = Path(args.scratch).expanduser().absolute() if args.scratch \
        else Path(tempfile.mkdtemp(prefix="auto-build-script-",
                                   dir=os.environ.get("TMPDIR", "/tmp")))
    scratch.mkdir(parents=True, exist_ok=True)

    build_system = detect_build_system(src)
    if not build_system:
        die(f"no recognized build system in: {src}")
    info(f"src={src} sanitizer={args.sanitizer} build_system={build_system}")
    info(f"scratch={scratch}")

    slug = src.name
    readme_excerpt = read_readme_excerpt(src)

    if args.widen_from:
        baseline_path = Path(args.widen_from).expanduser().absolute()
        try:
            baseline = baseline_path.read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            die(f"cannot read --widen-from recipe: {exc}")
        ok, reason = validate_proposed_script(baseline)
        if not ok:
            die(f"--widen-from recipe is invalid: {reason}")
        widened = widen_features(
            slug=slug, build_system=build_system, sanitizer=args.sanitizer,
            baseline_script=baseline, src=src, scratch=scratch,
            readme_excerpt=readme_excerpt,
            build_timeout_secs=args.build_timeout_secs,
            llm_timeout_secs=args.llm_timeout_secs,
            max_iters=args.max_iters,
        )
        if widened == "":
            die("feature widening is not applicable to this target", rc=4)
        if widened is None:
            die("feature widening did not produce a distinct working recipe", rc=3)
        write_recipe(
            out, widened,
            f"build_system={build_system} sanitizer={args.sanitizer} widened_from={baseline_path.name}",
        )
        info(f"widen: wrote {out}")
        print(str(out))
        if not args.keep_scratch:
            shutil.rmtree(scratch, ignore_errors=True)
        return 0

    script = initial_script(build_system, args.sanitizer, args.extra_flag)

    # Write the candidate script next to scratch each iteration so the
    # build can be inspected on failure.
    cand_path = scratch / "build.candidate.sh"

    last_log = ""
    success = False
    for i in range(1, args.max_iters + 1):
        cand_path.write_text(script, encoding="utf-8")
        os.chmod(cand_path, 0o755)
        # Fresh build dir per iteration so a failed configure doesn't
        # carry stale CMakeCache state forward.
        attempt_build = scratch / f"build-{i}"
        if attempt_build.exists():
            shutil.rmtree(attempt_build)
        attempt_build.mkdir(parents=True)

        info(f"iter {i}/{args.max_iters}: running candidate script")
        t0 = time.time()
        try:
            rc, log = run_script(cand_path, src, attempt_build,
                                 args.build_timeout_secs)
        except subprocess.TimeoutExpired:
            rc, log = 124, "[timeout]\n"
        elapsed = time.time() - t0
        last_log = log
        produced = build_produced_artifacts(attempt_build) if rc == 0 else False
        info(f"iter {i}: rc={rc} elapsed={elapsed:.1f}s produced_artifacts={produced}")

        if rc == 0 and produced:
            success = True
            break

        # Short-circuit on toolchain-missing failures. A "command not found"
        # in the build log means the host is missing the binary the recipe
        # depends on (cmake, ninja, meson, cargo, go, ...). The LLM cannot
        # fix this: validate_proposed_script blocks sudo/curl|sh, and a
        # recipe that installed packages would be unshippable to upstream
        # maintainers anyway (reproduce.sh must not modify their host). So
        # exit with an actionable diagnostic instead of burning the LLM
        # revision budget on a class of failure it has no path through.
        missing = detect_missing_commands(log)
        if missing:
            sys.stderr.write("\n[auto-build-script] LAST BUILD LOG TAIL:\n")
            sys.stderr.write(log[-2_000:])
            sys.stderr.write("\n")
            info(
                f"toolchain missing: {' '.join(missing)} — install in the "
                f"audit environment and rerun. The LLM revision loop is "
                f"skipped because the recipe baked into reproduce.sh must "
                f"not invoke sudo / apt-get / curl|sh on a maintainer's "
                f"box (see the safety rails in validate_proposed_script). "
                f"Inside bin/audit-container-shell, install with `apt-get "
                f"install -y {' '.join(missing)}` or extend the install "
                f"list in tests/run-tests.sh --install-container-deps."
            )
            return 3

        # Ask the LLM for a revised complete script.
        info(f"iter {i}: asking LLM for revision (log tail {min(len(log),_BUILD_LOG_TAIL_BYTES)} bytes)")
        revised = ask_llm_for_revision(
            slug=slug, build_system=build_system, sanitizer=args.sanitizer,
            current_script=script, build_log=log,
            readme_excerpt=readme_excerpt,
            timeout_secs=args.llm_timeout_secs,
        )
        if revised is None:
            info(f"iter {i}: LLM returned no script — giving up")
            break

        ok, reason = validate_proposed_script(revised)
        if not ok:
            info(f"iter {i}: rejecting LLM script ({reason})")
            break
        if revised.strip() == script.strip():
            info(f"iter {i}: LLM returned unchanged script — giving up")
            break
        script = revised

    if not success:
        sys.stderr.write("\n[auto-build-script] LAST BUILD LOG TAIL:\n")
        sys.stderr.write(last_log[-2_000:])
        sys.stderr.write("\n")
        die("did not converge", rc=3)

    # The converged script must retain the shell-quoted spelling. Requiring the
    # raw text alone could accept an LLM revision that unquoted shell syntax.
    dropped = [flag for flag in args.extra_flag if shlex.quote(flag) not in script]
    if dropped:
        die(f"converged configuration dropped required flag(s): {dropped}", rc=3)

    # Persist the working script. Add a provenance header.
    write_recipe(
        out, script,
        f"build_system={build_system} sanitizer={args.sanitizer} converged_after={i} iters",
    )
    info(f"converged: wrote {out}")
    print(str(out))
    if not args.keep_scratch:
        shutil.rmtree(scratch, ignore_errors=True)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
