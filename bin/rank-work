#!/usr/bin/env python3
"""Rank concrete work cards for sanitizer audit agents."""

from __future__ import annotations

import argparse
import json
import os
import sys
from collections import Counter
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))
from workqueue import add_common_args, annotate_card_buildability, apply_latest_claim_status, context_from_args, llm_rerank_cards, rank_target, read_jsonl, write_cards


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Rank target source files into concrete audit work cards")
    add_common_args(parser)
    parser.add_argument("--limit", type=int, default=80)
    parser.add_argument("--patch-cards", help="Patch-card JSONL path; defaults to <RESULTS_DIR>/patch-cards.jsonl")
    parser.add_argument("--s6-cards", help="S6 peer-fix card JSONL path; defaults to <RESULTS_DIR>/s6-peer-cards.jsonl")
    parser.add_argument("--llm-top-n", type=int, default=int(os.environ.get("RANK_WORK_LLM_TOP_N", "160")))
    parser.add_argument("--llm-timeout", type=int, default=int(os.environ.get("RANK_WORK_LLM_TIMEOUT", "20")))
    parser.add_argument("--output", help="Output JSONL path; defaults to <RESULTS_DIR>/work-cards.jsonl")
    parser.add_argument("--quiet", action="store_true")
    parser.add_argument("--jsonl", action="store_true", help="print full card JSONL to stdout")
    parser.add_argument("--summary-limit", type=int, default=8, help="number of top cards to show in compact stdout")
    args = parser.parse_args(argv)

    ctx = context_from_args(args)
    patch_cards = Path(args.patch_cards).expanduser().resolve() if args.patch_cards else None
    out = Path(args.output).expanduser().resolve() if args.output else ctx.results_dir / "work-cards.jsonl"
    cards = rank_target(ctx, args.limit, patch_cards)
    cards = llm_rerank_cards(ctx, cards, args.llm_top_n, args.llm_timeout)
    # Merge S6 peer-fix cards. bin/peer-fix-cards writes these to a
    # separate s6-peer-cards.jsonl, refreshed each iteration alongside
    # patch-cards.jsonl — but rank_target only ever rebuilds patch +
    # ranked-source cards, so without this merge the S6 cards are
    # written and then orphaned: they never land in work-cards.jsonl
    # and no agent can claim them. The s6 file is authoritative (it is
    # regenerated, not preserved), so we read it fresh. Dedup by id.
    s6_path = Path(args.s6_cards).expanduser().resolve() if args.s6_cards \
        else ctx.results_dir / "s6-peer-cards.jsonl"
    merged_ids = {c.get("id") for c in cards}
    s6_cards = [
        c for c in read_jsonl(s6_path)
        if c.get("kind") == "s6-peer-fix"
        and c.get("id") not in merged_ids
    ]
    cards = cards + s6_cards
    cards = annotate_card_buildability(ctx, cards)
    cards = apply_latest_claim_status(ctx, cards)
    write_cards(out, cards)
    if not args.quiet:
        if args.jsonl:
            for card in cards:
                print(json.dumps(card, sort_keys=True))
        else:
            print_compact_summary(cards, out, args.summary_limit)
    return 0


def _card_file(card: dict) -> str:
    for key in ("file", "path", "source"):
        value = str(card.get(key) or "").strip()
        if value:
            return value
    return "-"


def _clip(value: object, limit: int = 96) -> str:
    text = " ".join(str(value or "").split())
    if len(text) > limit:
        return text[: max(0, limit - 3)] + "..."
    return text


def _counter_text(cards: list[dict], key: str) -> str:
    counts = Counter(str(card.get(key) or "unknown") for card in cards)
    return ",".join(f"{name}:{count}" for name, count in sorted(counts.items()))


def print_compact_summary(cards: list[dict], out: Path, summary_limit: int) -> None:
    limit = max(0, summary_limit)
    print(f"rank-work: wrote {len(cards)} card(s) to {out}")
    if cards:
        print(f"rank-work: by_strategy={_counter_text(cards, 'strategy')} by_status={_counter_text(cards, 'status')}")
    if limit:
        print(f"rank-work: top {min(limit, len(cards))} card(s)")
        for card in cards[:limit]:
            reason = card.get("reason") or card.get("why_ranked") or ""
            print(
                "  "
                f"{card.get('id', '-')}"
                f" score={card.get('score', '-')}"
                f" strategy={card.get('strategy', '-')}"
                f" kind={card.get('kind', '-')}"
                f" file={_clip(_card_file(card), 72)}"
                f" reason={_clip(reason)}"
            )
    if len(cards) > limit:
        print(f"rank-work: ... {len(cards) - limit} more card(s); inspect with bin/state list-cards --limit N or rerun with --jsonl")


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
