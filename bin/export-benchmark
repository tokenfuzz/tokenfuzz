#!/usr/bin/env python3
"""bin/export-benchmark — package benchmark results into one self-contained,
shareable archive.

A benchmark run leaves its evidence spread across
`output/benchmark/<backend>/<runid>/` — rendered comparison pages, per-backend
ledgers, and a `pool/` of cluster + crash reports — with the heavy, internal
`cells/` and `recon-cache/` trees alongside. This tool selects the runs you
want, copies just the shareable, path-scrubbed artifacts into a staging tree,
re-renders the comparison page and ledgers so every link resolves *inside* the
bundle, and zips it. The recipient unzips and opens `benchmark-result.html`
offline — no network, no `/Users/...` paths, no harness checkout required.

It deliberately reuses the same renderers `bin/benchmark` uses
(`lib/benchmark.py`'s `crosstab` / `render_section` / `append_to_ledger`, and
`bin/render-md`) so a shared page is byte-for-byte the page the operator sees.

Scope follows the same confine-by-flag grammar as `bin/benchmark --regenerate`:

  bin/export-benchmark                       # every backend, every run
  bin/export-benchmark --backend codex       # one backend
  bin/export-benchmark --target pcre2        # one target, across backends
  bin/export-benchmark --target pcre2 --backend codex   # both, AND'd
  bin/export-benchmark --run-id <id> --backend codex    # a single run

Options (default in brackets):
  --bench-root <dir>   Source root holding <backend>/<runid>/ runs.
                       [output/benchmark]
  --backend <name>     Confine to one backend subtree.
  --target <slug>      Confine to runs whose run.json target matches. A run's
                       target lives in run.json, not its path, so this reads
                       each run's metadata — exactly as --regenerate does.
  --run-id <id>        Confine to a single run directory name. Requires
                       --backend, since run ids are not unique across backends.
  --format <fmt>       zip | tar | dir. [zip]
  --out <path>         Archive path (or directory, for --format dir).
                       [<bench-root>/benchmark-share[-<backend>][-<target>].<ext>]

Included per run: report.json, run.json, clusters-*.json, pool-members.json,
and the whole pool/ tree of cluster reports and crash/finding bundles — REPORT,
sanitizer output, harness source, and the testcase input (the crash trigger,
kept even when it is binary). Dropped from a crash/finding dir: its internal
.audit/ (harness session state), *.dSYM debug bundles, and compiled executables
— the last two are machine-specific build output the recipient regenerates from
the shipped source + reproduce.sh, and they embed an unscrubbable absolute build
path. Excluded at the run level: cells/, recon-cache/, console.log,
severity.log — heavy harness internals and operator-side logs.

Every text file is scrubbed of local /Users... paths via the harness
path-replacer (lib/benchmark._scrub_local_paths) — the same collapse to
repo-relative / ~ a live run applies, widened here to the whole staged run.

The bundle contains AddressSanitizer reports and target crash signatures. It is
a local artifact you hand off deliberately; nothing is uploaded.
"""

from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

SCRIPT_DIR = Path(__file__).absolute().parent
SCRIPT_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(SCRIPT_ROOT / "lib"))

import benchmark as B  # noqa: E402  (runtime sys.path adjustment)

# Run-level subtrees / files never shipped, plus each crash dir's internal
# .audit/. cells/, recon-cache/ are heavy harness internals and the *.log files
# are operator-side logs. A *.dSYM is a macOS debug-symbol bundle — build output
# the recipient regenerates, and it embeds the absolute build path.
EXCLUDE = ("cells", "recon-cache", ".audit", "console.log", "severity.log")


def log(msg: str) -> None:
    print(f"[export-benchmark] {msg}", file=sys.stderr)


def _ignore(_dir: str, names: list[str]) -> set[str]:
    """copytree filter: skip the EXCLUDE names and any *.dSYM debug bundle."""
    return {n for n in names if n in EXCLUDE or n.endswith(".dSYM")}


def _is_binary(path: Path) -> bool:
    """A NUL byte in the first 8 KiB is the classic text-vs-binary sniff."""
    try:
        with path.open("rb") as fh:
            return b"\x00" in fh.read(8192)
    except OSError:
        return False


def clean_tree(root: Path) -> None:
    """Make a staged run portable and leak-free:

      * drop compiled executables (binary + exec bit). They are machine/arch
        output the recipient rebuilds from the shipped harness source +
        reproduce.sh, so they reproduce nothing on their own, and they embed an
        absolute build path inside the blob that no scrubber can reach. A binary
        *testcase input* has no exec bit and is KEPT — it is the crash trigger.
      * scrub local /Users/... paths from every text file, reusing the harness
        path-replacer (lib/benchmark._scrub_local_paths) — the same scrub a live
        run applies to pooled reports, widened to the whole staged run.
    """
    for path in root.rglob("*"):
        if not path.is_file() or path.is_symlink():
            continue
        if _is_binary(path):
            if path.stat().st_mode & 0o111:  # executable bit set
                path.unlink(missing_ok=True)
            continue  # non-exec binary (testcase input) ships as-is
        try:
            if path.stat().st_size > B._MAX_SCRUB_BYTES:
                continue
            original = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        scrubbed = B._scrub_local_paths(original)
        if scrubbed != original:
            try:
                path.write_text(scrubbed, encoding="utf-8")
            except OSError:
                pass


def _is_run_dir(d: Path) -> bool:
    return d.is_dir() and (d / "report.json").is_file()


def _run_target(run_dir: Path) -> str:
    """The target slug for a run, read from run.json (falls back to report.json).

    The target is metadata, not a path component — the run directory is keyed by
    timestamp — so confining by target means reading each run's recorded slug,
    the same source bin/benchmark --regenerate uses.
    """
    for src, path in (("run", run_dir / "run.json"),
                      ("report", run_dir / "report.json")):
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, ValueError):
            continue
        run = data.get("run", data) if src == "report" else data
        target = run.get("target")
        if target:
            return str(target)
    return ""


def select_runs(bench_root: Path, backend: str, target: str,
                run_id: str) -> list[tuple[str, Path]]:
    """(backend_name, run_dir) for every run matching the scope filters.

    Backend detection reuses lib/benchmark._benchmark_roots so the layout is
    structurally identified (a dir holding >=1 run with report.json) rather than
    name-matched.
    """
    selected: list[tuple[str, Path]] = []
    for backend_dir in B._benchmark_roots(bench_root):
        name = backend_dir.name
        if backend and name != backend:
            continue
        for run_dir in sorted(d for d in backend_dir.iterdir() if _is_run_dir(d)):
            if run_id and run_dir.name != run_id:
                continue
            if target and _run_target(run_dir) != target:
                continue
            selected.append((name, run_dir))
    return selected


def _set_bench_dir(report_path: Path, value: str) -> None:
    try:
        report = json.loads(report_path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return
    if report.get("bench_dir"):
        report["bench_dir"] = value
        report_path.write_text(json.dumps(report, indent=2) + "\n",
                               encoding="utf-8")


def stage_run(run_dir: Path, dest: Path) -> None:
    """Copy one run into the staging tree (minus EXCLUDE / *.dSYM / executables,
    text scrubbed), then repoint its report.json bench_dir at the staged
    absolute path so crosstab/ledger links resolve inside the bundle. main()
    rewrites it back to a clean relative path once rendering is done."""
    shutil.copytree(run_dir, dest, ignore=_ignore)
    clean_tree(dest)
    _set_bench_dir(dest / "report.json", str(dest.resolve()))


def render_html_sibling(md_path: Path) -> None:
    """Emit the styled .html sibling via bin/render-md (the same renderer
    bin/benchmark uses). Best-effort: a missing/failed renderer leaves the .md,
    which is still a valid, linkable artifact."""
    render_md = SCRIPT_ROOT / "bin" / "render-md"
    if not render_md.exists():
        log("WARN: bin/render-md not found; shipping markdown only")
        return
    try:
        subprocess.run([sys.executable, str(render_md), str(md_path),
                        "--html-sibling"],
                       check=True, stdout=subprocess.DEVNULL,
                       stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        log(f"WARN: render-md failed for {md_path.name}; shipping markdown only")


def rebuild_ledger(backend_dir: Path) -> None:
    """Rebuild one backend's benchmark-results.md from the staged runs' existing
    report.json files. We replay render_section (not the `ledger` subcommand)
    because that subcommand re-aggregates from cells/, which the bundle omits —
    report.json already holds the aggregated result render_section consumes."""
    ledger = backend_dir / "benchmark-results.md"
    ledger.unlink(missing_ok=True)
    (backend_dir / "benchmark-results.html").unlink(missing_ok=True)
    for run_dir in sorted(d for d in backend_dir.iterdir() if _is_run_dir(d)):
        try:
            report = json.loads((run_dir / "report.json").read_text("utf-8"))
            # Links in the section resolve relative to the ledger's own
            # directory, so the page stays portable once the bundle is unzipped.
            with B._render_relative_to(ledger.parent):
                section = B.render_section(report)
            B.append_to_ledger(ledger, section)
        except (OSError, ValueError, KeyError) as exc:
            # Fail open: a malformed report.json drops one ledger row rather
            # than aborting the whole export.
            log(f"WARN: skipped ledger row for {run_dir.name}: {exc}")
    if ledger.exists():
        render_html_sibling(ledger)


def rebuild_crosstab(staging: Path) -> Path:
    """Rebuild the cross-backend comparison page over the staged runs. crosstab
    reads report.json only, so it scopes to exactly the runs present in the
    staging tree — no extra filtering, no links to excluded runs."""
    crosstab_md = staging / "benchmark-result.md"
    with B._render_relative_to(staging):
        md = B.crosstab(staging)
    crosstab_md.write_text(md, encoding="utf-8")
    render_html_sibling(crosstab_md)
    return crosstab_md


def default_out(bench_root: Path, backend: str, target: str, run_id: str,
                fmt: str) -> Path:
    parts = ["benchmark-share"]
    if backend:
        parts.append(backend)
    if target:
        parts.append(target)
    if run_id:
        parts.append(run_id)
    stem = "-".join(parts)
    ext = {"zip": ".zip", "tar": ".tar.gz", "dir": ""}[fmt]
    return bench_root / f"{stem}{ext}"


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(
        prog="bin/export-benchmark",
        description="Package benchmark results into a self-contained archive.")
    ap.add_argument("--bench-root", type=Path,
                    default=SCRIPT_ROOT / "output" / "benchmark")
    ap.add_argument("--backend", default="")
    ap.add_argument("--target", default="")
    ap.add_argument("--run-id", default="")
    ap.add_argument("--format", choices=("zip", "tar", "dir"), default="zip")
    ap.add_argument("--out", type=Path, default=None)
    args = ap.parse_args(argv)

    bench_root = args.bench_root.resolve()
    if not bench_root.is_dir():
        log(f"FATAL: bench root not found: {bench_root}")
        return 1
    if args.run_id and not args.backend:
        log("FATAL: --run-id requires --backend (run ids are not unique "
            "across backends)")
        return 1

    runs = select_runs(bench_root, args.backend, args.target, args.run_id)
    if not runs:
        scope = ", ".join(f"{k}={v}" for k, v in (
            ("backend", args.backend), ("target", args.target),
            ("run-id", args.run_id)) if v) or "no filters"
        log(f"FATAL: no benchmark runs matched ({scope}) under {bench_root}")
        return 2

    out = args.out or default_out(bench_root, args.backend, args.target,
                                  args.run_id, args.format)
    out = out.resolve()

    staging = Path(tempfile.mkdtemp(prefix="benchmark-share-"))
    try:
        log(f"selected {len(runs)} run(s); staging at {staging}")
        staged: list[Path] = []
        for backend_name, run_dir in runs:
            dest = staging / backend_name / run_dir.name
            stage_run(run_dir, dest)
            staged.append(dest)
            log(f"  + {backend_name}/{run_dir.name}")

        for backend_dir in sorted({d.parent for d in staged}):
            rebuild_ledger(backend_dir)
        crosstab_md = rebuild_crosstab(staging)
        entry = crosstab_md.with_suffix(".html")
        entry = entry if entry.exists() else crosstab_md

        # Rendering is done; the absolute staging path stored in each
        # report.json bench_dir has served its purpose. Rewrite it to a clean
        # bundle-relative path so the shipped JSON carries no machine path.
        for dest in staged:
            _set_bench_dir(dest / "report.json",
                           str(dest.relative_to(staging)))

        out.parent.mkdir(parents=True, exist_ok=True)
        if args.format == "dir":
            if out.exists():
                shutil.rmtree(out)
            shutil.move(str(staging), str(out))
            produced = out
        else:
            fmt = {"zip": "zip", "tar": "gztar"}[args.format]
            ext = {"zip": ".zip", "tar": ".tar.gz"}[args.format]
            base = str(out)[:-len(ext)] if str(out).endswith(ext) else str(out)
            produced = Path(shutil.make_archive(base, fmt, root_dir=staging))
    finally:
        if staging.exists() and args.format != "dir":
            shutil.rmtree(staging, ignore_errors=True)

    log(f"wrote {produced}")
    log(f"entry point: {entry.name} (at the archive root)")
    log("NOTE: bundle contains AddressSanitizer reports and target crash "
        "signatures — share deliberately.")
    print(produced)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
