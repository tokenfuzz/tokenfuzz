#!/usr/bin/env python3
"""Aggregate per-agent edge journals into a subsystem coverage report.

The journals are written by ``lib/edges.py`` under
``<results_root>/coverage/edges-agent-*.journal``. Each non-empty record has
the form ``<function>|<file>:<line>``.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import stat
import sys
from collections import Counter
from datetime import datetime, timezone
from pathlib import Path

TOOL = "coverage-summary"
JOURNAL_RE = re.compile(r"edges-agent-.*\.journal\Z")
LINE_SUFFIX_RE = re.compile(rb":[0-9]+\Z")


class ArgumentParser(argparse.ArgumentParser):
    """Keep the command's established concise argument errors."""

    def error(self, message: str) -> None:
        missing = re.fullmatch(r"argument (--[^:]+): expected one argument", message)
        if missing:
            self.exit(2, f"[{TOOL}] {missing.group(1)} requires a value\n")
        if message.startswith("unrecognized arguments: "):
            unknown = message.removeprefix("unrecognized arguments: ").split()[0]
            self.exit(2, f"[{TOOL}] unknown arg: {unknown}\n")
        self.exit(2, f"[{TOOL}] {message}\n")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = ArgumentParser(
        prog=TOOL,
        description="Aggregate edge-novelty data into a subsystem coverage report.",
    )
    parser.add_argument(
        "--slug",
        default=os.environ.get("TARGET_SLUG", ""),
        help="target slug (default: TARGET_SLUG)",
    )
    parser.add_argument(
        "--depth",
        default="2",
        help="path-component depth used to group edges (default: 2)",
    )
    parser.add_argument(
        "--min-edges",
        default="1",
        help="drop subsystems with fewer edges (default: 1)",
    )
    parser.add_argument(
        "--format",
        default="md",
        help="output format: md (default), tsv, or json",
    )
    parser.add_argument("--out", default="", help="write to this path instead of stdout")
    parser.add_argument(
        "--results-dir",
        default="",
        help="override the results root and skip slug lookup",
    )
    args = parser.parse_args(argv)

    for flag, value in (("--depth", args.depth), ("--min-edges", args.min_edges)):
        if not value.isascii() or not value.isdigit():
            parser.exit(2, f"[{TOOL}] {flag} must be a non-negative integer\n")
    args.depth = int(args.depth)
    args.min_edges = int(args.min_edges)
    if args.depth < 1:
        parser.exit(2, f"[{TOOL}] --depth must be a positive integer\n")
    if args.format not in {"md", "tsv", "json"}:
        parser.exit(2, f"[{TOOL}] --format must be md, tsv, or json\n")
    return args


def coverage_root(args: argparse.Namespace) -> Path | None:
    results_dir = (
        args.results_dir
        or os.environ.get("EDGES_RESULTS_DIR", "")
        or os.environ.get("RESULTS_DIR", "")
    )
    if results_dir:
        return Path(results_dir) / "coverage"

    script_root = os.environ.get("SCRIPT_ROOT", "")
    if not args.slug or not script_root:
        return None
    output_slug = os.environ.get("TARGET_OUTPUT_SLUG", "") or args.slug
    output_root = Path(script_root) / "output" / output_slug
    results_root = output_root / "results" if (output_root / "results").is_dir() else output_root
    return results_root / "coverage"


def journal_paths(root: Path) -> list[Path]:
    try:
        entries = list(os.scandir(root))
    except OSError:
        return []

    paths: list[Path] = []
    for entry in entries:
        if not JOURNAL_RE.fullmatch(entry.name):
            continue
        try:
            mode = entry.stat(follow_symlinks=False).st_mode
        except OSError:
            continue
        if stat.S_ISREG(mode):
            paths.append(Path(entry.path))
    return sorted(paths, key=lambda path: os.fsencode(path.name))


def read_edge_union(paths: list[Path]) -> set[bytes]:
    edges: set[bytes] = set()
    for path in paths:
        try:
            data = path.read_bytes()
        except OSError:
            continue
        lines = data.split(b"\n")
        if lines and lines[-1] == b"":
            lines.pop()
        edges.update(lines)
    return edges


def subsystem_counts(edges: set[bytes], depth: int) -> list[tuple[bytes, int]]:
    counts: Counter[bytes] = Counter()
    for edge in edges:
        _separator, found, path = edge.rpartition(b"|")
        if not found or not path:
            continue
        path = LINE_SUFFIX_RE.sub(b"", path)
        parts = path.split(b"/")
        subsystem = b"/".join(parts[:depth])
        counts[subsystem] += 1
    return sorted(counts.items(), key=lambda item: (-item[1], item[0]))


def text(value: bytes) -> str:
    return value.decode("utf-8", errors="replace")


def share(count: int, total: int) -> float:
    return count * 100.0 / total if total else 0.0


def render_tsv(rows: list[tuple[bytes, int]], total: int, minimum: int) -> str:
    lines = ["subsystem\tedges\tshare_pct"]
    lines.extend(
        f"{text(subsystem)}\t{count}\t{share(count, total):.2f}"
        for subsystem, count in rows
        if count >= minimum
    )
    return "\n".join(lines) + "\n"


def render_json(
    slug: str, depth: int, rows: list[tuple[bytes, int]], total: int, minimum: int
) -> str:
    payload = {
        "slug": slug,
        "depth": depth,
        "total_edges": total,
        "subsystems": [
            {
                "subsystem": text(subsystem),
                "edges": count,
                "share_pct": round(share(count, total), 2),
            }
            for subsystem, count in rows
            if count >= minimum
        ],
    }
    return json.dumps(payload, ensure_ascii=False, separators=(",", ":")) + "\n"


def render_markdown(
    slug: str, depth: int, rows: list[tuple[bytes, int]], total: int, minimum: int
) -> str:
    lines = ["# Coverage Summary", ""]
    if slug:
        lines.append(f"- **Target:** `{slug}`")
    lines.extend(
        [
            f"- **Total edges seen:** {total}",
            f"- **Group depth:** {depth} path component(s)",
            f"- **Generated:** {datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')}",
            "",
            "| Subsystem | Edges | Share |",
            "|-----------|------:|------:|",
        ]
    )
    lines.extend(
        f"| `{text(subsystem)}` | {count} | {share(count, total):.2f}% |"
        for subsystem, count in rows
        if count >= minimum
    )
    lines.extend(["", "_Generated by `bin/coverage-summary`._"])
    return "\n".join(lines) + "\n"


def emit(output: str, out_path: str) -> int:
    if not out_path:
        try:
            sys.stdout.write(output)
        except BrokenPipeError:
            return 1
        return 0

    path = Path(out_path)
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(output, encoding="utf-8")
    except OSError as error:
        print(f"[{TOOL}] could not write {path}: {error}", file=sys.stderr)
        return 2
    return 0


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    root = coverage_root(args)
    if root is None:
        print(
            f"[{TOOL}] could not resolve coverage root (need --slug or --results-dir)",
            file=sys.stderr,
        )
        return 2

    paths = journal_paths(root)
    if not paths:
        print(
            f"[{TOOL}] no edge journals under {root} - "
            "run bin/hits with --slug/--agent first",
            file=sys.stderr,
        )
        return 1

    edges = read_edge_union(paths)
    rows = subsystem_counts(edges, args.depth)
    total = len(edges)
    if args.format == "tsv":
        output = render_tsv(rows, total, args.min_edges)
    elif args.format == "json":
        output = render_json(args.slug, args.depth, rows, total, args.min_edges)
    else:
        output = render_markdown(args.slug, args.depth, rows, total, args.min_edges)
    return emit(output, args.out)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
