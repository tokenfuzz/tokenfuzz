#!/usr/bin/env python3
"""Display bounded source ranges or run grep with bounded context."""

from __future__ import annotations

import os
import sys
import tempfile
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))
from file_tools import cap_output_file, capture_command
from command_tools import find_executable


USAGE = """Usage:
  bin/peek <FILE>:<START>-<END>            show line range (byte-capped)
  bin/peek <FILE>:<START>                  show START..end of file
  bin/peek <FILE>                          show whole file (byte-capped)
  bin/peek [grep flags] PATTERN FILE...    grep with clamped -A/-B/-C

Env knobs: PEEK_GREP_AFTER (30), PEEK_GREP_BEFORE (8). The ~50 KiB byte cap
bounds size. Pass --no-cap to disable clamping.
"""


def fail(message: str) -> int:
    print(f"[peek] {message}", file=sys.stderr)
    return 2


def real_command(name: str) -> str | None:
    wrapper = Path(
        os.environ.get("AGENT_WRAPPERS_PATH", str(ROOT / "lib" / "wrappers"))
    ).resolve()
    return find_executable(name, skip=(wrapper,))


def emit_file(path: Path, label: str, no_cap: bool) -> int:
    if no_cap:
        with path.open("rb") as source:
            while chunk := source.read(1024 * 1024):
                sys.stdout.buffer.write(chunk)
        return 0
    try:
        data = cap_output_file(path, label)
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 2
    sys.stdout.buffer.write(data)
    return 0


def range_mode(raw: str, no_cap: bool) -> int:
    if ":" in raw:
        filename, spec = raw.split(":", 1)
    else:
        filename, spec = raw, ""
    path = Path(filename)
    if not path.is_file():
        return fail(f"file not found: {filename}")

    if not spec:
        start, end = 1, None
    elif "-" in spec:
        start_text, end_text = spec.split("-", 1)
        if not start_text.isdigit() or not end_text.isdigit():
            return fail(
                f"bad range '{spec}': start and end must be positive integers"
            )
        start, end = int(start_text), int(end_text)
        if start < 1 or end < start:
            return fail(f"bad range '{spec}': require 1 <= start <= end")
    else:
        if not spec.isdigit():
            return fail(f"bad start '{spec}': must be a positive integer")
        start, end = int(spec), None
        if start < 1:
            return fail(f"bad start '{spec}': must be >= 1")

    if start == 1 and end is None:
        return emit_file(path, "peek-range", no_cap)
    with tempfile.TemporaryDirectory(prefix="peek-range-") as directory:
        selected = Path(directory) / "range"
        with path.open("rb") as source, selected.open("wb") as target:
            for number, line in enumerate(source, 1):
                if number < start:
                    continue
                if end is not None and number > end:
                    break
                target.write(line)
        return emit_file(selected, "peek-range", no_cap)


def clamp(value: str, maximum: int, no_cap: bool) -> str:
    if no_cap or not value.isdigit():
        return value
    return str(min(int(value), maximum))


def clamp_grep_args(
    args: list[str], after: int, before: int, no_cap: bool
) -> tuple[list[str], str, str]:
    output: list[str] = []
    clamped_after = ""
    clamped_before = ""
    index = 0
    while index < len(args):
        arg = args[index]
        separate = {
            "-A": (after, "after"),
            "--after-context": (after, "after"),
            "-B": (before, "before"),
            "--before-context": (before, "before"),
        }
        if arg in separate and index + 1 < len(args):
            maximum, side = separate[arg]
            value = args[index + 1]
            current = clamp(value, maximum, no_cap)
            if current != value:
                if side == "after":
                    clamped_after = f"{value}->{current}"
                else:
                    clamped_before = f"{value}->{current}"
            output.extend((arg, current))
            index += 2
            continue
        handled = False
        for prefix, maximum, side in (
            ("-A", after, "after"),
            ("-B", before, "before"),
            ("--after-context=", after, "after"),
            ("--before-context=", before, "before"),
        ):
            if arg.startswith(prefix) and arg != prefix:
                value = arg[len(prefix) :]
                current = clamp(value, maximum, no_cap)
                if current != value:
                    if side == "after":
                        clamped_after = f"{value}->{current}"
                    else:
                        clamped_before = f"{value}->{current}"
                output.append(prefix + current)
                handled = True
                break
        if handled:
            index += 1
            continue

        context_value: str | None = None
        joined = False
        if arg in ("-C", "--context") and index + 1 < len(args):
            context_value = args[index + 1]
        elif arg.startswith("-C") and arg != "-C":
            context_value = arg[2:]
            joined = True
        elif arg.startswith("--context="):
            context_value = arg.split("=", 1)[1]
            joined = True
        if context_value is not None:
            current_before = clamp(context_value, before, no_cap)
            current_after = clamp(context_value, after, no_cap)
            if current_before != context_value:
                clamped_before = f"{context_value}->{current_before}"
            if current_after != context_value:
                clamped_after = f"{context_value}->{current_after}"
            output.extend(("-B" + current_before, "-A" + current_after))
            index += 1 if joined else 2
            continue

        output.append(arg)
        index += 1
    return output, clamped_after, clamped_before


def main(argv: list[str] | None = None) -> int:
    incoming = list(sys.argv[1:] if argv is None else argv)
    args: list[str] = []
    no_cap = False
    index = 0
    while index < len(incoming):
        arg = incoming[index]
        if arg == "--no-cap":
            no_cap = True
        elif arg in ("-h", "--help"):
            print(USAGE, file=sys.stderr, end="")
            return 0
        elif arg == "--":
            args.extend(incoming[index:])
            break
        else:
            args.append(arg)
        index += 1
    if not args:
        print(USAGE, file=sys.stderr, end="")
        return 2

    after_text = os.environ.get("PEEK_GREP_AFTER", "30")
    before_text = os.environ.get("PEEK_GREP_BEFORE", "8")
    if not after_text.isdigit():
        return fail(f"non-numeric PEEK_GREP_AFTER: {after_text}")
    if not before_text.isdigit():
        return fail(f"non-numeric PEEK_GREP_BEFORE: {before_text}")

    explicit_operand = len(args) == 2 and args[0] == "--"
    if explicit_operand:
        args = args[1:]
    first = args[0]
    is_range = len(args) == 1 and (
        explicit_operand
        or (not first.startswith("-") and (":" in first or Path(first).exists()))
    )
    if len(args) == 1 and not is_range and (
        "/" in first or ("." in Path(first).name and not first.startswith("-"))
    ):
        return fail(f"file not found: {first}")
    if is_range:
        return range_mode(first, no_cap)

    grep = real_command("grep")
    if not grep:
        return fail("grep not found in PATH")
    adjusted, changed_after, changed_before = clamp_grep_args(
        args, int(after_text), int(before_text), no_cap
    )
    with capture_command([grep, *adjusted], capture_stderr=False) as completed:
        rc = emit_file(completed.stdout, "peek-grep", no_cap)
        if rc != 0:
            return rc
        if not no_cap and (changed_after or changed_before):
            message = "[peek: clamped grep context"
            if changed_after:
                message += f" -A {changed_after}"
            if changed_before:
                message += f" -B {changed_before}"
            message += (
                ". PEEK_GREP_AFTER=N, PEEK_GREP_BEFORE=N, or --no-cap to widen.]\n"
            )
            sys.stdout.write(message)
        return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
