#!/usr/bin/env python3
"""UndefinedBehaviorSanitizer runner for browser and standalone targets."""

from __future__ import annotations

import filecmp
import os
import shutil
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))

import sanitizer
import target_config
from sanitizer_helpers import _BROWSER_NOISE, copy_file, copy_filtered, file_contains
from sanitizer_run import SanitizerRunner
from timeout import capture_timeout, run_timeout

PROFILE_PREFS = '''user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
user_pref("toolkit.telemetry.reportingpolicy.firstRun", false);
user_pref("browser.aboutConfig.showWarning", false);
user_pref("browser.tabs.warnOnClose", false);
user_pref("browser.warnOnQuit", false);
user_pref("dom.ipc.processCount", 1);
user_pref("dom.allow_scripts_to_close_windows", true);
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("startup.homepage_welcome_url", "");
user_pref("startup.homepage_welcome_url.additional", "");
user_pref("browser.startup.homepage_override.mstone", "ignore");
user_pref("browser.startup.page", 0);
user_pref("devtools.console.stdout.content", true);
'''


def load_config():
    probe = sys.argv[2] if len(sys.argv) > 2 else Path.cwd()
    try:
        return target_config.load(probe)
    except (FileNotFoundError, ValueError):
        return None


CONFIG = load_config()
ENV = sanitizer.prepare_runtime_env("ubsan")
sanitizer.warn_if_disabled("ubsan", CONFIG)
TARGET_ROOT = CONFIG.target_root if CONFIG else ENV.get("TARGET_ROOT", str(ROOT / "targets/firefox"))
BUILD_DIR = sanitizer.build_dir("ubsan", TARGET_ROOT, ENV)


def browser_binary() -> str:
    if ENV.get("UBSAN_BROWSER"):
        return ENV["UBSAN_BROWSER"]
    if CONFIG and CONFIG.ubsan_bin:
        return CONFIG.resolve_path(CONFIG.ubsan_bin)
    darwin = BUILD_DIR / "dist/Nightly.app/Contents/MacOS/firefox"
    linux = BUILD_DIR / "dist/bin/firefox"
    preferred = darwin if sys.platform == "darwin" else linux
    fallback = linux if sys.platform == "darwin" else darwin
    return str(preferred if os.access(preferred, os.X_OK) else fallback)


def mode_options(mode: str) -> str:
    return sanitizer.compose_options("ubsan", sanitizer.options_for("ubsan", mode), CONFIG)


def run_browser(options: str, timeout: int, args: list[str]) -> int:
    resolved = [
        Path(arg).resolve().as_uri() if not arg.startswith("-") and Path(arg).is_file() else arg
        for arg in args
    ]
    with tempfile.TemporaryDirectory(prefix="ubsan-profile-") as profile_name, tempfile.TemporaryDirectory(prefix="ubsan-output-") as output_name:
        profile = Path(profile_name)
        output_dir = Path(output_name)
        (profile / "user.js").write_text(PROFILE_PREFS)
        environment = {
            **ENV,
            "UBSAN_OPTIONS": sanitizer.runtime_options(
                "ubsan", f"{options}:log_path={output_dir / 'ubsan.log'}", ENV
            ),
            "MOZ_DISABLE_CONTENT_SANDBOX": "1",
            "MOZ_HEADLESS": "1",
        }
        with capture_timeout(
            [browser_binary(), "--profile", str(profile), "--no-remote", *resolved],
            timeout,
            env=environment,
        ) as (completed, output):
            copy_filtered(output, sys.stdout.buffer, _BROWSER_NOISE)
            reports = [path for path in output_dir.glob("ubsan.log.*") if path.stat().st_size]
            for report in reports:
                print(f"=== UBSan report: {report.name} ===")
                copy_file(report, sys.stdout.buffer)
            if reports:
                print("[run-ubsan] UBSan issue detected", file=sys.stderr)
                persist = ENV.get("UBSAN_CRASH_LOG_DIR")
                if persist and Path(persist).is_dir():
                    for report in reports:
                        shutil.copy2(report, persist)
                    shutil.copy2(output, Path(persist) / "browser-output.txt")
                    print(f"[run-ubsan] Raw UBSan logs preserved in {persist}", file=sys.stderr)
            elif file_contains(output, b"TESTCASE_EXECUTED"):
                print("[run-ubsan] EXECUTION VERIFIED: testcase ran (no UBSan issue)", file=sys.stderr)
            else:
                print("[run-ubsan] WARNING: no UBSan issue and no execution evidence - testcase may not have run", file=sys.stderr)
            return completed.returncode


def run_js_diff(options: str, timeout: int, args: list[str]) -> int:
    if not args:
        print("Usage: run-ubsan js-diff <testcase.js> [extra args...]", file=sys.stderr)
        return 1
    eager = CONFIG.s4_diff_pairs.get("jit_eager", []) if CONFIG else []
    off = CONFIG.s4_diff_pairs.get("jit_off", []) if CONFIG else []
    eager = eager or ["--ion-eager"]
    off = off or ["--no-ion"]
    js = ENV.get("UBSAN_JS", str(BUILD_DIR / "dist/bin/js"))
    environment = {**ENV, "UBSAN_OPTIONS": sanitizer.runtime_options("ubsan", options, ENV)}
    print(f"=== Running with {' '.join(eager)} (JIT eager) ===", file=sys.stderr)
    with capture_timeout([js, *eager, *args], timeout, env=environment) as (_, eager_out):
        print(f"=== Running with {' '.join(off)} (JIT off) ===", file=sys.stderr)
        with capture_timeout([js, *off, *args], timeout, env=environment) as (_, off_out):
            print(f"=== {' '.join(eager)} output ===")
            copy_file(eager_out, sys.stdout.buffer)
            print(f"\n=== {' '.join(off)} output ===")
            copy_file(off_out, sys.stdout.buffer)
            print()
            if filecmp.cmp(eager_out, off_out, shallow=False):
                print("[run-ubsan] DIFFERENTIAL: outputs MATCH (no divergence)", file=sys.stderr)
            else:
                print("[run-ubsan] DIFFERENTIAL: outputs DIFFER - potential JIT bug!", file=sys.stderr)
            if file_contains(eager_out, b"runtime error:"):
                print(f"[run-ubsan] UBSan issue in {' '.join(eager)} mode", file=sys.stderr)
            if file_contains(off_out, b"runtime error:"):
                print(f"[run-ubsan] UBSan issue in {' '.join(off)} mode", file=sys.stderr)
    return 0


def browser_fuzz(options: str, timeout: int, args: list[str], repro: bool) -> int:
    fuzzer = ENV.get("FUZZER", "")
    if not fuzzer:
        print("Error: FUZZER env var must be set.", file=sys.stderr)
        return 1
    if not sanitizer.validate_fuzzer_name(fuzzer):
        print(f"Error: FUZZER must match ^[A-Za-z_][A-Za-z0-9_]*$ (got '{fuzzer}')", file=sys.stderr)
        return 2
    if repro and not args:
        print("Error: provide a crash file to reproduce.", file=sys.stderr)
        return 1
    clean_args = args if repro else [arg for arg in args if not arg.startswith("-fork=")]
    environment = {
        **ENV,
        "FUZZER": fuzzer,
        "MOZ_RUN_GTEST": "1",
        "MOZ_FUZZ": "1",
        "LIBFUZZER": "1",
        "MOZ_DISABLE_CONTENT_SANDBOX": "1",
        "UBSAN_OPTIONS": sanitizer.runtime_options("ubsan", options, ENV),
    }
    return run_timeout([browser_binary(), *clean_args], timeout, env=environment).returncode


def main(argv: list[str]) -> int:
    modes = {"browser", "browser-minimal", "js", "js-diff", "generic", "fuzz", "fuzz-repro", "fuzz-js"}
    if not argv or argv[0] not in modes:
        print("Usage: run-ubsan {browser|browser-minimal|js|js-diff|generic|fuzz|fuzz-repro|fuzz-js} [args...]")
        return 1
    mode, args = argv[0], argv[1:]
    timeout = int(ENV.get("UBSAN_TIMEOUT", "15" if mode not in {"js", "js-diff"} else "10"))
    runner = SanitizerRunner("ubsan", CONFIG, ENV)
    if mode == "browser":
        return run_browser(mode_options("full"), timeout, args)
    if mode == "browser-minimal":
        return run_browser(mode_options("minimal"), timeout, args)
    if mode == "js":
        return runner.js(mode_options("js"), timeout, args)
    if mode == "js-diff":
        return run_js_diff(mode_options("js"), timeout, args)
    if mode == "generic":
        return runner.generic(mode_options("full"), timeout, args)
    if mode == "fuzz":
        return browser_fuzz(mode_options("fuzz"), int(ENV.get("UBSAN_TIMEOUT", "600")), args, False)
    if mode == "fuzz-repro":
        return browser_fuzz(mode_options("fuzz-repro"), int(ENV.get("UBSAN_FUZZ_REPRO_TIMEOUT", "20")), args, True)
    return runner.fuzz_js(mode_options("fuzz"), int(ENV.get("UBSAN_TIMEOUT", "600")), args)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
