#!/usr/bin/env bash
set -euo pipefail

# Parallel agent orchestrator for sanitizer-based security QA.
#
# Spawns concurrent backend agents to investigate memory-safety
# issues in a target codebase using AddressSanitizer. Each agent gets
# isolated state, scratch dirs, and output namespaces.
#
# Usage:
#   bin/audit --target curl --backend <backend> 5
#   bin/audit --target-path /path/to/repo
#
# Output: output/<target>/<backend>/results/  and  output/<target>/<backend>/logs/
# If --backend is omitted, configured hosted backends are cycled and still
# write to their normal backend-specific output directories.

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# Export so child Python tools (bin/peer-fix-cards, bin/suggest-*) pick
# up the facade path instead of falling back to Path(__file__) — which
# inside a benchmark cell facade chases the bin/ symlink and lands in
# the wrong tree.
export SCRIPT_ROOT
cd "$SCRIPT_ROOT" || { echo "FATAL: cannot cd to $SCRIPT_ROOT" >&2; exit 1; }

# triage.sh assigns the hosted-backend default while it is sourced below.
# Remember whether the operator provided a value before that default is applied.
AUDIT_LLM_DECISION_TIMEOUT_USER_SET="${LLM_DECISION_TIMEOUT:+1}"

# Source extracted modules (runtime vars like RESULTS_DIR are bound at call-time).
for _lib in platform.sh fmt.sh timeout.sh target_config.sh process_tree.sh llm_invoke.sh llm_decide.sh structured_state.sh vocab.sh triage.sh quality.sh housekeeping.sh audit_debug.sh prompt.sh gemini_watchdog.sh; do
  [ -f "$SCRIPT_ROOT/lib/$_lib" ] || { echo "FATAL: missing lib/$_lib" >&2; exit 1; }
  source "$SCRIPT_ROOT/lib/$_lib"
done
unset _lib

# ─── Timestamped logging ────────────────────────────────────────
# Every [audit] line gets a short HH:MM:SS prefix for real-time analysis.
# Usage: log "message"  or  log "message" | tee -a "$INDEX"  (orchestrator,
# single-process) or  index_log "message"  (run_agent, backgrounded).
_ts() { date +%H:%M:%S; }
log() { echo "[$(_ts)] $*"; }

# Append a line to a file under an exclusive advisory lock. Python fcntl
# flock works on macOS and Linux; GNU flock(1) does not ship on macOS.
# Best-effort — a lock/open failure must never abort an audit over a log
# line.
audit_flock_append() {
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" flock-append "$1" "$2" 2>/dev/null || true
}

# Instance lock — prevents two bin/audit invocations from writing to the
# same output directory at the same time. Lock-dir style: mkdir is
# atomic, no fd preservation needed, works identically on macOS + Linux.
# Stale-PID reclamation: if the holder is dead the lock is reclaimable.
# --allow-concurrent overrides (concurrent instances WILL corrupt shared
# state — only set when you genuinely know they target disjoint slots).
audit_acquire_instance_lock() {
  [ -n "${LOGDIR:-}" ] || return 0
  [ "${ALLOW_CONCURRENT_AUDIT:-0}" -eq 1 ] && return 0
  local lockdir="$LOGDIR/.instance.lock.d"
  mkdir -p "$LOGDIR" 2>/dev/null || true
  if mkdir "$lockdir" 2>/dev/null; then
    printf '%s\n' "$$" > "$lockdir/pid" 2>/dev/null || true
    INSTANCE_LOCK_DIR="$lockdir"
    INSTANCE_LOCK_ACQUIRED=1
    return 0
  fi
  # Lock held — check if the holder is still alive.
  local prev_pid=""
  [ -f "$lockdir/pid" ] && prev_pid=$(head -1 "$lockdir/pid" 2>/dev/null)
  if [ -n "$prev_pid" ] && ! kill -0 "$prev_pid" 2>/dev/null; then
    rm -rf "$lockdir" 2>/dev/null || true
    if mkdir "$lockdir" 2>/dev/null; then
      printf '%s\n' "$$" > "$lockdir/pid" 2>/dev/null || true
      INSTANCE_LOCK_DIR="$lockdir"
      INSTANCE_LOCK_ACQUIRED=1
      log "Instance lock: reclaimed stale lock from dead PID ${prev_pid}" >&2
      return 0
    fi
  fi
  log "FATAL: another bin/audit instance is writing to ${LOGDIR} (holder PID=${prev_pid:-unknown}). Wait for it to finish, kill it, or pass --allow-concurrent to override (concurrent instances WILL corrupt shared state)." >&2
  exit 1
}

audit_release_instance_lock() {
  [ "${INSTANCE_LOCK_ACQUIRED:-0}" -eq 1 ] || return 0
  [ -n "${INSTANCE_LOCK_DIR:-}" ] || return 0
  # Only remove if we own it — guards against racing reclamation.
  local owner=""
  [ -f "$INSTANCE_LOCK_DIR/pid" ] && owner=$(head -1 "$INSTANCE_LOCK_DIR/pid" 2>/dev/null)
  if [ -z "$owner" ] || [ "$owner" = "$$" ]; then
    rm -rf "$INSTANCE_LOCK_DIR" 2>/dev/null || true
  fi
  INSTANCE_LOCK_ACQUIRED=0
}

# Emit one timestamped line to stdout AND the shared index.log timeline.
# run_agent runs backgrounded — one process per agent (see the `&` at its
# launch site) — so its index.log appends race. Serialize them with the
# same flock discipline lib/audit_log_summary.py uses for index.jsonl.
# Orchestrator-only log lines are single-process and keep `| tee -a`.
index_log() {
  local line="[$(_ts)] $*"
  printf '%s\n' "$line"
  [ -n "${INDEX:-}" ] && audit_flock_append "$INDEX" "$line"
}

# Estimate token count from a string (chars/4 is a reasonable approximation
# for English+code mixed content with Claude's tokenizer).
estimate_tokens() {
  local char_count=${#1}
  echo $(( char_count / 4 ))
}

usage() {
  cat <<'EOF'
Usage:
  bin/audit [options] [max_iterations]

Options:
  --target <dir-name>                 Target directory name under targets/ (default: firefox)
  --target-path <path>                Override target path directly
  --backend <backend>               Select one backend. One of: all, claude, codex, gemini, oss. If omitted, cycle configured hosted backends like --backend all. 'oss' runs OpenCode against a local OpenAI-compatible endpoint and requires --model.
  --model <model>                   Override the model for supported backends. Required for --backend oss, where it must match the exact local served model name from /v1/models. For --backend gemini with agy, pass either the config slug (e.g. gemini-3.1-pro-preview) or an exact 'agy models' label (e.g. "Gemini 3.1 Pro (High)"); the harness maps the slug to a label and the preflight rejects an unresolved one.
  --experiment <name>               Isolate artifacts under output/<target>-<name>/
  --strategy <S1|S2|S3|S4|S5|S6|S7|S8> Pin the first investigation strategy for
                                    focused smoke validation. Omit for normal
                                    strategy rotation.
  --claude-bin <path>               Claude CLI binary to use (default: claude)
  --codex-bin <path>                Codex CLI binary to use (default: codex)
  --gemini-bin <path>               Gemini backend binary to use (default: agy, or gemini with USE_GEMINI_CLI=1)
  --new-target <slug>               Seed output/<slug>/target.toml from
                                    targets/<slug>/ introspection and backend
                                    bootstrap suggestions, then exit.
                                    Review unresolved fields before a long audit.
  --allow-concurrent                Skip the output-dir instance lock and allow
                                    a second bin/audit to run in parallel on
                                    the same target+backend. Default is to
                                    refuse, because concurrent instances write
                                    to the same index.log, work-cards.jsonl,
                                    and recon-hypotheses.jsonl with no
                                    coordination and produce corrupted state.
  --enable-memory                   Opt back in to the backend's cross-run
                                    auto-memory (Claude Code MEMORY.md/memory/*,
                                    Codex ~/.codex/memories/, Gemini CLI
                                    save_memory). OFF by default: a single wrong
                                    learned note poisons every later run. With
                                    this flag, watch those memory files and
                                    prune stale entries. (Default agy/Antigravity
                                    keeps persistent state under
                                    ~/.gemini/antigravity-cli and exposes no
                                    memory-off flag, so it is NOT disabled by
                                    default either way; use USE_GEMINI_CLI=1 for
                                    strict Gemini memory isolation.)
  -h, --help                        Show this help

Arguments:
  max_iterations                    0 or omitted means run forever. 1 is
                                    treated as a smoke test: one worker and
                                    no recon seeding.
EOF
}

MAX_ITERATIONS=0  # 0 = infinite
MAX_ITERATIONS_PROVIDED=0
TARGET_NAME="firefox"
TARGET_PATH=""
TARGET_ROOT=""
TARGET_SLUG=""
TARGET_OUTPUT_SLUG=""
TARGET_REPO_TYPE="none"
IS_BROWSER_TARGET=0
ASAN_BUILD_DIR=""
ASAN_BUILD_AVAILABLE=0
ASAN_BUILD_BINARY=""
SANITIZER_BUILD_AVAILABLE=0
SANITIZER_BUILD_SUMMARY=""
SANITIZER_BUILD_MISSING=""
SANITIZER_BUILD_DISABLED=0
RESULTS_DIR=""
LOGDIR=""
INDEX=""
LOG_INDEX_JSONL=""
COUNTER_FILE=""
COOLDOWN="${COOLDOWN:-5}"
# Agent pool. Browser targets: 1 browser + 2 shell agents.
# Generic targets: flat pool of 3 equivalent agents.
# Override with NUM_AGENTS, BROWSER_AGENTS, SHELL_AGENTS, or AGENT_ROLES.
agent_count_overridden=0
[ -n "${BROWSER_AGENTS:-}" ] || [ -n "${SHELL_AGENTS:-}" ] || [ -n "${NUM_AGENTS:-}" ] && agent_count_overridden=1
BROWSER_AGENTS="${BROWSER_AGENTS:-1}"
SHELL_AGENTS="${SHELL_AGENTS:-2}"
_detect_free_ram_mb() {
  local meminfo_path="${PROC_MEMINFO:-/proc/meminfo}"
  if [ -r "$meminfo_path" ]; then
    local mem_available_kb
    mem_available_kb=$(awk '/^MemAvailable:/ {print $2; exit}' "$meminfo_path" 2>/dev/null || true)
    if [[ "$mem_available_kb" =~ ^[0-9]+$ ]]; then
      echo $(( mem_available_kb / 1024 ))
      return 0
    fi

    # Older Linux kernels may not expose MemAvailable. Approximate it from
    # reclaimable page-cache fields without relying on distro-specific tools.
    local fallback_mb
    fallback_mb=$(awk '
      /^MemFree:/ {free=$2}
      /^Buffers:/ {buffers=$2}
      /^Cached:/ {cached=$2}
      /^SReclaimable:/ {sreclaimable=$2}
      /^Shmem:/ {shmem=$2}
      END {
        available = free + buffers + cached + sreclaimable - shmem
        if (available > 0) printf "%d\n", available / 1024
      }
    ' "$meminfo_path" 2>/dev/null || true)
    if [[ "$fallback_mb" =~ ^[0-9]+$ ]]; then
      echo "$fallback_mb"
      return 0
    fi
  fi

  command -v vm_stat >/dev/null 2>&1 || return 1
  local vm_out page_size page_free page_ina page_spec
  vm_out=$(vm_stat 2>/dev/null) || return 1
  page_size=$(printf '%s\n' "$vm_out" | head -1 | grep -oE '[0-9]+' | tail -1 || true)
  if [ -z "$page_size" ]; then
    page_size=$(getconf PAGE_SIZE 2>/dev/null || pagesize 2>/dev/null || true)
  fi
  [[ "$page_size" =~ ^[0-9]+$ ]] || page_size=4096
  page_free=$(printf '%s\n' "$vm_out" | awk '/Pages free/{gsub("\\.","",$3); print $3; exit}')
  page_ina=$(printf '%s\n' "$vm_out" | awk '/Pages inactive/{gsub("\\.","",$3); print $3; exit}')
  page_spec=$(printf '%s\n' "$vm_out" | awk '/Pages speculative/{gsub("\\.","",$3); print $3; exit}')
  [[ "$page_free" =~ ^[0-9]+$ ]] && [[ "$page_ina" =~ ^[0-9]+$ ]] || return 1
  page_spec=${page_spec:-0}
  [[ "$page_spec" =~ ^[0-9]+$ ]] || page_spec=0
  echo $(( (page_free + page_ina + page_spec) * page_size / 1048576 ))
}
# NUM_AGENTS can be set directly as an env var (flat pool) or derived from
# the browser+shell split. For generic targets, the pool is re-derived
# after IS_BROWSER_TARGET is determined (see below).
if [ -n "${NUM_AGENTS:-}" ] && [ "$agent_count_overridden" -eq 1 ]; then
  BROWSER_AGENTS=0
  SHELL_AGENTS="$NUM_AGENTS"
else
  NUM_AGENTS=$((BROWSER_AGENTS + SHELL_AGENTS))
fi
[ "$NUM_AGENTS" -ge 1 ] || { log "FATAL: agent count must be >= 1"; exit 1; }
# Global STALL_STOP threshold. Must be ≥ the longest per-strategy dry
# streak (STRATEGY_S1_DRY_STREAK_THRESHOLD), otherwise the global counter
# fires before per-agent strategy rotation can. The auto_clamp logic
# below recomputes this once per audit run if a user override leaves it
# too small. Soft signal — the strategy / effort gates below are
# authoritative for rotation decisions.
MAX_DRY_SESSIONS="${MAX_DRY_SESSIONS:-10}"
# An iteration that produced no findings/crashes but DID mark new
# ENV-BLOCKED entries is diagnostic work, not stalled exploration —
# the harness is mapping out the build's dead-code regions so future
# iterations can avoid them. These iterations do not bump dry_streak.
# There is no per-streak cap: ENV-BLOCKED entries monotonically
# disposition cards in the work queue (workqueue.py marks them
# `blocked`), so once the eligible queue is exhausted, the existing
# `target_exhausted_hard_stop_ready` path fires STALL_STOP naturally
# — we don't need a magic-number streak limit on top.
CURRENT_LAUNCH_AGENT_COUNT="$NUM_AGENTS"
CURRENT_LAUNCH_AGENT_LIST=""
# Effort-based rotation gates (replace the pure-iteration-count rotation).
# An agent rotates ONLY when it has verified work on disk to prove the
# subsystem is exhausted: N hypotheses DISCARDED + M .asan.txt artifacts.
# Keeping these conservative at first; tune up once coverage HITs are logged.
MIN_DISCARDS_BEFORE_ROTATE=6
MIN_ASAN_RUNS_BEFORE_ROTATE=15
ENV_BLOCKED_BEFORE_ROTATE=2       # env-blocked subsystems can rotate without the full effort gate
# Runaway-only safety; the actual session length is bounded by AGENT_TIMEOUT
# (120 min wall clock). At observed ~3–15 s/turn across targets, AGENT_TIMEOUT
# binds first for any productive session — Firefox shell agents naturally land
# at ~400–500 turns, generic targets like libxml2/pcre2 finish at ~80–150.
# Tuning per target was the original failure mode (200 was right for pcre2,
# starvation for Firefox); this constant exists only so a degenerate agent
# spinning on cheap tool calls can't run forever.
MAX_TURNS_ANALYSIS="${MAX_TURNS_ANALYSIS:-1000}"
# Per-agent, per-iteration ASan invocation budget. Soft-enforced: the
# wrapper prints a warning on excess but doesn't kill in-flight work.
BROWSER_ASAN_RUN_BUDGET="${BROWSER_ASAN_RUN_BUDGET:-25}"
SHELL_ASAN_RUN_BUDGET="${SHELL_ASAN_RUN_BUDGET:-60}"
if [ -n "${ASAN_RUN_BUDGET_PER_ITERATION:-}" ]; then
  BROWSER_ASAN_RUN_BUDGET="$ASAN_RUN_BUDGET_PER_ITERATION"
  SHELL_ASAN_RUN_BUDGET="$ASAN_RUN_BUDGET_PER_ITERATION"
fi
ASAN_RUN_BUDGET_PER_ITERATION="${ASAN_RUN_BUDGET_PER_ITERATION:-$BROWSER_ASAN_RUN_BUDGET}"
AGENT_TIMEOUT="${AGENT_TIMEOUT:-7200}"         # 120 minutes per agent session
GRACEFUL_WARNING="${GRACEFUL_WARNING:-900}"       # warn agent 15 min before timeout
# Soft turn cap: stop a codex session at this many completed command_executions.
# Codex sessions are quadratic in turn count because every tool output is
# replayed as cached input on each later turn. Empirical fit across 145
# recent sessions: cached_input ≈ 20,139·N + 232.7·N² (R²=0.85). The
# linear/quadratic breakeven is at N ≈ 87, so capping below ~75 turns hurts
# more than it helps (resume-overhead is paid twice). Default 75 is the
# breakeven minus a small margin. Set to 0 to disable.
# Only applied to codex; Claude has its own --max-turns and the Antigravity
# CLI (gemini backend) self-paces.
TURN_SOFT_CAP="${TURN_SOFT_CAP:-75}"
# Polling interval for the turn-cap watcher. 10 s is short enough to react
# within one or two turns of the cap firing; longer intervals risk
# overshooting by several turns on slow models.
TURN_SOFT_CAP_POLL_SECS="${TURN_SOFT_CAP_POLL_SECS:-10}"
COMBINED_STATE_MAX_LINES=320
MAX_STATE_LINES_PER_AGENT=120
PER_HYPOTHESIS_TURN_LIMIT=120  # force rotation after N tool calls with no new findings
GUARD_CHAIN_ROTATION_THRESHOLD=6  # same guard blocks N hypotheses → bypass/guard-audit directive
CLAUDE_RESUME_CACHE_CAP="${CLAUDE_RESUME_CACHE_CAP:-2000000}"
CLAUDE_RESUME="${CLAUDE_RESUME:-1}"
CODEX_RESUME="${CODEX_RESUME:-1}"
GEMINI_RESUME="${GEMINI_RESUME:-1}"
OSS_RESUME="${OSS_RESUME:-0}"
RESUME_DRY_CAP="${RESUME_DRY_CAP:-2}"
# Strategy rotation: when an agent has used the same strategy for N dry
# iterations on a subsystem, force it to try the next strategy in priority
# order. This prevents the observed failure mode where agents run Strategy S1
# for 60 iterations and never try S2, S3, S4, S5, etc.
STRATEGY_DRY_STREAK_THRESHOLD="${STRATEGY_DRY_STREAK_THRESHOLD:-3}"
# S1 (prior-fix review) needs more iterations to read patches deeply
STRATEGY_S1_DRY_STREAK_THRESHOLD="${STRATEGY_S1_DRY_STREAK_THRESHOLD:-8}"
# Auto-clamp: MAX_DRY_SESSIONS must give per-agent rotation a fair shot.
# If a user override leaves it below the longest per-strategy threshold,
# the global stall fires before per-agent rotation can rotate off S1, so
# the queue never sees S2/S3/… strategy work. Add a 2-iter safety margin.
__strat_max="$STRATEGY_S1_DRY_STREAK_THRESHOLD"
if [ "${STRATEGY_DRY_STREAK_THRESHOLD:-0}" -gt "$__strat_max" ]; then
  __strat_max="$STRATEGY_DRY_STREAK_THRESHOLD"
fi
__strat_floor=$(( __strat_max + 2 ))
if [ "$MAX_DRY_SESSIONS" -lt "$__strat_floor" ]; then
  MAX_DRY_SESSIONS="$__strat_floor"
fi
unset __strat_max __strat_floor
# Priority-ordered strategy rotation list. Agents cycle through this when
# their current strategy stalls. Matches the priority order in strategies/README.md.
STRATEGY_ROTATION_ORDER=(S1 S2 S3 S4 S5 S6 S7 S8)  # 8 strategies; REF is a pattern reference, not a strategy
RANK_WORK_LIMIT="${RANK_WORK_LIMIT:-120}"
SUBSYSTEM_BLOCKLIST_FILE=""       # resolved post-RESULTS_DIR; agents are told to refuse hypotheses in these subsystems
# Subsystems with no direct audit leverage. Keep this empty by default: vendored
# parser/codec/network code is audit-eligible and should not be suppressed just
# because it lives under third_party/ or vendor-style paths.
SUBSYSTEM_BLOCKLIST_DEFAULT=()
AUDIT_BACKEND="${AUDIT_BACKEND:-all}"
BACKEND_FLAG_PROVIDED=0
MODEL_FLAG_PROVIDED=0
AUDIT_FIXED_STRATEGY=""
AUDIT_EXPERIMENT_NAME=""
EXPERIMENT_FLAG_PROVIDED=0
AUDIT_EXPERIMENT_SUFFIX=""
ENSEMBLE_MODE=0
ENSEMBLE_BACKENDS=()
ENSEMBLE_NEXT_INDEX=0
NEW_TARGET_SLUG=""
AUDIT_MODEL=""
CLAUDE_BIN="claude"
CODEX_BIN="codex"
OPENCODE_BIN="${OPENCODE_BIN:-opencode}"
# The "gemini" backend keeps one harness-visible name. By default it
# invokes Antigravity (`agy`); USE_GEMINI_CLI=1 switches the underlying
# dialect to Google Gemini CLI (`gemini`) without changing artifact paths.
GEMINI_BIN="${GEMINI_BIN:-$(llm_gemini_default_bin)}"
AGENT_GUIDE_PATH=""
REFERENCE_DIR=".agents/references"

# Instance-lock state. ALLOW_CONCURRENT_AUDIT is set by --allow-concurrent
# and bypasses the lock entirely. INSTANCE_LOCK_DIR / INSTANCE_LOCK_ACQUIRED
# are managed by audit_acquire_instance_lock / audit_release_instance_lock.
ALLOW_CONCURRENT_AUDIT=0
INSTANCE_LOCK_DIR=""
INSTANCE_LOCK_ACQUIRED=0

# Cross-run backend auto-memory is OFF by default (see llm_apply_memory_policy):
# learned notes from a prior run poison every later one. --enable-memory opts
# back in for cumulative learning.
ENABLE_MEMORY=0
AUDIT_SKIP_RECON=0

while [ $# -gt 0 ]; do
  case "$1" in
    --target=*)
      TARGET_NAME="${1#--target=}"
      shift
      ;;
    --target)
      [ $# -ge 2 ] || { log "FATAL: --target requires a value" >&2; usage; exit 1; }
      TARGET_NAME="$2"
      shift 2
      ;;
    --target-path=*)
      TARGET_PATH="${1#--target-path=}"
      shift
      ;;
    --target-path)
      [ $# -ge 2 ] || { log "FATAL: --target-path requires a value" >&2; usage; exit 1; }
      TARGET_PATH="$2"
      shift 2
      ;;
    --backend=*)
      AUDIT_BACKEND="${1#--backend=}"
      BACKEND_FLAG_PROVIDED=1
      shift
      ;;
    --backend)
      [ $# -ge 2 ] || { log "FATAL: --backend requires a value" >&2; usage; exit 1; }
      AUDIT_BACKEND="$2"
      BACKEND_FLAG_PROVIDED=1
      shift 2
      ;;
    --model=*)
      AUDIT_MODEL="${1#--model=}"
      MODEL_FLAG_PROVIDED=1
      shift
      ;;
    --model)
      [ $# -ge 2 ] || { log "FATAL: --model requires a value" >&2; usage; exit 1; }
      AUDIT_MODEL="$2"
      MODEL_FLAG_PROVIDED=1
      shift 2
      ;;
    --experiment=*)
      AUDIT_EXPERIMENT_NAME="${1#--experiment=}"
      EXPERIMENT_FLAG_PROVIDED=1
      shift
      ;;
    --experiment)
      [ $# -ge 2 ] || { log "FATAL: --experiment requires a value" >&2; usage; exit 1; }
      AUDIT_EXPERIMENT_NAME="$2"
      EXPERIMENT_FLAG_PROVIDED=1
      shift 2
      ;;
    --strategy=*)
      AUDIT_FIXED_STRATEGY="${1#--strategy=}"
      shift
      ;;
    --strategy)
      [ $# -ge 2 ] || { log "FATAL: --strategy requires a value" >&2; usage; exit 1; }
      AUDIT_FIXED_STRATEGY="$2"
      shift 2
      ;;
    --claude-bin=*)
      CLAUDE_BIN="${1#--claude-bin=}"
      shift
      ;;
    --claude-bin)
      [ $# -ge 2 ] || { log "FATAL: --claude-bin requires a value" >&2; usage; exit 1; }
      CLAUDE_BIN="$2"
      shift 2
      ;;
    --codex-bin=*)
      CODEX_BIN="${1#--codex-bin=}"
      shift
      ;;
    --codex-bin)
      [ $# -ge 2 ] || { log "FATAL: --codex-bin requires a value" >&2; usage; exit 1; }
      CODEX_BIN="$2"
      shift 2
      ;;
    --gemini-bin=*)
      GEMINI_BIN="${1#--gemini-bin=}"
      shift
      ;;
    --gemini-bin)
      [ $# -ge 2 ] || { log "FATAL: --gemini-bin requires a value" >&2; usage; exit 1; }
      GEMINI_BIN="$2"
      shift 2
      ;;
    --new-target=*)
      NEW_TARGET_SLUG="${1#--new-target=}"
      shift
      ;;
    --new-target)
      [ $# -ge 2 ] || { log "FATAL: --new-target requires a value" >&2; usage; exit 1; }
      NEW_TARGET_SLUG="$2"
      shift 2
      ;;
    --allow-concurrent)
      ALLOW_CONCURRENT_AUDIT=1
      shift
      ;;
    --skip-recon)
      AUDIT_SKIP_RECON=1
      shift
      ;;
    --enable-memory)
      ENABLE_MEMORY=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      log "FATAL: unknown option '$1'" >&2
      usage
      exit 1
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]]; then
        if [ "$MAX_ITERATIONS_PROVIDED" -eq 1 ]; then
          log "FATAL: max_iterations specified more than once" >&2
          usage
          exit 1
        fi
        MAX_ITERATIONS="$1"
        MAX_ITERATIONS_PROVIDED=1
        shift
      else
        log "FATAL: unexpected argument '$1'" >&2
        usage
        exit 1
      fi
      ;;
  esac
done

if [ "$MODEL_FLAG_PROVIDED" -eq 1 ] && [ -z "${AUDIT_MODEL:-}" ]; then
  log "FATAL: --model requires a non-empty value" >&2
  usage
  exit 1
fi
if [ "$EXPERIMENT_FLAG_PROVIDED" -eq 1 ] && [ -z "${AUDIT_EXPERIMENT_NAME:-}" ]; then
  log "FATAL: --experiment requires a non-empty value" >&2
  usage
  exit 1
fi
case "${AUDIT_FIXED_STRATEGY:-}" in
  ""|S1|S2|S3|S4|S5|S6|S7|S8) ;;
  *)
    log "FATAL: --strategy must be one of S1, S2, S3, S4, S5, S6, S7, S8 (got '$AUDIT_FIXED_STRATEGY')" >&2
    usage
    exit 1
    ;;
esac

# Disable cross-run backend auto-memory by default (poison-resistant); opt
# back in with --enable-memory. Exported here so every backend child the run
# spawns inherits the decision. (llm_apply_memory_policy lives in llm_invoke.sh.)
llm_apply_memory_policy "$ENABLE_MEMORY"

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

backend_bin() {
  case "$1" in
    claude) printf '%s\n' "$CLAUDE_BIN" ;;
    codex)  printf '%s\n' "$CODEX_BIN" ;;
    gemini) printf '%s\n' "$GEMINI_BIN" ;;
    *) return 1 ;;
  esac
}

backend_configured() {
  # Hosted backend participation requires both an installed CLI and a
  # non-interactive auth/config status command that exits cleanly. This avoids
  # cycling into an installed-but-unusable CLI during unattended runs.
  local backend="$1" bin
  bin=$(backend_bin "$backend") || return 1
  command_exists "$bin" || return 1
  case "$backend" in
    claude)
      "$bin" auth status >/dev/null 2>&1
      ;;
    codex)
      "$bin" login status >/dev/null 2>&1
      ;;
    gemini)
      if llm_use_gemini_cli; then
        # Google Gemini CLI exposes a cheap version probe. Auth/API-key
        # failures surface during model preflight.
        "$bin" --version >/dev/null 2>&1
      else
        # Antigravity CLI authenticates lazily on first --print via the
        # system keyring. `agy changelog` exits cleanly without touching
        # auth, so we use it as the "installed" probe; missing auth
        # surfaces on the first real model call.
        "$bin" changelog >/dev/null 2>&1
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

oss_model_available() {
  local model="$1"
  _llm_invoke_export_env
  python3 "$SCRIPT_ROOT/lib/llm_invoke.py" local-model-available --model "$model" >/dev/null 2>&1
}

oss_local_base_url() {
  llm_local_base_url 2>/dev/null || printf '%s\n' "http://127.0.0.1:8000/v1"
}

oss_resolved_model_name() {
  llm_resolve_model_name oss "$1" 2>/dev/null || printf '%s\n' "$1"
}

discover_ensemble_backends() {
  # Alphabetical order is deliberate — it's the only neutral tiebreaker in
  # an OSS harness that supports multiple vendor CLIs. Do NOT reorder by
  # frequency-of-use, install probability, or perceived quality: any such
  # rule looks like vendor bias to readers of the public repo. Ensemble
  # mode cycles through these per iteration, so the listing order only
  # decides which backend ACTIVE_BACKEND defaults to at cold-start.
  local backend
  for backend in claude codex gemini; do
    if backend_configured "$backend"; then
      printf '%s\n' "$backend"
    fi
  done
}

# One-time README in $LOGDIR pointing readers at the high-signal files.
# Idempotent: skips the write if the README already exists. Failures are
# best-effort — never block session setup.
audit_write_logdir_readme() {
  local logdir="$1"
  local readme="$logdir/README.md"
  [ -f "$readme" ] && return 0
  cat > "$readme" <<'EOF' 2>/dev/null || true
# Debugging tour

Start here when investigating token waste, errors, or unexpected agent behavior.
Files are listed in roughly the order you should consult them.

## High-signal entry points (read first)

| File | What it tells you |
|---|---|
| `index.log`          | Human-readable per-iteration timeline. Each agent gets `finished` + `waste` lines with tokens, tool counts, top commands, largest output, cache-hit %. Grep here first. |
| `index.jsonl`        | One JSON row per agent session. Same data as `index.log` but structured — ideal for `jq`. Append is `flock`-guarded so rows never interleave under concurrent agents. |
| `llm-decisions.log`  | Ledger of harness sub-LLM calls (`crash_triage`, `crash_confirm`, …). Use to attribute cost / failures to specific decision paths. |
| `*.summary.md`       | Per-session digest (one screen per agent). Read after you've spotted a session of interest in `index.log`. |
| `*.prompt.md`        | The exact system prompt sent to each agent. Critical when input tokens look bloated — input cost IS the prompt. |

## Forensic dumps (under `.raw/`, rarely useful)

`.raw/session_*.log.raw` and `.raw/recon_*.raw` are the full backend JSON
dialogue streams. They're hidden so default `ls`/`find` and the agent
permission model skip them. Only read when you need the literal model
output.

Failed model preflights leave a `model-preflight-*.raw` at this level
(no sibling `.message`); successful preflights leave only the
`.model_preflight_*.ok` marker.

## Orchestrator scratch (dotfiles)

`.session_id_*`, `.prev_*`, `.iter_cache/`, `.warns/`, `.prompt_meta_*`
etc. are per-iteration state read by the next iteration's prompt
builder. Don't edit them by hand.
EOF
}

# Map a logfile path to its .raw counterpart under $RAW_DIR. The .raw
# dialogue dumps live in logs/.raw/ so dotdir-skipping ls/find scans
# don't surface them. Callers should always go through this helper
# instead of computing "${logfile}.raw" by hand.
audit_raw_path() {
  local logfile="$1"
  local base="${logfile##*/}"
  local raw_root="${RAW_DIR:-${LOGDIR:-/tmp}/.raw}"
  mkdir -p "$raw_root" 2>/dev/null || true
  printf '%s/%s.raw' "$raw_root" "$base"
}

sanitize_target_slug() {
  local raw="$1"
  raw="${raw##*/}"
  raw=$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')
  raw=$(printf '%s' "$raw" | tr -cs '[:alnum:]._-' '-')
  raw="${raw#-}"
  raw="${raw%-}"
  [ -n "$raw" ] || { log "FATAL: target slug resolved to empty string" >&2; exit 1; }
  echo "$raw"
}

resolve_target_root() {
  local raw_path=""
  if [ -n "$TARGET_PATH" ]; then
    raw_path="$TARGET_PATH"
  else
    raw_path="$SCRIPT_ROOT/targets/$TARGET_NAME"
  fi
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$raw_path"
}

detect_repo_type() {
  target_detect_repo_type "$1"
}

_audit_append_line() {
  local var_name="$1"
  local line="$2"
  local current=""
  eval "current=\${${var_name}:-}"
  if [ -n "$current" ]; then
    printf -v "$var_name" '%s\n%s' "$current" "$line"
  else
    printf -v "$var_name" '%s' "$line"
  fi
}

_audit_resolve_target_path() {
  local raw="$1"
  [ -n "$raw" ] || return 1
  if declare -F target_resolve_path >/dev/null 2>&1; then
    target_resolve_path "$raw"
  elif [ "${raw#/}" != "$raw" ]; then
    printf '%s\n' "$raw"
  else
    printf '%s/%s\n' "$TARGET_ROOT" "$raw"
  fi
}

_audit_record_sanitizer_found() {
  local san="$1"
  local path="$2"
  local kind="$3"
  SANITIZER_BUILD_AVAILABLE=1
  _audit_append_line SANITIZER_BUILD_SUMMARY "- ${san}: \`${path}\` (${kind})"
  if [ "$san" = "asan" ]; then
    ASAN_BUILD_AVAILABLE=1
    ASAN_BUILD_BINARY="$path"
  fi
}

_audit_record_sanitizer_missing() {
  local san="$1"
  local reason="$2"
  _audit_append_line SANITIZER_BUILD_MISSING "- ${san}: ${reason}"
}

_audit_nm_has_symbol() {
  local bin="$1" pattern="$2" count
  count=$(nm "$bin" 2>/dev/null | grep -c "$pattern" || true)
  [ "${count:-0}" -gt 0 ]
}

_audit_scan_sanitizer_build_dir() {
  local san="$1"
  local build_dir="$2"
  local symbol="$3"
  local candidate=""
  [ -d "$build_dir" ] || return 1
  command -v nm >/dev/null 2>&1 || return 1
  while IFS= read -r candidate; do
    [ -n "$candidate" ] || continue
    [ -x "$candidate" ] || continue
    if _audit_nm_has_symbol "$candidate" "$symbol"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done <<EOF
$(find "$build_dir" -type f 2>/dev/null | head -50)
EOF
  return 1
}

_audit_detect_configured_binary() {
  local san="$1"
  local raw="$2"
  local path=""
  [ -n "$raw" ] || return 1
  path="$(_audit_resolve_target_path "$raw" 2>/dev/null || true)"
  if [ -n "$path" ] && [ -x "$path" ]; then
    _audit_record_sanitizer_found "$san" "$path" "configured binary"
    return 0
  fi
  _audit_record_sanitizer_missing "$san" "configured binary is not executable: ${raw}"
  return 1
}

_audit_detect_configured_file() {
  local san="$1"
  local raw="$2"
  local path=""
  local kind="$3"
  [ -n "$raw" ] || return 1
  path="$(_audit_resolve_target_path "$raw" 2>/dev/null || true)"
  if [ -n "$path" ] && [ -f "$path" ]; then
    _audit_record_sanitizer_found "$san" "$path" "$kind"
    return 0
  fi
  _audit_record_sanitizer_missing "$san" "configured ${kind} is missing: ${raw}"
  return 1
}

_audit_detect_asan_build() {
  local found=1
  local fallback=""
  local saw_config=0
  if [ -n "${TARGET_ASAN_BIN:-}" ]; then
    saw_config=1
    _audit_detect_configured_binary asan "$TARGET_ASAN_BIN" && found=0
  fi
  if [ "$found" -ne 0 ] && [ -n "${TARGET_ASAN_LIB:-}" ]; then
    saw_config=1
    _audit_detect_configured_file asan "$TARGET_ASAN_LIB" "configured library" && found=0
  fi
  if [ "$found" -ne 0 ] && [ "$saw_config" -eq 0 ]; then
    fallback="$(_audit_scan_sanitizer_build_dir asan "$ASAN_BUILD_DIR" "__asan_" 2>/dev/null || true)"
    if [ -n "$fallback" ]; then
      _audit_record_sanitizer_found asan "$fallback" "fallback scan"
      found=0
    else
      _audit_record_sanitizer_missing asan "set asan_bin/asan_lib in target.toml or build under ${ASAN_BUILD_DIR}"
    fi
  fi
  return "$found"
}

_audit_detect_binary_sanitizer_build() {
  local san="$1"
  local raw="$2"
  local build_dir="$3"
  local symbol="$4"
  local fallback=""
  if [ -n "$raw" ]; then
    _audit_detect_configured_binary "$san" "$raw"
    return $?
  fi
  fallback="$(_audit_scan_sanitizer_build_dir "$san" "$build_dir" "$symbol" 2>/dev/null || true)"
  if [ -n "$fallback" ]; then
    _audit_record_sanitizer_found "$san" "$fallback" "fallback scan"
    return 0
  fi
  _audit_record_sanitizer_missing "$san" "set [sanitizer].${san}_bin in target.toml or build under ${build_dir}"
  return 1
}

_audit_runner_bin_available() {
  local raw="$1"
  local path=""
  [ -n "$raw" ] || return 1
  if command -v "$raw" >/dev/null 2>&1; then
    command -v "$raw"
    return 0
  fi
  if [ -x "$raw" ]; then
    printf '%s\n' "$raw"
    return 0
  fi
  path="$(_audit_resolve_target_path "$raw" 2>/dev/null || true)"
  if [ -n "$path" ] && [ -x "$path" ]; then
    printf '%s\n' "$path"
    return 0
  fi
  return 1
}

_audit_detect_race_runner() {
  local runner=""
  local arg=""
  local has_race=1
  runner="$(_audit_runner_bin_available "${TARGET_RUNNER_BIN:-}" 2>/dev/null || true)"
  for arg in "${TARGET_RUNNER_ARGS[@]:-}"; do
    case "$arg" in
      -race|*-race*) has_race=0 ;;
    esac
  done
  if [ -n "$runner" ] && [ "$has_race" -eq 0 ]; then
    _audit_record_sanitizer_found race "$runner ${TARGET_RUNNER_ARGS[*]:-}" "runner"
    return 0
  fi
  if [ -z "${TARGET_RUNNER_BIN:-}" ]; then
    _audit_record_sanitizer_missing race "set [runner].bin with [runner].args including -race"
  elif [ -z "$runner" ]; then
    _audit_record_sanitizer_missing race "configured runner is not executable: ${TARGET_RUNNER_BIN}"
  else
    _audit_record_sanitizer_missing race "configured runner args do not include -race"
  fi
  return 1
}

detect_sanitizer_builds() {
  # AUDIT_BUILD_SUFFIX is set by bin/audit-container-shell to the short
  # image ID so different container images do not share build trees;
  # outside a container it is empty and paths stay as ${TARGET_ROOT}/build-asan.
  ASAN_BUILD_DIR="${ASAN_BUILD_DIR:-${TARGET_ROOT}/build-asan${AUDIT_BUILD_SUFFIX:-}}"
  ASAN_BUILD_AVAILABLE=0
  ASAN_BUILD_BINARY=""
  SANITIZER_BUILD_AVAILABLE=0
  SANITIZER_BUILD_SUMMARY=""
  SANITIZER_BUILD_MISSING=""
  SANITIZER_BUILD_DISABLED=0

  if [ "${IS_BROWSER_TARGET:-0}" -ne 0 ]; then
    export ASAN_BUILD_DIR ASAN_BUILD_AVAILABLE ASAN_BUILD_BINARY
    export SANITIZER_BUILD_AVAILABLE SANITIZER_BUILD_SUMMARY SANITIZER_BUILD_MISSING SANITIZER_BUILD_DISABLED
    return 0
  fi

  if [ "${TARGET_SANITIZERS_EXPLICITLY_DISABLED:-0}" = "1" ]; then
    SANITIZER_BUILD_DISABLED=1
    export ASAN_BUILD_DIR ASAN_BUILD_AVAILABLE ASAN_BUILD_BINARY
    export SANITIZER_BUILD_AVAILABLE SANITIZER_BUILD_SUMMARY SANITIZER_BUILD_MISSING SANITIZER_BUILD_DISABLED
    return 0
  fi

  local enabled=()
  local san=""
  if [ -n "${TARGET_SANITIZERS_ENABLED+set}" ] && [ "${#TARGET_SANITIZERS_ENABLED[@]}" -gt 0 ]; then
    enabled=("${TARGET_SANITIZERS_ENABLED[@]}")
  else
    enabled=("asan")
  fi

  for san in "${enabled[@]}"; do
    case "$san" in
      asan)
        _audit_detect_asan_build || true
        ;;
      ubsan)
        _audit_detect_binary_sanitizer_build ubsan "${TARGET_UBSAN_BIN:-}" \
          "${UBSAN_BUILD_DIR:-${TARGET_ROOT}/build-ubsan${AUDIT_BUILD_SUFFIX:-}}" "__ubsan_" || true
        ;;
      msan)
        _audit_detect_binary_sanitizer_build msan "${TARGET_MSAN_BIN:-}" \
          "${MSAN_BUILD_DIR:-${TARGET_ROOT}/build-msan${AUDIT_BUILD_SUFFIX:-}}" "__msan_" || true
        ;;
      tsan)
        _audit_detect_binary_sanitizer_build tsan "${TARGET_TSAN_BIN:-}" \
          "${TSAN_BUILD_DIR:-${TARGET_ROOT}/build-tsan${AUDIT_BUILD_SUFFIX:-}}" "__tsan_" || true
        ;;
      race)
        _audit_detect_race_runner || true
        ;;
    esac
  done

  export ASAN_BUILD_DIR ASAN_BUILD_AVAILABLE ASAN_BUILD_BINARY
  export SANITIZER_BUILD_AVAILABLE SANITIZER_BUILD_SUMMARY SANITIZER_BUILD_MISSING SANITIZER_BUILD_DISABLED
}

list_candidate_subsystems() {
  find "$TARGET_ROOT" -maxdepth 2 -type d \
    ! -path '*/.git*' \
    ! -path '*/.hg*' \
    ! -path '*/.svn*' \
    ! -path '*/.github*' \
    ! -path '*/build*' \
    ! -path '*/ci*' \
    ! -path '*/doc*' \
    ! -path '*/docs*' \
    ! -path '*/example*' \
    ! -path '*/examples*' \
    ! -path '*/out*' \
    ! -path '*/dist*' \
    ! -path '*/node_modules*' \
    ! -path '*/single_include*' \
    ! -path '*/target*' \
    ! -path '*/test*' \
    ! -path '*/tests*' \
    ! -path '*/testing*' \
    ! -path '*/cmake-build*' \
    | python3 "$SCRIPT_ROOT/lib/audit_helpers.py" relpath-list "$TARGET_ROOT" \
    | sed '/^$/d' \
    | sort \
    | head -20
}


# Count VERIFIED ASan runs — .asan.txt files whose contents prove

# Count testcase files in the scratch dir that LACK the mandatory


# Per-agent paths for the coverage-verdict log, the tried-inputs memory,
# and the per-subsystem guards database. These are referenced both by
# agents (in directive text) and by the harness (rotation gate, etc).
# Keeping them in one place prevents drift between the harness-side
# grep and the agent-side writer.
hits_log_path() {
  # Per-agent append-only coverage-verdict log. bin/hits --log
  # writes one "^HIT:|MISSED:|EXEC_FAIL:|NO_COVERAGE:" line per call.
  local agent_num="$1"
  printf '%s/hits-%s.log' "$RESULTS_DIR" "$agent_num"
}
tried_inputs_log_path() {
  # Per-agent append-only testcase memory. run-asan-multi.sh appends one
  # line per invocation. Used by the agent to avoid re-running an
  # identical testcase after context compression, and by the harness
  # to display recent activity in the deep-investigation prompt.
  local agent_num="$1"
  printf '%s/tried-inputs-%s.log' "$RESULTS_DIR" "$agent_num"
}
asan_run_counter_path() {
  # Per-agent, per-iteration counter for browser/js ASan invocations.
  # run-asan-multi.sh increments this via ASAN_RUN_COUNTER_FILE; the audit
  # harness resets it to 0 at the start of each iteration. Lives under
  # LOGDIR so it's co-located with other per-iteration housekeeping
  # (prev_tools, prev_findings, guard-chain snapshots).
  local agent_num="$1"
  printf '%s/.asan_runs_%s' "$LOGDIR" "$agent_num"
}
reset_asan_run_counter() {
  local agent_num="$1"
  local f
  f=$(asan_run_counter_path "$agent_num")
  printf '0' > "$f" 2>/dev/null || true
}
guards_db_path() {
  # Shared, persistent subsystem → upstream-guard → bypass catalog.
  # Agents read this at session start to skip guards that were already
  # hit in prior sessions; they append a new row whenever a testcase
  # dies to a reproducible guard string.
  printf '%s/guards-db.md' "$RESULTS_DIR"
}
fuzz_leads_path() {
  # Triaged fuzz-crash leads, one section per non-noise crash. Written
  # by bin/triage-fuzz-crashes before each iteration.
  printf '%s/fuzz-leads.md' "$RESULTS_DIR"
}
# Initialise the guards database if absent. Agents will append rows;
# the harness never rewrites it. The header + schema lets agents
# grep by subsystem without reading the full file.
init_guards_db() {
  local f
  f=$(guards_db_path)
  [ -f "$f" ] && return 0
  cat > "$f" <<'GDB'
# Guards Database (append-only)

Cross-session memory of upstream validation guards that block reachability
from external input to a suspected defect. Agents MUST check this file
before building a hypothesis — if a guard for the target subsystem is
already listed, either plan the bypass or pick a different target.

## Schema
Each entry is a fenced block:
```
SUBSYSTEM: <top-level path, e.g. dom/canvas>
GUARD: <exact error string or validator identifier, e.g. "Error: regexp too big">
WHERE: <file:function:line of the check, if known>
SEEN_BY: <agent_num> on <iso-ts>
BYPASS: <concrete alternative path if known, else "unknown">
NOTES: <one sentence>
```

Append new entries at the bottom. Do not rewrite existing entries —
they are a historical record. If a listed BYPASS is proven wrong,
append a new entry with the corrected bypass rather than editing.

## Entries

GDB
}

# Count ENV-BLOCKED rows in an agent's state file (supports the
# rotation-gate carve-out: if an agent has hit ≥ N environment walls in
# the same subsystem, that subsystem is done for this host — rotation
# should be permitted even without the full effort gate.)
count_env_blocked() {
  local state_file="$1"
  [ -f "$state_file" ] || { echo 0; return; }
  local n
  n=$(grep -c "ENV-BLOCKED" "$state_file" 2>/dev/null) || true
  echo "${n:-0}"
}

resolve_guide_path() {
  echo "AGENTS.md"  # unified browser + generic audit guide
}

init_backend_selection() {
  case "$AUDIT_BACKEND" in
    all)
      if [ "$MODEL_FLAG_PROVIDED" -eq 1 ]; then
        log "FATAL: --model requires a single backend. Use --backend claude, --backend codex, --backend oss, or --backend gemini with USE_GEMINI_CLI=1." >&2
        exit 1
      fi
      local discovered
      discovered=$(discover_ensemble_backends)
      if [ -z "$discovered" ]; then
        log "FATAL: none of '$CLAUDE_BIN', '$CODEX_BIN', '$GEMINI_BIN' is installed and authenticated/configured" >&2
        exit 1
      fi
      ENSEMBLE_BACKENDS=()
      local backend
      while IFS= read -r backend; do
        [ -n "$backend" ] && ENSEMBLE_BACKENDS+=("$backend")
      done <<EOF
$discovered
EOF
      ENSEMBLE_MODE=1
      ACTIVE_BACKEND="${ENSEMBLE_BACKENDS[0]}"
      ;;
    claude)
      backend_configured claude || { log "FATAL: '$CLAUDE_BIN' not found or Claude authentication is not configured" >&2; exit 1; }
      ACTIVE_BACKEND="claude"
      ;;
    codex)
      backend_configured codex || { log "FATAL: '$CODEX_BIN' not found or Codex authentication is not configured" >&2; exit 1; }
      ACTIVE_BACKEND="codex"
      ;;
    gemini)
      backend_configured gemini || { log "FATAL: '$GEMINI_BIN' not found or the gemini backend CLI is not configured" >&2; exit 1; }
      ACTIVE_BACKEND="gemini"
      ;;
    oss)
      command_exists "$OPENCODE_BIN" || { log "FATAL: '$OPENCODE_BIN' not found in PATH. Install OpenCode, or set OPENCODE_BIN=/path/to/opencode." >&2; exit 1; }
      if [ -z "${AUDIT_MODEL:-}" ]; then
        log "FATAL: --backend oss requires --model <served-model-name> (the exact model id listed by the provider's /v1/models endpoint)" >&2
        exit 1
      fi
      local base_url resolved
      base_url="$(oss_local_base_url)"
      resolved="$(oss_resolved_model_name "$AUDIT_MODEL")"
      if ! oss_model_available "$AUDIT_MODEL"; then
        log "FATAL: local model '$AUDIT_MODEL' resolved to '$resolved', but ${base_url} did not list it from /models." >&2
        log "Start a local OpenAI-compatible server first, for example: vllm serve <hf-model-or-local-path> --served-model-name '$resolved'" >&2
        log "For Ollama, use: AUDIT_LOCAL_BASE_URL=http://127.0.0.1:11434/v1 bin/audit --backend oss --model '$resolved' ..." >&2
        exit 1
      fi
      ACTIVE_BACKEND="oss"
      ;;
    *)
      log "FATAL: AUDIT_BACKEND must be all, claude, codex, gemini, or oss (got '$AUDIT_BACKEND')" >&2
      exit 1
      ;;
  esac
}

apply_backend_decision_timeout_defaults() {
  if [ -z "${AUDIT_LLM_DECISION_TIMEOUT_USER_SET:-}" ] && [ "${ACTIVE_BACKEND:-}" = "oss" ]; then
    LLM_DECISION_TIMEOUT=180
  fi
  if ! [[ "${LLM_DECISION_TIMEOUT:-}" =~ ^[0-9]+$ ]] || [ "$LLM_DECISION_TIMEOUT" -le 0 ]; then
    log "FATAL: LLM_DECISION_TIMEOUT must be a positive integer number of seconds (got '${LLM_DECISION_TIMEOUT:-}')" >&2
    exit 1
  fi
  export LLM_DECISION_TIMEOUT
}

resolve_model() {
  local model=""
  if [ -n "${AUDIT_MODEL:-}" ]; then
    model="$AUDIT_MODEL"
  else
    case "${ACTIVE_BACKEND}" in
      claude|codex|gemini|oss) model="$(llm_default_model "$ACTIVE_BACKEND")" ;;
      *)
        log "FATAL: unsupported backend: ${ACTIVE_BACKEND}" >&2
        exit 1
        ;;
    esac
  fi
  case "${ACTIVE_BACKEND}" in
    oss) llm_resolve_model_name oss "$model" ;;
    claude|codex|gemini) printf '%s\n' "$model" ;;
    *)
      log "FATAL: unsupported backend: ${ACTIVE_BACKEND}" >&2
      exit 1
      ;;
  esac
}

model_preflight_stamp_path() {
  local backend="$1"
  local model="$2"
  local safe_model stamp_backend
  safe_model=$(printf '%s' "$model" | tr -cs '[:alnum:]._-' '_')
  safe_model="${safe_model#_}"
  safe_model="${safe_model%_}"
  [ -n "$safe_model" ] || safe_model="model"
  stamp_backend="$backend"
  # OSS used to have an echo-only connectivity preflight. Keep tool-aware
  # approvals separate so old stamps cannot bless a weak local model.
  [ "$backend" = "oss" ] && stamp_backend="oss_tool_v1"
  printf '%s/.model_preflight_%s_%s.ok' "$LOGDIR" "$stamp_backend" "$safe_model"
}

oss_tool_preflight() {
  local model="$1"
  local timeout_secs="$2"
  local raw="$3"
  local preflight_dir sentinel token prompt text rc

  preflight_dir="$LOGDIR/.preflight"
  mkdir -p "$preflight_dir" || return 1
  sentinel="$preflight_dir/oss-tool-sentinel.txt"
  token="OSS_TOOL_PREFLIGHT_OK_$(date -u '+%Y%m%d%H%M%S')_$$"
  printf '%s\n' "$token" > "$sentinel" || return 1

  prompt="$(render_prompt_template oss_tool_preflight.md.j2)"

  rc=0
  llm_run_agent_prompt oss "$prompt" "$timeout_secs" "$raw" \
    "$model" 6 "$preflight_dir" "$preflight_dir" || rc=$?
  [ "$rc" -eq 0 ] || return "$rc"

  text=$(llm_extract_text oss "$raw" 2>/dev/null || true)
  if ! llm_raw_has_tool "$raw" read; then
    log "WARN: oss preflight: model did not use the required read tool — treating as failure" | tee -a "$INDEX"
    return 45
  fi
  if ! grep -qxF "$token" <<<"$text"; then
    log "WARN: oss preflight: model did not return the hidden sentinel after tool use — treating as failure" | tee -a "$INDEX"
    return 46
  fi

  rm -f "$sentinel" 2>/dev/null || true
  return 0
}

# One-time backend bootstrap for the audit process. Side-effect helpers
# that were previously called inside model_preflight (which fires every
# iteration) actually answer machine-state, not per-iteration state
# questions — running them once per audit is sufficient. Idempotent by
# the AUDIT_BACKEND_BOOTSTRAP_DONE_<backend> guard so accidental second
# calls are free.
audit_one_time_backend_bootstrap() {
  local backend="$1"
  [ -n "$backend" ] || return 0
  local guard
  guard="AUDIT_BACKEND_BOOTSTRAP_DONE_$(printf '%s' "$backend" | tr '[:lower:]' '[:upper:]')"
  [ -n "${!guard:-}" ] && return 0
  case "$backend" in
    gemini)
      # gemini-cli ships without a bundled ripgrep binary on most installs;
      # the diagnostic prints a one-time WARN with the symlink command an
      # operator can run once per machine to restore native rg. The
      # underlying state is the filesystem layout of the npm bundle —
      # constant for the audit process lifetime.
      gemini_cli_check_bundled_ripgrep
      # Currently a no-op stub kept for forward compatibility with the
      # Antigravity (agy) CLI. Calling it once at startup means any future
      # session pruning logic also runs once, not per iteration.
      gemini_prune_stale_sessions
      ;;
  esac
  printf -v "$guard" 1
  export "$guard"
}

gemini_prune_stale_sessions() {
  # Hook kept for callers that still reference it. The Antigravity CLI
  # (agy) does not require per-startup pruning. Set AUDIT_GEMINI_PRUNE=0
  # to disable any future agy pruning logic added here.
  [ "${AUDIT_GEMINI_PRUNE:-1}" = "1" ] || return 0
  return 0
}

# Diagnostic: the Google gemini-cli (USE_GEMINI_CLI=1) hardcodes ripgrep
# lookup to a bundled platform binary at
# bundle/vendor/ripgrep/rg-<platform>-<arch> inside its own npm install,
# and does NOT consult $PATH. The published npm package ships without
# that binary, so every cold start logs "Ripgrep is not available.
# Falling back to GrepTool." and grep operations fall through to the
# slower JavaScript implementation — functionally correct but a real
# perf hit on large source trees.
#
# This is an upstream packaging miss; the harness fix is purely
# advisory. Print the exact symlink command the operator can run once
# per machine to point gemini-cli at their system rg. No file outside
# the work directory is touched here. Suppress by setting
# AUDIT_GEMINI_RG_HINT=0.
gemini_cli_check_bundled_ripgrep() {
  [ "${AUDIT_GEMINI_RG_HINT:-1}" = "1" ] || return 0
  llm_use_gemini_cli || return 0
  command -v node >/dev/null 2>&1 || return 0
  local gemini_bin gemini_target bundle_dir plat_arch vendor_rg system_rg
  gemini_bin="$(command -v "${GEMINI_BIN:-gemini}" 2>/dev/null)"
  [ -n "$gemini_bin" ] || return 0
  # Resolve the symlink chain to find the bundle directory. node is
  # already present (we just checked), so use it for portable realpath
  # — macOS readlink lacks -f.
  bundle_dir="$(node -e 'const p=require("path"),f=require("fs");process.stdout.write(p.dirname(f.realpathSync(process.argv[1])))' "$gemini_bin" 2>/dev/null)"
  [ -n "$bundle_dir" ] || return 0
  plat_arch="$(node -e 'process.stdout.write(process.platform+"-"+process.arch)' 2>/dev/null)"
  [ -n "$plat_arch" ] || return 0
  local bin_name="rg-${plat_arch}"
  case "$plat_arch" in win32-*) bin_name="${bin_name}.exe" ;; esac
  vendor_rg="$bundle_dir/vendor/ripgrep/$bin_name"
  [ -e "$vendor_rg" ] && return 0
  system_rg="$(command -v rg 2>/dev/null || true)"
  log "WARN: gemini-cli ships without its bundled ripgrep binary at $vendor_rg; grep ops fall back to a slower JS implementation and every cold start logs 'Ripgrep is not available'. This is upstream cosmetic-and-perf, not a correctness issue." | tee -a "$INDEX"
  if [ -n "$system_rg" ]; then
    log "WARN: to fix once per machine: mkdir -p \"${vendor_rg%/*}\" && ln -sfn \"$system_rg\" \"$vendor_rg\"" | tee -a "$INDEX"
  else
    log "WARN: to fix once per machine, install ripgrep (brew install ripgrep / apt install ripgrep) then symlink it: mkdir -p \"${vendor_rg%/*}\" && ln -sfn \"\$(command -v rg)\" \"$vendor_rg\"" | tee -a "$INDEX"
  fi
  return 0
}

# agy (the Antigravity CLI used as the gemini backend) writes its real
# diagnostics — notably 429 / RESOURCE_EXHAUSTED account-quota rejections —
# only to its own rotating CLI log, never to stdout. When agy exits 0 with
# empty stdout the failure is otherwise undiagnosable, so copy the tail of
# its newest CLI log into the given destination file. Honors GEMINI_DIR the
# same way agy resolves its app-data dir; AUDIT_GEMINI_CLI_LOG_DIR overrides
# the directory outright (used by the test suite).
gemini_capture_cli_log_diag() {
  local dest="$1"
  llm_capture_gemini_cli_log_diag "$dest"
}

validate_model_for_backend() {
  local backend="$1"
  local model="$2"
  local default_timeout_secs=60
  # The Google Gemini CLI can take longer than a minute to emit even a
  # one-token response under concurrent agent load. Real Gemini
  # validator calls already use a 300s ceiling, so give CLI preflight the
  # same default while keeping AUDIT_MODEL_PREFLIGHT_TIMEOUT as the
  # operator/test override.
  if [ "$backend" = "gemini" ] && [ "${USE_GEMINI_CLI:-0}" = "1" ]; then
    default_timeout_secs=300
  fi
  local timeout_secs="${AUDIT_MODEL_PREFLIGHT_TIMEOUT:-$default_timeout_secs}"
  local prompt
  prompt="$(render_prompt_template model_preflight.md.j2)"
  local stamp raw msg rc
  local gemini_quota_blocked=0

  [ "${AUDIT_MODEL_PREFLIGHT:-1}" = "1" ] || return 0
  [ -n "${model:-}" ] || { log "FATAL: no model resolved for backend '$backend'" >&2; exit 1; }
  if ! [[ "$timeout_secs" =~ ^[0-9]+$ ]] || [ "$timeout_secs" -le 0 ]; then
    log "FATAL: AUDIT_MODEL_PREFLIGHT_TIMEOUT must be a positive integer (got '$timeout_secs')" >&2
    exit 1
  fi

  case "$backend" in
    claude|codex|gemini|oss) ;;
    *)
      log "FATAL: unsupported backend for model preflight: $backend" >&2
      exit 1
      ;;
  esac

  mkdir -p "$LOGDIR"
  stamp=$(model_preflight_stamp_path "$backend" "$model")
  # Per-process short-circuit: once a backend/model pair has passed
  # preflight inside this audit process, subsequent iter-boundary calls
  # don't need to re-prove reachability. Keyed by backend+model+PID so a
  # different model (or a fresh `bin/audit` run) still preflights once.
  local process_guard
  process_guard="AUDIT_MODEL_PREFLIGHT_OK_${backend}_${model}_$$"
  process_guard=$(printf '%s' "$process_guard" | tr -cs '[:alnum:]_' '_')
  if [ -n "${!process_guard:-}" ]; then
    return 0
  fi

  if ! raw=$(mktemp "$LOGDIR/model-preflight-${backend}.XXXXXX"); then
    log "FATAL: could not create model preflight log under $LOGDIR" >&2
    exit 1
  fi
  mv "$raw" "${raw}.raw"
  raw="${raw}.raw"
  msg="${raw%.raw}.message"
  rc=0

  # Retry with exponential backoff: a transient API/network blip should
  # not take the whole audit down before any work begins. Default 3
  # attempts with 15s -> 60s backoff between them. Override with
  # AUDIT_MODEL_PREFLIGHT_ATTEMPTS (>=1) and AUDIT_MODEL_PREFLIGHT_BACKOFF
  # (initial seconds, ×4 each retry).
  local max_attempts="${AUDIT_MODEL_PREFLIGHT_ATTEMPTS:-3}"
  local backoff="${AUDIT_MODEL_PREFLIGHT_BACKOFF:-15}"
  if ! [[ "$max_attempts" =~ ^[0-9]+$ ]] || [ "$max_attempts" -le 0 ]; then
    max_attempts=3
  fi
  if ! [[ "$backoff" =~ ^[0-9]+$ ]] || [ "$backoff" -le 0 ]; then
    backoff=15
  fi

  # Per-audit backend bootstrap (machine-state side effects). Idempotent
  # via internal guard — extra calls are cheap. Moved out of the
  # preflight hot path so it runs once per audit, not once per iter.
  audit_one_time_backend_bootstrap "$backend"

  # Preflight now launches via the shared helper (below), so it inherits the
  # real agent flags — including claude's --dangerously-skip-permissions,
  # which the CLI rejects under euid 0 unless IS_SANDBOX=1. The container is
  # the sandbox boundary here (same reasoning as run_agent and the
  # bin/validate-finding / bin/audit-recon validator paths). Other backends
  # ignore the variable.
  export IS_SANDBOX=1

  # agy 1.0.5 takes --model but silently falls back to its persistent /model
  # on a value it can't resolve to an `agy models` label (see
  # lib/llm_invoke.py:agy_model_label) — exit 0, and the fallback model still
  # echoes MODEL_PREFLIGHT_OK, so the echo check below can't catch it. Pin
  # agy's log to a per-probe file via AGY_LOG_FILE so the rc==0 branch can
  # read back the unresolved-flag signature deterministically; the shared CLI
  # log dir is unsafe under concurrent benchmark cells. Only agy honors
  # AGY_LOG_FILE (the Google Gemini CLI and other backends ignore it).
  local _agy_preflight_log=""
  if [ "$backend" = "gemini" ] && [ "${USE_GEMINI_CLI:-0}" != "1" ]; then
    _agy_preflight_log="${raw%.raw}.agylog"
    export AGY_LOG_FILE="$_agy_preflight_log"
  fi

  log "Model preflight: checking that ${backend} backend can reach model='${model}' (timeout per attempt=$(fmt_secs "$timeout_secs"), up to ${max_attempts} attempt(s) with exponential backoff)" | tee -a "$INDEX"
  local attempt
  for ((attempt=1; attempt<=max_attempts; attempt++)); do
    rc=0
    : > "$raw"
    [ -n "$_agy_preflight_log" ] && : > "$_agy_preflight_log"
    # Every backend launches through the shared flag picker (lib/llm_invoke.sh)
    # so preflight exercises the exact same wiring as the real agent loop,
    # bin/audit-recon, and bin/validate-finding — stream-json/json output
    # shape, sandbox bypass, model selection, and --add-dir / --cd. No
    # hand-rolled flag lists to drift out of sync. max_turns=1 keeps this a
    # one-token litmus; the prompt asks the model to echo MODEL_PREFLIGHT_OK.
    # Claude/codex success is the CLI exit code; the gemini branch below
    # additionally requires the assistant to have echoed MODEL_PREFLIGHT_OK
    # (agy can exit 0 with no output on upstream quota rejection).
    if [ "$backend" = "oss" ]; then
      oss_tool_preflight "$model" "$timeout_secs" "$raw" || rc=$?
    else
      llm_run_agent_prompt "$backend" "$prompt" "$timeout_secs" "$raw" \
        "$model" 1 "$SCRIPT_ROOT" "$SCRIPT_ROOT" || rc=$?
    fi
    # Some gemini CLI failures can exit 0 while emitting no assistant text
    # (for agy this has happened on upstream RESOURCE_EXHAUSTED / 429 /
    # quota failures written only to private logs). A genuine preflight
    # success always echoes the assistant reply, so missing extracted
    # assistant text is a failure even if stream-json metadata exists.
    if [ "$rc" -eq 0 ] && [ "$backend" = "gemini" ]; then
      local gemini_preflight_text
      gemini_preflight_text=$(llm_extract_text gemini "$raw" 2>/dev/null || true)
      if ! grep -qx 'MODEL_PREFLIGHT_OK' <<<"$gemini_preflight_text"; then
        rc=44
        # agy exits 0 with empty stdout when the upstream request is rejected;
        # the real cause is only in agy's private CLI log. Pull it into $raw so
        # the failure is diagnosable instead of a silent empty file. Only agy
        # behaves this way — the Google Gemini CLI (USE_GEMINI_CLI=1) writes
        # its errors to stderr, which is already captured in $raw, and does
        # not use agy's log dir, so scraping it there would mis-attribute a
        # stale agy quota error to a different CLI.
        if [ "${USE_GEMINI_CLI:-0}" != "1" ]; then
          gemini_capture_cli_log_diag "$raw"
        fi
        if [ "$(python3 "$SCRIPT_ROOT/lib/audit_helpers.py" provider-issue "$raw" 2>/dev/null || printf '%s\n' none)" = "capacity_limited" ]; then
          gemini_quota_blocked=1
          log "WARN: gemini preflight: agy reports the account quota is exhausted — retrying will not help until it resets" | tee -a "$INDEX"
        elif [ -n "$gemini_preflight_text" ]; then
          log "WARN: gemini preflight: CLI did not return MODEL_PREFLIGHT_OK — treating as failure" | tee -a "$INDEX"
        else
          log "WARN: gemini preflight: CLI exited 0 but produced no output — treating as failure" | tee -a "$INDEX"
        fi
      fi
    fi
    # agy can exit 0 AND echo MODEL_PREFLIGHT_OK while running a different
    # model than requested: handed a name it can't resolve to a label, it
    # silently falls back to its persistent /model, leaving the only trace in
    # its own log. That's a config error, not a transient blip — fail hard
    # immediately (so retries and AUDIT_MODEL_PREFLIGHT_OPTIONAL can't mask it)
    # before a benchmark cell runs and prices the wrong model. _agy_preflight_log
    # is set only for gemini-on-agy, so its presence is the backend gate.
    if [ "$rc" -eq 0 ] && [ -n "$_agy_preflight_log" ] \
       && grep -q 'Failed to resolve model flag' "$_agy_preflight_log" 2>/dev/null; then
      log "FATAL: model preflight: agy could not resolve model '${model}' to a known 'agy models' label and silently fell back to its persistent /model. Pass an exact label (e.g. \"Gemini 3.1 Pro (High)\") or map the slug in lib/llm_invoke.py (_AGY_SLUG_TO_LABEL)." >&2
      grep -E 'Failed to resolve model flag|Propagating selected model override' "$_agy_preflight_log" 2>/dev/null | tail -4 | sed 's/^/[model-preflight] /' >&2 || true
      exit 1
    fi
    [ "$rc" -eq 0 ] && break
    # A quota exhaustion does not clear within the retry window — stop now
    # and surface the real reason instead of burning the backoff budget.
    if [ "$gemini_quota_blocked" = "1" ]; then
      break
    fi
    if [ "$attempt" -lt "$max_attempts" ]; then
      log "WARN: model preflight attempt ${attempt}/${max_attempts} for ${backend}/${model} failed (CLI exit code=${rc}); retrying after $(fmt_secs "$backoff") backoff" | tee -a "$INDEX"
      if [ -s "$raw" ]; then
        tail -5 "$raw" 2>/dev/null | sed 's/^/[model-preflight] /' >&2 || true
      fi
      sleep "$backoff"
      backoff=$(( backoff * 4 ))
    fi
  done

  # Done probing — stop redirecting agy's log so real agent launches in this
  # same process write to their normal CLI log dir.
  [ -n "$_agy_preflight_log" ] && unset AGY_LOG_FILE

  if [ "$rc" -ne 0 ]; then
    # Fail fast by default: a backend that cannot complete this one-token
    # litmus request is not usable for unattended agent launches. Operators
    # running long scheduled jobs may explicitly set
    # AUDIT_MODEL_PREFLIGHT_OPTIONAL=1 to downgrade transient preflight
    # failures to WARN and let the first real agent invocation surface any
    # persistent backend error with full context. No stamp is written on
    # the optional path, so the next audit retries preflight from scratch.
    if [ "${AUDIT_MODEL_PREFLIGHT_OPTIONAL:-0}" = "1" ]; then
      log "WARN: model preflight failed for backend=${backend} model=${model} after ${max_attempts} attempt(s) (last exit=${rc}); continuing because AUDIT_MODEL_PREFLIGHT_OPTIONAL=1. First agent invocation will surface persistent errors." | tee -a "$INDEX"
      log "WARN: preflight log: $raw" | tee -a "$INDEX"
      if [ -s "$raw" ]; then
        tail -20 "$raw" 2>/dev/null | sed 's/^/[model-preflight] /' >&2 || true
      fi
      return 0
    fi
    if [ "$gemini_quota_blocked" = "1" ]; then
      log "FATAL: model preflight failed for backend=${backend} model=${model}: the Antigravity (agy) account quota is exhausted — see the agy CLI log tail below for the reset window. Wait for the quota to reset, retry with USE_GEMINI_CLI=1 (Google Gemini CLI uses a separate quota pool), or run the audit with --backend claude/codex." >&2
    else
      log "FATAL: model preflight failed for backend=${backend} model=${model} after ${max_attempts} attempt(s) (last exit=${rc}). Check the model name, backend support, and CLI authentication/configuration." >&2
    fi
    log "FATAL: preflight log: $raw" >&2
    if [ -s "$raw" ]; then
      tail -20 "$raw" 2>/dev/null | sed 's/^/[model-preflight] /' >&2 || true
    fi
    exit 1
  fi

  printf 'backend=%s\nmodel=%s\nchecked_at=%s\n' "$backend" "$model" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" > "$stamp"
  # Success path: the .ok stamp records the verdict; the .raw / .message
  # files are pure noise (every successful preflight produces an identical
  # "MODEL_PREFLIGHT_OK" payload). Delete them so they don't accumulate.
  # Failure path above returns/exits before reaching here, so .raw is
  # preserved as the only on-disk evidence of the failure mode.
  rm -f "$raw" "$msg" 2>/dev/null || true
  # Record success in the per-process guard so subsequent iter-boundary
  # calls inside this audit short-circuit. Uses the same key as the
  # early-return path above.
  printf -v "$process_guard" 1
  export "$process_guard"
  log "Model preflight passed: ${backend} backend can reach model='${model}' — proceeding with agent launches" | tee -a "$INDEX"
}

validate_active_model() {
  validate_model_for_backend "$ACTIVE_BACKEND" "$MODEL"
}

configure_active_backend() {
  local backend="$1"
  ACTIVE_BACKEND="$backend"
  MODEL="$(resolve_model)"

  # Output layout: output/<target>[-<experiment>]/<backend>/{results,logs}. Raw model
  # dialogue dumps (session_*.log.raw, recon_*.raw) live under
  # logs/.raw/ so they don't dominate `ls logs/` and so agent file scans
  # naturally skip them (dotdir).
  RESULTS_DIR="$(target_backend_results_dir "$ACTIVE_BACKEND")"
  export RESULTS_DIR
  LOGDIR="$(target_backend_logs_dir "$ACTIVE_BACKEND")"
  RAW_DIR="$LOGDIR/.raw"
  INDEX="$LOGDIR/index.log"
  LOG_INDEX_JSONL="$LOGDIR/index.jsonl"
  COUNTER_FILE="$LOGDIR/.session_counter"
  SUBSYSTEM_BLOCKLIST_FILE="$RESULTS_DIR/.subsystem_blocklist"
  export LLM_DECIDE_COUNTER_FILE="$LOGDIR/.llm_decisions_harness"
  export LLM_DECIDE_MAX_CALLS="${LLM_DECIDE_MAX_CALLS:-1000}"

  TARGET_CONFIG_DIR="$(target_output_root)"
  TARGET_TOML="$TARGET_CONFIG_DIR/target.toml"
  mkdir -p "$TARGET_CONFIG_DIR" "$LOGDIR" "$RAW_DIR" "$RESULTS_DIR"
  # With cross-run memory off (default) and the Gemini CLI dialect, stage a
  # clean empty GEMINI_CLI_HOME under $LOGDIR so the global ~/.gemini/GEMINI.md
  # is neither read nor written. No-op for agy and for --enable-memory runs;
  # fatal if isolation applies but cannot be guaranteed (see the function).
  llm_stage_gemini_memory_home "$ACTIVE_BACKEND" || exit 1
  audit_write_logdir_readme "$LOGDIR"
  local target_rev
  target_rev="$(target_detect_rev "$TARGET_ROOT")"
  # Backend-local session env is the authoritative discovery point for
  # testcase/probe paths. The legacy target-root copy remains for manual
  # commands started outside a backend results tree.
  target_write_session_env "$RESULTS_DIR" "$RESULTS_DIR" "$TARGET_ROOT" \
    "$TARGET_SLUG" "$target_rev" "$LOGDIR"
  target_write_session_env "$TARGET_CONFIG_DIR" "$RESULTS_DIR" "$TARGET_ROOT" \
    "$TARGET_SLUG" "$target_rev" "$LOGDIR"
}

prepare_active_backend_runtime() {
  mkdir -p "$LOGDIR" "$RESULTS_DIR" \
           "$RESULTS_DIR/crashes" "$RESULTS_DIR/crashes-rejected" "$RESULTS_DIR/findings" \
           "$(corpus_dir_root)" "$RESULTS_DIR/state"
  local _i
  for _i in $(seq 1 "$NUM_AGENTS"); do
    mkdir -p "$(scratch_dir_path "$_i")"
    if [ -n "${AUDIT_FIXED_STRATEGY:-}" ]; then
      set_agent_strategy "$_i" "$AUDIT_FIXED_STRATEGY"
      reset_agent_strategy_streak "$_i"
    fi
  done
  init_guards_db

  # P6: stable record of run configuration the benchmark harness can
  # read back without parsing log lines. Lets bin/benchmark surface
  # the *actual* NUM_AGENTS in cell.json so cells running 1 worker
  # aren't silently averaged with cells running 3. Written as JSON so
  # extending it later (max_turns, model_id, sanitizer set, ...) is a
  # mechanical add.
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$RESULTS_DIR/state/run-config.json" "$NUM_AGENTS" \
        "${BROWSER_AGENTS:-0}" "${SHELL_AGENTS:-0}" \
        "${ACTIVE_BACKEND:-}" "${MODEL:-}" "${TARGET_SLUG:-}" "${agent_count_overridden:-0}" <<'PY' 2>/dev/null || true
import json, sys
path, num, browser, shell, backend, model, target, overridden = sys.argv[1:]
def _i(s):
    try: return int(s)
    except Exception: return 0
json.dump({
    "num_agents": _i(num),
    "browser_agents": _i(browser),
    "shell_agents": _i(shell),
    "backend": backend,
    "model": model,
    "target_slug": target,
    "agent_count_overridden": _i(overridden) == 1,
}, open(path, "w"), indent=2, sort_keys=True)
PY
  fi

  # Compress old text logs opportunistically; raw transcript cleanup is handled
  # explicitly by bin/cleanup_logs so retention is not tied to audit startup.
  find "$LOGDIR" -name "*.log" -mtime +3 ! -name "index.log" ! -name ".session_counter" -exec gzip -q {} \; 2>/dev/null || true
}

select_ensemble_backend_for_iteration() {
  [ "$ENSEMBLE_MODE" -eq 1 ] || return 0
  local count="${#ENSEMBLE_BACKENDS[@]}"
  [ "$count" -gt 0 ] || { log "FATAL: ensemble mode has no configured hosted backends" >&2; exit 1; }
  local idx=$(( ENSEMBLE_NEXT_INDEX % count ))
  configure_active_backend "${ENSEMBLE_BACKENDS[$idx]}"
  ENSEMBLE_NEXT_INDEX=$(( (idx + 1) % count ))
}

extract_usage_field() {
  # Extract a usage accounting field from a raw transcript. Delegates to
  # lib/llm_usage.py — the same module bin/benchmark uses — so the agy
  # plain-text estimator (which fixes the silent tokens=0 regression in
  # the previous in-line jq implementation) is shared, not duplicated.
  #
  # The python helper handles:
  #   - Claude stream-json (running usage on each message; take MAX)
  #   - Codex item.completed (single summary event)
  #   - gemini-cli stream-json (result.stats final cumulative)
  #   - agy plain text (estimate from assistant transcript length;
  #     row flagged estimated:true so downstream reporting stays
  #     honest)
  #
  # The third optional argument is a path to the rendered prompt; when
  # supplied for agy, input_tokens is also estimated from prompt bytes.
  # Callers that don't pass it get 0 for input (agy's prompt isn't
  # otherwise recoverable from the raw log).
  local file="$1"
  local field="$2"
  local prompt_path="${3:-}"
  [ -f "$file" ] || { echo ""; return; }
  local backend="${ACTIVE_BACKEND:-${AUDIT_BACKEND:-claude}}"
  if [ -n "$prompt_path" ] && [ -f "$prompt_path" ]; then
    python3 "$SCRIPT_ROOT/lib/llm_usage.py" extract-field \
      "$field" "$backend" "$file" --prompt "$prompt_path" 2>/dev/null \
      || echo ""
  else
    python3 "$SCRIPT_ROOT/lib/llm_usage.py" extract-field \
      "$field" "$backend" "$file" 2>/dev/null \
      || echo ""
  fi
}

extract_usage_fields() {
  # Extract every usage accounting field needed at agent-session end in one
  # Python process and one raw-log read. Keep extract_usage_field above for
  # targeted callers (resume cache gate, tests), but don't pay six full scans
  # on the run_agent hot path.
  local file="$1"
  local prompt_path="${2:-}"
  [ -f "$file" ] || {
    printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
    return
  }
  local backend="${ACTIVE_BACKEND:-${AUDIT_BACKEND:-claude}}"
  if [ -n "$prompt_path" ] && [ -f "$prompt_path" ]; then
    python3 "$SCRIPT_ROOT/lib/llm_usage.py" extract-fields \
      "$backend" "$file" --prompt "$prompt_path" 2>/dev/null \
      || printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
  else
    python3 "$SCRIPT_ROOT/lib/llm_usage.py" extract-fields \
      "$backend" "$file" 2>/dev/null \
      || printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
  fi
}

# Count tool invocations / shell commands executed by the agent.
# Backend-aware parsing lives in lib/audit_helpers.py so the shell-side
# dead-session logic and JSONL session summaries use the same transcript
# shapes for Codex, Claude, and Gemini CLI.
extract_completed_item_count() {
  local file="$1"
  local item_type="$2"
  [ -f "$file" ] || { echo 0; return; }
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" count-tools "$file" "$item_type" 2>/dev/null || echo 0
}

extract_tool_counts() {
  local file="$1"
  [ -f "$file" ] || { printf 'command_execution=0\nall_tools=0\n'; return; }
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" count-tools-all "$file" 2>/dev/null \
    || printf 'command_execution=0\nall_tools=0\n'
}

extract_raw_status() {
  local file="$1"
  [ -f "$file" ] || {
    printf 'rate_limit=0\ncodex_completed=0\ncodex_failed=0\ngemini_success=0\n'
    return
  }
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" raw-status "$file" 2>/dev/null \
    || printf 'rate_limit=0\ncodex_completed=0\ncodex_failed=0\ngemini_success=0\n'
}

log_provider_issue() {
  local file="$1"
  [ -f "$file" ] || { printf '%s\n' none; return; }
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" provider-issue "$file" 2>/dev/null \
    || printf '%s\n' none
}

extract_finish_fields() {
  local file="$1"
  local backend="${2:-${ACTIVE_BACKEND:-${AUDIT_BACKEND:-claude}}}"
  local prompt_path="${3:-}"
  [ -f "$file" ] || {
    printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
    printf 'command_execution=0\nall_tools=0\n'
    printf 'rate_limit=0\ncodex_completed=0\ncodex_failed=0\ngemini_success=0\n'
    return
  }
  if [ -n "$prompt_path" ] && [ -f "$prompt_path" ]; then
    python3 "$SCRIPT_ROOT/lib/audit_helpers.py" finish-fields "$file" "$backend" --prompt "$prompt_path" 2>/dev/null || {
      printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
      printf 'command_execution=0\nall_tools=0\n'
      printf 'rate_limit=\ncodex_completed=\ncodex_failed=\ngemini_success=\n'
    }
  else
    python3 "$SCRIPT_ROOT/lib/audit_helpers.py" finish-fields "$file" "$backend" 2>/dev/null || {
      printf 'total_tokens=\ninput_tokens=\ncached_input_tokens=\ncache_creation_input_tokens=\noutput_tokens=\nduration_ms=\n'
      printf 'command_execution=0\nall_tools=0\n'
      printf 'rate_limit=\ncodex_completed=\ncodex_failed=\ngemini_success=\n'
    }
  fi
}

# Total tool invocations across all tools (any name). Used for richer
# observability than command_execution alone (which only counts shells).
extract_total_tool_uses() {
  local file="$1"
  [ -f "$file" ] || { echo 0; return; }
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" count-tools "$file" all_tools 2>/dev/null || echo 0
}

extract_waste_telemetry() {
  local file="$1"
  [ -f "$file" ] || {
    echo 'tool_bytes=0 max_output=0 over8k=0 native_tools=Read:0,Grep:0,Glob:0 top_cmds=none largest="none"'
    return
  }

  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" waste-telemetry "$file" 2>/dev/null \
    || echo 'tool_bytes=0 max_output=0 over8k=0 native_tools=Read:0,Grep:0,Glob:0 top_cmds=error largest="parser-error"'
}

write_session_log_summary() {
  local rawfile="$1"
  local logfile="$2"
  # summary.json was previously written here too, but every byte of it is
  # already in the index.jsonl row (verified field-by-field). Dropped to
  # eliminate the duplicate-write file-count tax. Callers that still need
  # one-session-per-file can `jq 'select(.files.log==...)' index.jsonl`.
  local summary_md="$3"
  local index_jsonl="$4"
  local role="$5"
  local agent_num="$6"
  local backend="$7"
  local model="$8"
  local mode="$9"
  local exit_code="${10}"
  local prompt_tokens="${11}"
  local input_tokens="${12}"
  local cached_input_tokens="${13}"
  local output_tokens="${14}"
  local total_tokens="${15}"
  local duration_ms="${16}"
  local command_count="${17}"
  local tool_uses="${18}"
  local waste_telemetry="${19}"
  local cache_creation_tokens="${20:-}"

  [ -f "$rawfile" ] || return 0
  [ -f "${SCRIPT_ROOT:-}/lib/audit_log_summary.py" ] || return 0

  # Pull the build-time prompt metadata stashed by write_prompt_artifacts.
  # Missing stash (e.g., on resume sessions where the stash was never
  # written) leaves these fields empty in the index row.
  local stash="${LOGDIR:-}/.prompt_meta_${agent_num}"
  local stash_subsystem="" stash_suggested="" stash_strategy="" stash_launch=""
  local stash_prompt_tokens_build=""
  if [ -f "$stash" ]; then
    local stash_key stash_value
    while IFS='=' read -r stash_key stash_value; do
      case "$stash_key" in
        subsystem) stash_subsystem="$stash_value" ;;
        suggested_subsystem) stash_suggested="$stash_value" ;;
        strategy) stash_strategy="$stash_value" ;;
        launch) stash_launch="$stash_value" ;;
        prompt_tokens_est) stash_prompt_tokens_build="$stash_value" ;;
      esac
    done < "$stash"
  fi

  local print_waste=0
  [ -z "$waste_telemetry" ] && print_waste=1

  SESSION_SUMMARY_TARGET="${TARGET_SLUG:-}" \
  SESSION_SUMMARY_ROLE="$role" \
  SESSION_SUMMARY_AGENT="$agent_num" \
  SESSION_SUMMARY_BACKEND="$backend" \
  SESSION_SUMMARY_MODEL="$model" \
  SESSION_SUMMARY_MODE="$mode" \
  SESSION_SUMMARY_EXIT="$exit_code" \
  SESSION_SUMMARY_PROMPT_TOKENS="$prompt_tokens" \
  SESSION_SUMMARY_PROMPT_TOKENS_BUILD="$stash_prompt_tokens_build" \
  SESSION_SUMMARY_INPUT_TOKENS="$input_tokens" \
  SESSION_SUMMARY_CACHED_INPUT_TOKENS="$cached_input_tokens" \
  SESSION_SUMMARY_CACHE_CREATION_TOKENS="$cache_creation_tokens" \
  SESSION_SUMMARY_OUTPUT_TOKENS="$output_tokens" \
  SESSION_SUMMARY_TOTAL_TOKENS="$total_tokens" \
  SESSION_SUMMARY_DURATION_MS="$duration_ms" \
  SESSION_SUMMARY_COMMANDS="$command_count" \
  SESSION_SUMMARY_TOOLS="$tool_uses" \
  SESSION_SUMMARY_WASTE="$waste_telemetry" \
  SESSION_SUMMARY_PRINT_WASTE="$print_waste" \
  SESSION_SUMMARY_SUBSYSTEM="$stash_subsystem" \
  SESSION_SUMMARY_SUGGESTED_SUBSYSTEM="$stash_suggested" \
  SESSION_SUMMARY_STRATEGY="$stash_strategy" \
  SESSION_SUMMARY_LAUNCH="$stash_launch" \
  python3 "$SCRIPT_ROOT/lib/audit_log_summary.py" \
    "$rawfile" "$logfile" "$summary_md" "$index_jsonl" 2>/dev/null || true
}

# ─── Log recovery for failed sessions ─────────��───────────────────
# When --output-last-message fails (e.g., Codex SDK crash), recover
# partial output from the raw JSON stream so we have observability.

recover_log_from_raw() {
  local logfile="$1"
  local rawfile="$(audit_raw_path "$logfile")"

  # Nothing to recover from
  [ -f "$rawfile" ] || return 0
  # Log already exists and is non-empty — no recovery needed
  [ -f "$logfile" ] && [ -s "$logfile" ] && return 0

  log "Codex did not write its --output-last-message file as expected — reconstructing the agent's final assistant message from the raw JSON stream so the session log isn't lost" | tee -a "$INDEX"
  # Extract assistant text from supported raw JSONL streams. Codex emits
  # item.agent_message; Claude emits assistant message.content text
  # blocks. The gemini backend (Antigravity CLI) emits plain text — the
  # raw file *is* the assistant message and no JSON extraction is needed.
  jq -Rr '
    fromjson? |
    (
      select(.item.type? == "agent_message") | .item.text // empty
    ),
    (
      select(.type? == "message" and .role? == "assistant") | .content // empty
    ),
    (
      select(.type? == "assistant") |
      .message.content[]? |
      select(.type? == "text") |
      .text // empty
    )
  ' "$rawfile" 2>/dev/null > "${logfile}.recovered" || true

  if [ -s "${logfile}.recovered" ]; then
    mv "${logfile}.recovered" "$logfile"
  else
    # Fallback: grab last few lines of raw output for debugging
    tail -20 "$rawfile" > "$logfile" 2>/dev/null || true
    rm -f "${logfile}.recovered"
  fi
}

# ─── Subsystem blocklist & per-subsystem streak tracking ─────────
# The global MAX_DRY_SESSIONS counter can't distinguish "agent stuck on one
# subsystem" from "codebase genuinely exhausted." We track dry sessions per
# subsystem so rotation kicks in even if the global counter resets.
#
# The blocklist is a fail-closed list of subsystem prefixes agents must not
# audit. Prompts inject it, prompt builders exclude these from target lists,
# and build_rotation_directive sees which subsystem the agent is on and bounces
# them out if blocklisted.

load_blocklist() {
  # Start with defaults. An audit owner can append lines to
  # $RESULTS_DIR/.subsystem_blocklist (one prefix per line) for persistent
  # additions observed at runtime (e.g., guard-saturation auto-promotions).
  local blocklist=()
  local p
  for p in "${SUBSYSTEM_BLOCKLIST_DEFAULT[@]:-}"; do
    [ -n "$p" ] && blocklist+=("$p")
  done
  if [ -n "${SUBSYSTEM_BLOCKLIST_FILE:-}" ] && [ -f "$SUBSYSTEM_BLOCKLIST_FILE" ]; then
    while IFS= read -r line; do
      line="${line%%#*}"
      line="${line## }"; line="${line%% }"
      [ -n "$line" ] && blocklist+=("$line")
    done < "$SUBSYSTEM_BLOCKLIST_FILE"
  fi
  [ "${#blocklist[@]}" -gt 0 ] && printf '%s\n' "${blocklist[@]}"
}

subsystem_is_blocklisted() {
  local subsystem="$1"
  [ -z "$subsystem" ] && return 1
  [ "$subsystem" = "unknown" ] && return 1
  local entry
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    # Prefix match: entry "js/src" matches "js/src", "js/src/jit", etc.
    case "$subsystem" in
      "$entry"|"$entry"/*) return 0 ;;
    esac
  done < <(load_blocklist)
  return 1
}

blocklist_description() {
  # Render blocklist as a comma-separated list for prompt injection.
  local entries=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && entries+=("$line")
  done < <(load_blocklist)
  local IFS=', '
  [ "${#entries[@]}" -gt 0 ] && echo "${entries[*]}" || echo ""
}

subsystem_dry_streak_path() {
  local subsystem="$1"
  # Slashes → underscores for filename safety
  local slug
  slug=$(printf '%s' "$subsystem" | tr '/' '_')
  printf '%s/.subsystem_dry_%s' "$RESULTS_DIR" "$slug"
}

get_subsystem_dry_streak() {
  local subsystem="$1"
  local f
  f=$(subsystem_dry_streak_path "$subsystem")
  if [ -f "$f" ]; then cat "$f" 2>/dev/null || echo 0; else echo 0; fi
}

bump_subsystem_dry_streak() {
  local subsystem="$1"
  local delta="${2:-1}"
  [ -z "$subsystem" ] && return 0
  [ "$subsystem" = "unknown" ] && return 0
  local f
  f=$(subsystem_dry_streak_path "$subsystem")
  local n
  n=$(get_subsystem_dry_streak "$subsystem")
  n=$((n + delta))
  printf '%s' "$n" > "$f"
}

reset_subsystem_dry_streak() {
  local subsystem="$1"
  [ -z "$subsystem" ] && return 0
  local f
  f=$(subsystem_dry_streak_path "$subsystem")
  rm -f "$f" 2>/dev/null || true
}

# ─── Per-agent strategy tracking ─────────────────────────────────
# Track which strategy each agent is using and how many dry iterations
# they've spent on it. When the streak hits STRATEGY_DRY_STREAK_THRESHOLD,
# the prompt system forces rotation to the next strategy in priority order.

agent_strategy_path() {
  local agent_num="$1"
  printf '%s/.agent_strategy_%s' "$RESULTS_DIR" "$agent_num"
}

agent_strategy_streak_path() {
  local agent_num="$1"
  printf '%s/.agent_strategy_streak_%s' "$RESULTS_DIR" "$agent_num"
}

# Read current strategy for an agent from its state file's "Strategies Applied"
# or "Strategy" column in hypothesis table, falling back to the tracking file.
get_agent_strategy() {
  local agent_num="$1"
  if [ -n "${AUDIT_FIXED_STRATEGY:-}" ]; then
    echo "$AUDIT_FIXED_STRATEGY"
    return
  fi
  local track_file track_strategy
  track_file=$(agent_strategy_path "$agent_num")
  if [ -f "$track_file" ]; then
    track_strategy=$(cat "$track_file" 2>/dev/null || true)
    track_strategy=$(printf '%s' "$track_strategy" | grep -oE '^(S[0-9]+|REF)' | head -1 || true)
    if [ -n "$track_strategy" ] && declare -F count_active_hypotheses_for_agent >/dev/null 2>&1; then
      local active_count
      active_count=$(count_active_hypotheses_for_agent "$agent_num" 2>/dev/null || echo "")
      if [[ "$active_count" =~ ^[0-9]+$ ]] && [ "$active_count" -eq 0 ]; then
        echo "$track_strategy"
        return
      fi
    fi
  fi

  local structured_strategy
  structured_strategy=$(structured_state_latest_strategy "$agent_num" 2>/dev/null || true)
  structured_strategy=$(printf '%s' "$structured_strategy" | grep -oE '^(S[0-9]+|REF)' | head -1 || true)
  [ -n "$structured_strategy" ] && { echo "$structured_strategy"; return; }

  local sf
  sf=$(state_file_path "$agent_num")

  # Primary source: most recent non-DISCARDED hypothesis Strategy column.
  # Table: | # | Hypothesis | File | Input | Guard | Diagnostic | Strategy | Status |
  #        $1   $2           $3     $4      $5      $6           $7         $8       $9
  if [ -f "$sf" ]; then
    local strat
    strat=$(awk -F'|' '
      /^## Current Hypothesis Queue/ { in_q=1; next }
      /^## / && in_q { exit }
      in_q && /^\| / {
        strat = $8
        status = $9
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", strat)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", status)
        if (strat == "" || strat == "Strategy" || status == "DISCARDED") next
        last = strat
      }
      END { if (last != "") print last }
    ' "$sf" 2>/dev/null || true)
    # Normalize: extract the strategy ID (e.g., "S1" from "S1-prior-fix-review")
    strat=$(printf '%s' "$strat" | grep -oE '^(S[0-9]+|REF)' | head -1 || true)
    [ -n "$strat" ] && { echo "$strat"; return; }
  fi

  # Fallback: tracking file written by the harness
  if [ -n "${track_strategy:-}" ]; then
    echo "$track_strategy"
    return
  fi
  # P4: cold-start default. The old "S1" default wedged every fresh
  # agent on Prior-fix-review (the bucket most prone to memory-driven
  # auto-discard and structurally the thinnest tier). Load-weighted
  # pick across the live queue, with fan-out across families, gives
  # the agent a meaningful strategy from the first iteration.
  # Opt-out via AUDIT_COLD_START_STRATEGY=S1 (or any other strategy
  # letter) for benchmarks or experiments that want the old behaviour.
  if [ -n "${AUDIT_COLD_START_STRATEGY:-}" ]; then
    printf '%s\n' "$AUDIT_COLD_START_STRATEGY"
    return
  fi
  if declare -F pick_cold_start_strategy >/dev/null 2>&1; then
    pick_cold_start_strategy "$agent_num"
    echo
    return
  fi
  echo "S1"  # last-resort default when picker isn't loaded yet
}

set_agent_strategy() {
  local agent_num="$1" strategy="$2"
  if [ -n "${AUDIT_FIXED_STRATEGY:-}" ]; then
    strategy="$AUDIT_FIXED_STRATEGY"
  fi
  printf '%s' "$strategy" > "$(agent_strategy_path "$agent_num")"
}

get_agent_strategy_streak() {
  local agent_num="$1"
  local f
  f=$(agent_strategy_streak_path "$agent_num")
  if [ -f "$f" ]; then cat "$f" 2>/dev/null || echo 0; else echo 0; fi
}

bump_agent_strategy_streak() {
  local agent_num="$1"
  local f n
  f=$(agent_strategy_streak_path "$agent_num")
  n=$(get_agent_strategy_streak "$agent_num")
  n=$((n + 1))
  printf '%s' "$n" > "$f"
}

reset_agent_strategy_streak() {
  local agent_num="$1"
  rm -f "$(agent_strategy_streak_path "$agent_num")" 2>/dev/null || true
}

# Read the per-strategy completion status for `agent_num` on `strategy`
# from notes.jsonl. Returns the JSON status row on stdout (always — even
# when the floor is met). The exit code is 0 when complete, 1 when not,
# 2 on error. Caller is expected to parse with `jq`. The Python helper
# is exported via `bin/state strategy-status` so any consumer can ask
# the same question without re-implementing the heuristics.
strategy_completion_for_agent() {
  local agent_num="$1" strategy="$2"
  [ -x "bin/state" ] || { echo '{"complete": true, "evidence": 0, "threshold": 0}'; return 0; }
  bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
    strategy-status --agent "$agent_num" --strategy "$strategy" 2>/dev/null
}

strategy_completion_fields() {
  local status_json="$1"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "$status_json" | jq -r '
      [
        (if has("complete") then .complete else true end),
        (.evidence // "?"),
        (.threshold // "?")
      ] | @tsv
    ' 2>/dev/null && return 0
  fi
  printf 'true\t?\t?\n'
}

# Given the current strategy letter, return the next one in STRATEGY_ROTATION_ORDER.
next_strategy_in_rotation() {
  local current="$1"
  local found=0
  local first=""
  for s in "${STRATEGY_ROTATION_ORDER[@]}"; do
    [ -z "$first" ] && first="$s"
    if [ "$found" -eq 1 ]; then
      echo "$s"
      return
    fi
    [ "$s" = "$current" ] && found=1
  done
  # Wrap around to first, or return S2 if current wasn't in the list
  echo "${first:-S2}"
}

# LLM strategy picker. Reads ROI summary + current state, returns one of
# S1..S7. Empty stdout means LLM unavailable / refused — caller falls back
# to next_strategy_in_rotation.
llm_pick_next_strategy() {
  local agent_num="$1" current="$2" subsystem="${3:-unknown}" streak="${4:-?}"
  declare -f llm_decide >/dev/null 2>&1 || return 1

  local roi_block=""
  local roi_file="${RESULTS_DIR:-}/strategy-roi.md"
  if [ -f "$roi_file" ] && [ -s "$roi_file" ]; then
    roi_block=$(awk '
      /^- [A-Z]+:/ {
        strat = $2; sub(/:$/, "", strat)
        total[strat] += ($3 + 0)
      }
      END {
        for (s in total) print "- " s ": " total[s] " finding(s)"
      }
    ' "$roi_file" | sort -k3 -rn 2>/dev/null)
  fi
  [ -n "$roi_block" ] || roi_block="(no findings yet this session)"

  local recent_log_block=""
  if [ -f "${INDEX:-}" ]; then
    recent_log_block=$(grep -E 'STRATEGY_ROTATION|CRASH-|FIND-|GUARD_SATURATION' "$INDEX" 2>/dev/null \
      | tail -10)
  fi
  [ -n "$recent_log_block" ] || recent_log_block="(no events)"

  local target_slug="${TARGET_SLUG:-unknown}"
  local target_kind="generic"
  [ "${IS_BROWSER_TARGET:-0}" = "1" ] && target_kind="browser"

  local prompt
  prompt=$(render_prompt_template strategy_picker.md.j2 \
    --var "target_slug=${target_slug}" \
    --var "target_kind=${target_kind}" \
    --var "agent_num=${agent_num}" \
    --var "current_strategy=${current}" \
    --var "subsystem=${subsystem}" \
    --var "streak=${streak}" \
    --var "roi_block=${roi_block}" \
    --var "recent_log_block=${recent_log_block}")

  local json
  json=$(printf '%s' "$prompt" | llm_decide strategy_pick "strategy,reason" 12) || return 1
  local picked reason
  picked=$(printf '%s' "$json" | jq -r '.strategy' 2>/dev/null)
  reason=$(printf '%s' "$json" | jq -r '.reason // ""' 2>/dev/null | tr '\n\t' '  ')
  case "$picked" in
    S1|S2|S3|S4|S5|S6|S7|S8) printf '%s\t%s' "$picked" "$reason"; return 0 ;;
    *) return 1 ;;
  esac
}

# Map strategy letter to its reference filename.
# 8 strategies + 1 pattern reference (REF). Unknown letters return empty.
strategy_file_for_letter() {
  local letter="$1"
  case "$letter" in
    S1)  echo "S1-prior-fix-review.md";;
    S2)  echo "S2-assert-negation.md";;
    S3)  echo "S3-spec-vs-impl.md";;
    S4)  echo "S4-differential.md";;
    S5)  echo "S5-reentrancy.md";;
    S6)  echo "S6-cross-project.md";;
    S7)  echo "S7-fuzz-improvement.md";;
    S8)  echo "S8-property-based.md";;
    REF) echo "REF-pattern-search.md";;
    *)  echo "";;
  esac
}

# ─── Wall-clock subsystem tenure tracker ──────────────────────────
# Track how long each agent has been working on the same subsystem.
# When cumulative time exceeds SUBSYSTEM_TENURE_CAP_SECS (8h default),
# inject a strong rotation advisory. Prevents 20+ hour dead-end spirals
# where an agent is "disciplined" enough to write testcases but never
# finds anything.
SUBSYSTEM_TENURE_CAP_SECS="${SUBSYSTEM_TENURE_CAP_SECS:-28800}"  # 8 hours

agent_tenure_path() {
  local agent_num="$1"
  printf '%s/.subsystem_tenure_%s' "$RESULTS_DIR" "$agent_num"
}

# Record when an agent started working on its current subsystem.
# Called after each iteration; only writes if subsystem changed.
update_agent_tenure() {
  local agent_num="$1"
  local f
  f=$(agent_tenure_path "$agent_num")
  local current_sub
  current_sub=$(get_agent_subsystem "$agent_num" 2>/dev/null || echo "unknown")
  [ "$current_sub" = "unknown" ] && return 0
  if [ -f "$f" ]; then
    local stored_sub
    stored_sub=$(head -1 "$f" 2>/dev/null | awk '{print $1}')
    if [ "$stored_sub" = "$current_sub" ]; then
      return 0  # same subsystem, keep the original timestamp
    fi
  fi
  # New subsystem or first time — record subsystem + start timestamp
  printf '%s %s\n' "$current_sub" "$(date +%s)" > "$f"
}

# Get elapsed seconds on current subsystem. Returns 0 if no record.
get_agent_tenure_secs() {
  local agent_num="$1"
  local f
  f=$(agent_tenure_path "$agent_num")
  [ -f "$f" ] || { echo 0; return; }
  local start_ts
  start_ts=$(head -1 "$f" 2>/dev/null | awk '{print $2}')
  [ -n "$start_ts" ] || { echo 0; return; }
  local now
  now=$(date +%s)
  echo $(( now - start_ts ))
}


# ─── Guard-chain tracker ──────────────────────────────────────────
# When every testcase in a subsystem dies with the same upstream guard string
# ("Error: regexp too big", "too much recursion", "TypeError: invalid range"),
# that's the guard that needs an input path past it — not individual hypotheses. We
# scan new ASan outputs in each scratch dir, extract the first error/diagnostic
# line, and count repeats per subsystem. When a single guard hits the threshold
# we surface it as a meta-hypothesis. This is non-destructive: the prompt asks
# for a bypass path, guard audit, or manual rotation, but the harness does not
# auto-blocklist the subsystem.

guard_chain_path() {
  local subsystem="$1"
  local slug
  slug=$(printf '%s' "$subsystem" | tr '/' '_')
  printf '%s/.guard_chain_%s' "$RESULTS_DIR" "$slug"
}

# Comprehensive regex matching upstream-guard / early-failure diagnostic
# lines across target families. Shapes:
#   *Error / *Exception        → JS engines (Type/Range/Reference/URI/...),
#                                DOM exceptions (NotSupported, QuotaExceeded,
#                                InvalidState, …), Java/Python style
#   ALLCAPS macro_(ERR|ERROR|FAIL)  → NS_ERROR_*, SSL_ERROR_*, Z_*_ERROR,
#                                XML_ERROR_*, EVP_*_ERR, …
#   error -?N                  → pcre2-style numeric codes
#   error:HHHHHH:…             → OpenSSL stack-encoded errors
#   <encoding|format> error:   → UTF-8 / Pattern conversion / JSON / XML / YAML
#   {error,Error,ERROR,warning,fatal}:  → generic compiler/library prefix
#   {Failed to,Cannot,Unable to,Could not,Unrecognized,Invalid,Unsupported,
#    Unknown,Illegal,Malformed,Corrupted}  → diagnostic verbs
#   bare emergency phrases     → too much recursion / out of memory / …
#
# We pre-strip lines starting with `#` (testcase metadata, pcre2test
# comments, ASan stack frames `#0 0x…`) and `//` (C/C++ comments) so prose
# mentions of "error" in a benign clean run cannot match.
GUARD_DIAGNOSTIC_REGEX='([A-Z][A-Za-z0-9_]*(Error|Exception)\b[^[:cntrl:]]{0,160}|[A-Z][A-Z0-9_]{2,}_(ERR|ERROR|FAIL)[A-Z0-9_]*|error -?[0-9]+[^[:cntrl:]]{0,160}|error:[0-9A-Fa-f]{6,}:[^[:cntrl:]]{0,160}|(UTF-?8|Pattern conversion|Encoding|JSON|XML|YAML) error:[^[:cntrl:]]{0,160}|(error|Error|ERROR|warning|Warning|WARN|fatal|FATAL): [^[:cntrl:]]{1,160}|(Failed to|Cannot|Unable to|Could not|Unrecognized|Invalid|Unsupported|Unknown|Illegal|Malformed|Corrupted) [a-zA-Z][^[:cntrl:]]{1,160}|too much recursion|regexp too big|out of memory|stack overflow|assertion failed|segmentation fault|integer overflow|division by zero)'

# Scan this iteration's new ASan output files and record which upstream guard
# (if any) blocked the testcase from reaching a real crash. Call once per
# iteration AFTER agents exit.
record_iteration_guard_chain() {
  for i in $(seq 1 "$NUM_AGENTS"); do
    local d
    d=$(scratch_dir_path "$i")
    [ -d "$d" ] || continue
    local subsystem
    subsystem=$(get_agent_subsystem "$i")
    [ "$subsystem" = "unknown" ] && continue
    local gpath
    gpath=$(guard_chain_path "$subsystem")
    # Look at .txt files newer than COUNTER_FILE (this iteration's outputs).
    local f
    for f in "$d"/*.txt; do
      [ -f "$f" ] || continue
      [ "$f" -nt "$COUNTER_FILE" ] || continue
      # Skip files that actually crashed — those aren't guard-blocked.
      if grep -q "ERROR: AddressSanitizer" "$f" 2>/dev/null; then
        continue
      fi
      # Extract first diagnostic line via comprehensive regex. We bound the
      # scan to the head of the file (real guards appear early — runs that
      # reach the intended path produce normal output further down) and
      # skip comment / stack-frame lines so benign prose can't match.
      local guard
      guard=$(head -n 200 "$f" 2>/dev/null \
        | grep -vE '^[[:space:]]*(#|//)' \
        | grep -oE "$GUARD_DIAGNOSTIC_REGEX" \
        | head -1 || true)
      if [ -n "$guard" ]; then
        printf '%s\n' "$guard" >> "$gpath"
      fi
    done
  done
}

# Returns the most-frequent guard in the given subsystem IF it has hit the
# rotation threshold; prints "<count>:<guard>". Empty output = no saturation.
detect_guard_saturation() {
  local subsystem="$1"
  local gpath
  gpath=$(guard_chain_path "$subsystem")
  [ -f "$gpath" ] || return 0
  # Count unique guards, take the top one
  local top_line
  top_line=$(sort "$gpath" 2>/dev/null | uniq -c | sort -rn | head -1)
  [ -z "$top_line" ] && return 0
  local count guard
  count=$(awk '{print $1}' <<<"$top_line")
  guard=$(awk '{ $1=""; sub(/^ +/,""); print }' <<<"$top_line")
  if [ "${count:-0}" -ge "$GUARD_CHAIN_ROTATION_THRESHOLD" ]; then
    printf '%s:%s' "$count" "$guard"
  fi
}

guard_saturation_slug() {
  printf '%s' "$1" | tr -cs '[:alnum:]._-' '-'
}

guard_saturation_action_path() {
  printf '%s/.guard_saturation_%s' "$RESULTS_DIR" "$(guard_saturation_slug "$1")"
}

guard_saturated_subsystems_path() {
  printf '%s/.guard_saturated_subsystems' "$RESULTS_DIR"
}

record_guard_saturation_action() {
  local subsystem="$1" guard="$2" f prev_guard prev_count
  f=$(guard_saturation_action_path "$subsystem")
  prev_guard=$(sed -n '1p' "$f" 2>/dev/null || true)
  prev_count=$(sed -n '2p' "$f" 2>/dev/null || true)
  case "$prev_count" in ''|*[!0-9]*) prev_count=0 ;; esac
  if [ "$prev_guard" = "$guard" ]; then
    prev_count=$((prev_count + 1))
  else
    prev_count=1
  fi
  {
    printf '%s\n' "$guard"
    printf '%s\n' "$prev_count"
    date +%s
  } > "$f" 2>/dev/null || true
  printf '%s\n' "$prev_count"
}

append_guard_bypass_card() {
  local subsystem="$1" guard="$2" work_file id now id_hash
  work_file=$(work_cards_path)
  mkdir -p "$(dirname "$work_file")" 2>/dev/null || true
  id_hash=$(printf '%s:%s:%s' "$TARGET_SLUG" "$subsystem" "$guard" \
    | audit_sha1 2>/dev/null \
    | awk '{print substr($1,1,12)}')
  [ -n "$id_hash" ] || id_hash="$(date +%s)"
  id="GUARD-${id_hash}"
  if grep -q "\"id\": \"$id\"" "$work_file" 2>/dev/null; then
    return 0
  fi
  now=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" append-guard-card \
    "$work_file" "$id" "$TARGET_SLUG" "$subsystem" "$guard" "$now" || return 0
}

mark_guard_saturated_subsystem() {
  local subsystem="$1" f
  f=$(guard_saturated_subsystems_path)
  mkdir -p "$(dirname "$f")" 2>/dev/null || true
  grep -Fxq "$subsystem" "$f" 2>/dev/null && return 0
  printf '%s\n' "$subsystem" >> "$f" 2>/dev/null || true
}

unmark_guard_saturated_subsystem() {
  local subsystem="$1" f tmp
  f=$(guard_saturated_subsystems_path)
  [ -f "$f" ] || return 0
  tmp="${f}.tmp.$$"
  grep -Fxv "$subsystem" "$f" > "$tmp" 2>/dev/null || true
  mv "$tmp" "$f" 2>/dev/null || rm -f "$tmp"
}

# ─── Preflight harness smoke test ──────────────────────────────────
# Before agents spawn, verify that the ASan harness actually captures traces.
# This catches silently broken builds where agents would write 100+ testcases,
# see "no crash," and waste a full session. Only runs for browser targets — the
# generic path doesn't assume a specific sanitizer harness.

preflight_harness_check() {
  [ "$IS_BROWSER_TARGET" -eq 1 ] || return 0

  local canary_dir canary_js canary_out
  canary_dir="$RESULTS_DIR/.preflight"
  mkdir -p "$canary_dir"
  canary_js="$canary_dir/canary.js"
  canary_out="$canary_dir/canary-asan.txt"

  # Tiny JS that MUST print the sentinel if the harness runs at all.
  cat > "$canary_js" <<'JS_CANARY'
print('TESTCASE_EXECUTED');
JS_CANARY

  local asan_5x="bin/run-asan-multi"
  [ -x "$asan_5x" ] || { log "PREFLIGHT WARN: $asan_5x not executable — skipping harness check" | tee -a "$INDEX"; return 0; }

  # Single run is enough for a sentinel check; 5x would triple startup overhead.
  ASAN_RUNS=1 ASAN_OUTPUT_FILE="$canary_out" \
    "$asan_5x" js "$canary_js" >/dev/null 2>&1 || true

  if [ ! -s "$canary_out" ]; then
    log "PREFLIGHT FATAL: the ASan harness canary produced no output at all — the sanitizer wrapper appears silent. Agents would write hundreds of testcases without ever seeing a sanitizer trace, so the audit cannot start." | tee -a "$INDEX"
    log "PREFLIGHT FATAL: fix bin/run-asan or re-run 'ff-bsan asan' to rebuild the sanitizer toolchain before retrying." | tee -a "$INDEX"
    return 1
  fi
  if ! grep -q "TESTCASE_EXECUTED" "$canary_out" 2>/dev/null; then
    log "PREFLIGHT FATAL: the ASan canary ran but its 'TESTCASE_EXECUTED' sentinel never appeared in the output — the JavaScript shell or harness wrapper looks broken." | tee -a "$INDEX"
    log "PREFLIGHT FATAL: first 20 lines of the canary output (full file at ${canary_out}):" | tee -a "$INDEX"
    head -20 "$canary_out" | sed 's/^/  /' | tee -a "$INDEX"
    return 1
  fi
  log "PREFLIGHT OK: the ASan harness canary ran successfully and the sanitizer captured its output — agent launches can begin." | tee -a "$INDEX"
  return 0
}

# ─── Preflight: ensure the native ASan build matches the source ────
# bin/audit owns the build lazily: if the checkout moved since build-asan was
# compiled (an upstream pull or local edit), agents would silently audit the
# wrong binary, because the prompt tells them not to rebuild. So before agents
# spawn we (re)build a missing or stale native ASan tree via setup-target
# --build, reusing the same freshness probe + stamp setup-target writes.
#
# Fail-open by design: not every target has a convergeable ASan recipe
# (language targets build via cargo/go/pip; some are audited read-only), so a
# build that can't run or fails must WARN and let the audit proceed — agents
# treat a missing/stale artifact as ENV-BLOCKED. The probe returns "skip" for
# browsers (handled by the canary above + ff-bsan) and non-native build
# systems, so this is a no-op there.
preflight_build_freshness() {
  [ "$IS_BROWSER_TARGET" -eq 1 ] && return 0
  local state
  state="$(python3 "$SCRIPT_ROOT/lib/target_config.py" \
             build-freshness "$TARGET_ROOT" asan 2>/dev/null || echo skip)"
  case "$state" in
    fresh)
      # Build is current, so the rebuild path (setup-target, where .dSYMs are
      # generated) is skipped — ensure them here too, for every enabled
      # sanitizer build. On macOS the offline symbolizer needs a .dSYM to
      # resolve library crash frames to file:line. Idempotent; best-effort;
      # no-op on Linux. Stale/missing fall through to setup-target below, which
      # generates .dSYMs after building.
      audit_make_dsyms_for_target "$TARGET_ROOT" >/dev/null 2>&1 || true
      return 0 ;;
    skip) return 0 ;;
  esac
  log "PREFLIGHT: native ASan build is '${state}' relative to source — (re)building via bin/setup-target --build before agents start (fail-open: the audit proceeds even if this cannot complete)" | tee -a "$INDEX"
  local build_log="${LOGDIR:-$RESULTS_DIR}/setup-build.log"
  "$SCRIPT_ROOT/bin/setup-target" "$TARGET_SLUG" --build >> "$build_log" 2>&1 || true
  # Re-probe rather than trust the exit status: `setup-target --build` exits 0
  # even when it skips recipe convergence (no LLM backend) or a materialize
  # fails, so a 0 does not mean a fresh build exists. Only claim success when
  # freshness actually confirms it.
  local after
  after="$(python3 "$SCRIPT_ROOT/lib/target_config.py" \
             build-freshness "$TARGET_ROOT" asan 2>/dev/null || echo skip)"
  case "$after" in
    fresh|skip)
      log "PREFLIGHT: ASan build refreshed (log: $build_log)" | tee -a "$INDEX" ;;
    *)
      log "PREFLIGHT WARN: ASan build is still '${after}' after auto-build (see $build_log); agents will treat missing/stale artifacts as ENV-BLOCKED — audit continues" | tee -a "$INDEX" ;;
  esac
  return 0
}

# Validate required external tools before doing anything expensive.
_missing_tools=()
for _tool in jq python3; do
  command_exists "$_tool" || _missing_tools+=("$_tool")
done
if [ "${#_missing_tools[@]}" -gt 0 ]; then
  log "FATAL: missing required tool(s): ${_missing_tools[*]}" >&2
  log "Install them before running the audit harness." >&2
  exit 1
fi
unset _missing_tools _tool

init_backend_selection
apply_backend_decision_timeout_defaults

# --new-target: seed output/<slug>/target.toml then exit. Used to bootstrap
# a brand-new target before running the first audit session.
if [ -n "$NEW_TARGET_SLUG" ]; then
  _nt_root="$SCRIPT_ROOT/targets/$NEW_TARGET_SLUG"
  [ -d "$_nt_root" ] || { log "FATAL: targets/$NEW_TARGET_SLUG not found" >&2; exit 1; }
  _nt_out="$SCRIPT_ROOT/output/$NEW_TARGET_SLUG/target.toml"
  if [ -f "$_nt_out" ] && [ -z "${FORCE:-}" ]; then
    log "$_nt_out already exists. Set FORCE=1 to overwrite." >&2
    exit 1
  fi
  target_seed_toml "$_nt_root" "$_nt_out" ""

  # LLM bootstrap: replace the conservative seed defaults with a real
  # starting [threat_model] and [s6_peers] so a fresh target does not begin
  # an audit byte-only / peerless. Best-effort — target_seed_toml already
  # wrote valid values, so a missing backend (rc 2/3) or an already-curated
  # section (rc 4) is non-fatal: we log and keep the seed. The helpers write
  # their own "review this" comment into target.toml. Skipped when LLM
  # decisions are disabled, or via AUDIT_NEW_TARGET_BOOTSTRAP=0.
  if [ "${AUDIT_NEW_TARGET_BOOTSTRAP:-1}" != "0" ] && [ "${LLM_DECIDE_DISABLE:-0}" != "1" ]; then
    for _nt_helper in suggest-threat-model suggest-peers; do
      _nt_rc=0
      "$SCRIPT_ROOT/bin/$_nt_helper" "$NEW_TARGET_SLUG" --apply || _nt_rc=$?
      case "$_nt_rc" in
        0) log "new-target: bootstrapped ${NEW_TARGET_SLUG} via ${_nt_helper}" ;;
        4) log "new-target: ${_nt_helper} — target.toml already has a curated section; kept as-is" ;;
        *) log "new-target: ${_nt_helper} bootstrap skipped (rc=${_nt_rc}); conservative seed kept — run 'bin/${_nt_helper} ${NEW_TARGET_SLUG}' once a backend is configured" ;;
      esac
    done
  fi

  log "Wrote a starter target config at ${_nt_out} — review and edit the asan_bin / asan_lib / link_libs fields (and anything marked FILL_ME), and sanity-check the LLM-suggested [threat_model] / [s6_peers] sections, before running 'bin/audit --target ${NEW_TARGET_SLUG}' for real."
  exit 0
fi

