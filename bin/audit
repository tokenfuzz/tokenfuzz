# Backend selection must precede any `tee -a "$INDEX"` — configure_active_backend
# is what assigns LOGDIR/INDEX. Before this call, INDEX="" (initialized at the
# top of the file) and `tee -a ""` emits `tee: '': No such file or directory`
# on stderr without dropping the line on stdout. The agent-pool log below was
# previously ordered above this call and silently produced that warning on
# every audit start.
configure_active_backend "$ACTIVE_BACKEND"

# Acquire the output-dir instance lock now that LOGDIR is set but before
# any iteration / agent writes to it. Two bin/audit instances writing to
# the same output/<target>/<backend>/ produce corrupted shared state
# (recon-hypotheses.jsonl, work-cards.jsonl, index.log). --allow-concurrent
# overrides this for operators who genuinely understand the trade-off.
audit_acquire_instance_lock

# One consolidated agent-pool decision line. Logged after target
# classification so the message describes the *actual* pool shape the
# audit will run with, not the early defaults.
if target_git_is_shallow_checkout "$TARGET_ROOT"; then
  log "WARN: target git checkout is shallow; S1 prior-fix history and patch-card queues may be incomplete. Run: git -C \"$TARGET_ROOT\" fetch --unshallow" | tee -a "$INDEX"
fi
if [ "$IS_BROWSER_TARGET" -eq 1 ]; then
  log "Agent pool: ${NUM_AGENTS} worker(s) total — ${BROWSER_AGENTS} browser-mode + ${SHELL_AGENTS} shell-mode (browser target: ${TARGET_SLUG}). Set BROWSER_AGENTS / SHELL_AGENTS in the environment to override." | tee -a "$INDEX"
else
  log "Agent pool: flat pool of ${NUM_AGENTS} generic worker(s) (non-browser target). Set NUM_AGENTS in the environment to override." | tee -a "$INDEX"
fi
if [ "$MAX_ITERATIONS" -eq 1 ]; then
  log "Smoke test mode: max_iterations=1 clamps the run to one worker and skips recon seeding." | tee -a "$INDEX"
fi

