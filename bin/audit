  ln -s "../${TARGET_SLUG}/target.toml" "$TARGET_TOML" 2>/dev/null \
    || cp "$TARGET_BASE_TOML" "$TARGET_TOML"
fi

if ! target_load_toml "$TARGET_TOML"; then
  log "FATAL: target config does not parse: $TARGET_TOML" >&2
  log "Run bin/setup-target $TARGET_SLUG after building ASan, then review unresolved fields." >&2
  exit 1
fi
[ "${TARGET_IS_BROWSER:-0}" = "1" ] && IS_BROWSER_TARGET=1

# Generic targets: re-apply the flat pool now that target.toml may have
# flipped IS_BROWSER_TARGET. Keeps the pool consistent with the final
# classification regardless of override order.
if [ "$IS_BROWSER_TARGET" -eq 0 ] && [ "$agent_count_overridden" -eq 0 ]; then
  BROWSER_AGENTS=0
  if [ "$SHELL_AGENTS" -le 0 ]; then SHELL_AGENTS=3; fi
  NUM_AGENTS="$SHELL_AGENTS"
