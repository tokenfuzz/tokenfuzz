state_file_path() {
  local agent_num="$1"
  printf '%s/AUDIT_STATE-%s.md' "$RESULTS_DIR" "$agent_num"
}

# ─── Dead-session streak (structural-signal only) ──────────────────
# Counts consecutive sessions where an agent emitted 0 tool uses (early-exit,
# refusal, SDK failure, watchdog kill before any work). Uses ONLY structural
# signals — tool-use count from raw JSONL, plus structured JSON field strings
# like "stop_reason":"refusal" / "type":"refusal". No English-language refusal
# vocabulary is grepped, so the detector itself cannot trip the safety classifier
# when archived logs/state files are later re-read by an agent.
#
# Threshold: after MAX_DEAD_STREAK consecutive sessions with zero tool use, the
# agent's state file is archived and the agent cold-starts on a fresh subsystem
# next iteration. Default 2 (i.e. one bad no-work session is forgiven, two in a
# row triggers rotation). Refusal markers in sessions that did real tool work
# are logged only; they do not wipe active hypotheses.
MAX_DEAD_STREAK="${MAX_DEAD_STREAK:-2}"

dead_streak_path() {
  local agent_num="$1"
  printf '%s/.dead_streak_%s' "$LOGDIR" "$agent_num"
}

get_dead_streak() {
  local agent_num="$1"
  local f
  f=$(dead_streak_path "$agent_num")
  if [ -f "$f" ]; then cat "$f" 2>/dev/null || echo 0; else echo 0; fi
}

bump_dead_streak() {
  local agent_num="$1"
  local cur
  cur=$(get_dead_streak "$agent_num")
  printf '%s' "$((cur + 1))" > "$(dead_streak_path "$agent_num")" 2>/dev/null || true
}

reset_dead_streak() {
  local agent_num="$1"
  printf '0' > "$(dead_streak_path "$agent_num")" 2>/dev/null || true
}

# Structural refusal signal: count occurrences of structured JSON field strings
# that are emitted by the SDK on refusal, plus the observed "single agent
# message, zero tool items" raw-log shape the browser refusal used on
# This stays structural: it looks at item topology, not English refusal
# prose. Returns 0 or a positive integer.
count_structural_refusal_signals() {
  local raw_log="$1"
  [ -f "$raw_log" ] || { echo 0; return; }
  local log_bytes
  log_bytes=$(wc -c < "$raw_log" 2>/dev/null || echo 999999)
  awk -v log_bytes="${log_bytes:-999999}" '
    /"stop_reason":"refusal"|"type":"refusal"/ { explicit++ }
    /"type":"agent_message"/ { msg++ }
    /"type":"item.started"/ { started++ }
    /"type":"command_execution"|"type":"file_change"|"type":"todo_list"/ { work++ }
    /"type":"error"/ { error++ }
    /"type":"turn.failed"/ { failed++ }
    END {
      if (explicit > 0) {
        print explicit
      } else if (msg == 1 && started == 0 && work == 0) {
        print (log_bytes < 8000 ? 1 : 0)
      } else if (error > 0 && failed > 0) {
        print 1
      } else {
        print 0
      }
    }
  ' "$raw_log" 2>/dev/null || echo 0
}

# Detect API rate limits from the most recent iteration's raw logs.
# Returns 0 (true) if rate-limited, 1 otherwise.
# Stdout format: "<reset_unix_ts>" or "unknown" (429 without a usable resetsAt).
#
# Two-stage detection — must confirm an actual 429 fired before consulting any
# rate_limit_event metadata. The Claude CLI emits informational rate_limit_event
# heartbeats with status="allowed" or "allowed_warning" on every turn; their
# resetsAt is just metadata about the seven_day/five_hour window edges, not a
# signal that a request was rejected. Treating those as rate-limit hits caused
# spurious 30-minute backoffs.
#
# Stage 1 — confirm a provider rejection actually happened:
#   Claude CLI: {"type":"result",...,"api_error_status":429,...}
#   Codex CLI:  {"type":"error","message":"..."} or
#               {"type":"turn.failed","error":{"message":"..."}}
#               with payload containing either "Server returned 429" (legacy)
#               or a JSON-encoded "status":429 (current shape).
#   Gemini/OpenCode/oss: provider stderr or JSON error events containing 429,
#               5xx, quota/capacity, overload, or network-unavailable text.
# Stage 2 — only after a provider rejection, look up the most recent
#   rate_limit_event whose status is NOT allowed/allowed_warning (i.e. an
#   actual rejection) and use its resetsAt. Pick the largest resetsAt across
#   agents — when both five_hour and seven_day windows reject, the later one is
#   when we can safely retry. If a provider only gives text such as "try again
#   at ..." or "reset after ...", parse that as a reset too. Backends without
#   any reset window fall back to the default backoff.

provider_text_reset_at() {
  local logfile="$1"
  python3 "$SCRIPT_ROOT/lib/audit_helpers.py" provider-reset-at "$logfile" 2>/dev/null
}

log_has_rate_limit_rejection() {
  local logfile="$1"
  [ -f "$logfile" ] || return 1
  # Single source of truth for "did the backend reject this iteration?" —
  # 429 (rate limit) and 5xx (500/502/503/529 server overload), across all
  # backends — lives in the Python raw-status parser (extract_raw_status).
  # Delegating here means:
  #   * it JSON-parses events, so a "status:500" / "UNAVAILABLE" string inside
  #     a tool_result (audited program output) is NOT mistaken for a backend
  #     overload, and gemini detection is event-scoped (no false positives);
  #   * no `grep | grep -q` over a large raw log, which under `set -o pipefail`
  #     can SIGPIPE the producer and turn a real match into a false negative.
  # Capture-then-here-string keeps even this 4-line read SIGPIPE-proof, and
  # extract_raw_status already fails open (prints rate_limit=0) on any error.
  local rs
  rs=$(extract_raw_status "$logfile")
  grep -q '^rate_limit=1' <<<"$rs"
}

codex_raw_has_completed_turn() {
  local logfile="$1"
  [ -f "$logfile" ] || return 1
  grep -qF '"type":"turn.completed"' "$logfile" 2>/dev/null
}

codex_raw_has_failed_turn() {
  local logfile="$1"
  [ -f "$logfile" ] || return 1
  grep -qE '"type":"(error|turn\.failed)"' "$logfile" 2>/dev/null
}

gemini_raw_has_success_result() {
  local logfile="$1"
  [ -f "$logfile" ] || return 1
  grep -qF '"type":"result"' "$logfile" 2>/dev/null \
    && grep -qF '"status":"success"' "$logfile" 2>/dev/null
}

normalize_agent_exit_code() {
  local backend="$1" exit_code="$2" rawfile="$3"
  local rate_limit_rejected="${4:-}"
  local codex_completed="${5:-}"
  local codex_failed="${6:-}"
  local gemini_success="${7:-}"
  if [ -z "$rate_limit_rejected" ]; then
    if log_has_rate_limit_rejection "$rawfile"; then
      rate_limit_rejected=1
    else
      rate_limit_rejected=0
    fi
  fi
  if [ "${exit_code:-0}" -ne 0 ]; then
    case "$backend" in
      codex)
        # `codex exec` can return non-zero when a command inside an otherwise
        # completed turn fails. Audit agents intentionally run failing probes
        # during exploration, so trust the structured turn status instead of
        # the aggregate process status for this narrow case.
        if { [ "$codex_completed" = "1" ] || { [ -z "$codex_completed" ] && codex_raw_has_completed_turn "$rawfile"; }; } \
           && { [ "$codex_failed" = "0" ] || { [ -z "$codex_failed" ] && ! codex_raw_has_failed_turn "$rawfile"; }; } \
           && [ "$rate_limit_rejected" -eq 0 ]; then
          echo 0
          return 0
        fi
        ;;
      gemini)
        # Gemini CLI can return a non-zero aggregate status when a tool call
        # inside an otherwise completed session fails. The stream-json result
        # event is the session-level status.
        if { [ "$gemini_success" = "1" ] || { [ -z "$gemini_success" ] && gemini_raw_has_success_result "$rawfile"; }; } \
           && [ "$rate_limit_rejected" -eq 0 ]; then
          echo 0
          return 0
        fi
        ;;
    esac
  fi
  echo "${exit_code:-0}"
}

detect_rate_limit() {
  local timestamp="$1"
  local reset_at="" saw_provider_rejection=0
  local i role mode logfile
  for i in $(seq 1 "$NUM_AGENTS"); do
    for role in cold-start deep_investigation; do
      for mode in generic browser shell; do
        logfile="$RAW_DIR/session_${timestamp}_${role}-${i}-${mode}.log.raw"
        [ -f "$logfile" ] || continue
        # Same single source of truth as everywhere else (429/5xx, all
        # backends, event-scoped). detect_rate_limit only adds the
        # reset-time extraction on top of that boolean.
        log_has_rate_limit_rejection "$logfile" || continue
        saw_provider_rejection=1
        # Some providers include a reset window only as human text.
        local text_reset
        text_reset=$(provider_text_reset_at "$logfile" 2>/dev/null || true)
        if [ -n "$text_reset" ] && [ "$text_reset" -gt 0 ] 2>/dev/null; then
          if [ -z "$reset_at" ] || [ "$text_reset" -gt "$reset_at" ] 2>/dev/null; then
            reset_at="$text_reset"
          fi
        fi
        # Stage 2: pick a usable resetsAt from a non-allowed* rate_limit_event.
        local candidate
        candidate=$(grep -F '"type":"rate_limit_event"' "$logfile" 2>/dev/null \
          | grep -v '"status":"allowed"' \
          | grep -v '"status":"allowed_warning"' \
          | grep -m1 -o '"resetsAt":[0-9]*' || true)
        if [ -n "$candidate" ]; then
          candidate="${candidate#*:}"
          if [ -z "$reset_at" ] || [ "$candidate" -gt "$reset_at" ] 2>/dev/null; then
            reset_at="$candidate"
          fi
        fi
      done
    done
  done
  if [ -n "$reset_at" ] && [ "$reset_at" -gt 0 ] 2>/dev/null; then
    printf '%s\n' "$reset_at"
    return 0
  fi
  if [ "$saw_provider_rejection" -eq 1 ]; then
    printf '%s\n' "unknown"
    return 0
  fi
  return 1
}

RATE_LIMIT_DEFAULT_BACKOFF="${RATE_LIMIT_DEFAULT_BACKOFF:-300}"  # 5 minutes when no reset time is available
RATE_LIMIT_MAX_BACKOFF="${RATE_LIMIT_MAX_BACKOFF:-1800}"          # hard cap: 30 minutes
if ! [[ "$RATE_LIMIT_DEFAULT_BACKOFF" =~ ^[0-9]+$ ]] || [ "$RATE_LIMIT_DEFAULT_BACKOFF" -lt 1 ]; then
  RATE_LIMIT_DEFAULT_BACKOFF=300
fi
if ! [[ "$RATE_LIMIT_MAX_BACKOFF" =~ ^[0-9]+$ ]] || [ "$RATE_LIMIT_MAX_BACKOFF" -lt 1 ]; then
  RATE_LIMIT_MAX_BACKOFF=1800
fi
# When a capacity/account limit's reset is further away than the backoff cap,
# stop the audit immediately as provider-limited instead of sleeping the cap and
# retrying. Default off: a standalone audit has no deadline and should keep
# waiting so a recoverable window (e.g. a 1-hour quota reset) resumes the
# session. bin/benchmark sets this to 1 because a cell's wall budget is far
# shorter than the sustained-streak halt (MAX_RATE_LIMIT_BACKOFFS × cap), so
# without an early stop the cell is SIGTERM'd mid-backoff and mis-recorded as a
# clean done instead of provider-limited.
RATE_LIMIT_CAPACITY_HARD_STOP="${RATE_LIMIT_CAPACITY_HARD_STOP:-0}"
[ "$RATE_LIMIT_CAPACITY_HARD_STOP" = "1" ] || RATE_LIMIT_CAPACITY_HARD_STOP=0
# After this many *consecutive* iterations whose only outcome was a
# rate-limit / overload backoff (the whole pool was rejected, no forward
# progress), stop with a distinct BACKEND_UNAVAILABLE reason instead of
# sleeping out the rest of the wall budget against a backend that isn't
# recovering. The streak resets the moment an iteration runs without a
# rejection, so a transient blip just costs a backoff or two. 0 disables
# the cap (back off indefinitely until the wall budget). Default 6 ≈ at
# least ~30 min sustained at the 300s default backoff.
MAX_RATE_LIMIT_BACKOFFS="${MAX_RATE_LIMIT_BACKOFFS:-6}"
if ! [[ "$MAX_RATE_LIMIT_BACKOFFS" =~ ^[0-9]+$ ]]; then
  MAX_RATE_LIMIT_BACKOFFS=6
fi
RATE_LIMIT_BACKOFF_STREAK=0

run_quality_path() {
  printf '%s/.run-quality' "$LOGDIR"
}

backend_unavailable_path() {
  printf '%s/.backend-unavailable' "$LOGDIR"
}

mark_run_quality() {
  local quality="$1" path current
  case "$quality" in
    clean|provider_recovered|provider_limited) ;;
    *) quality=clean ;;
  esac
  path="$(run_quality_path)"
  current="$(cat "$path" 2>/dev/null || true)"
  # provider_limited is terminal for this audit run; do not downgrade it when
  # later cleanup probes inspect logs.
  [ "$current" = "provider_limited" ] && return 0
  printf '%s\n' "$quality" > "$path" 2>/dev/null || true
}

mark_backend_unavailable() {
  mark_run_quality provider_limited
  : > "$(backend_unavailable_path)" 2>/dev/null || true
}

provider_issue_for_timestamp() {
  local timestamp="$1"
  local issue saw_transient=0
  local i role mode logfile
  for i in $(seq 1 "$NUM_AGENTS"); do
    for role in cold-start deep_investigation; do
      for mode in generic browser shell; do
        logfile="$RAW_DIR/session_${timestamp}_${role}-${i}-${mode}.log.raw"
        [ -f "$logfile" ] || continue
        issue="$(log_provider_issue "$logfile")"
        case "$issue" in
          capacity_limited) printf '%s\n' capacity_limited; return 0 ;;
          transient) saw_transient=1 ;;
        esac
      done
    done
  done
  if [ "$saw_transient" -eq 1 ]; then
    printf '%s\n' transient
  else
    printf '%s\n' none
  fi
}

rate_limit_cooldown_path() {
  printf '%s/.rate_limit_cooldown' "$LOGDIR"
}

rate_limit_cooldown_expiry() {
  local reset_at="$1" now expires_at cap_at
  now=$(date +%s)
  if [ "$reset_at" = "unknown" ]; then
    printf '%s\n' "$((now + RATE_LIMIT_DEFAULT_BACKOFF))"
    return 0
  fi
  case "$reset_at" in ''|*[!0-9]*) return 1 ;; esac
  [ "$reset_at" -gt "$now" ] 2>/dev/null || return 1
  expires_at=$((reset_at + 30))
  cap_at=$((now + RATE_LIMIT_MAX_BACKOFF))
  if [ "$expires_at" -gt "$cap_at" ]; then
    expires_at="$cap_at"
  fi
  printf '%s\n' "$expires_at"
}

persist_rate_limit_cooldown() {
  local timestamp="$1" reset_at="$2" expires_at now path
  expires_at=$(rate_limit_cooldown_expiry "$reset_at" 2>/dev/null) || return 1
  now=$(date +%s)
  path=$(rate_limit_cooldown_path)
  {
    printf 'backend=%s\n' "${ACTIVE_BACKEND:-unknown}"
    printf 'reset_at=%s\n' "$reset_at"
    printf 'expires_at=%s\n' "$expires_at"
    printf 'source_timestamp=%s\n' "$timestamp"
    printf 'created_at=%s\n' "$now"
  } > "$path" 2>/dev/null || true
}

read_rate_limit_cooldown_field() {
  local key="$1" path
  path=$(rate_limit_cooldown_path)
  [ -f "$path" ] || return 1
  sed -n "s/^${key}=//p" "$path" 2>/dev/null | tail -1
}

clear_rate_limit_cooldown() {
  rm -f "$(rate_limit_cooldown_path)" 2>/dev/null || true
}

clear_startup_rate_limit_cooldowns() {
  local backend path cleared=0
  for backend in claude codex gemini oss; do
    path="$(target_backend_logs_dir "$backend")/.rate_limit_cooldown"
    [ -f "$path" ] || continue
    rm -f "$path" 2>/dev/null || continue
    cleared=$((cleared + 1))
    log "RATE_LIMIT: cleared the stale ${backend} cooldown from a previous run — the backend will be re-probed when the next agent launches." | tee -a "$INDEX"
  done
  [ "$cleared" -gt 0 ] || return 0
}

active_rate_limit_cooldown_wait() {
  local path backend expires_at created_at now wait max_expires_at
  path=$(rate_limit_cooldown_path)
  [ -f "$path" ] || return 1
  backend=$(read_rate_limit_cooldown_field backend 2>/dev/null || true)
  if [ -n "$backend" ] && [ "$backend" != "${ACTIVE_BACKEND:-unknown}" ]; then
    return 1
  fi
  expires_at=$(read_rate_limit_cooldown_field expires_at 2>/dev/null || true)
  case "$expires_at" in ''|*[!0-9]*) clear_rate_limit_cooldown; return 1 ;; esac
  created_at=$(read_rate_limit_cooldown_field created_at 2>/dev/null || true)
  case "$created_at" in
    ''|*[!0-9]*) ;;
    *)
      max_expires_at=$((created_at + RATE_LIMIT_MAX_BACKOFF))
      if [ "$expires_at" -gt "$max_expires_at" ] 2>/dev/null; then
        expires_at="$max_expires_at"
      fi
      ;;
  esac
  now=$(date +%s)
  wait=$((expires_at - now))
  if [ "$wait" -le 0 ]; then
    clear_rate_limit_cooldown
    return 1
  fi
  if [ "$wait" -gt "$RATE_LIMIT_MAX_BACKOFF" ]; then
    wait="$RATE_LIMIT_MAX_BACKOFF"
  fi
  printf '%s\n' "$wait"
}

sleep_for_active_rate_limit_cooldown() {
  local wait reset_at expires_at human
  wait=$(active_rate_limit_cooldown_wait 2>/dev/null) || return 1
  reset_at=$(read_rate_limit_cooldown_field reset_at 2>/dev/null || echo unknown)
  expires_at=$(read_rate_limit_cooldown_field expires_at 2>/dev/null || echo "")
  if [ -n "$expires_at" ] && [ "$expires_at" != "unknown" ]; then
    human=$(audit_format_epoch_local "$expires_at" '%H:%M:%S %Z' 2>/dev/null || echo "unknown")
  else
    human="unknown"
  fi
  log "RATE_LIMIT: the ${ACTIVE_BACKEND:-LLM} API is currently rate-limited (reset reported as ${reset_at}); sleeping $(fmt_secs "$wait") before launching agents — agent state and dry_streak are left unchanged so we don't lose progress. Cooldown expires around ${human}." | tee -a "$INDEX"
  sleep "$wait"
  return 0
}

# If rate-limited, sleep until the reset time plus a small buffer.
# For 429s without a reset time (e.g. Codex), uses a default backoff.
# Returns: 0 = backed off this iteration (caller should `continue` without
#          counting it as exploration); 1 = no rejection (proceed normally);
#          2 = sustained rejection past MAX_RATE_LIMIT_BACKOFFS (caller should
#          stop the run with a BACKEND_UNAVAILABLE outcome).
handle_rate_limit_backoff() {
  local timestamp="$1"
  local reset_at provider_issue
  # No rejection this iteration — the backend responded, so a prior streak
  # is over. Reset and let the caller run its normal accounting.
  reset_at=$(detect_rate_limit "$timestamp" 2>/dev/null) || { RATE_LIMIT_BACKOFF_STREAK=0; return 1; }
  provider_issue="$(provider_issue_for_timestamp "$timestamp" 2>/dev/null || echo none)"
  [ "$provider_issue" = "none" ] && provider_issue=transient
  persist_rate_limit_cooldown "$timestamp" "$reset_at" || true

  local now wait_secs reset_human
  now=$(date +%s)

  if [ "$reset_at" = "unknown" ]; then
    wait_secs="$RATE_LIMIT_DEFAULT_BACKOFF"
    reset_human="unknown (using ${wait_secs}s default backoff)"
  else
    wait_secs=$(( reset_at - now + 30 ))
    if [ "$wait_secs" -le 0 ]; then
      # Reset time already passed — the limit has cleared. Treat as recovery.
      RATE_LIMIT_BACKOFF_STREAK=0
      return 1
    fi
    reset_human=$(audit_format_epoch_local "$reset_at" '%H:%M:%S %Z' 2>/dev/null || echo "unknown")
    reset_human="${reset_human} (+30s buffer)"
  fi
  if [ "$wait_secs" -gt "$RATE_LIMIT_MAX_BACKOFF" ]; then
    if [ "$provider_issue" = "capacity_limited" ] && [ "$RATE_LIMIT_CAPACITY_HARD_STOP" = "1" ]; then
      log "BACKEND_UNAVAILABLE: the ${ACTIVE_BACKEND:-LLM} API is capacity-limited until ${reset_human}, which is $(fmt_secs "$wait_secs") away and exceeds RATE_LIMIT_MAX_BACKOFF=$(fmt_secs "$RATE_LIMIT_MAX_BACKOFF") — stopping this audit as provider-limited instead of sleeping out the benchmark budget." | tee -a "$INDEX"
      mark_backend_unavailable
      return 2
    fi
    log "RATE_LIMIT: the API reset is $(fmt_secs "$wait_secs") away, which exceeds the configured backoff cap RATE_LIMIT_MAX_BACKOFF=$(fmt_secs "$RATE_LIMIT_MAX_BACKOFF") — sleeping the cap instead and will retry sooner." | tee -a "$INDEX"
    wait_secs="$RATE_LIMIT_MAX_BACKOFF"
  fi
  RATE_LIMIT_BACKOFF_STREAK=$((RATE_LIMIT_BACKOFF_STREAK + 1))
  mark_run_quality provider_recovered
  log "RATE_LIMIT: the ${ACTIVE_BACKEND:-LLM} API returned a provider rejection (${provider_issue}) — sleeping $(fmt_secs "$wait_secs") until ${reset_human} before retrying (consecutive backoff ${RATE_LIMIT_BACKOFF_STREAK}$( [ "$MAX_RATE_LIMIT_BACKOFFS" -gt 0 ] && printf '/%s' "$MAX_RATE_LIMIT_BACKOFFS"))." | tee -a "$INDEX"
  sleep "$wait_secs"
  # Sustained, pool-wide rejection that is not clearing: stop loudly rather
  # than burn the rest of the budget retrying, and so the run never reports a
  # clean exhaustion when the real cause was an unreachable backend.
  if [ "$MAX_RATE_LIMIT_BACKOFFS" -gt 0 ] && [ "$RATE_LIMIT_BACKOFF_STREAK" -ge "$MAX_RATE_LIMIT_BACKOFFS" ]; then
    log "BACKEND_UNAVAILABLE: the ${ACTIVE_BACKEND:-LLM} API rejected every agent for ${RATE_LIMIT_BACKOFF_STREAK} consecutive iteration(s) (sustained provider rejection: ${provider_issue}) — stopping the audit. Results are partial, not a clean exhaustion; re-run when the backend is healthy, or raise MAX_RATE_LIMIT_BACKOFFS to wait longer." | tee -a "$INDEX"
    mark_backend_unavailable
    return 2
  fi
  return 0
}

# Clear a dead agent's state file so the next iteration cold-starts on a fresh
# subsystem. No archive — old state is not fed back to agents (reduces context
# bloat and safety-classifier pressure from accumulated hypothesis language).
archive_dead_agent_state() {
  local agent_num="$1"
  local live
  live=$(state_file_path "$agent_num")
  [ -f "$live" ] || return 0
  rm -f "$live" 2>/dev/null || true
}

