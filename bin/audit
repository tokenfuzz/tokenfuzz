}

quality_feedback_path() {
  local agent_num="$1"
  printf '%s/.quality_feedback_%s' "$RESULTS_DIR" "$agent_num"
}

combined_state_path() {
  printf '%s/AUDIT_STATE.md' "$RESULTS_DIR"
}

# Per-subsystem corpus directory. Agents drop testcases here once they reach
# the target (confirmed by hits.sh HIT) so cross-session runs can seed from
# inputs that already made it past upstream guards. Slug is derived from
# get_agent_subsystem by stripping non-alnum.
corpus_dir_root() {
  printf '%s/corpus' "$RESULTS_DIR"
}
prepare_active_backend_runtime
clear_startup_rate_limit_cooldowns
rm -f "$(run_quality_path)" "$(backend_unavailable_path)" 2>/dev/null || true
backend_detail="(hosted API)"
if [ "$ACTIVE_BACKEND" = "oss" ]; then
  backend_detail="base_url=$(oss_local_base_url)"
fi
log "LLM backend: provider=${ACTIVE_BACKEND} model=${MODEL} ${backend_detail} decision_timeout=$(fmt_secs "$LLM_DECISION_TIMEOUT")" | tee -a "$INDEX"
unset backend_detail
if [ "$ENSEMBLE_MODE" -eq 1 ]; then
  log "Ensemble mode: cycling through backends ${ENSEMBLE_BACKENDS[*]} across iterations (artifacts written under output/${TARGET_OUTPUT_SLUG}/<backend>/)" | tee -a "$INDEX"
fi
log "Target under audit: slug=${TARGET_SLUG} path=${TARGET_ROOT} repo_type=${TARGET_REPO_TYPE} agent_guide=${AGENT_GUIDE_PATH}" | tee -a "$INDEX"
log "Artifact output roots: results (crashes/findings/state) → ${RESULTS_DIR}/    logs (sessions/index) → ${LOGDIR}/" | tee -a "$INDEX"

# One-time legend so the rest of the log is self-explanatory for readers
# who aren't familiar with the harness conventions. The codes embedded
# in subsequent lines (strategy IDs, hypothesis states, K=V tokens) are
# defined here once instead of being expanded inline on every line.
if [ "${AUDIT_LOG_LEGEND:-1}" = "1" ]; then
  log "Legend — investigation strategies (one is active per agent at a time; the K=V token 'strategy=Sn' uses the short code, prose/prefix use the full 'StrategyN(name)' form): Strategy1(Prior-fix-review), Strategy2(Invariant-negation), Strategy3(Spec-vs-impl), Strategy4(Differential-build), Strategy5(Lifetime-and-state), Strategy6(Cross-project-mining), Strategy7(Adversarial-input), Strategy8(Property-oracle)" | tee -a "$INDEX"
  log "Legend — hypothesis lifecycle states (appear in agent state files and log summaries): PENDING=hypothesis written, waiting on a testcase | INVESTIGATING=agent is actively probing it | NEEDS_TESTCASE=evidence is in, awaiting a reproducer | ACTIVE=shorthand for any of the previous three | DISCARDED=rejected as non-security or not reproducible" | tee -a "$INDEX"
  log "Legend — per-agent log line prefix: [AgentN·(cold|deep)·StrategyX(short-name)·probe budget=remaining/total] — cold = first iteration with no prior agent state, deep = resuming an in-progress investigation, probe budget = sanitizer/runner test runs left in this iteration before the wrapper asks the agent to stop opening new hypotheses" | tee -a "$INDEX"
  log "Legend — recurring metric names: asan_runs=probe executions recorded in scratch output | hits=testcases that triggered a sanitizer or runner diagnostic | cards=work items waiting in the queue | dry=iterations in a row without finding anything new | cmds=shell commands the agent ran via Bash | tools=LLM tool calls (Read/Grep/Glob/etc.) | tokens=LLM input/output token count" | tee -a "$INDEX"
fi

