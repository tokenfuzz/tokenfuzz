dry_streak=0

is_cold_start() {
  # Cold start if NO agent has a state file
  local i
  for i in $(seq 1 "$NUM_AGENTS"); do
    [ -f "$(state_file_path "$i")" ] && return 1
    structured_state_agent_has_rows "$i" 2>/dev/null && return 1
  done
  return 0
}


count_security_crash_candidates() {
  local count=0
  local d
  for d in "$RESULTS_DIR"/crashes/CRASH-*/; do
    [ -d "$d" ] || continue
    [ -f "$d/.promotion_pending" ] && continue
    count=$((count + 1))
  done
  echo "$count"
}

count_confirmed_findings() {
  # Count only curated confirmed security findings. Pending crash candidates are
  # tracked separately so they never inflate "finding" metrics.
  local count=0
  local d
  for d in "$RESULTS_DIR"/findings/FIND-*/; do
    [ -d "$d" ] || continue
    count=$((count + 1))
  done
  echo "$count"
}

count_active_security_results() {
  # Count the active result set: pending security crash candidates plus
  # curated confirmed security findings. Use this for productivity heuristics, not
  # for user-facing "finding" counts.
  local count=0
  local d
  for d in "$RESULTS_DIR"/crashes/CRASH-*/ "$RESULTS_DIR"/findings/FIND-*/; do
    [ -d "$d" ] || continue
    [ -f "$d/.promotion_pending" ] && continue
    count=$((count + 1))
  done
  echo "$count"
}

# Count actionable state transitions that represent real forward progress.
# This is compared before vs after an iteration; a stale NEEDS_TESTCASE row
# from a prior session should not reset the dry streak forever.
count_actionable_state_entries() {
  if structured_state_available 2>/dev/null; then
    structured_state_actionable_count 2>/dev/null || echo 0
    return
  fi
  local count=0
  for i in $(seq 1 "$NUM_AGENTS"); do
    local f
    f=$(state_file_path "$i")
    if [ -f "$f" ]; then
      local c
      c=$(grep -cE 'CRASH-|FIND-|NEEDS_TESTCASE' "$f" 2>/dev/null || true)
      count=$((count + ${c:-0}))
    fi
  done
  echo "$count"
}

# Total ENV-BLOCKED markers across all agent state files. Compared
# before vs after an iteration to detect "diagnostic-only" iterations
# (mapped out a dead subsystem but produced no findings/crashes), which
# should not count against the global dry_streak — they are forward
# progress, just narrowing the search space rather than producing
# results. The queue's natural exhaustion (target_exhausted_hard_stop_ready
# + eligible_work_card_exists) fires STALL_STOP when there is genuinely
# no work left, so no per-streak cap is needed on top.
count_total_env_blocked() {
  if structured_state_available 2>/dev/null; then
    structured_state_count_all_status_regex '^ENV-BLOCKED$' 2>/dev/null || echo 0
    return
  fi
  local total=0
  for i in $(seq 1 "$NUM_AGENTS"); do
    local f
    f=$(state_file_path "$i" 2>/dev/null || true)
    if [ -f "$f" ]; then
      local c
      c=$(count_env_blocked "$f" 2>/dev/null || echo 0)
      total=$((total + ${c:-0}))
    fi
  done
  echo "$total"
}

count_iteration_progress_snapshot() {
  # One-pass progress snapshot for iteration dry-streak accounting. This
  # replaces separate scans for crash candidates, findings, actionable state,
  # and ENV-BLOCKED rows at the same checkpoint.
  local confirmed_findings=0 security_crashes=0 actionable=0 env_blocked=0
  local d
  for d in "$RESULTS_DIR"/crashes/CRASH-*/; do
    [ -d "$d" ] || continue
    [ -f "$d/.promotion_pending" ] && continue
    security_crashes=$((security_crashes + 1))
  done
  for d in "$RESULTS_DIR"/findings/FIND-*/; do
    [ -d "$d" ] || continue
    confirmed_findings=$((confirmed_findings + 1))
  done

  if structured_state_available 2>/dev/null; then
    local f state_counts
    f=$(structured_state_hypotheses_path)
    state_counts=$(jq -R -s -r '
      split("\n")
      | map(select(length > 0) | fromjson?)
      | reduce .[] as $r ({actionable: 0, env_blocked: 0};
          ($r.status // "") as $s
          | .actionable += (if (($s | test("^(CRASH|FIND)(-|$)")) or $s == "NEEDS_TESTCASE") then 1 else 0 end)
          | .env_blocked += (if $s == "ENV-BLOCKED" then 1 else 0 end)
        )
      | "\(.actionable) \(.env_blocked)"
    ' "$f" 2>/dev/null) || state_counts=""
    if [ -n "$state_counts" ]; then
      read -r actionable env_blocked <<< "$state_counts"
    fi
  else
    local i f state_counts a e
    for i in $(seq 1 "$NUM_AGENTS"); do
      f=$(state_file_path "$i" 2>/dev/null || true)
      [ -f "$f" ] || continue
      state_counts=$(awk '
        /CRASH-|FIND-|NEEDS_TESTCASE/ { actionable++ }
        /ENV-BLOCKED/ { env_blocked++ }
        END { printf "%d %d\n", actionable + 0, env_blocked + 0 }
      ' "$f" 2>/dev/null) || state_counts=""
      read -r a e <<< "$state_counts"
      case "${a:-0}" in ''|*[!0-9]*) a=0 ;; esac
      case "${e:-0}" in ''|*[!0-9]*) e=0 ;; esac
      actionable=$((actionable + a))
      env_blocked=$((env_blocked + e))
    done
  fi

  case "${actionable:-0}" in ''|*[!0-9]*) actionable=0 ;; esac
  case "${env_blocked:-0}" in ''|*[!0-9]*) env_blocked=0 ;; esac
  printf 'confirmed_findings=%s\n' "$confirmed_findings"
  printf 'security_crashes=%s\n' "$security_crashes"
  printf 'actionable=%s\n' "$actionable"
  printf 'env_blocked=%s\n' "$env_blocked"
}

load_iteration_progress_snapshot() {
  local _v_confirmed="$1" _v_crashes="$2" _v_actionable="$3" _v_env_blocked="$4"
  local _confirmed=0 _crashes=0 _actionable=0 _env_blocked=0
  local _snapshot _key _value
  _snapshot=$(count_iteration_progress_snapshot)
  while IFS='=' read -r _key _value; do
    case "$_key" in
      confirmed_findings) _confirmed="$_value" ;;
      security_crashes) _crashes="$_value" ;;
      actionable) _actionable="$_value" ;;
      env_blocked) _env_blocked="$_value" ;;
    esac
  done <<< "$_snapshot"
  case "${_confirmed:-0}" in ''|*[!0-9]*) _confirmed=0 ;; esac
  case "${_crashes:-0}" in ''|*[!0-9]*) _crashes=0 ;; esac
  case "${_actionable:-0}" in ''|*[!0-9]*) _actionable=0 ;; esac
  case "${_env_blocked:-0}" in ''|*[!0-9]*) _env_blocked=0 ;; esac
  printf -v "$_v_confirmed" '%s' "$_confirmed"
  printf -v "$_v_crashes" '%s' "$_crashes"
  printf -v "$_v_actionable" '%s' "$_actionable"
  printf -v "$_v_env_blocked" '%s' "$_env_blocked"
}

# ─── Subsystem exhaustion & overlap detection ──────────────────────
# Detects when agents have 0 PENDING hypotheses (exhausted) or when
# multiple agents are working on the same subsystem prefix.

count_total_pending() {
  if structured_state_available 2>/dev/null; then
    structured_state_count_all_status_regex '^PENDING$' 2>/dev/null || echo 0
    return
  fi
  local total=0
  for i in $(seq 1 "$NUM_AGENTS"); do
    local f
    f=$(state_file_path "$i")
    if [ -f "$f" ]; then
      local c
      c=$(grep -c "PENDING" "$f" 2>/dev/null || true)
      total=$((total + ${c:-0}))
    fi
  done
  echo "$total"
}

count_active_hypotheses_for_agent() {
  local agent_num="$1"
  if structured_state_agent_has_rows "$agent_num" 2>/dev/null; then
    structured_state_agent_active_count "$agent_num" 2>/dev/null || echo 0
    return
  fi
  local f
  f=$(state_file_path "$agent_num")
  [ -f "$f" ] || { echo 0; return; }
  local c
  c=$(grep -cE 'PENDING|INVESTIGATING|NEEDS_TESTCASE' "$f" 2>/dev/null || true)
  echo "${c:-0}"
}

count_total_active_hypotheses() {
  if structured_state_available 2>/dev/null; then
    structured_state_count_all_status_regex '^(PENDING|INVESTIGATING|NEEDS_TESTCASE)$' 2>/dev/null || echo 0
    return
  fi
  local total=0 i c
  for i in $(seq 1 "$NUM_AGENTS"); do
    c=$(count_active_hypotheses_for_agent "$i" 2>/dev/null || echo 0)
    total=$((total + ${c:-0}))
  done
  echo "$total"
}

fuzz_leads_empty() {
  local f
  f=$(fuzz_leads_path)
  [ -s "$f" ] || return 0
  awk '
    NF && $0 !~ /^#/ && $0 !~ /^_/ { found = 1 }
    END { exit(found ? 1 : 0) }
  ' "$f" 2>/dev/null
}

fuzz_leads_signature_file() {
  printf '%s/.fuzz-leads-signature' "$RESULTS_DIR"
}

fuzz_leads_signature_exists() {
  local sig_file
  sig_file=$(fuzz_leads_signature_file)
  [ -s "$sig_file" ]
}

current_fuzz_leads_signature() {
  local f
  f=$(fuzz_leads_path)
  if [ ! -s "$f" ]; then
    printf 'empty\n'
    return 0
  fi
  awk 'NF && $0 !~ /^#/ && $0 !~ /^_/ { print }' "$f" 2>/dev/null \
    | audit_sha1 2>/dev/null \
    | awk '{print $1}'
}

fuzz_leads_changed_since_last_iteration() {
  local sig_file current previous
  sig_file=$(fuzz_leads_signature_file)
  [ -f "$sig_file" ] || return 0
  current=$(current_fuzz_leads_signature)
  previous=$(cat "$sig_file" 2>/dev/null || true)
  [ -n "$current" ] && [ "$current" != "$previous" ]
}

refresh_fuzz_leads_signature() {
  local sig_file
  sig_file=$(fuzz_leads_signature_file)
  mkdir -p "$(dirname "$sig_file")" 2>/dev/null || true
  current_fuzz_leads_signature > "$sig_file" 2>/dev/null || true
}

target_source_signature_file() {
  printf '%s/.target-source-signature' "$RESULTS_DIR"
}

target_source_signature_exists() {
  local sig_file
  sig_file=$(target_source_signature_file)
  [ -s "$sig_file" ]
}

current_target_source_signature() {
  local vcs_timeout
  vcs_timeout="${AUDIT_VCS_SIGNATURE_TIMEOUT:-5}"
  if ! [[ "$vcs_timeout" =~ ^[0-9]+$ ]] || [ "$vcs_timeout" -lt 1 ]; then
    vcs_timeout=5
  fi
  case "${TARGET_REPO_TYPE:-none}" in
    git)
      {
        audit_timeout_run "$vcs_timeout" git -C "$TARGET_ROOT" rev-parse HEAD 2>/dev/null || true
        audit_timeout_run "$vcs_timeout" git -C "$TARGET_ROOT" status --porcelain --untracked-files=no 2>/dev/null || true
      } | sed '/^$/d'
      ;;
    hg)
      {
        audit_timeout_run "$vcs_timeout" hg -R "$TARGET_ROOT" id -i 2>/dev/null | sed 's/+//g' || true
        audit_timeout_run "$vcs_timeout" hg -R "$TARGET_ROOT" status -mard 2>/dev/null || true
      } | sed '/^$/d'
      ;;
    *)
      printf '%s\n' "${TARGET_REV:-unknown}"
      ;;
  esac
}

target_source_unchanged_since_last_iteration() {
  local sig_file current previous
  sig_file=$(target_source_signature_file)
  [ -f "$sig_file" ] || return 1
  current=$(current_target_source_signature)
  previous=$(cat "$sig_file" 2>/dev/null || true)
  [ -n "$current" ] && [ "$current" = "$previous" ]
}

refresh_target_source_signature() {
  local sig_file
  sig_file=$(target_source_signature_file)
  mkdir -p "$(dirname "$sig_file")" 2>/dev/null || true
  current_target_source_signature > "$sig_file" 2>/dev/null || true
}

launch_evidence_is_new() {
  # Missing baselines mean this is a fresh or migrated run; allow one launch so
  # the harness can establish signatures before applying the dry-streak stop.
  fuzz_leads_signature_exists || return 0
  target_source_signature_exists || return 0
  fuzz_leads_changed_since_last_iteration && return 0
  target_source_unchanged_since_last_iteration || return 0
  return 1
}

refresh_launch_evidence_signatures() {
  refresh_fuzz_leads_signature
  refresh_target_source_signature
}

target_has_prior_audit_progress() {
  # Do not hard-stop a truly fresh target just because rank-work is empty or
  # broken. Bootstrap the no-op signature only after prior structured work
  # proves this is an exhausted target being relaunched.
  [ -s "$RESULTS_DIR/state/claims.jsonl" ] && return 0
  [ -s "$RESULTS_DIR/state/hypotheses.jsonl" ] && return 0
  [ -s "$RESULTS_DIR/state/runs.jsonl" ] && return 0
  return 1
}

eligible_work_card_exists() {
  [ -x "bin/state" ] || return 1
  [ -s "${RESULTS_DIR:-}/work-cards.jsonl" ] || return 1
  local i mode role
  for i in $(seq 1 "$NUM_AGENTS"); do
    mode=$(agent_mode "$i" 2>/dev/null || echo "")
    role=$(agent_role "$i" 2>/dev/null || echo "")
    if bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
        next-card --agent "$i" --mode "$mode" --role "$role" --peek >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

# Per-agent pre-launch skip decision. Returns 0 (skip) when ALL three
# sources of work are dry for THIS agent:
#   - No eligible work card claimable by agent N (--peek check)
#   - No active hypothesis in agent N's state file
#   - No fuzz leads (pool-wide; conservative — only skip when empty)
# Slot 1 always launches so cold-start discovery survives the case where
# the orchestrator-side counters report empty incorrectly. The model side
# of these "zero-work" launches produces 4-5k tokens explaining there's
# nothing to do; skipping the LLM round-trip is the wall-time win.
audit_should_skip_launch() {
  local agent_num="$1"
  [ -n "$agent_num" ] || return 1
  # Always allow at least one slot to launch each iteration — preserves
  # the discovery path on a freshly-refreshed queue.
  [ "$agent_num" -eq 1 ] && return 1
  # An active hypothesis in the state file is work regardless of the queue.
  local active
  active=$(count_active_hypotheses_for_agent "$agent_num" 2>/dev/null || echo 0)
  case "$active" in ''|*[!0-9]*) active=0 ;; esac
  [ "$active" -gt 0 ] && return 1
  # Eligible card for THIS agent? --peek does not claim, only tests.
  if [ -x "bin/state" ] && [ -s "${RESULTS_DIR:-}/work-cards.jsonl" ]; then
    local mode role
    mode=$(agent_mode "$agent_num" 2>/dev/null || echo "")
    role=$(agent_role "$agent_num" 2>/dev/null || echo "")
    if bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
        next-card --agent "$agent_num" --mode "$mode" --role "$role" --peek >/dev/null 2>&1; then
      return 1
    fi
  fi
  # Fuzz leads count as work even without a card. fuzz_leads_empty returns 0
  # (true) when empty, 1 (false) when there are leads. Skip only when empty.
  if declare -F fuzz_leads_empty >/dev/null 2>&1; then
    fuzz_leads_empty || return 1
  fi
  # All three sources are dry for this agent — skip the LLM launch.
  return 0
}

# Release card claims with no active hypothesis. The audit loop calls this
# every iteration so the queue does not starve on leases left behind by
# completed/wedged agents. The Python helper is idempotent and writes
# release rows to claims.jsonl rather than mutating prior rows.
release_stale_card_claims() {
  [ -x "bin/state" ] || return 0
  local out
  out=$(bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
    release-stale-claims --quiet 2>/dev/null || echo 0)
  case "$out" in
    ''|*[!0-9]*) out=0 ;;
  esac
  if [ "${out:-0}" -gt 0 ]; then
    log "queue: released ${out} stale work-card claim(s) (the claiming agent has no active hypothesis anymore, so the cards are returned to the pool for other agents to pick up)" | tee -a "$INDEX"
  fi
  return 0
}

write_queue_exhaustion_report() {
  [ -x "bin/state" ] || return 0
  local report mode_args i mode reason_counts
  report="$RESULTS_DIR/queue-exhaustion-report.jsonl"
  mode_args=()
  for i in $(seq 1 "$NUM_AGENTS"); do
    mode=$(agent_mode "$i" 2>/dev/null || echo "")
    mode_args+=(--mode "$mode")
  done
  bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
    explain-queue --all "${mode_args[@]}" > "$report" 2>/dev/null || return 0
  # explain-queue emits JSONL — one object per line. jq parses it correctly
  # even when a `reason` value contains escaped quotes, which the previous
  # `sed` regex would truncate at the first inner ".
  if command -v jq >/dev/null 2>&1; then
    reason_counts=$(jq -r '.reason // empty' "$report" 2>/dev/null \
      | sort | uniq -c | awk '{$1=$1; print}' | paste -sd '; ' - || true)
  else
    reason_counts=$(sed -n 's/.*"reason": "\([^"]*\)".*/\1/p' "$report" \
      | sort | uniq -c | awk '{$1=$1; print}' | paste -sd '; ' - 2>/dev/null || true)
  fi
  log "QUEUE_EXHAUSTED: nothing left for agents to do — 0 open hypotheses, 0 eligible work cards, 0 fuzz leads; wrote diagnostic ${report}${reason_counts:+ (rejection reasons: ${reason_counts})}" | tee -a "$INDEX"
}

expand_structured_work_cards_if_exhausted() {
  [ -x "bin/rank-work" ] || return 1
  [ -x "bin/state" ] || return 1
  eligible_work_card_exists && return 1
  target_has_prior_audit_progress || return 1

  local work_file patch_file current_count base_limit max_limit next_limit
  work_file=$(work_cards_path)
  patch_file=$(patch_cards_path)
  current_count=0
  [ -s "$work_file" ] && current_count=$(wc -l < "$work_file" 2>/dev/null | tr -d ' ' || echo 0)
  base_limit="${RANK_WORK_EXPAND_STEP:-${RANK_WORK_LIMIT:-80}}"
  max_limit="${RANK_WORK_EXPAND_MAX:-5000}"
  case "$base_limit" in ''|*[!0-9]*) base_limit=80 ;; esac
  case "$max_limit" in ''|*[!0-9]*) max_limit=5000 ;; esac

  next_limit=$(( current_count + base_limit ))
  [ "$next_limit" -lt "$base_limit" ] && next_limit="$base_limit"
  [ "$next_limit" -gt "$max_limit" ] && next_limit="$max_limit"
  if [ "$current_count" -ge "$max_limit" ]; then
    log "BATCH_EXHAUSTED: no eligible work cards in the current batch and we've already grown the ranked queue to its max=${max_limit}; the target may genuinely be out of work" | tee -a "$INDEX"
    return 1
  fi

  # Futility check: if the last expansion requested MORE cards than the
  # generator could produce, the ranked-card source is exhausted — growing
  # the limit again re-runs the whole rank pipeline (source scan + LLM
  # rerank) for the exact same inputs. Skip it unless the rank INPUTS have
  # changed since: queue content (a recon/patch card landing, a status
  # flip, a re-score — created_at/updated_at are normalized out because
  # the refresh restamps them every iteration) OR the target source
  # signature (rank-work scans the tree, so a pulled commit / local edit
  # must reopen expansion even when the queue files happen not to move).
  # jq-less hosts get an empty sha, which disables the skip (fail-open to
  # re-ranking). Without this check, every dry iteration on a small
  # target re-paid the full rank cost.
  _expand_futility_sha() {
    command -v jq >/dev/null 2>&1 || return 0
    {
      { cat "$1" "$2" 2>/dev/null || true; } \
        | jq -cR 'try (fromjson | del(.created_at, .updated_at)) catch .' 2>/dev/null
      current_target_source_signature 2>/dev/null || true
    } | audit_sha1 | awk '{print $1}'
  }
  local expand_marker="$RESULTS_DIR/state/.rank-expand-marker"
  local queue_sha=""
  queue_sha=$(_expand_futility_sha "$work_file" "$patch_file")
  if [ -n "$queue_sha" ] && [ -s "$expand_marker" ]; then
    local last_requested last_result last_sha
    read -r last_requested last_result last_sha < "$expand_marker" 2>/dev/null || true
    case "$last_requested" in ''|*[!0-9]*) last_requested=0 ;; esac
    case "$last_result" in ''|*[!0-9]*) last_result=0 ;; esac
    if [ "$last_requested" -gt "$last_result" ] && [ "${last_sha:-}" = "$queue_sha" ]; then
      log "BATCH_EXHAUSTED: ranked-card generator is exhausted at ${last_result} card(s) (last expansion requested ${last_requested}); skipping the re-rank until the queue changes" | tee -a "$INDEX"
      return 1
    fi
  fi

  log "BATCH_EXHAUSTED: no eligible work cards in the current batch of ${current_count}; growing the ranked queue to ${next_limit} card(s) to surface more options" | tee -a "$INDEX"
  bin/rank-work --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
    --results-dir "$RESULTS_DIR" --patch-cards "$patch_file" \
    --limit "$next_limit" \
    --output "$work_file" --quiet >>"$INDEX" 2>&1 || return 1
  local grown_count grown_sha=""
  grown_count=$(wc -l < "$work_file" 2>/dev/null | tr -d ' ' || echo 0)
  case "$grown_count" in ''|*[!0-9]*) grown_count=0 ;; esac
  grown_sha=$(_expand_futility_sha "$work_file" "$patch_file")
  if [ -n "$grown_sha" ]; then
    mkdir -p "$(dirname "$expand_marker")" 2>/dev/null || true
    printf '%s %s %s\n' "$next_limit" "$grown_count" "$grown_sha" > "$expand_marker" 2>/dev/null || true
  fi

  if eligible_work_card_exists; then
    local events ts
    events="$RESULTS_DIR/state/events.jsonl"
    mkdir -p "$(dirname "$events")" 2>/dev/null || true
    ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    printf '{"created_at":"%s","event":"work-queue-expanded","target":"%s","previous_limit":%s,"new_limit":%s}\n' \
      "$ts" "$TARGET_SLUG" "${current_count:-0}" "$next_limit" >> "$events" 2>/dev/null || true
    log "BATCH_EXHAUSTED: queue expansion uncovered eligible work cards; continuing audit" | tee -a "$INDEX"
    return 0
  fi

  # No internal write_queue_exhaustion_report here: the sole caller
  # (hard_stop_if_target_exhausted) writes the diagnostic once after a
  # failed expansion — writing it here too produced back-to-back duplicate
  # QUEUE_EXHAUSTED reports (two explain-queue sweeps) every dry iteration.
  log "BATCH_EXHAUSTED: grew queue to ${next_limit} card(s) but still found nothing eligible" | tee -a "$INDEX"
  return 1
}

record_exhaustion_heartbeat() {
  local reason="$1" active pending events ts
  active=$(count_total_active_hypotheses 2>/dev/null || echo 0)
  pending=$(count_total_pending 2>/dev/null || echo 0)
  events="$RESULTS_DIR/state/events.jsonl"
  mkdir -p "$(dirname "$events")" 2>/dev/null || true
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  printf '{"created_at":"%s","event":"target-exhausted","target":"%s","reason":"%s","pending":%s,"active":%s}\n' \
    "$ts" "$TARGET_SLUG" "$reason" "${pending:-0}" "${active:-0}" >> "$events" 2>/dev/null || true
}

resume_state_path() {
  local agent_num="$1" field="$2"
  printf '%s/.resume_%s_%s' "$LOGDIR" "$field" "$agent_num"
}

resume_state_read() {
  local agent_num="$1" field="$2" f
  f=$(resume_state_path "$agent_num" "$field")
  [ -f "$f" ] || return 1
  cat "$f" 2>/dev/null
}

resume_state_write() {
  local agent_num="$1" field="$2" value="$3" f
  f=$(resume_state_path "$agent_num" "$field")
  printf '%s' "$value" > "$f" 2>/dev/null || true
}

resume_bool_enabled() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

backend_resume_enabled() {
  local backend="$1"
  case "$backend" in
    claude)
      resume_bool_enabled "${CLAUDE_RESUME:-1}"
      ;;
    codex)
      resume_bool_enabled "${CODEX_RESUME:-1}"
      ;;
    oss)
      resume_bool_enabled "${OSS_RESUME:-0}"
      ;;
    gemini)
      llm_use_gemini_cli || return 1
      resume_bool_enabled "${GEMINI_RESUME:-1}"
      ;;
    *)
      return 1
      ;;
  esac
}

generate_resume_session_id() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    python3 - <<'PY'
import uuid
print(uuid.uuid4())
PY
  fi
}

agent_active_card_id() {
  local agent_num="$1"
  if structured_state_agent_has_rows "$agent_num" 2>/dev/null; then
    jq -s -r --arg agent "$agent_num" '
      [ .[]
        | select((.agent // "") == $agent)
        | select((.status // "") | test("^(PENDING|INVESTIGATING|NEEDS_TESTCASE)$"))
        | .card_id // ""
        | select(. != "")
      ] | last // empty
    ' "$(structured_state_hypotheses_path)" 2>/dev/null || true
    return
  fi
  # Legacy markdown state has no reliable card-id field; leave the gate
  # unanchored rather than guessing from prose.
  return 0
}

latest_agent_resume_raw_log() {
  local agent_num="$1" latest="" _f
  for _f in "$RAW_DIR"/session_*_cold-start-"${agent_num}"-*.log.raw \
            "$RAW_DIR"/session_*_deep_investigation-"${agent_num}"-*.log.raw; do
    [ -f "$_f" ] || continue
    if [ -z "$latest" ] || [ "$_f" -nt "$latest" ]; then
      latest="$_f"
    fi
  done
  [ -n "$latest" ] && printf '%s\n' "$latest"
}

should_disable_resume_for_cache() {
  local backend="$1" rawfile="$2"
  [ "$backend" = "claude" ] || return 1
  local cap="${CLAUDE_RESUME_CACHE_CAP:-2000000}" cached
  cached=$(extract_usage_field "$rawfile" cached_input_tokens 2>/dev/null || true)
  [[ "${cached:-}" =~ ^[0-9]+$ ]] || return 1
  [ "$cached" -gt "$cap" ]
}

# Detect whether the prior session's raw stream-json transcript contains
# extended-thinking content blocks. The Claude CLI's --resume path
# reconstructs the conversation from its local transcript, but extended
# thinking blocks carry signatures the CLI does not preserve byte-exact,
# so the API rejects with "thinking or redacted_thinking blocks in the
# latest assistant message cannot be modified" (status 400). Returns 0
# (resume must be disabled) when any thinking block is present.
# Repro context: observed 9 sessions across iters 2-17 in the
# sample-cplusplus run on 2026-05-28; all four affected sessions were on
# claude-opus-4-8 which uses extended thinking by default.
should_disable_resume_for_thinking_blocks() {
  local backend="$1" rawfile="$2"
  [ "$backend" = "claude" ] || return 1
  [ -s "$rawfile" ] || return 1
  # Stream-json content_block events for either thinking-block flavor.
  # grep -E pattern matches: "type":"thinking" or "type":"redacted_thinking"
  # with optional whitespace around the colon. -c (full consumer) so we
  # don't SIGPIPE the producer under set -euo pipefail.
  local n
  n=$(grep -cE '"type"[[:space:]]*:[[:space:]]*"(thinking|redacted_thinking)"' "$rawfile" 2>/dev/null || true)
  [ "${n:-0}" -gt 0 ]
}

clear_agent_resume_state() {
  local agent_num="$1"
  rm -f \
    "$LOGDIR/.session_id_${agent_num}" \
    "$LOGDIR/.prev_subsystem_${agent_num}" \
    "$(resume_state_path "$agent_num" session_id)" \
    "$(resume_state_path "$agent_num" backend)" \
    "$(resume_state_path "$agent_num" mode)" \
    "$(resume_state_path "$agent_num" subsystem)" \
    "$(resume_state_path "$agent_num" strategy)" \
    "$(resume_state_path "$agent_num" card)" \
    "$(resume_state_path "$agent_num" dry_count)" \
    "$(resume_state_path "$agent_num" fallback)" \
    2>/dev/null || true
}

clear_all_agent_resume_state() {
  local i
  for i in $(seq 1 "$NUM_AGENTS"); do
    clear_agent_resume_state "$i"
  done
}

target_exhausted_hard_stop_ready() {
  local pending active
  # --strategy is explicitly documented as focused smoke validation. Even when
  # prior runs exhausted the queue, still launch once so the pinned backend /
  # prompt path is exercised instead of reporting a false no-op pass.
  [ -z "${AUDIT_FIXED_STRATEGY:-}" ] || return 1
  pending=$(count_total_pending 2>/dev/null || echo 0)
  active=$(count_total_active_hypotheses 2>/dev/null || echo 0)
  [ "${pending:-0}" -eq 0 ] || return 1
  [ "${active:-0}" -eq 0 ] || return 1
  target_has_prior_audit_progress || return 1
  launch_evidence_is_new && return 1
  if eligible_work_card_exists; then
    [ "${dry_streak:-0}" -ge "$MAX_DRY_SESSIONS" ] || return 1
  fi
  return 0
}

# Emit work-cards.jsonl rows with the same effective claim-status overlay
# bin/state uses: terminal/claim rows in state/claims.jsonl win over a stale
# work-cards.jsonl `.status`, so already-claimed or closed cards are not
# reported as unclaimed. One JSON object per line; callers filter on .status
# exactly as they did against the raw file. Falls back to the raw file when
# python3/the helper is unavailable or errors, so callers never lose the queue.
effective_work_card_rows() {
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  if command -v python3 >/dev/null 2>&1 && [ -r "$SCRIPT_ROOT/lib/audit_helpers.py" ]; then
    local rows
    rows=$(python3 "$SCRIPT_ROOT/lib/audit_helpers.py" effective-work-cards \
      "$SCRIPT_ROOT" "${TARGET_ROOT:-$SCRIPT_ROOT}" "${TARGET_SLUG:-}" "$RESULTS_DIR" 2>/dev/null || true)
    if [ -n "$rows" ]; then
      printf '%s\n' "$rows"
      return 0
    fi
  fi
  cat "$cards_file" 2>/dev/null || true
}

# Distinct strategies (e.g. "S1 S3 S7") of work cards still available for
# claim. Uses the same effective status overlay as bin/state so terminal
# claim rows in state/claims.jsonl override stale work-cards.jsonl entries.
unclaimed_strategy_counts() {
  # $1 is the lowest strategy number to report (1 includes S1, 2 skips it).
  local min_strategy="${1:-1}"
  case "$min_strategy" in ''|*[!0-9]*) min_strategy=1 ;; esac
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  command -v jq >/dev/null 2>&1 || return 1
  # A card is claimable under its primary strategy OR any entry in its
  # allowed_strategies set (mirrors card_strategy_matches in lib/workqueue.py).
  # Emit the deduped union per card so availability counts match claim
  # semantics — otherwise a Promoted card primaried S7 but allowing S5 is
  # invisible to S5 scheduling even though an S5 agent can claim it.
  effective_work_card_rows | jq -r '
    select((.status // "") == "unclaimed")
    | ([.strategy // empty] + (.allowed_strategies // []))
    | map(select(type == "string" and . != "") | ascii_upcase)
    | unique[]
  ' 2>/dev/null | awk -v min_strategy="$min_strategy" '
    /^S[1-9]$/ {
      n = substr($0, 2) + 0
      if (n >= min_strategy) counts[$0]++
    }
    END {
      remaining = 0
      for (n = min_strategy; n <= 9; n++) {
        s = "S" n
        if (counts[s] > 0) remaining++
      }
      while (remaining > 0) {
        best = ""
        best_count = -1
        for (n = min_strategy; n <= 9; n++) {
          s = "S" n
          if (counts[s] > 0 && (counts[s] > best_count || (counts[s] == best_count && (best == "" || s < best)))) {
            best = s
            best_count = counts[s]
          }
        }
        print best "\t" best_count
        counts[best] = -1
        remaining--
      }
    }
  '
}

unclaimed_card_strategies() {
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  local present=" " strat _count
  while IFS="$(printf '\t')" read -r strat _count; do
    [ -n "$strat" ] && present="${present}${strat} "
  done < <(unclaimed_strategy_counts 1)
  for strat in S1 S2 S3 S4 S5 S6 S7 S8 S9; do
    case "$present" in *" $strat "*) printf '%s ' "$strat" ;; esac
  done
}

# Count unclaimed work-cards matching the given strategy. Optional 2nd arg
# narrows to one subsystem. Echoes the integer count; "?" if jq/cards
# unavailable so log lines stay parseable.
count_unclaimed_cards_for() {
  local strategy="$1" subsystem="${2:-}"
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  if [ ! -s "$cards_file" ] || ! command -v jq >/dev/null 2>&1; then
    printf '?'
    return 0
  fi
  if [ -n "$subsystem" ]; then
    effective_work_card_rows | jq -n -r --arg s "$strategy" --arg sub "$subsystem" '
      reduce inputs as $r (0;
        if (($r.status // "") == "unclaimed"
            and (($r.strategy // "") == $s or (($r.allowed_strategies // []) | map(select(type == "string") | ascii_upcase) | index($s)))
            and ($r.subsystem // "") == $sub
            and (($r.id // "") | length) > 0) then
          . + 1
        else
          .
        end
      )
    ' 2>/dev/null
  else
    effective_work_card_rows | jq -n -r --arg s "$strategy" '
      reduce inputs as $r (0;
        if (($r.status // "") == "unclaimed"
            and (($r.strategy // "") == $s or (($r.allowed_strategies // []) | map(select(type == "string") | ascii_upcase) | index($s)))
            and (($r.id // "") | length) > 0) then
          . + 1
        else
          .
        end
      )
    ' 2>/dev/null
  fi
}

count_unclaimed_cards_for_two_strategies() {
  local first="$1" second="$2"
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  if [ ! -s "$cards_file" ] || ! command -v jq >/dev/null 2>&1; then
    printf '?\t?\n'
    return 0
  fi
  local counts first_count=0 second_count=0 strat count
  counts=$(unclaimed_strategy_counts 1) || { printf '?\t?\n'; return 0; }
  while IFS="$(printf '\t')" read -r strat count; do
    case "$strat" in
      "$first") first_count="$count" ;;
      "$second") second_count="$count" ;;
    esac
  done <<< "$counts"
  printf '%s\t%s\n' "$first_count" "$second_count"
}

count_unclaimed_cards_for_strategy_subsystem() {
  local strategy="$1" subsystem="$2"
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  if [ ! -s "$cards_file" ] || ! command -v jq >/dev/null 2>&1; then
    printf '?\t?\n'
    return 0
  fi
  effective_work_card_rows | jq -n -r --arg s "$strategy" --arg sub "$subsystem" '
    reduce inputs as $r ({total:0, subsystem:0};
      if (($r.status // "") == "unclaimed"
          and (($r.strategy // "") == $s or (($r.allowed_strategies // []) | map(select(type == "string") | ascii_upcase) | index($s)))
          and (($r.id // "") | length) > 0) then
        .total += 1
        | if (($r.subsystem // "") == $sub) then
            .subsystem += 1
          else
            .
          end
      else
        .
      end
    )
    | "\(.total)\t\(.subsystem)"
  ' 2>/dev/null
}

# Distinct strategies currently assigned across all agents (e.g. "S1 S2").
active_agent_strategies() {
  local i s
  for i in $(seq 1 "$NUM_AGENTS"); do
    s=$(get_agent_strategy "$i" 2>/dev/null || true)
    [ -n "$s" ] && printf '%s\n' "$s"
  done | sort -u | tr '\n' ' '
}

# Distinct subsystems with unclaimed cards in the queue (space-separated).
# Empty when jq is unavailable or the work-card file is empty — matches the
# conservative behavior of unclaimed_card_strategies.
unclaimed_card_subsystems() {
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  if command -v jq >/dev/null 2>&1; then
    effective_work_card_rows | jq -r 'select(.status == "unclaimed") | .subsystem // empty' 2>/dev/null \
      | awk 'NF' \
      | sort -u \
      | tr '\n' ' '
  fi
}

# Distinct subsystems currently held by agents (active hypothesis or
# recent claim). Read via get_agent_subsystem so the same source of
# truth as the rotation logic is used.
active_agent_subsystems() {
  local i s
  for i in $(seq 1 "$NUM_AGENTS"); do
    s=$(get_agent_subsystem "$i" 2>/dev/null || echo "")
    [ -n "$s" ] && [ "$s" != "unknown" ] && printf '%s\n' "$s"
  done | sort -u | tr '\n' ' '
}

# Strategies (space-separated, ordered by STRATEGY_ROTATION_ORDER) that have
# unclaimed cards in subsystems NO agent currently holds. Returns nothing
# when the entire queue is in agent-held subsystems or jq is missing.
unclaimed_strategies_in_untouched_subsystems() {
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  local active sub_list
  active=$(active_agent_subsystems)
  # Build a jq array literal of held subsystems. The list is small and
  # comes from get_agent_subsystem, which already filters out hostile
  # characters by virtue of structured-state parsing — but quote
  # defensively anyway.
  sub_list=$(printf '%s\n' $active | awk 'NF' | jq -R -s -c 'split("\n") | map(select(length > 0))' 2>/dev/null || echo '[]')
  local cand
  cand=$(effective_work_card_rows | jq -r --argjson held "$sub_list" '
    select(.status == "unclaimed") |
    select(((.subsystem // "") | IN($held[])) | not) |
    .strategy // empty
  ' 2>/dev/null \
    | grep -E '^S[1-9]$' \
    | sort -u)
  [ -z "$cand" ] && return 0
  # Re-emit in STRATEGY_ROTATION_ORDER so callers get a stable preference
  # (S1 before S7 etc.) without needing to know the canonical order.
  local out="" s
  for s in "${STRATEGY_ROTATION_ORDER[@]}"; do
    if printf '%s\n' "$cand" | grep -qx "$s"; then
      out="${out}${out:+ }${s}"
    fi
  done
  printf '%s' "$out"
}

# ── Rotation helpers ──────────────────────────────────────────────
# Two small primitives shared by the rotation entry points
# (force_rotate_to_unclaimed_strategies, force_rotate_to_unclaimed_subsystems,
# pick_exhaustion_recovery_strategy). Each entry point used to inline
# these loops, which silently drifted when the streak/order semantics
# changed. Centralizing them ensures every rotation site agrees on
# "who's most stuck" and "what's the next strategy worth trying."

# Echo the agent_num (1..NUM_AGENTS) with the highest strategy_streak,
# i.e. the agent that has gone longest without rotating off its current
# strategy. Stable tiebreak: the first agent with the maximum streak
# wins (matches the original inlined loops byte-for-byte). Echoes ""
# when no agents are configured so callers can `[ -z ... ]` test the
# result instead of carrying their own sentinel.
most_stuck_agent() {
  local i streak best_i=0 best_streak=-1
  for i in $(seq 1 "$NUM_AGENTS"); do
    streak=$(get_agent_strategy_streak "$i" 2>/dev/null || echo 0)
    if [ "${streak:-0}" -gt "$best_streak" ]; then
      best_streak="$streak"
      best_i="$i"
    fi
  done
  [ "$best_i" -ge 1 ] && printf '%s' "$best_i"
}

# Echo the first strategy in STRATEGY_ROTATION_ORDER that:
#   - appears in $1 (space-separated allow-list of candidates), AND
#   - does NOT appear in $2 (optional space-separated deny-list).
# Empty deny-list disables the second filter. Returns rc=1 (no output)
# when nothing matches so the caller can apply its own fallback.
#
# DEPRECATED in favour of pick_strategy_by_load when the queue is
# loaded; retained as a deterministic fallback (and for tests that
# specifically assert the ordering primitive). Callers should prefer
# pick_strategy_by_load, which scales with where the actual work is
# rather than biasing toward lower-numbered strategies.
first_strategy_in_order() {
  local allowed="$1" denied="${2:-}" s
  for s in "${STRATEGY_ROTATION_ORDER[@]}"; do
    case " $allowed " in *" $s "*) ;; *) continue ;; esac
    if [ -n "$denied" ]; then
      case " $denied " in *" $s "*) continue ;; esac
    fi
    printf '%s' "$s"
    return 0
  done
  return 1
}

# P0: load-weighted rotation pick. Replaces first_strategy_in_order's
# STRATEGY_ROTATION_ORDER bias with `argmax_{s in allowed} unclaimed_count(s)`,
# with random tie-breaks across strategies that share the same count.
#
# Why this matters: the old "lowest-numbered strategy wins" rule pinned
# rotated agents to S2/S3 even when S7 had 175 unclaimed cards and S2/S3
# had ~20 each. Multiple force-rotations in the same iteration then
# ping-ponged between S2 and S3 indefinitely because each was always the
# numerically-lowest missing strategy from the active set. Reading the
# queue's actual unclaimed distribution and routing the agent there
# solves both problems in one place.
#
# Inputs:
#   $1  space-separated allow-list of candidate strategies (typically
#       the unclaimed_card_strategies output)
#   $2  optional space-separated deny-list (strategies held by other
#       agents, so we fan out instead of doubling up)
#
# Output: a single strategy id (e.g. "S7") on stdout. Returns rc=0 on
# success, rc=1 with no output when allow-list is empty, the queue is
# empty/missing, jq is unavailable, or every candidate is denied. In
# that case the caller should fall back to first_strategy_in_order.
#
# Determinism: AUDIT_STRATEGY_TIEBREAK_INDEX (0-based integer) pins the
# tie-break selection — used by tests to assert specific outcomes
# without locking the production behaviour to a particular RANDOM seed.
# When unset, $RANDOM is consulted per call.
pick_strategy_by_load() {
  local allowed="$1" denied="${2:-}"
  [ -n "$allowed" ] || return 1
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -n "$cards_file" ] && [ -s "$cards_file" ] || return 1
  command -v jq >/dev/null 2>&1 || return 1

  local counts
  counts=$(unclaimed_strategy_counts 1) || return 1
  [ -n "$counts" ] || return 1

  local strat count c_strat c_count best_count=-1 best_strats=""
  for strat in $allowed; do
    [ -n "$strat" ] || continue
    case " $denied " in *" $strat "*) continue ;; esac
    count=0
    while IFS="$(printf '\t')" read -r c_strat c_count; do
      if [ "$c_strat" = "$strat" ]; then
        count="$c_count"
        break
      fi
    done <<< "$counts"
    case "$count" in ''|*[!0-9]*) count=0 ;; esac
    if [ "$count" -gt "$best_count" ]; then
      best_count="$count"
      best_strats="$strat"
    elif [ "$count" -eq "$best_count" ] && [ "$best_count" -ge 0 ]; then
      best_strats="${best_strats} ${strat}"
    fi
  done
  [ -n "$best_strats" ] || return 1
  # When every candidate strategy reports 0 unclaimed cards (e.g.
  # the single queue scan returned 0 for all of them), there is no
  # signal here to drive a load-based choice. Let the caller fall back
  # to first_strategy_in_order rather than picking randomly among zero
  # buckets — that fallback at least gives deterministic behaviour for
  # an already-empty queue.
  [ "$best_count" -gt 0 ] || return 1

  # shellcheck disable=SC2206  # word-split intentional
  local -a strat_arr=( $best_strats )
  local n="${#strat_arr[@]}"
  local idx
  if [ -n "${AUDIT_STRATEGY_TIEBREAK_INDEX:-}" ] \
     && [[ "${AUDIT_STRATEGY_TIEBREAK_INDEX}" =~ ^[0-9]+$ ]]; then
    idx="$AUDIT_STRATEGY_TIEBREAK_INDEX"
    [ "$idx" -ge "$n" ] && idx=$(( idx % n ))
  else
    idx=$(( RANDOM % n ))
  fi
  printf '%s' "${strat_arr[$idx]}"
}

# When STALL_STOP would fire but the queue still holds unclaimed cards
# on strategies no agent currently has, force-rotate the most-stuck
# agent(s) to one of those missing strategies. Bypasses the per-strategy
# evidence floor — at this point the floor signal isn't useful (the
# unclaimed S3/S7 cards are evidence enough that the agent's current
# strategy is the wrong one). Echoes the chosen mapping for the caller
# to log. Returns 0 if at least one agent was rotated, 1 if no rotation
# was possible (no unclaimed strategies are missing from the active set).
force_rotate_to_unclaimed_strategies() {
  local unclaimed active s
  unclaimed=$(unclaimed_card_strategies)
  active=$(active_agent_strategies)
  [ -n "$unclaimed" ] || return 1
  # Set difference: unclaimed - active.
  local missing_list=""
  for s in $unclaimed; do
    case " $active " in
      *" $s "*) ;;
      *) missing_list="${missing_list}${missing_list:+ }${s}" ;;
    esac
  done
  [ -n "$missing_list" ] || return 1

  local best_i target_strat prev_strat
  best_i=$(most_stuck_agent)
  [ -n "$best_i" ] || return 1
  # P0: load-weighted pick — route the rotated agent to the strategy
  # with the largest unclaimed pool, randomly tiebreaking when two
  # strategies are equally loaded. Falls back to first_strategy_in_order
  # only when the queue is empty / jq unavailable / every count is 0,
  # i.e. there's no load signal to drive the choice. The lower-numbered
  # bias of the fallback only ever fires in the cold-queue degenerate
  # case where it doesn't matter which strategy we pick.
  target_strat=$(pick_strategy_by_load "$missing_list" 2>/dev/null) \
    || target_strat=$(first_strategy_in_order "$missing_list") \
    || target_strat="${missing_list%% *}"
  prev_strat=$(get_agent_strategy "$best_i" 2>/dev/null || echo "?")
  set_agent_strategy "$best_i" "$target_strat"
  reset_agent_strategy_streak "$best_i"
  log "STALL_FORCE_ROTATE: agent=${best_i} $(strategy_tag "$prev_strat")→$(strategy_tag "$target_strat") — the queue has unclaimed work for strategies [${missing_list// /,}] that no agent currently holds (active=[${active// /,}]); rotating the most-stuck agent there to unblock the queue" | tee -a "$INDEX"
  return 0
}

# Secondary stall fallback. Triggered when every queue strategy is
# already held by some agent (so force_rotate_to_unclaimed_strategies
# cannot fire) but the queue still contains unclaimed cards in
# subsystems no agent currently holds. We pick the most-stuck agent and
# switch it to a strategy that has cards in one of those untouched
# subsystems; the diversity gate in claim_next_card (lib/workqueue.py)
# then naturally routes the agent to one of the untouched-subsystem
# cards on its next resume.
#
# Returns 0 if an agent was rotated, 1 otherwise. Pure: queries the
# card pool and the per-agent strategy state — no target-specific
# names, paths, or vocabulary.
force_rotate_to_unclaimed_subsystems() {
  local cands
  cands=$(unclaimed_strategies_in_untouched_subsystems 2>/dev/null || true)
  [ -n "$cands" ] || return 1
  local active_subs unclaimed_subs target_strat
  active_subs=$(active_agent_subsystems)
  unclaimed_subs=$(unclaimed_card_subsystems)
  # Untouched subsystems with unclaimed cards = unclaimed_subs - active_subs.
  local untouched="" s
  for s in $unclaimed_subs; do
    case " $active_subs " in
      *" $s "*) ;;
      *) untouched="${untouched}${untouched:+ }${s}" ;;
    esac
  done
  [ -n "$untouched" ] || return 1
  # P0: load-weighted pick across the helper's candidate strategies so
  # we route the rotated agent to where the unclaimed work actually
  # lives, not to the lowest-numbered strategy in
  # STRATEGY_ROTATION_ORDER. Fallback to the helper's first emission
  # preserves the prior deterministic behaviour for empty/zero-count
  # queues where no load signal is available.
  target_strat=$(pick_strategy_by_load "$cands" 2>/dev/null) \
    || target_strat="${cands%% *}"
  [ -n "$target_strat" ] || return 1
  local best_i prev_strat
  best_i=$(most_stuck_agent)
  [ -n "$best_i" ] || return 1
  prev_strat=$(get_agent_strategy "$best_i" 2>/dev/null || echo "?")
  # Avoid a no-op rotation. If the agent is already on the chosen
  # strategy, the diversity gate should be doing the work already; the
  # most useful nudge then is to clear its resume state so the next
  # resume re-picks a candidate from scratch (rather than re-reading a
  # stale prev_subsystem hint).
  if [ "$prev_strat" = "$target_strat" ]; then
    clear_agent_resume_state "$best_i" 2>/dev/null || true
    reset_agent_strategy_streak "$best_i" 2>/dev/null || true
    log "STALL_FORCE_REPIN: agent=${best_i} strategy=$(strategy_tag "$target_strat") kept; cleared resume state so it re-picks from the queue (untouched subsystems still available: [${untouched// /,}])" | tee -a "$INDEX"
    return 0
  fi
  set_agent_strategy "$best_i" "$target_strat"
  reset_agent_strategy_streak "$best_i"
  clear_agent_resume_state "$best_i" 2>/dev/null || true
  log "STALL_FORCE_REPIN: agent=${best_i} $(strategy_tag "$prev_strat")→$(strategy_tag "$target_strat") — re-pinning so the agent moves to an untouched subsystem next iteration (untouched: [${untouched// /,}], active: [${active_subs// /,}])" | tee -a "$INDEX"
  return 0
}

# One-line per-iteration queue snapshot. Lets you grep `index.log` for
# QUEUE: lines and see at a glance whether agent strategies/subsystems
# match where the unclaimed work actually is. Cheap: jq runs over a
# small JSONL file once per iteration. Silent (no log line) if jq is
# missing or the queue is empty — we never want this diagnostic to
# block the loop.
# Summarize card-claim activity since the iteration started. Reads
# state/claims.jsonl and counts events whose timestamp is at or after
# $1 (epoch seconds). Silent when the file is missing/empty or python3
# is unavailable — diagnostic only, must never block the loop.
log_card_activity_since() {
  local since_epoch="$1"
  local claims_file="${RESULTS_DIR:-}/state/claims.jsonl"
  [ -s "$claims_file" ] || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  case "$since_epoch" in ''|*[!0-9]*) return 0 ;; esac
  local summary
  summary=$(python3 "$SCRIPT_ROOT/lib/audit_helpers.py" claims-activity-since \
    "$claims_file" "$since_epoch" 2>/dev/null || true)
  [ -n "$summary" ] || return 0
  log "CARDS: ${summary}" | tee -a "$INDEX"
}

log_queue_state() {
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  [ -s "$cards_file" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  local rows
  rows=$(effective_work_card_rows)
  [ -n "$rows" ] || return 0
  local total unclaimed claimed blocked other by_strat by_sub active_strats active_subs top_score
  local summary
  summary=$(printf '%s\n' "$rows" | jq -n -r '
    def hist($m; $limit):
      ($m
       | to_entries
       | sort_by(-.value, .key)
       | if $limit == 0 then . else .[:$limit] end
       | map("\(.key):\(.value)")
       | join(" "));
    reduce inputs as $r (
      {total:0, unclaimed:0, claimed:0, blocked:0, top_score:null, by_strategy:{}, by_subsystem:{}};
      .total += 1
      | ($r.status // "") as $status
      | if $status == "unclaimed" then
          .unclaimed += 1
          | ($r.score // 0 | tonumber? // 0) as $score
          | .top_score = ([.top_score // $score, $score] | max)
          | ($r.strategy // "?") as $strategy
          | .by_strategy[$strategy] = ((.by_strategy[$strategy] // 0) + 1)
          | ($r.subsystem // "?") as $subsystem
          | .by_subsystem[$subsystem] = ((.by_subsystem[$subsystem] // 0) + 1)
        elif $status == "claimed" then
          .claimed += 1
        elif $status == "blocked" then
          .blocked += 1
        else
          .
        end
    )
    | [
        .total,
        .unclaimed,
        .claimed,
        .blocked,
        (.total - .unclaimed - .claimed - .blocked),
        (.top_score // "?"),
        hist(.by_strategy; 0),
        hist(.by_subsystem; 8)
      ]
    | @tsv
  ' 2>/dev/null) || return 0
  [ -n "$summary" ] || return 0
  IFS="$(printf '\t')" read -r total unclaimed claimed blocked other top_score by_strat by_sub <<< "$summary"
  [ "${unclaimed:-0}" -gt 0 ] || return 0
  by_strat=$(fmt_strategy_histogram "$by_strat")
  active_strats=$(active_agent_strategies)
  active_strats=$(fmt_strategy_list "$active_strats")
  active_subs=$(active_agent_subsystems)
  log "QUEUE: total=${total} unclaimed=${unclaimed} claimed=${claimed} blocked=${blocked}${other:+ other=${other}} top_score=${top_score:-?} | by_strategy=${by_strat:-none} | by_subsystem(top8)=${by_sub:-none} | agents_on=${active_strats:-none} subsystems_on=${active_subs:-none}" | tee -a "$INDEX"
}

# Pick the strategy a brand-new agent should boot on at cold start.
# Replaces the old "always S1" default that wedged every fresh agent
# onto Prior-fix-review — the bucket most likely to be auto-discarded
# by Claude Code auto-memory (the "saturated, skip future sweeps"
# entries from previous runs) and structurally the thinnest tier
# (typical pool: 9 S1 vs 175 S7 cards in pcre2).
#
# Algorithm: rank non-S1 strategies by unclaimed-card count (largest
# first) and round-robin by agent_num. Agent 1 takes the top strategy,
# agent 2 the second, agent N the (N mod K)-th when K distinct non-S1
# strategies exist. Falls back to S1 when the queue has no non-S1
# cards or jq is unavailable.
#
# Earlier versions inspected peer agents' tracking files to avoid two
# agents booting onto the same strategy. The peer lookup was fragile
# (one revision called back into get_agent_strategy, which falls
# through to this function for cold-start peers and formed an
# unbounded $(...) mutual recursion that fork-bombed the cold-start
# prompt build until the wall-budget killer fired). Round-robin by
# agent_num produces the same observable fan-out in the typical case
# without any cross-agent state inspection — for K >= NUM_AGENTS the
# fan-out is perfect; for K < NUM_AGENTS some agents share a
# strategy, which the rotation gate already tolerates downstream.
pick_cold_start_strategy() {
  local agent_num="$1"
  local cards_file="${RESULTS_DIR:-}/work-cards.jsonl"
  if [ -z "$cards_file" ] || [ ! -s "$cards_file" ] || ! command -v jq >/dev/null 2>&1; then
    printf '%s' "S1"
    return 0
  fi

  local ranked_file="${ITERATION_CACHE_DIR:-}/cold_start_strategies.txt"
  if [ -n "${ITERATION_CACHE_DIR:-}" ] && [ -f "$ranked_file" ]; then
    local -a cached_ranked=()
    local cached_strat
    while IFS= read -r cached_strat; do
      case "$cached_strat" in
        S[2-9]) cached_ranked+=("$cached_strat") ;;
      esac
    done < "$ranked_file"
    local cached_count=${#cached_ranked[@]}
    if [ "$cached_count" -gt 0 ]; then
      printf '%s' "${cached_ranked[$(( (agent_num - 1) % cached_count ))]}"
      return 0
    fi
    printf '%s' "S1"
    return 0
  fi

  local -a ranked=()
  local strat _count
  while IFS="$(printf '\t')" read -r strat _count; do
    [ -n "$strat" ] && ranked+=("$strat")
  done < <(unclaimed_strategy_counts 2)
  local count=${#ranked[@]}
  if [ "$count" -eq 0 ]; then
    printf '%s' "S1"
    return 0
  fi
  # 1-based round-robin: agent 1 → top strategy, agent 2 → second, etc.
  printf '%s' "${ranked[$(( (agent_num - 1) % count ))]}"
}

# Pick the strategy an exhausted agent should be assigned for its next
# cold-start. Replaces the old "always S1" reset that caused agents to
# permanently wedge on S1 after each iteration-end exhaustion. Selection
# order:
#   1. A strategy with unclaimed cards that no *other* agent currently holds
#      (per STRATEGY_ROTATION_ORDER for a stable preference).
#   2. The next strategy after the agent's prior one in STRATEGY_ROTATION_ORDER.
#   3. S1 as a last resort (only when steps 1+2 produced no candidate).
# Pure: queries card pool + active agent strategies, no target-specific
# vocabulary. Echoes the chosen strategy on stdout; never fails.
pick_exhaustion_recovery_strategy() {
  local agent_num="$1"
  local prior other_active="" unclaimed="" i s candidate=""
  prior=$(get_agent_strategy "$agent_num" 2>/dev/null || echo "")
  # Active strategies on *other* agents (so we can avoid duplicating
  # coverage when the queue offers an unused alternative).
  for i in $(seq 1 "$NUM_AGENTS"); do
    [ "$i" = "$agent_num" ] && continue
    s=$(get_agent_strategy "$i" 2>/dev/null || true)
    [ -n "$s" ] && other_active="${other_active} ${s} "
  done
  unclaimed=$(unclaimed_card_strategies 2>/dev/null || true)
  # Step 1: prefer the unclaimed strategy with the largest pool that no
  # other agent currently holds. P0 swap-in: was first_strategy_in_order,
  # which biased toward S1/S2/S3 even when S7 had an order-of-magnitude
  # more cards. Fall through to the order-based fallback when there's no
  # load signal (empty queue, jq unavailable, all-zero counts).
  candidate=$(pick_strategy_by_load "$unclaimed" "$other_active" 2>/dev/null) \
    || candidate=$(first_strategy_in_order "$unclaimed" "$other_active") \
    || candidate=""
  if [ -n "$candidate" ]; then
    printf '%s' "$candidate"
    return 0
  fi
  # Step 2: rotate forward from the agent's prior strategy.
  if [ -n "$prior" ]; then
    candidate=$(next_strategy_in_rotation "$prior" 2>/dev/null || echo "")
    if [ -n "$candidate" ] && [ "$candidate" != "$prior" ]; then
      printf '%s' "$candidate"
      return 0
    fi
  fi
  # Step 3: queue might be empty or all-claimed; fall back to S1 so the
  # cold-start path has a defined starting point.
  printf '%s' "S1"
}

# Find agents that ended the iteration on the *same* subsystem (typical
# at cold-start, where each agent independently picks the top-ranked
# unclaimed subsystem). For each collision group of size N>1 keep the
# agent with the most accumulated probe activity (asan_runs / hits) and
# clear the rest's resume state + rotate their strategy so the next
# iteration's planner re-pulls fresh subsystem hints from the queue.
#
# Returns 0 if at least one collision was found and resolved, 1 otherwise.
# Pure: no target-specific names; reads get_agent_subsystem +
# pick_exhaustion_recovery_strategy.
# Canonical (file, function) key for an agent-reported subsystem string.
# Different agents observe different lines for the same bug; the work-
# card scorer also produces qualified C++ names ("Store::render") while
# agents may strip the class qualifier. Without a normalized key the
# subsystem-collision detector and the queue-side overlap gate miss the
# duplicate and we end up with N agents on the same (file, function).
#
# Transformations (applied in order):
#   1. Strip trailing line numbers — one or more ":NNN" segments.
#   2. Strip C++ class qualifiers — any "Identifier::" sequence.
#
# Examples (verified by tests/test_audit_normalize_subsystem.sh):
#   src/sampledb.cpp:Store::write_selected:247 -> src/sampledb.cpp:write_selected
#   src/sampledb.cpp:write_selected:241        -> src/sampledb.cpp:write_selected
#   Store::render:266                          -> render
#   src/main.cpp                               -> src/main.cpp
#   ""                                         -> unknown
#   unknown                                    -> unknown
# Canonical subsystem identity = (file_part, last_qualifier_or_empty, function_name),
# emitted as "file|last_q|func" (pipe-delimited) for downstream comparison
# via _subsystem_keys_collide. Two keys "collide" — i.e. refer to the same
# function — when their file and function fields match AND their last
# qualifier fields match, treating an empty qualifier as a wildcard so an
# agent that reported the function bare matches any class-qualified
# variant of the same function in the same file.
#
# Why keep the innermost qualifier instead of stripping every "::":
# strip-all would conflate Foo::bar and Foo::Baz::bar in the same file as
# one subsystem — distinct nested-class methods with potentially distinct
# bugs would be treated as a single agent-collision and one of them would
# get displaced. Keeping the innermost qualifier preserves that
# distinction while still letting Store::write_selected (qualified) and
# write_selected (bare) recognize each other as the same function.
_normalize_subsystem_key() {
  local raw="$1"
  [ -z "$raw" ] && { printf 'unknown'; return; }
  [ "$raw" = "unknown" ] && { printf '%s' "$raw"; return; }
  awk -v s="$raw" 'BEGIN {
    # Strip one-or-more trailing ":NNN" line-number segments.
    sub(/(:[0-9]+)+$/, "", s)
    # Split on "::". After this:
    #   parts[N]   = leaf function name
    #   parts[N-1] = innermost class qualifier (if N >= 2)
    #   parts[1]   = "<file>:<firstQual>" or just "<firstQual>" (if no file prefix)
    # Variable names avoid "func" because BSD awk on macOS treats it as
    # a reserved word.
    n = split(s, parts, "::")
    fn = parts[n]
    lq = ""
    fp = ""
    if (n == 1) {
      # No "::" — parts[1] is either "<file>:<fn>" or just "<fn>".
      if (match(parts[1], /:[A-Za-z_][A-Za-z_0-9]*$/)) {
        fp = substr(parts[1], 1, RSTART - 1)
        fn = substr(parts[1], RSTART + 1)
      } else {
        fn = parts[1]
      }
    } else if (n == 2) {
      # "<file>:<qual>::<fn>" or "<qual>::<fn>".
      if (match(parts[1], /:[A-Za-z_][A-Za-z_0-9]*$/)) {
        fp = substr(parts[1], 1, RSTART - 1)
        lq = substr(parts[1], RSTART + 1)
      } else {
        lq = parts[1]
      }
    } else {
      # n >= 3 — innermost qualifier is parts[n-1] (no file glue possible
      # here). File part, if any, is glued to the outermost qualifier in
      # parts[1].
      lq = parts[n-1]
      if (match(parts[1], /:[A-Za-z_][A-Za-z_0-9]*$/)) {
        fp = substr(parts[1], 1, RSTART - 1)
      }
    }
    print fp "|" lq "|" fn
  }'
}

# Two canonical keys refer to the same function under the wildcard rule:
# (file, func) must match exactly; last qualifiers match if equal or if
# either is empty. Empty / "unknown" / malformed (non-3-tuple) keys never
# collide.
_subsystem_keys_collide() {
  local k1="$1" k2="$2"
  [ -z "$k1" ] || [ -z "$k2" ] && return 1
  [ "$k1" = "unknown" ] || [ "$k2" = "unknown" ] && return 1
  case "$k1" in *\|*\|*) ;; *) return 1 ;; esac
  case "$k2" in *\|*\|*) ;; *) return 1 ;; esac
  local f1 r1 q1 fn1 f2 r2 q2 fn2
  f1="${k1%%|*}"; r1="${k1#*|}"
  q1="${r1%%|*}"; fn1="${r1#*|}"
  f2="${k2%%|*}"; r2="${k2#*|}"
  q2="${r2%%|*}"; fn2="${r2#*|}"
  [ "$f1" = "$f2" ] || return 1
  [ "$fn1" = "$fn2" ] || return 1
  [ "$q1" = "$q2" ] || [ -z "$q1" ] || [ -z "$q2" ]
}

diversify_subsystem_collisions() {
  # Pairwise collision detection across active agents. Two agents collide
  # when _subsystem_keys_collide returns 0 (their canonical (file, func)
  # match, with last-qualifier wildcard semantics). The wildcard rule means
  # straight group-by-key in awk would miss the qualified-vs-bare case
  # (`Store::write_selected` and bare `write_selected`), so we iterate
  # pairs and probe via the helper. NUM_AGENTS is small (typically 2–3),
  # so O(N²) is fine.
  local i a b s skey
  local -a key_by_agent=() disp_by_agent=()
  for i in $(seq 1 "$NUM_AGENTS"); do
    key_by_agent[$i]=""
    disp_by_agent[$i]=""
    s=$(get_agent_subsystem "$i" 2>/dev/null || echo "")
    [ -z "$s" ] && continue
    [ "$s" = "unknown" ] && continue
    skey=$(_normalize_subsystem_key "$s")
    [ -z "$skey" ] || [ "$skey" = "unknown" ] && continue
    key_by_agent[$i]="$skey"
    disp_by_agent[$i]="$s"
  done

  local resolved=0
  local resolved_agents=" "  # space-padded list of already-handled agents
  for a in $(seq 1 "$NUM_AGENTS"); do
    [ -z "${key_by_agent[$a]:-}" ] && continue
    case "$resolved_agents" in *" $a "*) continue ;; esac
    # Build the collision group anchored at a.
    local group="$a"
    for b in $(seq $((a + 1)) "$NUM_AGENTS"); do
      [ -z "${key_by_agent[$b]:-}" ] && continue
      case "$resolved_agents" in *" $b "*) continue ;; esac
      if _subsystem_keys_collide "${key_by_agent[$a]}" "${key_by_agent[$b]}"; then
        group="$group $b"
      fi
    done
    # Singleton — no collision involving a.
    case "$group" in *" "*) ;; *) continue ;; esac
    # Keeper = highest probe activity, ties broken by smallest agent_num.
    local best_agent="" best_score=-1 cand_score agent keeper
    for agent in $group; do
      cand_score=$(agent_probe_activity_score "$agent" 2>/dev/null || echo 0)
      if [ "${cand_score:-0}" -gt "$best_score" ]; then
        best_score="$cand_score"
        best_agent="$agent"
      fi
    done
    keeper="${best_agent:-${group%% *}}"
    local recovery_pair prev_strat next_strat keeper_disp agent_disp
    keeper_disp="${disp_by_agent[$keeper]}"
    for agent in $group; do
      resolved_agents="${resolved_agents}${agent} "
      [ "$agent" = "$keeper" ] && continue
      agent_disp="${disp_by_agent[$agent]}"
      recovery_pair=$(recover_exhausted_agent "$agent" "subsystem-collision")
      prev_strat="${recovery_pair%% *}"
      next_strat="${recovery_pair##* }"
      log "SUBSYSTEM_DIVERSIFY: agent ${agent} (subsystem='${agent_disp}') collides with keeper ${keeper} (subsystem='${keeper_disp}') — same canonical (file, function); keeping agent ${keeper} (more probe activity); resetting agent ${agent} and rotating its strategy $(strategy_tag "$prev_strat")→$(strategy_tag "$next_strat") so it picks fresh work next iteration" | tee -a "$INDEX"
      resolved=1
    done
  done
  [ "$resolved" -eq 1 ] || return 1
  return 0
}

# Cheap proxy for "this agent has invested the most effort in its
# current subsystem". Used as a tiebreak when N agents collide on the
# same subsystem so the *least* invested ones get re-pinned, not the
# most. Reads the agent's state file when possible; returns 0 on
# missing data so we don't bias toward unknown agents.
agent_probe_activity_score() {
  local agent_num="$1"
  local state runs hits score
  state=$(state_file_path "$agent_num" 2>/dev/null || echo "")
  [ -n "$state" ] && [ -f "$state" ] || { echo 0; return 0; }
  # grep -c exits 1 with "0" on stdout when there are zero matches.
  # The naive "$(grep -c ... || echo 0)" form then produces "0\n0"
  # which breaks `$((..))`. Sink stderr, take the first numeric line.
  runs=$(grep -cE '^- \[' "$state" 2>/dev/null | head -1)
  hits=$(grep -cE 'asan_runs|HITS:' "$state" 2>/dev/null | head -1)
  runs=${runs:-0}
  hits=${hits:-0}
  score=$((runs + hits))
  echo "$score"
}

# Convenience wrapper: archive + clear resume state + rotate to a
# non-S1-monoculture strategy + reset streak. Used by both the pre-launch
# and post-iteration exhaustion handlers so they stay in sync. Echoes the
# (prev, next) strategy pair on stdout in "prev next" form for logging.
recover_exhausted_agent() {
  local agent_num="$1"
  local reason="${2:-exhausted}"
  local prev next
  prev=$(get_agent_strategy "$agent_num" 2>/dev/null || echo "")
  next=$(pick_exhaustion_recovery_strategy "$agent_num")
  archive_exhausted_agent_state "$agent_num" "$reason"
  clear_agent_resume_state "$agent_num"
  set_agent_strategy "$agent_num" "$next"
  reset_agent_strategy_streak "$agent_num"
  printf '%s %s' "${prev:-?}" "$next"
}

hard_stop_if_target_exhausted() {
  if target_exhausted_hard_stop_ready; then
    if eligible_work_card_exists; then
      # Before stalling, see if the queue holds unclaimed cards on
      # strategies no agent currently has. If yes, force-rotate one
      # agent and keep running — the stall would otherwise quit while
      # genuinely-actionable work sits idle.
      if force_rotate_to_unclaimed_strategies; then
        # Allow another iteration before stalling again.
        dry_streak=0
        return 1
      fi
      # Secondary fallback: every queue strategy is held by some agent,
      # but the queue still has cards in subsystems no agent reaches.
      # Repin one agent toward those subsystems before giving up.
      if force_rotate_to_unclaimed_subsystems; then
        dry_streak=0
        return 1
      fi
      log "STALL_STOP: dry_streak=${dry_streak:-0}/${MAX_DRY_SESSIONS} and the only signals left are stale (no open hypotheses, no new fuzz leads, no target source changes) — stopping the audit so we don't burn cycles on a dead queue" | tee -a "$INDEX"
      record_exhaustion_heartbeat "stalled-no-new-evidence"
    else
      if expand_structured_work_cards_if_exhausted; then
        return 1
      fi
      write_queue_exhaustion_report
      record_exhaustion_heartbeat "queue-exhausted-prelaunch"
    fi
    clear_all_agent_resume_state
    return 0
  fi
  return 1
}

archive_exhausted_agent_state() {
  local agent_num="$1"
  local reason="${2:-exhausted}"
  local live
  live=$(state_file_path "$agent_num")
  [ -f "$live" ] || return 0
  local archive_dir ts
  archive_dir="$RESULTS_DIR/.state_archive"
  mkdir -p "$archive_dir" 2>/dev/null || true
  ts=$(date +%Y%m%d_%H%M%S)
  mv "$live" "${archive_dir}/AUDIT_STATE-${agent_num}.${reason}.${ts}.md" 2>/dev/null || rm -f "$live"
}

archive_prelaunch_exhausted_states() {
  local i active
  for i in $(seq 1 "$NUM_AGENTS"); do
    local sf
    sf=$(state_file_path "$i")
    [ -f "$sf" ] || continue
    active=$(count_active_hypotheses_for_agent "$i" 2>/dev/null || echo 0)
    if [ "${active:-0}" -eq 0 ]; then
      local recovery_pair prev_strat next_strat
      recovery_pair=$(recover_exhausted_agent "$i" "prelaunch-exhausted")
      prev_strat="${recovery_pair%% *}"
      next_strat="${recovery_pair##* }"
      log "PRELAUNCH_EXHAUSTION: agent ${i} has no open hypotheses going into this iteration — archiving its state so it cold-starts (a deep-investigation session with nothing to investigate would be wasted); rotating strategy $(strategy_tag "$prev_strat")→$(strategy_tag "$next_strat")" | tee -a "$INDEX"
    fi
  done
}

# Extract the subsystem an agent is focused on from its state file header.
# Prefers structured JSONL when available, otherwise delegates to
# lib/parse_state.py which runs the four-stage markdown extraction
# (Primary Subsystem → Hypothesis Queue → Entry Point Coverage → grep).
get_agent_subsystem() {
  local agent_num="$1"
  local structured_sub
  structured_sub=$(structured_state_agent_subsystem "$agent_num" 2>/dev/null || true)
  if [ -n "$structured_sub" ] && [ "$structured_sub" != "unknown" ]; then
    echo "$structured_sub"
    return
  fi
  local f
  f=$(state_file_path "$agent_num")
  [ -f "$f" ] || { echo "unknown"; return; }
  local args=()
  if [ "${IS_BROWSER_TARGET:-0}" -eq 1 ]; then
    args+=(--subsystems "$SCRIPT_ROOT/lib/subsystems/${TARGET_SLUG:-firefox}.txt")
  fi
  python3 "$SCRIPT_ROOT/lib/parse_state.py" subsystem "$f" \
    ${args[@]+"${args[@]}"} 2>/dev/null \
    || echo "unknown"
}

# Map agent number → execution mode. Agents 1..BROWSER_AGENTS drive the
# browser via run-asan.sh browser; the remainder drive the JS shell or
# xpcshell. The split is positional so per-agent state files are stable
# across runs even if the user retunes the BROWSER_AGENTS/SHELL_AGENTS
# knobs.
agent_mode() {
  local agent_num="$1"
  if [ "$IS_BROWSER_TARGET" -eq 0 ]; then
    echo generic
  elif [ "$agent_num" -le "$BROWSER_AGENTS" ]; then
    echo browser
  else
    echo shell
  fi
}

# Map agent number → role. Roles shape the prompt's emphasis:
#   "analysis"  — deep code review, prior-fix review, data flow tracing.
#                 No "testcase by turn 20" pressure. Output: hypotheses
#                 with full data flow traces, guard analysis, and
#                 concrete reproduction plans.
#   "reproduce" — testcase writing, ASan runs, variant mutation, crash
#                 improvement. Takes hypotheses from analysis agents or
#                 its own state file and turns them into crashes.
#
# Override: AGENT_ROLES="analysis,reproduce,analysis" (comma-separated,
# one per agent). Default: alternate starting with reproduce for agent 1.
AGENT_ROLES="${AGENT_ROLES:-}"

agent_role() {
  local agent_num="$1"
  # User override via comma-separated AGENT_ROLES env var
  if [ -n "$AGENT_ROLES" ]; then
    local role
    role=$(printf '%s' "$AGENT_ROLES" | cut -d',' -f"$agent_num" 2>/dev/null)
    case "$role" in
      analysis|reproduce) echo "$role"; return ;;
    esac
  fi
  # Default assignment: agent 1 = reproduce (browser), agent 2 = analysis
  # (shell — deep code review of JS engine), agent 3+ = reproduce.
  # Analysis agents are the LLM's strength: understanding code semantics,
  # recognizing incomplete patches, tracing cross-file data flows.
  case "$agent_num" in
    2) echo "analysis" ;;
    *) echo "reproduce" ;;
  esac
}

# Cold-start subsystem candidates per agent mode. Browser mode covers code
# reachable from web content via the browser launch path (DOM, layout,
# editor, image decoders, fonts, parser/html); shell mode covers code
# reachable from the js shell / xpcshell (JS engine, JIT, Wasm, irregexp,
# self-hosted builtins, xpcshell XPCOM).
#
# The lists are NOT hardcoded here — they live in the per-target overlay
# lib/subsystems/<slug>.txt ("<mode> <path>" per line), which is also the
# source for path->subsystem attribution (lib/parse_state.py). Adding a
# line there lets agents pick that subsystem; no code change. A target
# with no overlay file simply yields no cold-start candidates.
_mode_subsystems() {
  local want="$1" f
  f="$SCRIPT_ROOT/lib/subsystems/${TARGET_SLUG:-firefox}.txt"
  [ -f "$f" ] || return 0
  awk -v want="$want" '
    { sub(/#.*/, "") }
    NF >= 2 && ($1 == want || $1 == "both") { print $2 }
  ' "$f"
}
browser_mode_subsystems() {
  _mode_subsystems browser
}
shell_mode_subsystems() {
  _mode_subsystems shell
}

# Collect current subsystem claims across the whole pool.
collect_claimed_subsystems() {
  local i sub
  for i in $(seq 1 "$NUM_AGENTS"); do
    sub=$(get_agent_subsystem "$i")
    [ "$sub" = "unknown" ] && continue
    printf '%s\t%s\n' "$i" "$sub"
  done
}

# Check if any agents share the same subsystem (overlap detection).
detect_subsystem_overlap() {
  collect_claimed_subsystems \
    | awk -F'\t' '
        {
          if (agents[$2] == "") {
            agents[$2] = $1
          } else {
            agents[$2] = agents[$2] ", " $1
          }
          count[$2]++
        }
        END {
          for (subsystem in count) {
            if (count[subsystem] > 1) {
              print "Agents " agents[subsystem] " overlap on " subsystem
            }
          }
        }
      ' \
    | sort
}

detect_agent_overlap() {
  local agent_num="$1"
  collect_claimed_subsystems \
    | awk -F'\t' -v target="$agent_num" '
        {
          if (agents[$2] == "") {
            agents[$2] = $1
          } else {
            agents[$2] = agents[$2] ", " $1
          }
          count[$2]++
          if ($1 == target) mine[$2] = 1
        }
        END {
          for (subsystem in mine) {
            if (count[subsystem] > 1) {
              print "Agents " agents[subsystem] " overlap on " subsystem
            }
          }
        }
      ' \
    | sort
}


# Removed: is_state_productive() — the scratch-ASan inspection allowed
# untriaged scratch artifacts (rejected/dedup'd crashes that never
# reached `crashes/`) to count as PRODUCTIVE and reset the dry streak.
# That kept STALL_STOP from ever firing on cells where the agent
# produced scratch noise without escalating anything. Productivity is
# now defined as: at least one new confirmed finding or crash candidate
# this iteration. See agent_iteration_productive() for the per-agent
# variant.

agent_iteration_productive() {
  local agent_num="$1"
  [ -f "$COUNTER_FILE" ] || return 1

  # An agent is productive when triage promoted at least one CRASH-*/
  # FIND-* artifact for them this iteration. The prior implementation
  # also returned 0 for any non-autodiscard ASan scratch file, which
  # let a rejected/dedup'd crash keep the per-agent dry-streak from
  # bumping — and let the global PRODUCTIVE 0/0 branch fire. Scratch
  # is an intermediate; only the triage outcome counts.
  local d
  for d in "$RESULTS_DIR"/crashes/CRASH-*-"${agent_num}" "$RESULTS_DIR"/findings/FIND-*-"${agent_num}"-*; do
    [ -e "$d" ] || continue
    [ "$d" -nt "$COUNTER_FILE" ] && return 0
  done

  return 1
}


kill_zombie_asan() {
  [ "$IS_BROWSER_TARGET" -eq 1 ] || return 0
  # Kill zombie ASan browser processes left over from previous iterations.
  # Target only processes using temp profiles (audit-spawned), not actively
  # running instances. We kill processes whose temp profile dirs no longer
  # exist (the owning run-asan.sh already cleaned up and exited).
  for pid in $(pgrep -f "asan-profile-" 2>/dev/null); do
    local cmdline
    cmdline="$(ps -p "$pid" -o args= 2>/dev/null)" || continue
    local profile_dir
    profile_dir="$(echo "$cmdline" | grep -oE '/[^ ]*asan-profile-[^ ]*' | head -1 || true)"
    if [ -n "$profile_dir" ] && [ ! -d "$profile_dir" ]; then
      kill "$pid" 2>/dev/null || true
    fi
  done
}

# ─── State trim helper ────────────────────────────────────────────
# Auto-archive DISCARDED hypotheses from per-agent state files to prevent
# state bloat. Agents were generating 50+ hypotheses per session and the
# combined state reached 74KB, causing context compression and timeouts.

trim_agent_state() {
  local agent_num="$1"
  local state_file
  state_file=$(state_file_path "$agent_num")

  [ -f "$state_file" ] || return 0

  local line_count
  line_count=$(wc -l < "$state_file" 2>/dev/null | tr -d ' ' || echo 0)

  if [ "$line_count" -gt "$MAX_STATE_LINES_PER_AGENT" ]; then
    log "Trimming Agent${agent_num}'s state file: it has ${line_count} lines which is over MAX_STATE_LINES_PER_AGENT=${MAX_STATE_LINES_PER_AGENT} (large state files inflate every prompt — trimming keeps the audit affordable)"

    # Remove DISCARDED rows from the hypothesis table (keep header and non-DISCARDED rows).
    # IMPORTANT: PENDING/INVESTIGATING/NEEDS_TESTCASE rows and their associated
    # Working Context code snippets are preserved. These represent live leads
    # that need multi-iteration depth — losing them forces agents to re-discover
    # the same code paths next iteration.
    audit_sed_in_place '/DISCARDED/d' "$state_file" 2>/dev/null || true
    # Remove terminal Research Directions lines from the live state so they
    # don't prime the next agent toward already-dead areas.
    audit_sed_in_place -E '/exhausted for now|non-crashing|timed out 5\/5|no (sanitizer|asan|ubsan|msan|tsan|race) (signal|output|trace|diagnostic)|stay(ed)? clean|executed 5\/5 (clean|without)/Id' "$state_file" 2>/dev/null || true

    # Trim history sections to keep state compact. Active leads are never touched.
    python3 "$SCRIPT_ROOT/lib/trim_state.py" "$state_file"

    local new_count
    new_count=$(wc -l < "$state_file" 2>/dev/null | tr -d ' ' || echo 0)
    log "Agent${agent_num} state trimmed from ${line_count} → ${new_count} lines; PENDING and INVESTIGATING hypothesis rows were kept verbatim, older DISCARDED/closed context was dropped" | tee -a "$INDEX"
  fi

}

# ─── State merge helper ───────────────────────────────────────────
# After each iteration, merge per-agent state files into the combined
# AUDIT_STATE.md so agents can see each other's findings next iteration.
# Trim bloated state files FIRST, then merge.

merge_audit_state() {
  # Step 1: Trim bloated per-agent state files before merging
  for i in $(seq 1 "$NUM_AGENTS"); do
    trim_agent_state "$i"
  done

  # Step 2: Generate the canonical human-readable view from structured state.
  # Per-agent AUDIT_STATE-N.md files are legacy optional context; structured
  # JSONL owns scheduling, resume, and queue state.
  local combined
  combined=$(combined_state_path)
  if [ -x "bin/state" ]; then
    if bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
        summary > "${combined}.tmp" 2>/dev/null; then
      {
        echo ""
        echo "## Legacy Per-Agent Markdown"
        echo ""
        echo "_Optional context only. Agents should start from \`bin/state resume\`; these files are not the source of truth._"
        for i in $(seq 1 "$NUM_AGENTS"); do
          local f
          f=$(state_file_path "$i")
          if [ -f "$f" ]; then
            echo ""
            echo "---"
            echo "### Agent ${i} Legacy State"
            head -n "$MAX_STATE_LINES_PER_AGENT" "$f"
          fi
        done
      } >> "${combined}.tmp"
      mv "${combined}.tmp" "$combined"
      return 0
    fi
  fi

  # Fallback for older/manual sessions that have markdown state but no usable
  # structured state command.
  {
    echo "# Audit State Journal (Combined)"
    echo "## Last merged: $(date)"
    echo ""
    echo "**NOTE:** Only PENDING/INVESTIGATING/NEEDS_TESTCASE/ENV-BLOCKED hypotheses shown."
    echo ""
    for i in $(seq 1 "$NUM_AGENTS"); do
      local f
      f=$(state_file_path "$i")
      if [ -f "$f" ]; then
        echo ""
        echo "---"
        echo "## Agent ${i} State"
        cat "$f"
        echo ""
      fi
    done
  } > "${combined}.tmp"

  # Truncate to keep combined state readable. Previously used head -n which
  # dropped Agent 2's section entirely when Agent 1's content overflowed the
  # budget. Instead, give each agent an equal slice of the budget so both
  # agents' PENDING/INVESTIGATING hypotheses remain visible.
  if [ "$(wc -l < "${combined}.tmp")" -gt "$COMBINED_STATE_MAX_LINES" ]; then
    local per_agent_lines=$(( COMBINED_STATE_MAX_LINES / NUM_AGENTS ))
    [ "$per_agent_lines" -ge 1 ] || per_agent_lines=1
    {
      echo "# Audit State Journal (Combined)"
      echo "## Last merged: $(date)"
      echo ""
      echo "**NOTE:** Only PENDING/INVESTIGATING/NEEDS_TESTCASE/ENV-BLOCKED hypotheses shown."
      echo "Combined view was truncated (budget=${COMBINED_STATE_MAX_LINES} lines, ~${per_agent_lines}/agent). Read per-agent files for full state."
      echo ""
      echo "### Quick Index (subsystem + pending per agent)"
      for i in $(seq 1 "$NUM_AGENTS"); do
        local f nav_sub nav_pending nav_mode
        f=$(state_file_path "$i")
        if [ -f "$f" ]; then
          nav_sub=$(get_agent_subsystem "$i" 2>/dev/null || echo "unknown")
          nav_pending=$(grep -c "PENDING\|INVESTIGATING\|NEEDS_TESTCASE" "$f" 2>/dev/null || true)
          nav_mode=$(agent_mode "$i")
          echo "- **Agent ${i}** (${nav_mode}): \`${nav_sub}\`, ${nav_pending:-0} active — full state: \`$(state_file_path "$i")\`"
        fi
      done
      for i in $(seq 1 "$NUM_AGENTS"); do
        local f
        f=$(state_file_path "$i")
        if [ -f "$f" ]; then
          echo ""
          echo "---"
          echo "## Agent ${i} State (truncated to ${per_agent_lines} lines)"
          head -n "$per_agent_lines" "$f"
        fi
      done
    } > "$combined"
  else
    mv "${combined}.tmp" "$combined"
  fi
  rm -f "${combined}.tmp"

  # Count confirmed security findings and pending security crash candidates
  # separately so user-facing metrics never call crash candidates
  # "findings". crashes-rejected/ is intentionally excluded — it is the
  # non-finding quarantine, not part of the active result set.
  local find_count crash_count
  find_count=$(count_confirmed_findings 2>/dev/null || echo 0)
  crash_count=$(count_security_crash_candidates 2>/dev/null || echo 0)
  if [ "${find_count:-0}" -gt 0 ] || [ "${crash_count:-0}" -gt 0 ]; then
    log "Active results so far: ${crash_count} crash candidate(s) under triage and ${find_count} confirmed finding(s) — see ${RESULTS_DIR}/crashes/ and ${RESULTS_DIR}/findings/ for the artifacts" | tee -a "$INDEX"
  fi
}


work_cards_path() {
  printf '%s/work-cards.jsonl' "$RESULTS_DIR"
}

patch_cards_path() {
  printf '%s/patch-cards.jsonl' "$RESULTS_DIR"
}

# Content signature for a target tree without a usable VCS revision:
# sha1 over (relpath, content bytes) of the source files recon actually
# sweeps — the extension set comes from the shared languages registry and
# the directory exclusions from recon_slicer.SKIP_DIR_NAMES, so the key
# covers exactly the files recon reads (a .tsx/.pyx edit invalidates it
# the same way a .c edit does). Hashing real bytes (not size/mtime) means
# an edit can never slip past the key; os.walk prunes skipped trees
# before descending. Source trees are small relative to the 10-30 minute
# recon this guards, and this runs once per cold start, not per
# iteration. Prints nothing on failure (caller falls back to "norev").
recon_target_tree_sha() {
  local target_root="$1"
  command -v python3 >/dev/null 2>&1 || return 0
  python3 - "$target_root" "$SCRIPT_ROOT" <<'PY' 2>/dev/null
import hashlib, os, sys

root, script_root = sys.argv[1], sys.argv[2]
sys.path.insert(0, os.path.join(script_root, "lib"))
from languages import all_source_exts
from recon_slicer import SKIP_DIR_NAMES

exts = set(all_source_exts())
h = hashlib.sha1()
for dirpath, dirnames, filenames in os.walk(root):
    dirnames[:] = sorted(
        d for d in dirnames
        if d not in SKIP_DIR_NAMES and not d.startswith("build-")
    )
    for fn in sorted(filenames):
        if os.path.splitext(fn)[1].lower() not in exts:
            continue
        p = os.path.join(dirpath, fn)
        if not os.path.isfile(p):
            continue
        rel = os.path.relpath(p, root)
        h.update(rel.encode("utf-8", "replace") + b"\0")
        try:
            with open(p, "rb") as f:
                for chunk in iter(lambda: f.read(1 << 20), b""):
                    h.update(chunk)
        except OSError:
            h.update(b"<unreadable>")
        h.update(b"\0")
print(h.hexdigest())
PY
}

# Run breadth-first recon at cold start and seed its findings into the
# work-card pool. Cached on (target-source-git-SHA, recon-prompt-SHA)
# so subsequent cold-starts on the same code don't re-pay the recon
# cost. Returns 0 on success or cache-hit; non-zero on hard error
# (caller logs but continues without recon-seeded cards).
maybe_seed_recon_cards() {
  local backend="$1"
  local recon_out="$RESULTS_DIR/recon-hypotheses.jsonl"
  local recon_report="$RESULTS_DIR/recon-findings.md"
  local marker="$RESULTS_DIR/.recon-cache-marker"
  local work_file
  work_file=$(work_cards_path)

  if [ "${AUDIT_SKIP_RECON:-0}" = "1" ]; then
    log "Recon seed: skipped by --skip-recon" | tee -a "$INDEX"
    return 0
  fi

  if [ "$MAX_ITERATIONS" -eq 1 ]; then
    log "Recon seed: skipped for smoke test mode (max_iterations=1)" | tee -a "$INDEX"
    return 0
  fi

  [ -x "$SCRIPT_ROOT/bin/audit-recon" ] || { log "Recon seed: bin/audit-recon not executable; skipping" | tee -a "$INDEX"; return 1; }
  [ -x "$SCRIPT_ROOT/lib/recon_to_cards.py" ] || { log "Recon seed: lib/recon_to_cards.py not executable; skipping" | tee -a "$INDEX"; return 1; }

  # Cache key = (target HEAD SHA, hash of every harness file the recon
  # output depends on). Any of these changing means the cached
  # hypotheses + their interpretation could be stale, so re-run.
  # Files hashed:
  #   bin/audit-recon              — discovery driver + prompt template
  #   lib/recon_slicer.py          — how the target is partitioned
  #   lib/recon_to_cards.py        — hypothesis → work-card mapping
  #   lib/triage_validate.sh       — validator quorum rules
  #   bin/validate-finding         — per-validator prompt + parsing
  local current_target_sha current_logic_sha
  case "${TARGET_REPO_TYPE:-none}" in
    git)
      current_target_sha=$(git -C "$TARGET_ROOT" rev-parse HEAD 2>/dev/null || echo "norev")
      ;;
    hg)
      current_target_sha=$(hg -R "$TARGET_ROOT" id -i 2>/dev/null | sed 's/+//g' || echo "norev")
      ;;
    *)
      current_target_sha="norev"
      ;;
  esac
  # Local / no-VCS targets (and failed rev lookups) have no commit id, and
  # a bare "norev" key made the cache insensitive to content: the first
  # recon run cached forever, so edits to a local target silently reused
  # stale hypotheses. Derive a cheap content signature instead; fall back
  # to "norev" (logic-sha-only key) only when the walk fails.
  if [ "$current_target_sha" = "norev" ]; then
    local tree_sig
    tree_sig=$(recon_target_tree_sha "$TARGET_ROOT")
    [ -n "$tree_sig" ] && current_target_sha="tree-${tree_sig}"
  fi
  current_logic_sha=$(cat \
      "$SCRIPT_ROOT/bin/audit-recon" \
      "$SCRIPT_ROOT/lib/recon_slicer.py" \
      "$SCRIPT_ROOT/lib/recon_to_cards.py" \
      "$SCRIPT_ROOT/lib/triage_validate.sh" \
      "$SCRIPT_ROOT/bin/validate-finding" \
      2>/dev/null | audit_sha1 | awk '{print $1}')
  local current_key="$current_target_sha/$current_logic_sha"

  if [ -f "$marker" ] && [ -s "$recon_out" ]; then
    local cached_key
    cached_key=$(cat "$marker" 2>/dev/null)
    if [ "$cached_key" = "$current_key" ]; then
      local recon_count
      recon_count=$(grep -cE '^\{.*"id"[[:space:]]*:[[:space:]]*"REC(ON)?-' "$recon_out" 2>/dev/null || true)
      recon_count=${recon_count:-0}
      log "Recon seed: cache HIT for target SHA $current_target_sha ($recon_count hypothesis line(s)); reusing without re-running" | tee -a "$INDEX"
      _seed_cards_from_recon "$recon_out" "$work_file" || return 1
      return 0
    fi
  fi

  # Shared recon cache: a directory consulted across sibling runs on
  # identical source — e.g. the benchmark's three harness replicates,
  # which share a target SHA and backend and so produce the same recon.
  # When AUDIT_RECON_CACHE_DIR is set, the first run pays the cold recon
  # cost and the rest get a hit. The cache key still includes the recon
  # logic SHA, so a harness change invalidates it. Recon is backend- and
  # source-specific, so callers must scope the directory per backend.
  local shared_dir="${AUDIT_RECON_CACHE_DIR:-}"
  local shared_marker="" shared_out=""
  if [ -n "$shared_dir" ]; then
    shared_marker="$shared_dir/.recon-cache-marker"
    shared_out="$shared_dir/recon-hypotheses.jsonl"
    if [ -f "$shared_marker" ] && [ -s "$shared_out" ] \
        && [ "$(cat "$shared_marker" 2>/dev/null)" = "$current_key" ]; then
      cp "$shared_out" "$recon_out" 2>/dev/null || true
      printf '%s\n' "$current_key" > "$marker"
      local recon_count
      recon_count=$(grep -cE '^\{.*"id"[[:space:]]*:[[:space:]]*"REC(ON)?-' "$recon_out" 2>/dev/null || true)
      recon_count=${recon_count:-0}
      log "Recon seed: shared-cache HIT ($shared_dir; $recon_count hypothesis line(s)); reusing without re-running" | tee -a "$INDEX"
      _seed_cards_from_recon "$recon_out" "$work_file" || return 1
      return 0
    fi
  fi

  log "Recon seed: cache MISS (target SHA $current_target_sha); launching bin/audit-recon (this may take 10-30 minutes)" | tee -a "$INDEX"
  # Pass the resolved model through: hosted backends fall back to a config
  # default, but oss has no default and the OpenCode provider config errors
  # without an explicit served-model name (recon would emit empty output).
  if "$SCRIPT_ROOT/bin/audit-recon" \
      --target "$TARGET_SLUG" \
      --target-path "$TARGET_ROOT" \
      --backend "$backend" \
      --model "$MODEL" \
      --out "$recon_out" \
      --report "$recon_report" \
      2>&1 | sed -u 's/^/[recon-seed] /' | tee -a "$INDEX"; then
    printf '%s\n' "$current_key" > "$marker"
    local recon_count
    recon_count=$(grep -cE '^\{.*"id"[[:space:]]*:[[:space:]]*"REC(ON)?-' "$recon_out" 2>/dev/null || true)
    recon_count=${recon_count:-0}
    log "Recon seed: completed and cached ($recon_count hypothesis line(s) at $recon_out)" | tee -a "$INDEX"
    # Populate the shared cache so sibling runs on identical source skip
    # the cold recon entirely.
    if [ -n "$shared_marker" ]; then
      mkdir -p "$shared_dir" 2>/dev/null \
        && cp "$recon_out" "$shared_out" 2>/dev/null \
        && printf '%s\n' "$current_key" > "$shared_marker" \
        && log "Recon seed: shared cache refreshed at $shared_dir" | tee -a "$INDEX"
    fi
    _seed_cards_from_recon "$recon_out" "$work_file" || return 1
    return 0
  fi
  log "Recon seed: bin/audit-recon exited non-zero; not caching" | tee -a "$INDEX"
  return 1
}

# Internal helper: invoke lib/recon_to_cards.py to convert
# recon-hypotheses.jsonl into work-cards.jsonl entries that the
# strategy rotator will pick up.
_seed_cards_from_recon() {
  local recon_out="$1" work_file="$2"
  [ -s "$recon_out" ] || { log "Recon seed: hypothesis file empty; no cards to write" | tee -a "$INDEX"; return 0; }
  # Fan out one work-card per enabled sanitizer so a single recon
  # hypothesis gets one independent probe per (finding, sanitizer) — UBSan
  # catches integer-overflow that ASan misses, MSan catches uninit reads,
  # etc. The list comes straight from target.toml [sanitizer].enabled so
  # macOS arm64 (no MSan) operators simply don't list it and recon stays
  # within their declared support matrix.
  local sanitizers_csv="${TARGET_SANITIZERS_ENABLED_CSV:-asan}"
  if python3 "$SCRIPT_ROOT/lib/recon_to_cards.py" \
      --target-slug "$TARGET_SLUG" \
      --target-path "$TARGET_ROOT" \
      --recon-jsonl "$recon_out" \
      --work-cards "$work_file" \
      --sanitizers "$sanitizers_csv" \
      --results-dir "$RESULTS_DIR" 2>&1 | sed 's/^/[recon-cards] /' | tee -a "$INDEX"; then
    local cards_added
    cards_added=$(grep -cE '"kind":"recon-hypothesis"' "$work_file" 2>/dev/null || true)
    cards_added=${cards_added:-0}
    log "Recon seed: $cards_added recon-hypothesis card(s) now in $work_file" | tee -a "$INDEX"
    return 0
  fi
  log "Recon seed: lib/recon_to_cards.py failed; cards unchanged" | tee -a "$INDEX"
  return 1
}

structured_work_cards_refresh_required() {
  local work_file="$1" patch_file="$2"
  [ -s "$work_file" ] || return 0
  if ! eligible_work_card_exists; then
    log "work-cards: refresh required because no eligible card remains in current queue" | tee -a "$INDEX"
    return 0
  fi
  [ "${HOUSEKEEPING_DIRTY_CHECKS:-1}" = "0" ] && return 0

  local inputs=("$RESULTS_DIR/coverage" "$RESULTS_DIR/corpus")
  [ -s "$patch_file" ] && inputs+=("$patch_file")
  local sig
  sig=$(housekeeping_signature work-cards-refresh "${inputs[@]}" 2>/dev/null) || return 0
  if housekeeping_should_run work-cards-refresh "$sig"; then
    return 0
  fi
  return 1
}

mark_structured_work_cards_refreshed() {
  local work_file="$1" patch_file="$2"
  local inputs=("$RESULTS_DIR/coverage" "$RESULTS_DIR/corpus")
  [ -s "$patch_file" ] && inputs+=("$patch_file")
  local sig
  sig=$(housekeeping_signature work-cards-refresh "${inputs[@]}" 2>/dev/null || true)
  housekeeping_mark_clean work-cards-refresh "$sig"
}

work_card_refresh_summary() {
  local work_file="$1" patch_file="$2"
  local pc_lines=0
  if [ -f "$patch_file" ]; then
    pc_lines=$(awk 'END { print NR + 0 }' "$patch_file" 2>/dev/null || echo 0)
  fi

  if [ -s "$work_file" ] && command -v jq >/dev/null 2>&1; then
    local summary
    summary=$(jq -n -r '
      def hist($m):
        ($m
         | to_entries
         | sort_by(-.value, .key)
         | map("\(.key):\(.value)")
         | join(" "));
      reduce inputs as $r (
        {total:0, by_strategy:{}, by_status:{}};
        .total += 1
        | ($r.strategy // "?") as $strategy
        | .by_strategy[$strategy] = ((.by_strategy[$strategy] // 0) + 1)
        | ($r.status // "?") as $status
        | .by_status[$status] = ((.by_status[$status] // 0) + 1)
      )
      | [.total, hist(.by_strategy), hist(.by_status)]
      | @tsv
    ' "$work_file" 2>/dev/null) || summary=""
    if [ -n "$summary" ]; then
      local wc_lines wc_by_strat wc_by_status
      IFS="$(printf '\t')" read -r wc_lines wc_by_strat wc_by_status <<< "$summary"
      wc_by_strat=$(fmt_strategy_histogram "$wc_by_strat")
      printf '%s\t%s\t%s\t%s\n' "${wc_lines:-0}" "$pc_lines" "$wc_by_strat" "$wc_by_status"
      return 0
    fi
  fi

  local wc_lines=0
  if [ -f "$work_file" ]; then
    wc_lines=$(awk 'END { print NR + 0 }' "$work_file" 2>/dev/null || echo 0)
  fi
  printf '%s\t%s\t\t\n' "${wc_lines:-0}" "$pc_lines"
}

refresh_structured_work_cards() {
  [ -x "bin/state" ] || return 0
  bin/state --results-dir "$RESULTS_DIR" --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" init \
    >>"$INDEX" 2>&1 || return 0

  # Release card claims with no active hypothesis BEFORE re-ranking. Without
  # this, every iteration's claim_next_card walks past cards whose adopting
  # agent already finished or never started — the queue starves on stale
  # leases, not on real exhaustion. Idempotent and bounded by claims.jsonl.
  release_stale_card_claims

  local work_file patch_file
  work_file=$(work_cards_path)
  patch_file=$(patch_cards_path)

  if ! structured_work_cards_refresh_required "$work_file" "$patch_file"; then
    [ "${HOUSEKEEPING_LOG_SKIPS:-0}" = "1" ] && log "work-cards: skipped patch/rank refresh (inputs unchanged, queue still eligible)" | tee -a "$INDEX"
    return 0
  fi

  local refreshed=0 refresh_parts=""
  _wc_refresh_append() { refresh_parts="${refresh_parts}${refresh_parts:+,}$1"; refreshed=1; }
  if [ -x "bin/patch-cards" ]; then
    bin/patch-cards --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
      --results-dir "$RESULTS_DIR" --limit "$RANK_WORK_LIMIT" \
      --output "$patch_file" --quiet >>"$INDEX" 2>&1 \
      && _wc_refresh_append "patch"
  fi

  # S6 peer-fix cards (parallel to S1 patch cards). Soft-fail: peer
  # mining touches the network + LLM, so a transient failure here must
  # not abort the audit iteration. Skip when explicitly disabled via
  # AUDIT_DISABLE_PEER_FIX_CARDS=1.
  if [ "${AUDIT_DISABLE_PEER_FIX_CARDS:-0}" != "1" ] && [ -x "bin/peer-fix-cards" ]; then
    local s6_file="$RESULTS_DIR/s6-peer-cards.jsonl"
    local s6_limit="${RANK_S6_PEER_LIMIT:-${RANK_WORK_LIMIT:-40}}"
    bin/peer-fix-cards --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
      --results-dir "$RESULTS_DIR" --limit "$s6_limit" \
      --output "$s6_file" --quiet >>"$INDEX" 2>&1 \
      && _wc_refresh_append "s6-peer" \
      || log "work-cards: S6 peer-fix mining skipped or failed (non-fatal)" >> "$INDEX"
  fi

  if [ -x "bin/rank-work" ]; then
    bin/rank-work --target-path "$TARGET_ROOT" --target-slug "$TARGET_SLUG" \
      --results-dir "$RESULTS_DIR" --patch-cards "$patch_file" \
      --limit "$RANK_WORK_LIMIT" \
      --output "$work_file" --quiet >>"$INDEX" 2>&1 \
      && _wc_refresh_append "ranked"
  fi
  if [ "$refreshed" -eq 1 ]; then
    local wc_lines pc_lines wc_by_strat wc_by_status summary
    summary=$(work_card_refresh_summary "$work_file" "$patch_file")
    IFS="$(printf '\t')" read -r wc_lines pc_lines wc_by_strat wc_by_status <<< "$summary"
    log "work-cards refreshed [${refresh_parts}] — ${wc_lines} ranked card(s), ${pc_lines} patch card(s)${wc_by_strat:+ | by_strategy=${wc_by_strat}}${wc_by_status:+ by_status=${wc_by_status}}" | tee -a "$INDEX"
    mark_structured_work_cards_refreshed "$work_file" "$patch_file"
  fi
  return 0
}

# ─── Handoff file: analysis→reproduce pipeline ────────────────────
# Written during post-iteration housekeeping by refresh_handoff_file.
# Read during prompt build by build_handoff_directive. This decouples
# the handoff from live state-file parsing (which was brittle when
# agents wrote non-standard table formats).

handoff_file_path() {
  printf '%s/handoffs-pending.md' "$RESULTS_DIR"
}

# Scan all analysis agents' state files for NEEDS_TESTCASE rows and
# write them to a dedicated handoff file in a strict, greppable format.
# Called during post-iteration housekeeping.
refresh_handoff_file() {
  local hf
  hf=$(handoff_file_path)
  local rows=""
  local i sf role
  for i in $(seq 1 "$NUM_AGENTS"); do
    role=$(agent_role "$i" 2>/dev/null) || continue
    [ "$role" = "analysis" ] || continue

    if structured_state_agent_has_rows "$i" 2>/dev/null; then
      local structured_rows
      structured_rows=$(jq -s -r --arg agent "$i" '
        .[]
        | select((.agent // "") == $agent)
        | select((.status // "") == "NEEDS_TESTCASE")
        | "| \(.hypothesis // .id // "(hypothesis)") | \(.file // "—") | \(.input_shape // "—") | \(.guard_gap // "—") | \(.diagnostic // "—") | \(.strategy // "—") | Agent \($agent) |"
      ' "$(structured_state_hypotheses_path)" 2>/dev/null) || true
      [ -n "$structured_rows" ] && rows="${rows}${structured_rows}
"
      continue
    fi

    sf=$(state_file_path "$i")
    [ -f "$sf" ] || continue

    # Extract NEEDS_TESTCASE rows from the hypothesis table.
    local agent_rows
    agent_rows=$(awk -F'|' '
      {
        status = $9
        gsub(/^[ \t]+|[ \t]+$/, "", status)
        if (status == "NEEDS_TESTCASE") {
          hyp = $3; file = $4; input = $5; guard = $6; diag = $7; strat = $8
          gsub(/^[ \t]+|[ \t]+$/, "", hyp)
          gsub(/^[ \t]+|[ \t]+$/, "", file)
          gsub(/^[ \t]+|[ \t]+$/, "", input)
          gsub(/^[ \t]+|[ \t]+$/, "", guard)
          gsub(/^[ \t]+|[ \t]+$/, "", diag)
          gsub(/^[ \t]+|[ \t]+$/, "", strat)
          printf "| %s | %s | %s | %s | %s | %s | Agent %d |\n", hyp, file, input, guard, diag, strat, agent_num
        }
      }
    ' agent_num="$i" "$sf" 2>/dev/null) || true

    [ -n "$agent_rows" ] && rows="${rows}${agent_rows}
"
    # Also grep for simpler NEEDS_TESTCASE markers that aren't in table format
    # (agents sometimes write "Status: NEEDS_TESTCASE" or "- NEEDS_TESTCASE: ...")
    local simple_rows
    simple_rows=$(grep -n 'NEEDS_TESTCASE' "$sf" 2>/dev/null | grep -v '^[0-9]*:[[:space:]]*|' | head -5) || true
    if [ -n "$simple_rows" ]; then
      while IFS= read -r line; do
        rows+="| (from Agent ${i} state:${line%%:*}) | — | — | — | — | — | Agent ${i} |
"
      done <<< "$simple_rows"
    fi
  done

  if [ -n "$rows" ]; then
    {
      echo "# Pending Handoffs (analysis → reproduce)"
      echo "# Refreshed: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo ""
      echo "| Hypothesis | File:Function:Line | Input Shape | Guard Gap | Diagnostic | Strategy | Source |"
      echo "|-----------|-------------------|-------------|-----------|------------|----------|--------|"
      printf '%s' "$rows"
    } > "$hf"
    log "handoff: refreshed analysis→reproduce handoff file with $(echo "$rows" | grep -c '^|') pending item(s) at ${hf} (each row is a hypothesis the analysis pass found that still needs a reproducer testcase)" | tee -a "$INDEX"
  else
    # No pending handoffs — clear the file so stale entries don't persist
    rm -f "$hf" 2>/dev/null || true
  fi
}


# ─── Agent runner ──────────────────────────────────────────────────

run_agent() {
  local role="$1"     # deep_investigation-A, deep_investigation-B, cold-start-{1,2}
  local agent_num="$2" # 1 or 2
  local model="$3"
  local max_turns="$4"
  local prompt="$5"
  local timestamp="$6"
  local logfile="$LOGDIR/session_${timestamp}_${role}.log"

  # Per-agent, per-iteration counter file for browser/js ASan runs.
  # run-asan-multi.sh increments this and echoes "BUDGET: N/M" on each
  # invocation; the harness resets it at iteration start. We export the
  # path + budget so the wrapper picks them up without the agent having
  # to set env explicitly on every call.
  local asan_counter
  asan_counter=$(asan_run_counter_path "$agent_num")

  # Per-mode ASan run budget. Browser launches are serialized on a
  # global launch lock and cost ~3 GB + seconds of WindowServer startup;
  # shell launches are ~500 MB and start in <1 s. Budgets reflect that.
  local agent_mode_kind
  agent_mode_kind=$(agent_mode "$agent_num")
  local agent_asan_budget
  if [ "$agent_mode_kind" = "browser" ]; then
    agent_asan_budget="$BROWSER_ASAN_RUN_BUDGET"
  else
    agent_asan_budget="$SHELL_ASAN_RUN_BUDGET"
  fi

  # Dry-streak ASan budget scaling. When the run is dry (no new
  # findings / crashes for several iterations), each agent typically
  # ran out of ASan probes BEFORE varying input shape widely enough
  # to either confirm or genuinely DISCARD a hypothesis. Bump the
  # budget under sustained dry streaks so the agent has room to
  # vary inputs without hitting the budget at the cost of an
  # uninformed DISCARD. Capped at 3× the baseline to avoid runaway
  # cost when the queue is genuinely empty. Disable with
  # AUDIT_DRY_STREAK_BUDGET_SCALE=0.
  if [ "${AUDIT_DRY_STREAK_BUDGET_SCALE:-1}" = "1" ] && [ "${dry_streak:-0}" -ge 3 ]; then
    local _dry_excess=$(( dry_streak - 2 ))
    [ "$_dry_excess" -gt 4 ] && _dry_excess=4
    # Multiplier in halves: dry=3 → 1.5×, dry=4 → 2×, dry=5 → 2.5×, dry≥6 → 3×.
    local _scaled=$(( agent_asan_budget * (2 + _dry_excess) / 2 ))
    if [ "$_scaled" -gt "$agent_asan_budget" ]; then
      index_log "Dry-streak ${dry_streak}/${MAX_DRY_SESSIONS}: scaling Agent${agent_num} probe budget ${agent_asan_budget}→${_scaled} so input-shape exploration isn't budget-pinched (set AUDIT_DRY_STREAK_BUDGET_SCALE=0 to disable)"
      agent_asan_budget="$_scaled"
    fi
  fi

  # Build a self-describing per-line prefix for the agent's interleaved
  # streaming output. The original "[Agent-3-deep_investigation-3-generic]"
  # buried the fields a human reader actually cares about. New form:
  # "[Agent3·deep·Strategy2(Invariant-negation)·probe budget=4/60]" — agent
  # number, launch kind (cold-start vs resuming-deep-investigation),
  # current investigation strategy with its short description, and how
  # many sanitizer runs remain in this iteration's budget. Mode
  # (generic/shell/browser) is dropped because it never changes mid-run;
  # it still appears in session filenames.
  local _launch_short _strat _strat_tag _asan_consumed _asan_remaining _log_prefix
  case "$role" in
    cold-start-*)         _launch_short=cold ;;
    deep_investigation-*) _launch_short=deep ;;
    *)                    _launch_short="${role%%-*}" ;;
  esac
  _strat=$(get_agent_strategy "$agent_num" 2>/dev/null || echo "S?")
  _strat_tag=$(strategy_tag "$_strat" 2>/dev/null || echo "$_strat")
  _asan_consumed=$(cat "$asan_counter" 2>/dev/null || echo 0)
  case "$_asan_consumed" in ''|*[!0-9]*) _asan_consumed=0 ;; esac
  _asan_remaining=$(( agent_asan_budget - _asan_consumed ))
  [ "$_asan_remaining" -lt 0 ] && _asan_remaining=0
  _log_prefix="[Agent${agent_num}·${_launch_short}·${_strat_tag}·probe budget=${_asan_remaining}/${agent_asan_budget}]"
  # Friendly display name used in the harness's own log lines ("Agent3
  # deep Strategy1(Prior-fix-review) finished ..."). $role itself is
  # kept as-is because it's load-bearing in filenames
  # (session_<ts>_<role>.log).
  local _role_display="Agent${agent_num} ${_launch_short} ${_strat_tag}"

  local prompt_with_budget
  prompt_with_budget="${prompt}

## SESSION BUDGET

- Stay within roughly ${max_turns} turns or equivalent effort for this run.
- Prefer writing state, testcases, and probe output over broad exploratory chatter.

## PROBE RUN BUDGET (mode=${agent_mode_kind}) — your primary evidence, spend it

- You have **${agent_asan_budget} underlying probe invocations** this iteration (shared across hypotheses). \`bin/probe\` calls the correct sanitizer or runner wrapper; the wrapper prints \`BUDGET: N/${agent_asan_budget}\` after each call so you can track it. The budget is generous — agents almost never reach it — so an unused probe budget is missed coverage, not savings.
- **A \"safe / no-bug\" verdict is a probe result, not a reading.** Before you mark a reachable, buildable hypothesis DISCARDED because the code looks \"well-guarded\", \"bounded\", or \"safe by inspection\", run at least one \`bin/probe\` with an input shaped to stress that guard. Static analysis is enough to OPEN a FIND — file it immediately (see FIND-first) — but it is not enough to CLOSE a reachable path as clean: the bugs that matter hide in paths that looked guarded. (Exempt only when the path is unreachable / ENV-BLOCKED / compiled-out, where no probe can run.)
- **EXPLORATION vs CONFIRMATION.** Default \`bin/probe <tc>\` (1 run) when first probing an input shape. Only switch to \`bin/probe --confirm <tc>\` (5 runs) AFTER you've seen one crash on an input and need to prove it reproduces. A 0/5 variant wastes 4 runs. For **mode=shell** the runs are ~1 s each so confirmation is cheap — just don't replay identical inputs (check tried-inputs).
- **RUN VIA PROBE.** Write testcases and sibling harnesses under \`${RESULTS_DIR}/scratch-N/\`, then use \`bin/probe \"\${RESULTS_DIR}/scratch-N/<testcase>\"\` for browser/js/generic/differential probes. Do not create repo-root \`scratch-N/\` dirs. \`bin/probe\` reads TARGET / HYPOTHESIS-ID / HARNESS from the testcase header, discovers RESULTS_DIR / TARGET_ROOT from \`output/<slug>/.session-env\`, coverage-gates browser/js when possible, saves run output beside the testcase, and records structured run state.
- **SEED FIRST for any input / parser surface.** For a file/bytes/parser/decoder/regex/media hypothesis, your first probe MUST start from a real corpus seed: run \`bin/find-seed <file.cpp>[:<Function>]\`, take the top 2-3 candidates, and mutate them (seed+delta). A from-scratch input bounces off the target's format/magic/length validation and probes CLEAN without ever reaching the bug — that false negative is the most common way a reachable crash is missed and a guarded path is wrongly called \"hardened\". Only hand-write from scratch when \`find-seed\` returns nothing, or for a pure API-lifecycle / call-sequence bug that has no input corpus.
- If \`BUDGET: EXCEEDED\` appears, wrap up the active hypothesis (record state, save any artifact) and exit. Do NOT start a new investigation past the budget."

  # ── Session continuation (backend-neutral) ──
  # Resume is useful only when the scheduler says this is the same line of
  # work. The LLM transcript supplies only the session id; backend/mode/
  # subsystem/strategy/card/dry-loop metadata is owned by the harness.
  local session_id_file="$LOGDIR/.session_id_${agent_num}"
  local prev_session_id="" prev_backend="" prev_mode="" prev_sub="" prev_strategy="" prev_card="" prev_dry_count=0
  local current_sub current_strategy current_card active_for_resume
  local use_resume=0 resume_disabled_reason="" resume_backend="$ACTIVE_BACKEND"
  local resume_actionable_before resume_results_before resume_asan_before
  local gemini_fresh_session_id=""
  current_sub=$(get_agent_subsystem "$agent_num" 2>/dev/null || echo "unknown")
  current_strategy=$(get_agent_strategy "$agent_num" 2>/dev/null || echo "")
  current_card=$(agent_active_card_id "$agent_num" 2>/dev/null || true)
  active_for_resume=$(count_active_hypotheses_for_agent "$agent_num" 2>/dev/null || echo 0)
  case "${active_for_resume:-0}" in ''|*[!0-9]*) active_for_resume=0 ;; esac
  resume_actionable_before=$(count_actionable_state_entries 2>/dev/null || echo 0)
  resume_results_before=$(count_active_security_results 2>/dev/null || echo 0)
  resume_asan_before=$(count_verified_asan_runs "$(scratch_dir_path "$agent_num")" 2>/dev/null || echo 0)
  case "${resume_actionable_before:-0}" in ''|*[!0-9]*) resume_actionable_before=0 ;; esac
  case "${resume_results_before:-0}" in ''|*[!0-9]*) resume_results_before=0 ;; esac
  case "${resume_asan_before:-0}" in ''|*[!0-9]*) resume_asan_before=0 ;; esac

  prev_session_id=$(resume_state_read "$agent_num" session_id 2>/dev/null || true)
  [ -n "$prev_session_id" ] || prev_session_id=$(cat "$session_id_file" 2>/dev/null || true)
  prev_backend=$(resume_state_read "$agent_num" backend 2>/dev/null || true)
  prev_mode=$(resume_state_read "$agent_num" mode 2>/dev/null || true)
  prev_sub=$(resume_state_read "$agent_num" subsystem 2>/dev/null || true)
  [ -n "$prev_sub" ] || prev_sub=$(cat "$LOGDIR/.prev_subsystem_${agent_num}" 2>/dev/null || true)
  prev_strategy=$(resume_state_read "$agent_num" strategy 2>/dev/null || true)
  prev_card=$(resume_state_read "$agent_num" card 2>/dev/null || true)
  prev_dry_count=$(resume_state_read "$agent_num" dry_count 2>/dev/null || echo 0)
  case "${prev_dry_count:-0}" in ''|*[!0-9]*) prev_dry_count=0 ;; esac

  if ! backend_resume_enabled "$resume_backend"; then
    resume_disabled_reason="backend resume disabled or unsupported"
  elif [ -z "$prev_session_id" ]; then
    resume_disabled_reason="no prior session id"
  elif [ -n "$prev_backend" ] && [ "$prev_backend" != "$resume_backend" ]; then
    resume_disabled_reason="backend changed ${prev_backend}->${resume_backend}"
  elif [ -n "$prev_mode" ] && [ "$prev_mode" != "$agent_mode_kind" ]; then
    resume_disabled_reason="mode changed ${prev_mode}->${agent_mode_kind}"
  elif [ "$active_for_resume" -eq 0 ]; then
    resume_disabled_reason="no active hypotheses"
  elif [ -z "$current_sub" ] || [ "$current_sub" = "unknown" ]; then
    resume_disabled_reason="current subsystem unknown"
  elif [ -n "$prev_sub" ] && [ "$prev_sub" != "$current_sub" ]; then
    resume_disabled_reason="subsystem changed ${prev_sub}->${current_sub}"
  elif [ -n "$prev_strategy" ] && [ -n "$current_strategy" ] && [ "$prev_strategy" != "$current_strategy" ]; then
    resume_disabled_reason="strategy changed ${prev_strategy}->${current_strategy}"
  elif [ -n "$prev_card" ] && [ -n "$current_card" ] && [ "$prev_card" != "$current_card" ]; then
    resume_disabled_reason="work card changed ${prev_card}->${current_card}"
  elif [ "${prev_dry_count:-0}" -ge "${RESUME_DRY_CAP:-2}" ]; then
    resume_disabled_reason="dry resume count ${prev_dry_count} reached RESUME_DRY_CAP=${RESUME_DRY_CAP:-2}"
  else
    use_resume=1
  fi

  if [ "$use_resume" -eq 1 ]; then
    local latest_resume_log=""
    latest_resume_log=$(latest_agent_resume_raw_log "$agent_num" 2>/dev/null || true)
    if [ -n "$latest_resume_log" ] && should_disable_resume_for_cache "$resume_backend" "$latest_resume_log"; then
      use_resume=0
      resume_disabled_reason="previous session exceeded CLAUDE_RESUME_CACHE_CAP=${CLAUDE_RESUME_CACHE_CAP}"
    elif [ -n "$latest_resume_log" ] && should_disable_resume_for_thinking_blocks "$resume_backend" "$latest_resume_log"; then
      # Claude CLI's --resume rebuilds the conversation from its local
      # transcript, but extended-thinking block signatures don't survive
      # the round-trip and the API rejects with HTTP 400. Fall back to a
      # fresh prompt (the prior context is already restated by the
      # session-continuation tail and the active-hypothesis state file).
      use_resume=0
      resume_disabled_reason="previous session contains extended-thinking blocks (API 400 on --resume)"
    fi
  fi

  if [ "$use_resume" -ne 1 ] && [ -n "$prev_session_id" ] && [ "$resume_disabled_reason" != "no prior session id" ]; then
    clear_agent_resume_state "$agent_num"
    log "Session-resume disabled for Agent${agent_num} backend=${resume_backend}: ${resume_disabled_reason}; using fresh prompt/state" | tee -a "$INDEX"
  fi

  local total_prompt_tokens
  total_prompt_tokens=$(estimate_tokens "$prompt_with_budget")
  log "Starting agent $_role_display mode=${agent_mode_kind} probe_budget=${agent_asan_budget} prompt=$(fmt_count "$total_prompt_tokens")tok turns=$max_turns timeout=$(fmt_secs "$AGENT_TIMEOUT") resume=${use_resume} model=$model"

  # Run the entire pipeline in a subshell. The watchdog uses pkill -P to
  # recursively kill all descendants when the timeout fires.
  # Without this, a single agent can block the entire iteration loop for hours
  # (observed: patch_mine ran 5+ hours in iteration 2).
  local agent_start_epoch
  agent_start_epoch=$(date +%s)

  (
    # Make the per-iteration ASan-run budget + counter visible to
    # bin/run-asan-multi. Budget is per-mode (browser vs shell);
    # see agent_asan_budget above.
    export ASAN_RUN_BUDGET="$agent_asan_budget"
    export ASAN_RUN_COUNTER_FILE="$asan_counter"
    export AUDIT_AGENT_NUM="$agent_num"
    # Cap rg/grep output to 200 lines inside agent sessions. Agents
    # routinely run OR-chain greps returning 1 MB which then gets
    # re-sent on every subsequent turn (quadratic context growth).
    # The wrappers pass-through bounded flags (-c, -q, -l) unchanged.
    export PATH="$SCRIPT_ROOT/lib/wrappers:$PATH"
    # Codex spawns commands via `/bin/zsh -lc "..."`, and macOS's
    # /etc/zprofile runs path_helper which wipes the PATH we just set.
    # ZDOTDIR points zsh at lib/wrappers/_zdotdir/.zprofile, which runs
    # AFTER path_helper and re-prepends AGENT_WRAPPERS_PATH. Without
    # this, codex agents skip the rg/grep cap and pull 50–600 KB into
    # context per match. Harmless for Claude (its Bash tool inherits
    # PATH directly without re-running login init).
    export AGENT_WRAPPERS_PATH="$SCRIPT_ROOT/lib/wrappers"
    export ZDOTDIR="$SCRIPT_ROOT/lib/wrappers/_zdotdir"
    # Tried-inputs and hits logs are per-agent; expose them too so the
    # agent can invoke wrappers without restating the paths each time.
    export TRIED_INPUTS_LOG
    TRIED_INPUTS_LOG=$(tried_inputs_log_path "$agent_num")
    export HITS_LOG_PATH
    HITS_LOG_PATH=$(hits_log_path "$agent_num")
    export LLM_DECIDE_COUNTER_FILE
    LLM_DECIDE_COUNTER_FILE="$LOGDIR/.llm_decisions_${agent_num}"
    export LLM_DECIDE_MAX_CALLS="${LLM_DECIDE_MAX_CALLS:-1000}"
    _agent_attempt_has_text() {
      local backend="$1" raw="$2" text_log="$3" extracted=""
      [ -s "$text_log" ] && return 0
      [ -s "$raw" ] || return 1
      extracted=$(llm_extract_text "$backend" "$raw" 2>/dev/null || true)
      [ -n "$extracted" ]
    }
    _archive_resume_attempt() {
      local label="$1" raw_path text_path
      raw_path="$(audit_raw_path "$logfile")"
      text_path="$logfile"
      [ -e "$raw_path" ] && mv "$raw_path" "${raw_path}.${label}" 2>/dev/null || true
      [ -e "$text_path" ] && mv "$text_path" "${text_path}.${label}" 2>/dev/null || true
    }
    if [ "$ACTIVE_BACKEND" = "claude" ]; then
      # Claude Code's safety check rejects --dangerously-skip-permissions
      # under euid 0 unless IS_SANDBOX=1, exiting 4 before any agent turn
      # runs. The audit harness is the sandbox boundary here (we chose the
      # skip-permissions flag deliberately and confine the agent via the
      # subshell + watchdog), so signal that explicitly. Without this,
      # docker-shell sessions on Linux roots produce 93-byte error logs.
      export IS_SANDBOX=1
      # Shared flag picker (lib/llm_invoke.sh) keeps stream-json shape,
      # sandbox-skip, model defaults, and --add-dir wiring in sync with
      # bin/audit-recon, bin/validate-finding, and lib/llm_decide.sh.
      # Audit-only additions (--resume) are appended below.
      declare -a claude_base_flags=() claude_flags=()
      llm_agent_flags claude claude_base_flags "$model" "$max_turns" "$SCRIPT_ROOT"
      claude_flags=("${claude_base_flags[@]}")
      if [ "$use_resume" -eq 1 ] && [ -n "$prev_session_id" ]; then
        # Resume prior session — the prompt becomes a continuation message.
        # Claude will get cache hits on the entire prior conversation context.
        claude_flags+=(--resume "$prev_session_id")
      fi
      # Claude session with stream-idle restart.
      #
      # The hosted Claude API can drop the stream after extended idle gaps,
      # surfaced as "Stream idle timeout - partial response received" in the
      # CLI output. Without a retry path the harness loses the entire
      # iteration slot to that error. Strategy:
      #   1. Run the agent normally.
      #   2. After it exits, scan the raw log for the stream-idle error
      #      pattern AND verify the agent produced no completed turns
      #      (zero tool-use events or zero assistant text).
      #   3. If both hold, retry the agent ONCE with the same prompt. The
      #      retry path uses the same --resume semantics so cache hits are
      #      preserved.
      # If the retry also stalls, the slot is forfeit — same as today.
      # Override CLAUDE_STREAM_IDLE_RETRY=0 to disable the retry path.
      _stream_idle_pattern='Stream idle timeout|API Error: Stream idle'
      _claude_idle_retry="${CLAUDE_STREAM_IDLE_RETRY:-1}"
      _run_claude_once() {
        "${CLAUDE_BIN}" "${claude_flags[@]}" \
          -p "$prompt_with_budget" \
          2>&1 \
          | tee "$(audit_raw_path "$logfile")" \
          | jq --unbuffered -r '(.message.content[]?.text // .result // empty)' 2>/dev/null \
          | tee "$logfile" \
          | sed -u "s|^|${_log_prefix} |"
      }
      local _claude_rc=0
      _run_claude_once || _claude_rc=$?
      if [ "$use_resume" -eq 1 ] \
         && { [ "$_claude_rc" -ne 0 ] || ! _agent_attempt_has_text claude "$(audit_raw_path "$logfile")" "$logfile"; } \
         && ! log_has_rate_limit_rejection "$(audit_raw_path "$logfile")"; then
        index_log "RESUME_FALLBACK: Agent${agent_num} backend=claude resume failed or produced no assistant text; clearing resume state and retrying fresh once" >/dev/null 2>&1 || true
        clear_agent_resume_state "$agent_num"
        resume_state_write "$agent_num" fallback "1"
        _archive_resume_attempt "resume-attempt-1"
        claude_flags=("${claude_base_flags[@]}")
        _claude_rc=0
        _run_claude_once || _claude_rc=$?
      fi
      if [ "$_claude_idle_retry" = "1" ] \
         && [ -f "$(audit_raw_path "$logfile")" ] \
         && grep -qE "$_stream_idle_pattern" "$(audit_raw_path "$logfile")" 2>/dev/null; then
        # Productive activity = at least one tool_use event captured in raw
        # JSONL. If we have any, treat the stream-idle as a transient drop
        # and skip the retry (we'd lose the productive state on resume).
        local _tool_use_count
        _tool_use_count=$(grep -c '"type":"tool_use"' "$(audit_raw_path "$logfile")" 2>/dev/null || echo 0)
        if [ "${_tool_use_count:-0}" -lt 2 ]; then
          index_log "STREAM_IDLE_RETRY: agent=${agent_num} role=${role} hit Stream idle timeout with ${_tool_use_count} tool_use event(s); retrying once with fresh stream" >/dev/null 2>&1 || true
          mv "$(audit_raw_path "$logfile")" "$(audit_raw_path "$logfile").idle-attempt-1" 2>/dev/null || true
          mv "$logfile" "${logfile}.idle-attempt-1" 2>/dev/null || true
          _claude_rc=0
          _run_claude_once || _claude_rc=$?
        fi
      fi
      unset -f _run_claude_once 2>/dev/null || true
      exit "$_claude_rc"
    elif [ "$ACTIVE_BACKEND" = "gemini" ]; then
      # Gemini backend. agy emits plain assistant text; Google Gemini CLI
      # emits stream-json when USE_GEMINI_CLI=1. Both receive the prompt
      # on stdin via -p "". No --max-turns equivalent (the model self-paces).
      gemini_prune_stale_sessions
      # Shared flag picker — same source of truth as the other backend
      # branches and call sites.
      declare -a gemini_flags=()
      llm_agent_flags gemini gemini_flags "$model" 80 "$SCRIPT_ROOT,$TARGET_ROOT,$RESULTS_DIR"
      if llm_use_gemini_cli; then
        if [ "$use_resume" -eq 1 ] && [ -n "$prev_session_id" ]; then
          gemini_flags+=(--resume "$prev_session_id")
        fi
      fi
      if ! llm_use_gemini_cli; then
        # agy's --print mode aborts with "Error: timed out waiting for
        # response" after --print-timeout (default 5m0s). A real audit
        # agent session runs far longer, so pin the print-timeout to the
        # harness agent budget — the two-phase watchdog below stays the
        # controlling timeout instead of agy silently killing the run at
        # 5 minutes with zero tool calls.
        gemini_flags+=(--print-timeout "${AGENT_TIMEOUT}s")
      fi
      local gemini_bin
      gemini_bin="$(llm_backend_bin gemini)"
      if llm_use_gemini_cli; then
        local _gemini_rc=0
        printf '%s' "$prompt_with_budget" \
          | "$gemini_bin" "${gemini_flags[@]}" -p "" \
            > "$(audit_raw_path "$logfile")" 2>&1 || _gemini_rc=$?
        llm_extract_text gemini "$(audit_raw_path "$logfile")" > "$logfile" 2>/dev/null || true
        if [ "$use_resume" -eq 1 ] \
           && { [ "$_gemini_rc" -ne 0 ] || ! _agent_attempt_has_text gemini "$(audit_raw_path "$logfile")" "$logfile"; } \
           && ! log_has_rate_limit_rejection "$(audit_raw_path "$logfile")"; then
          index_log "RESUME_FALLBACK: Agent${agent_num} backend=gemini resume failed or produced no assistant text; clearing resume state and retrying fresh once" >/dev/null 2>&1 || true
          clear_agent_resume_state "$agent_num"
          resume_state_write "$agent_num" fallback "1"
          _archive_resume_attempt "resume-attempt-1"
          gemini_flags=()
          llm_agent_flags gemini gemini_flags "$model" 80 "$SCRIPT_ROOT,$TARGET_ROOT,$RESULTS_DIR"
          _gemini_rc=0
          printf '%s' "$prompt_with_budget" \
            | "$gemini_bin" "${gemini_flags[@]}" -p "" \
              > "$(audit_raw_path "$logfile")" 2>&1 || _gemini_rc=$?
          llm_extract_text gemini "$(audit_raw_path "$logfile")" > "$logfile" 2>/dev/null || true
        fi
        if [ -s "$logfile" ]; then
          sed -u "s|^|${_log_prefix} |" "$logfile"
        else
          sed -u "s|^|${_log_prefix} |" "$(audit_raw_path "$logfile")"
        fi
        exit "$_gemini_rc"
      else
        # agy raw stdout IS the assistant transcript. We background agy
        # so the gemini watchdog (lib/gemini_watchdog.sh) can poll for
        # the three known agy hang modes (quota dominates, post-Drip
        # spin, idle-heartbeat loop) and SIGTERM the process tree.
        # Without it the outer wall-clock watchdog (AGENT_TIMEOUT=7200)
        # is the only kill arm and the operator pays up to 2h per
        # stuck agent.
        local _agy_raw _agy_pid _agy_watcher_pid _agy_rc=0
        _agy_raw="$(audit_raw_path "$logfile")"
        printf '%s' "$prompt_with_budget" \
          | "$gemini_bin" "${gemini_flags[@]}" -p "" \
          > "$_agy_raw" 2>&1 &
        _agy_pid=$!
        start_gemini_watchdog "$_agy_raw" "$_agy_pid" \
          "$(scratch_dir_path "$agent_num")" "$_role_display" &
        _agy_watcher_pid=$!
        wait "$_agy_pid" || _agy_rc=$?
        # Watchdog runs `while sleep N; do ...`; a plain `kill` would be
        # deferred until sleep returns. Walk the tree so the sleep child
        # gets SIGTERM directly, then reap.
        _kill_tree "$_agy_watcher_pid" TERM 2>/dev/null || true
        wait "$_agy_watcher_pid" 2>/dev/null || true
        # Mirror the prior tee chain: raw === text for agy, then prefix
        # the lines for console display.
        cp "$_agy_raw" "$logfile" 2>/dev/null || true
        [ -s "$logfile" ] && sed -u "s|^|${_log_prefix} |" "$logfile"
        # If the watchdog touched .quota-exhausted in the agent scratch
        # dir, surface it the same way the preflight quota path does so
        # the outer iteration loop can see the failure mode.
        if [ -f "$(scratch_dir_path "$agent_num")/.quota-exhausted" ]; then
          index_log "GEMINI_QUOTA: Agent $_role_display aborted by watchdog (sustained 429s)" >/dev/null 2>&1 || true
        fi
        exit "$_agy_rc"
      fi
    elif [ "$ACTIVE_BACKEND" = "oss" ]; then
      declare -a opencode_flags=()
      llm_agent_flags oss opencode_flags "$model" 80 "$SCRIPT_ROOT,$TARGET_ROOT,$RESULTS_DIR"
      # Prompt rides in argv — OpenCode `run` has no stdin path. The canonical
      # prompt artifact is written separately by write_prompt_artifacts.
      local _opencode_config _opencode_rc=0
      _opencode_config="$(llm_opencode_config_content "$model")" || exit $?
      OPENCODE_CONFIG_CONTENT="$_opencode_config" \
        "$OPENCODE_BIN" "${opencode_flags[@]}" \
          "$prompt_with_budget" \
          > "$(audit_raw_path "$logfile")" 2>&1 || _opencode_rc=$?
      llm_extract_text oss "$(audit_raw_path "$logfile")" > "$logfile" 2>/dev/null || true
      if [ -s "$logfile" ]; then
        sed -u "s|^|${_log_prefix} |" "$logfile"
      else
        sed -u "s|^|${_log_prefix} |" "$(audit_raw_path "$logfile")"
      fi
      exit "$_opencode_rc"
    else
      # Shared flag picker; audit-only addition is --output-last-message.
      declare -a codex_flags=()
      llm_agent_flags codex codex_flags "$model" 80 "$SCRIPT_ROOT,$TARGET_ROOT,$RESULTS_DIR"
      codex_flags+=(--output-last-message "$logfile")
      _codex_drop_flag_args() {
        local out_var="$1"; shift
        local -a out=()
        local skip_next=0 f
        for f in "$@"; do
          if [ "$skip_next" -eq 1 ]; then
            skip_next=0
            continue
          fi
          case "$f" in
            --ephemeral)
              ;;
            --cd|--add-dir|--sandbox)
              skip_next=1
              ;;
            *)
              out+=("$f")
              ;;
          esac
        done
        _llm_assign_array "$out_var" "${out[@]}"
      }
      _codex_drop_ephemeral() {
        local out_var="$1"; shift
        local -a out=()
        local f
        for f in "$@"; do
          [ "$f" = "--ephemeral" ] && continue
          out+=("$f")
        done
        _llm_assign_array "$out_var" "${out[@]}"
      }
      declare -a codex_fresh_flags=() codex_resume_flags=()
      if backend_resume_enabled codex; then
        _codex_drop_ephemeral codex_fresh_flags "${codex_flags[@]}"
      else
        codex_fresh_flags=("${codex_flags[@]}")
      fi
      _codex_drop_flag_args codex_resume_flags "${codex_flags[@]}"
      local _codex_rc=0
      if [ "$use_resume" -eq 1 ] && [ -n "$prev_session_id" ]; then
        printf '%s' "$prompt_with_budget" \
          | "$CODEX_BIN" exec resume "${codex_resume_flags[@]}" "$prev_session_id" - \
              > "$(audit_raw_path "$logfile")" 2>&1 || _codex_rc=$?
      else
        printf '%s' "$prompt_with_budget" \
          | "$CODEX_BIN" exec "${codex_fresh_flags[@]}" - \
              > "$(audit_raw_path "$logfile")" 2>&1 || _codex_rc=$?
      fi
      if [ "$use_resume" -eq 1 ] \
         && { [ "$_codex_rc" -ne 0 ] || ! _agent_attempt_has_text codex "$(audit_raw_path "$logfile")" "$logfile"; } \
         && ! log_has_rate_limit_rejection "$(audit_raw_path "$logfile")"; then
        index_log "RESUME_FALLBACK: Agent${agent_num} backend=codex resume failed or produced no assistant text; clearing resume state and retrying fresh once" >/dev/null 2>&1 || true
        clear_agent_resume_state "$agent_num"
        resume_state_write "$agent_num" fallback "1"
        _archive_resume_attempt "resume-attempt-1"
        _codex_rc=0
        printf '%s' "$prompt_with_budget" \
          | "$CODEX_BIN" exec "${codex_fresh_flags[@]}" - \
              > "$(audit_raw_path "$logfile")" 2>&1 || _codex_rc=$?
      fi
      if [ -f "$logfile" ] && [ -s "$logfile" ]; then
        sed -u "s|^|${_log_prefix} |" "$logfile"
      else
        sed -u "s|^|${_log_prefix} |" "$(audit_raw_path "$logfile")"
      fi
      unset -f _codex_drop_flag_args _codex_drop_ephemeral 2>/dev/null || true
      exit "$_codex_rc"
    fi
  ) &
  local subshell_pid=$!

  # Watchdog: warn agent before timeout, then kill if still running.
  # Two-phase: SIGUSR1 at (AGENT_TIMEOUT - GRACEFUL_WARNING) to trigger state save,
  # then hard kill at AGENT_TIMEOUT.
  (
    local warn_at=$(( AGENT_TIMEOUT - GRACEFUL_WARNING ))
    if [ "$warn_at" -gt 0 ]; then
      sleep "$warn_at"
      if kill -0 "$subshell_pid" 2>/dev/null; then
        index_log "WARNING: Agent $_role_display has $(fmt_secs "$GRACEFUL_WARNING") remaining before timeout — checkpoint state NOW"
      fi
      sleep "$GRACEFUL_WARNING"
    else
      sleep "$AGENT_TIMEOUT"
    fi
    if kill -0 "$subshell_pid" 2>/dev/null; then
      index_log "TIMEOUT: Agent $_role_display exceeded $(fmt_secs "$AGENT_TIMEOUT") — killing process tree (pid=$subshell_pid)"
      pkill -TERM -P "$subshell_pid" 2>/dev/null || true
      sleep 2
      kill "$subshell_pid" 2>/dev/null || true
      sleep 3
      pkill -9 -P "$subshell_pid" 2>/dev/null || true
      kill -9 "$subshell_pid" 2>/dev/null || true
    fi
  ) 2>/dev/null &
  local watchdog_pid=$!

  # Turn-soft-cap watchdog (codex backend only).
  #
  # Why: Codex per-session cost grows as roughly 20K·N + 233·N² in cached
  # input tokens, where N = completed command_executions. The quadratic term
  # comes from each tool output getting replayed on every subsequent turn's
  # cached prefix. Below ~87 turns the linear term dominates, and stopping
  # the session early would pay double prompt/init overhead for marginal
  # savings. Above ~87 turns the quadratic dominates, and ending the session
  # plus resuming via bin/state recovers most of the cost.
  #
  # We poll the raw JSON stream (already being written by codex exec) for
  # completed command_execution items. When the count crosses TURN_SOFT_CAP,
  # send SIGTERM to the agent subshell. The subshell's existing graceful
  # shutdown lets codex flush any in-flight output and write the
  # --output-last-message file; bin/state checkpoints persist as normal
  # because the agent has been recording state continuously via add-hyp /
  # add-run / add-note over the session.
  #
  # No effect for Claude (--max-turns handles its own cap) or the gemini
  # backend (Antigravity CLI emits plain text, no completed-item replay
  # shape to count). TURN_SOFT_CAP=0 disables.
  local turncap_pid=""
  if [ "$ACTIVE_BACKEND" = "codex" ] && [ "${TURN_SOFT_CAP:-0}" -gt 0 ]; then
    local _turncap_raw="$(audit_raw_path "$logfile")"
    local _turncap_cap="$TURN_SOFT_CAP"
    local _turncap_poll="$TURN_SOFT_CAP_POLL_SECS"
    local _turncap_subshell="$subshell_pid"
    local _turncap_role="$_role_display"
    local _turncap_helper="$SCRIPT_ROOT/lib/audit_helpers.py"
    (
      # Brief startup grace — codex takes a few seconds to emit anything;
      # polling before the file exists just wastes a wakeup.
      sleep 3
      local _offset=0 _count=0 _delta_out="" _key="" _value="" _delta=0 _next_offset=0
      while kill -0 "$_turncap_subshell" 2>/dev/null; do
        # Count only newly appended complete JSONL events. The old watcher
        # rescanned the entire growing raw log with grep every poll; large
        # Codex sessions paid repeated full-file I/O while the model was
        # still running. The helper returns the next complete-line offset so
        # partially written events are retried instead of lost.
        if [ -f "$_turncap_raw" ]; then
          _delta_out=$(python3 "$_turncap_helper" codex-turn-delta "$_turncap_raw" "$_offset" 2>/dev/null || true)
          _delta=0
          _next_offset="$_offset"
          while IFS='=' read -r _key _value; do
            case "$_key" in
              count) case "${_value:-}" in ''|*[!0-9]*) _delta=0 ;; *) _delta="$_value" ;; esac ;;
              offset) case "${_value:-}" in ''|*[!0-9]*) ;; *) _next_offset="$_value" ;; esac ;;
            esac
          done <<< "$_delta_out"
          _count=$(( _count + _delta ))
          _offset="$_next_offset"
        fi
        if [ "$_count" -ge "$_turncap_cap" ]; then
          index_log "TURN_SOFT_CAP: Agent $_turncap_role hit ${_count} completed commands (soft cap=${_turncap_cap}) — stopping the session so it resumes on the next iteration"
          # Gentle stop first — let codex flush --output-last-message.
          pkill -TERM -P "$_turncap_subshell" 2>/dev/null || true
          sleep 5
          if kill -0 "$_turncap_subshell" 2>/dev/null; then
            pkill -9 -P "$_turncap_subshell" 2>/dev/null || true
            kill -9 "$_turncap_subshell" 2>/dev/null || true
          fi
          exit 0
        fi
        sleep "$_turncap_poll"
      done
    ) 2>/dev/null &
    turncap_pid=$!
  fi

  # Wait for the subshell to finish (either naturally or via watchdog kill)
  local exit_code=0
  wait "$subshell_pid" 2>/dev/null && exit_code=0 || exit_code=$?

  # Kill the watchdog if agent finished before timeout. Bash does not
  # reliably reap a foreground `sleep` when its parent watchdog shell is
  # killed, so terminate the watchdog's child first. Otherwise the orphaned
  # sleep keeps stdout/stderr pipes open and callers using `tee` never see EOF.
  pkill -TERM -P "$watchdog_pid" 2>/dev/null || true
  kill "$watchdog_pid" 2>/dev/null || true
  wait "$watchdog_pid" 2>/dev/null || true
  if [ -n "$turncap_pid" ]; then
    pkill -TERM -P "$turncap_pid" 2>/dev/null || true
    kill "$turncap_pid" 2>/dev/null || true
    wait "$turncap_pid" 2>/dev/null || true
  fi

  # Extract usage and command counts from the raw JSON stream.
  # extract_* helpers are backend-aware (see function docstrings).
  local total_tokens tool_uses duration_ms input_tokens cached_input_tokens cache_creation_tokens output_tokens command_count waste_telemetry
  local raw_logfile finish_fields finish_key finish_value
  raw_logfile="$(audit_raw_path "$logfile")"
  local rate_limit_rejected=0
  local raw_codex_completed="" raw_codex_failed="" raw_gemini_success=""
  command_count=0
  tool_uses=0
  finish_fields=$(extract_finish_fields "$raw_logfile" "$ACTIVE_BACKEND")
  while IFS='=' read -r finish_key finish_value; do
    case "$finish_key" in
      total_tokens) total_tokens="$finish_value" ;;
      input_tokens) input_tokens="$finish_value" ;;
      cached_input_tokens) cached_input_tokens="$finish_value" ;;
      cache_creation_input_tokens) cache_creation_tokens="$finish_value" ;;
      output_tokens) output_tokens="$finish_value" ;;
      duration_ms) duration_ms="$finish_value" ;;
      command_execution) command_count="$finish_value" ;;
      all_tools) tool_uses="$finish_value" ;;
      rate_limit) rate_limit_rejected="${finish_value:-0}" ;;
      codex_completed) raw_codex_completed="$finish_value" ;;
      codex_failed) raw_codex_failed="$finish_value" ;;
      gemini_success) raw_gemini_success="$finish_value" ;;
    esac
  done <<< "$finish_fields"
  if [ -z "$rate_limit_rejected" ]; then
    if log_has_rate_limit_rejection "$raw_logfile"; then
      rate_limit_rejected=1
    else
      rate_limit_rejected=0
    fi
  fi
  case "${duration_ms:-}" in
    ''|*[!0-9]*|0)
      duration_ms=$(( ($(date +%s) - ${agent_start_epoch:-$(date +%s)}) * 1000 ))
      ;;
  esac

  # Recover log file from raw JSON if --output-last-message failed (e.g., Codex SDK crash)
  recover_log_from_raw "$logfile"
  llm_log_refusal_warning "$ACTIVE_BACKEND" "$prompt_with_budget" "$raw_logfile" || true

  local normalized_exit_code
  normalized_exit_code=$(normalize_agent_exit_code "$ACTIVE_BACKEND" "$exit_code" "$raw_logfile" \
    "$rate_limit_rejected" "$raw_codex_completed" "$raw_codex_failed" "$raw_gemini_success")
  if [ "$normalized_exit_code" != "$exit_code" ]; then
    index_log "Agent $_role_display process exit=$exit_code but raw log has a completed ${ACTIVE_BACKEND} turn with no session-level error; treating the agent session as exit=0"
    exit_code="$normalized_exit_code"
  fi

  if [ "$rate_limit_rejected" -eq 1 ]; then
    # The Antigravity CLI can surface backend exhaustion through stderr
    # while the shell pipeline itself exits 0. Mark the agent as a
    # temporary backend failure so index.log and rc summaries do not
    # report a clean run.
    if [ "$exit_code" -eq 0 ]; then
      exit_code=75
    fi
  fi

  # Raw streams are retained for explicit post-mortem debugging. The default
  # analysis surface is the compact per-session summary and JSONL index written
  # below; remove raw/prompt artifacts explicitly with bin/cleanup_logs.

  if [ -n "${input_tokens:-}" ] || [ -n "${output_tokens:-}" ] || [ -n "${cached_input_tokens:-}" ]; then
    # Cache-hit percentage is backend-dependent because the backends report
    # input_tokens with different semantics:
    #   * Claude: input_tokens = FRESH input only (cached + creation reported
    #     separately). Total prompt = input + cache_read + cache_creation.
    #     Pre-fix this divided cached/input and rendered ~9,790,788% in logs.
    #   * Codex: input_tokens = TOTAL input (cached + fresh). Cache hit ratio
    #     is cached/input directly.
    #   * Gemini backend: Antigravity CLI emits plain text with no usage
    #     telemetry, so all three counters end up empty/0 and cache_pct
    #     ends up "?" for agy runs (expected; no consumer depends on it).
    # No downstream consumer parses this percentage — it's purely observability.
    local cache_pct="?" denom=0
    case "$ACTIVE_BACKEND" in
      claude)
        denom=$(( ${cached_input_tokens:-0} + ${cache_creation_tokens:-0} + ${input_tokens:-0} ))
        ;;
      *)
        denom=${input_tokens:-0}
        ;;
    esac
    if [ "$denom" -gt 0 ] && [ "${cached_input_tokens:-0}" -gt 0 ]; then
      cache_pct=$(( cached_input_tokens * 100 / denom ))
    fi
    index_log "Agent $_role_display finished exit=$exit_code dur=$(fmt_ms "${duration_ms:-0}") in=$(fmt_count "${input_tokens:-0}") cached=$(fmt_count "${cached_input_tokens:-0}")(${cache_pct}%) create=$(fmt_count "${cache_creation_tokens:-0}") out=$(fmt_count "${output_tokens:-0}") cmds=${command_count:-0} tools=${tool_uses:-0}"
  else
    index_log "Agent $_role_display finished exit=$exit_code dur=$(fmt_ms "${duration_ms:-0}") tokens=$(fmt_count "${total_tokens:-0}") cmds=${command_count:-0} tools=${tool_uses:-0}"
  fi
  waste_telemetry=$(write_session_log_summary "$raw_logfile" "$logfile" \
    "${logfile}.summary.md" "${LOG_INDEX_JSONL:-$LOGDIR/index.jsonl}" \
    "$role" "$agent_num" "$ACTIVE_BACKEND" "$model" "$agent_mode_kind" "$exit_code" \
    "$total_prompt_tokens" "$input_tokens" "$cached_input_tokens" "$output_tokens" "$total_tokens" \
    "$duration_ms" "$command_count" "$tool_uses" "" "$cache_creation_tokens")
  if [ -z "$waste_telemetry" ]; then
    waste_telemetry=$(extract_waste_telemetry "$raw_logfile")
  fi
  index_log "Agent $_role_display waste: ${waste_telemetry}"

  # Stash tool-use count, ASan run count, and active-result baseline for
  # quality-feedback and reverse-turn-budget directives next iteration.
  local verified_asan_runs active_security_results_after
  verified_asan_runs=$(count_verified_asan_runs "$(scratch_dir_path "$agent_num")" 2>/dev/null || echo 0)
  active_security_results_after=$(count_active_security_results 2>/dev/null || echo 0)
  case "${active_security_results_after:-0}" in ''|*[!0-9]*) active_security_results_after=0 ;; esac
  printf '%s' "${tool_uses:-0}" > "$LOGDIR/.prev_tools_${agent_num}" 2>/dev/null || true
  printf '%s' "$active_security_results_after" > "$LOGDIR/.prev_results_${agent_num}" 2>/dev/null || true
  printf '%s' "${verified_asan_runs:-0}" > "$LOGDIR/.prev_asan_runs_${agent_num}" 2>/dev/null || true

  # Stash session ID and scheduler metadata for guarded continuation.
  # The backend transcript supplies only the resumable id; all other gates
  # come from harness-owned state so stale conversations cannot silently
  # cross backend/mode/subsystem/strategy/card boundaries.
  local new_session_id="" resume_fallback_used=0 save_resume_state=0
  if [ -f "$(resume_state_path "$agent_num" fallback)" ]; then
    resume_fallback_used=1
    rm -f "$(resume_state_path "$agent_num" fallback)" 2>/dev/null || true
  fi
  if [ "$ACTIVE_BACKEND" = "claude" ]; then
    new_session_id=$(head -5 "$raw_logfile" 2>/dev/null \
      | jq -r 'select(.type == "system" and .subtype == "init") | .session_id // empty' 2>/dev/null \
      | head -1)
    # Fallback: extract from any message line
    if [ -z "$new_session_id" ]; then
      new_session_id=$(head -20 "$raw_logfile" 2>/dev/null \
        | jq -r '.session_id // empty' 2>/dev/null \
        | head -1)
    fi
  elif [ "$ACTIVE_BACKEND" = "codex" ]; then
    new_session_id=$(head -3 "$raw_logfile" 2>/dev/null \
      | jq -r 'select(.type == "thread.started") | .thread_id // empty' 2>/dev/null \
      | head -1)
    if [ -z "$new_session_id" ] && [ "$use_resume" -eq 1 ] && [ "$resume_fallback_used" -eq 0 ]; then
      new_session_id="$prev_session_id"
    fi
  elif [ "$ACTIVE_BACKEND" = "gemini" ] && llm_use_gemini_cli; then
    new_session_id=$(head -10 "$raw_logfile" 2>/dev/null \
      | jq -r 'select(.type == "init") | .session_id // empty' 2>/dev/null \
      | head -1)
    if [ -z "$new_session_id" ]; then
      if [ "$use_resume" -eq 1 ] && [ "$resume_fallback_used" -eq 0 ]; then
        new_session_id="$prev_session_id"
      fi
    fi
  fi
  if [ "$exit_code" -eq 0 ] \
     && [ -n "$new_session_id" ] \
     && backend_resume_enabled "$resume_backend" \
     && [ "$rate_limit_rejected" -eq 0 ]; then
    save_resume_state=1
  fi
  if [ "$save_resume_state" -eq 1 ]; then
    local saved_sub saved_strategy saved_card
    saved_sub=$(get_agent_subsystem "$agent_num" 2>/dev/null || echo "unknown")
    saved_strategy=$(get_agent_strategy "$agent_num" 2>/dev/null || echo "")
    saved_card=$(agent_active_card_id "$agent_num" 2>/dev/null || true)
    printf '%s' "$new_session_id" > "$LOGDIR/.session_id_${agent_num}" 2>/dev/null || true
    printf '%s' "$saved_sub" > "$LOGDIR/.prev_subsystem_${agent_num}" 2>/dev/null || true
    resume_state_write "$agent_num" session_id "$new_session_id"
    resume_state_write "$agent_num" backend "$resume_backend"
    resume_state_write "$agent_num" mode "$agent_mode_kind"
    resume_state_write "$agent_num" subsystem "$saved_sub"
    resume_state_write "$agent_num" strategy "$saved_strategy"
    resume_state_write "$agent_num" card "$saved_card"
  elif [ "$exit_code" -ne 0 ] && [ "$rate_limit_rejected" -eq 0 ]; then
    clear_agent_resume_state "$agent_num"
  fi

  if [ "$save_resume_state" -eq 1 ]; then
    if [ "$use_resume" -eq 1 ] && [ "$resume_fallback_used" -eq 0 ]; then
      local resume_actionable_after resume_results_after resume_asan_after next_dry_count
      resume_actionable_after=$(count_actionable_state_entries 2>/dev/null || echo 0)
      resume_results_after="$active_security_results_after"
      resume_asan_after="$verified_asan_runs"
      case "${resume_actionable_after:-0}" in ''|*[!0-9]*) resume_actionable_after=0 ;; esac
      case "${resume_results_after:-0}" in ''|*[!0-9]*) resume_results_after=0 ;; esac
      case "${resume_asan_after:-0}" in ''|*[!0-9]*) resume_asan_after=0 ;; esac
      if [ "$resume_actionable_after" -gt "${resume_actionable_before:-0}" ] \
         || [ "$resume_results_after" -gt "${resume_results_before:-0}" ] \
         || [ "$resume_asan_after" -gt "${resume_asan_before:-0}" ]; then
        next_dry_count=0
      else
        next_dry_count=$((prev_dry_count + 1))
      fi
      resume_state_write "$agent_num" dry_count "$next_dry_count"
    else
      resume_state_write "$agent_num" dry_count "0"
    fi
  fi

  # Generate a session seed (≤2 KB) summarizing what files the agent has
  # already Read and what testcases it has Written. Injected into the next
  # iteration's prompt so the agent doesn't re-Read the same ranges after
  # compaction. See lib/build_session_seed.py.
  local seed_path="$RESULTS_DIR/.session_seed_${agent_num}.md"
  if [ -f "$raw_logfile" ] && [ -s "$raw_logfile" ]; then
    python3 "$SCRIPT_ROOT/lib/build_session_seed.py" \
      "$raw_logfile" "$seed_path" 2>/dev/null || true
  fi

  if [ "${command_count:-0}" -eq 0 ] && [ "${verified_asan_runs:-0}" -eq 0 ]; then
    index_log "WARNING: Agent $_role_display produced 0 commands (early exit, SDK failure, or empty session)"
  fi

  # ── Structural dead-session detection ─────────────────────────────
  # Track consecutive empty / refused sessions per agent using ONLY structural
  # signals (tool-use count from raw JSONL + structured "stop_reason":"refusal"
  # JSON markers). No English-language refusal vocabulary is grepped, so this
  # detector cannot itself become a safety-classifier trigger when archived logs
  # are later read by an agent.
  local refusal_signals
  refusal_signals=$(count_structural_refusal_signals "$raw_logfile" 2>/dev/null || echo 0)
  # Split the two failure modes that used to share this branch:
  #   (a) tool_uses == 0         -> genuine dead session (early exit, SDK crash, timeout)
  #   (b) refusal_signals > 0    -> classifier hit after real work
  # Only (a) contributes to the destructive cold-start threshold. A classifier
  # hit with real tool work is evidence that the agent was alive and the current
  # queue is still useful, so preserve state and retry with the existing context.
  if [ "$rate_limit_rejected" -eq 1 ]; then
    reset_dead_streak "$agent_num"
    index_log "Agent $_role_display hit model rate limit (tools=${tool_uses:-0}) — state preserved; global rate-limit backoff will handle retry timing"
  # output_tokens > 0 keeps agy source-only sessions from false-tripping
  # the gate. agy plain-text transcripts emit no tool_use /
  # command_execution events the JSON-event scanner can count, so for an
  # S2/S3/S5/S8 investigation that produces a FIND without an ASan run,
  # the other three counters all sit at zero. The estimator in
  # lib/llm_usage.py recovers output_tokens from raw assistant prose;
  # any nonzero estimate is decisive evidence the agent did work.
  elif [ "${tool_uses:-0}" -eq 0 ] && [ "${command_count:-0}" -eq 0 ] && [ "${verified_asan_runs:-0}" -eq 0 ] && [ "${output_tokens:-0}" -eq 0 ]; then
    bump_dead_streak "$agent_num"
    local streak
    streak=$(get_dead_streak "$agent_num")
    log "Agent $_role_display dead-streak=${streak}/${MAX_DEAD_STREAK} (tools=${tool_uses:-0}, cmds=${command_count:-0}, asan_runs=${verified_asan_runs:-0}, refusal_signals=${refusal_signals:-0}, mode=hard) — agent finished without doing useful tool work" | tee -a "$INDEX"
    if [ "${streak:-0}" -ge "$MAX_DEAD_STREAK" ]; then
      log "Agent $_role_display hit dead-streak threshold — archiving its state and forcing a cold-start next iteration" | tee -a "$INDEX"
      archive_dead_agent_state "$agent_num"
      reset_dead_streak "$agent_num"
    fi
  elif [ "${refusal_signals:-0}" -gt 0 ]; then
    reset_dead_streak "$agent_num"
    log "Agent $_role_display saw a model refusal after doing real work (tools=${tool_uses:-0}, refusal_signals=${refusal_signals:-0}) — state preserved, will retry next iteration" | tee -a "$INDEX"
  else
    reset_dead_streak "$agent_num"
  fi

  return "$exit_code"
}


# ─── Corpus promotion ─────────────────────────────────────────────
# Salvage testcases that reached their target function and ran cleanly
# under ASan. These are not crashes, but they are valid regression seeds
# for the security-QA team: each one documents that "input X drives
# the target into function Y without hitting a sanitizer diagnostic." Future
# source changes in Y's area should re-run the corpus to confirm clean
# execution.
#
# Inputs:
#   - <RESULTS_DIR>/hits-<agent>.log  (append-only HIT:/MISSED: records
#       written by bin/hits)
#   - <RESULTS_DIR>/scratch-<agent>/<tc>  (the testcase)
#   - <RESULTS_DIR>/scratch-<agent>/<tc-base>.asan.txt  (verified ASan run)
#
# Promotion rules (ALL required):
#   1. hits-<agent>.log has a `HIT:` line for this testcase
#   2. a sibling .asan.txt exists and has the run-asan-multi header/summary


# ─── Review table regeneration ───────────────────────────────────
# Produces human-browsable cluster summaries plus the rejected-crash index:
#   - crashes/CRASH-CLUSTERS.md   → accepted/pending crash candidates
#   - findings/FINDING-CLUSTERS.md → curated confirmed security findings
#   - crashes-rejected/REJECTED-CRASHES.md
#                                 → auto-rejected crash classes; this is the
#                                   "don't re-file" list agents should grep
#                                   before promoting a new crash.
# Each is regenerated from on-disk state; safe to delete and recreate.


# ─── Cap context reuse ──────────────────────────────────────
# Cached input tokens grow monotonically across iterations and eventually
# push both per-session cost and safety classifier false-positive rate up
# superlinearly. When the prior session cached > CONTEXT_REUSE_CAP tokens,
# archive the state file so the next iteration cold-starts with a fresh,
# small context. The archived state is still on disk (not deleted) so a
# future session can mine it if useful.

# Context reuse cap — DISABLED by default (was 2M, caused cold-start every
# iteration because all agents exceed 2M cached tokens). State persistence
# across iterations is the #1 factor for finding bugs — agents that accumulate
# subsystem knowledge across 5+ sessions are far more effective than fresh
# cold-starts. Only archive when an agent explicitly rotates subsystem (handled
# by the rotation gate) or when truly extreme (50M+ = runaway prompt).
CONTEXT_REUSE_CAP="${CONTEXT_REUSE_CAP:-50000000}"

enforce_context_reuse_cap() {
  local agent_num="$1"
  # With the raised cap, this rarely fires. When it does, it catches
  # genuinely pathological sessions (runaway prompt concatenation, not
  # normal audit work).
  local latest
  latest=$(ls -1t "$RAW_DIR"/session_*_cold-start-${agent_num}*.log.raw \
                  "$RAW_DIR"/session_*_deep_investigation-${agent_num}*.log.raw 2>/dev/null | head -1)
  [ -n "$latest" ] && [ -f "$latest" ] || return 0
  local cached
  cached=$(extract_usage_field "$latest" cached_input_tokens 2>/dev/null)
  [ -n "$cached" ] || return 0
  [[ "$cached" =~ ^[0-9]+$ ]] || return 0
  if [ "$cached" -gt "$CONTEXT_REUSE_CAP" ]; then
    local sf
    sf=$(state_file_path "$agent_num")
    if [ -f "$sf" ]; then
      log "context-cap: Agent${agent_num} carried $(fmt_count "$cached") cached tokens into this iteration, which exceeds CONTEXT_REUSE_CAP=$(fmt_count "$CONTEXT_REUSE_CAP") — archiving its state so the next session starts cold with a small context (avoids LLM prompts growing unboundedly across iterations)" | tee -a "$INDEX"
      local archive_dir="$RESULTS_DIR/.context_archive"
      mkdir -p "$archive_dir" 2>/dev/null || true
      local ts
      ts=$(date +%Y%m%d_%H%M%S)
      mv "$sf" "${archive_dir}/AUDIT_STATE-${agent_num}.${ts}.md" 2>/dev/null || rm -f "$sf"
    fi
  fi
  return 0
}

# ─── Agent launch + post-iteration helpers ────────────────────────
# Factored out in v4 so cold-start and deep-investigation share one
# launch path and one housekeeping path. Before this, both branches
# inlined the same ~35 lines with subtle divergences. Scaling to N
# agents motivated the factoring.

# Launch one agent process into a slot. Used by both the default
# wait-for-all path and the opt-in refill loop. Sets globals:
#   _slot_pid (PID of the spawned agent)
#   _slot_role (role_name composed for this launch)
#   _slot_before_subsystem (subsystem the slot held before this launch)
# Inputs: slot index, role_prefix, prompt_builder fn name, ts, optional
# refill_index (>=1 means "this is a refill of slot N's R-th refill").
_launch_agent_into_slot() {
  local slot="$1" role_prefix="$2" prompt_builder="$3" ts="$4"
  local refill_index="${5:-0}"
  local prompt turns role_name mode prompt_tokens prompt_file
  _slot_before_subsystem=$(get_agent_subsystem "$slot" 2>/dev/null || echo "unknown")
  prompt=$("$prompt_builder" "$slot" | neutralize_qa_vocab_string | strip_novocab_markers)
  prompt_tokens=$(estimate_tokens "$prompt")
  turns="$MAX_TURNS_ANALYSIS"
  mode=$(agent_mode "$slot")
  if [ "$refill_index" -gt 0 ]; then
    role_name="${role_prefix}-${slot}-${mode}-r${refill_index}"
  else
    role_name="${role_prefix}-${slot}-${mode}"
  fi
  log "Prompt built for agent A${slot} (${role_name}): ~$(fmt_count "$prompt_tokens") tokens / ${#prompt} chars"
  prompt_file=$(write_prompt_artifacts "$ts" "$role_name" "$slot" "$role_prefix" "$prompt" "$prompt_tokens")
  log_agent_plan "$slot" "$role_prefix" "$role_name" "$prompt_tokens" "$prompt_file" ""
  run_agent "$role_name" "$slot" "$MODEL" "$turns" "$prompt" "$ts" &
  _slot_pid=$!
  _slot_role="$role_name"
}

# Finalize one agent's run: wait for the recorded PID, normalize exit
# code, log waste line / subsystem claim. Used by both paths.
# Sets _slot_rc to the final exit code.
signal_name_for_exit_status() {
  local rc="$1" sig name
  case "${rc:-}" in ''|*[!0-9]*) return 1 ;; esac
  [ "$rc" -gt 128 ] || return 1
  sig=$((rc - 128))
  name=$(kill -l "$sig" 2>/dev/null) || return 1
  [ -n "$name" ] || return 1
  case "$name" in
    SIG*) printf '%s\n' "$name" ;;
    *)    printf 'SIG%s\n' "$name" ;;
  esac
}

_finalize_agent_slot() {
  local slot="$1" role_prefix="$2" role_name="$3" pid="$4" before_subsystem="$5" ts="$6"
  local rc wait_raw normalized_rc signal_name
  wait "$pid" 2>/dev/null && rc=0 || rc=$?
  if [ "$rc" -ne 0 ]; then
    wait_raw="$RAW_DIR/session_${ts}_${role_name}.log.raw"
    normalized_rc=$(normalize_agent_exit_code "$ACTIVE_BACKEND" "$rc" "$wait_raw")
    if [ "$normalized_rc" != "$rc" ]; then
      log "Agent A${slot} (${role_name}) process exit=${rc} but raw log has a completed ${ACTIVE_BACKEND} turn with no session-level error; treating wait status as exit=${normalized_rc}" | tee -a "$INDEX"
      rc="$normalized_rc"
    fi
  fi
  record_subsystem_claim "$slot" "$role_prefix" "$role_name" "$before_subsystem" "$(get_agent_subsystem "$slot" 2>/dev/null || echo "unknown")"
  if signal_name=$(signal_name_for_exit_status "$rc"); then
    # 128+N: the agent subshell was terminated by signal N, or (more often)
    # it exited with that status after the backend CLI it ran was signaled and
    # the code propagated — `wait` cannot tell the two apart. Agents run the
    # backend directly under a bash watchdog, not timeout.py, so point at the
    # agent's own raw session log, not a wrapper log.
    log "WARNING: Agent A${slot} (${role_name}) reaped with signal-range status ${rc} (128+${signal_name}): the agent process or the backend command it ran was terminated by ${signal_name} — inspect ${wait_raw} for where it stopped" | tee -a "$INDEX"
  elif [ "$rc" -ne 0 ]; then
    log "WARNING: Agent A${slot} (${role_name}) exited with non-zero code ${rc}" | tee -a "$INDEX"
  fi
  _slot_rc="$rc"
}

# Refill predicate: returns 0 if slot $1 should attempt another launch
# this iteration. A slot can refill at most once per iter, and only
# while at least one OTHER agent is still running — refills never
# extend iter wall-time beyond the slowest initially-launched agent.
# Beyond a single refill per slot the iter has become a degenerate
# worker queue and the next iter's housekeeping/diversify pass adds
# more value than further in-iter refills.
_should_refill_slot() {
  local slot="$1"
  local used="$2"
  local any_running="$3"
  [ "$any_running" = "1" ] || return 1
  [ "$used" -lt 1 ] || return 1
  return 0
}

audit_signal_trap() {
  local signal="$1" rc="$2"
  trap - HUP INT TERM
  log "Received SIG${signal}; stopping child process trees" >&2 || true
  process_tree_kill_descendants "$$" TERM 1
  exit "$rc"
}

# Launch N agents in parallel, finalize each on exit. Any slot whose
# agent exits early — while at least one other agent is still running —
# gets a single replacement launch in that slot. Wall-time stays
# bounded by the slowest initially-launched agent.
# Args:
#   $1 = role prefix ("cold-start" | "deep_investigation")
#   $2 = prompt-builder function name (takes agent_num, echoes prompt)
# Uses NUM_AGENTS.
launch_agents_and_wait() {
  local role_prefix="$1"
  local prompt_builder="$2"
  local ts="$3"
  local -a pids=() roles=() before_subsystems=()
  local i launch_count launch_agents
  launch_agents="${CURRENT_LAUNCH_AGENT_LIST:-$(seq 1 "${CURRENT_LAUNCH_AGENT_COUNT:-$NUM_AGENTS}" | tr '\n' ' ')}"
  launch_count=$(printf '%s\n' "$launch_agents" | wc -w | tr -d ' ')
  if [ "${launch_count:-0}" -le 0 ]; then
    log "No agents launched for the ${role_prefix} phase this iteration: launch_count=${launch_count} (the eligible-agent filter ended up empty — usually means the active hypothesis pool is already saturated, the queue is exhausted, or a per-agent guard rejected every candidate)." | tee -a "$INDEX"
    return 0
  fi

  # Per-slot launch. Telemetry composition (PLAN line, prompt artifact
  # paths, role name) lives in _launch_agent_into_slot so refills share
  # the same path. Slots whose pre-launch eligibility check fires are
  # skipped entirely — saving the LLM round-trip the model would have
  # spent producing 4-5k tokens of "I have nothing to do".
  #
  # PLAN-time subsystem-claim ledger (#4): we track the canonical
  # (file, function) keys claimed by earlier slots in THIS iteration and,
  # if the next agent's resume-pinned subsystem collides, clear its
  # resume state so its prompt builder re-picks from the queue. Without
  # this, sticky resume hints from a prior iteration funnel two or three
  # agents onto the same dead-end subsystem (observed: iter 4 had 4-5
  # PLAN entries on Store::alias_user:227 in a row). The existing
  # diversify_subsystem_collisions mechanism fires only AFTER agents
  # have already run; this prevents the collision proactively.
  local -a slot_skipped=()
  local _iter_subsystem_keys=""
  local _resume_pinned_sub _resume_pinned_key
  for i in $launch_agents; do
    slot_skipped[$i]=0
    if audit_should_skip_launch "$i"; then
      log "SKIP_LAUNCH: agent=${i} role=${role_prefix} — no eligible work cards, no active hypothesis, no fuzz leads for this agent; skipping the LLM round-trip this iteration" | tee -a "$INDEX"
      slot_skipped[$i]=1
      pids[$i]=""
      roles[$i]=""
      before_subsystems[$i]="$(get_agent_subsystem "$i" 2>/dev/null || echo "unknown")"
      continue
    fi
    # PLAN-time collision check. If this slot is resume-pinned to a
    # subsystem already grabbed by a prior slot this iteration, clear
    # its resume hint so the prompt builder picks fresh work from the
    # queue. Slot 1 is always launched first and never sees a collision.
    _resume_pinned_sub=$(get_agent_subsystem "$i" 2>/dev/null || echo "")
    _resume_pinned_key=$(_normalize_subsystem_key "$_resume_pinned_sub")
    if [ -n "$_resume_pinned_key" ] && [ "$_resume_pinned_key" != "unknown" ] && [ -n "$_iter_subsystem_keys" ]; then
      # Probe each prior slot's canonical key under the wildcard rule so
      # a bare 'write_selected' pin still matches a prior slot that
      # claimed 'Store::write_selected' in the same file. Straight string
      # equality would miss that case post-(b).
      local _prior_key _collides=0
      while IFS= read -r _prior_key; do
        [ -z "$_prior_key" ] && continue
        if _subsystem_keys_collide "$_resume_pinned_key" "$_prior_key"; then
          _collides=1
          break
        fi
      done <<<"$_iter_subsystem_keys"
      if [ "$_collides" -eq 1 ]; then
        log "PLAN_DEDUP: agent=${i} resume-pinned to '${_resume_pinned_sub}' (canonical='${_resume_pinned_key}') already held by another slot this iteration; clearing resume state so the queue picks fresh work" | tee -a "$INDEX"
        clear_agent_resume_state "$i" 2>/dev/null || true
      fi
    fi
    _launch_agent_into_slot "$i" "$role_prefix" "$prompt_builder" "$ts" 0
    pids[$i]="$_slot_pid"
    roles[$i]="$_slot_role"
    before_subsystems[$i]="$_slot_before_subsystem"
    # Re-read post-launch — the prompt builder may have rotated the
    # agent to a different card. Track the canonical key so subsequent
    # slots in this iteration know what's already claimed.
    local _post_sub _post_key
    _post_sub=$(get_agent_subsystem "$i" 2>/dev/null || echo "")
    _post_key=$(_normalize_subsystem_key "$_post_sub")
    if [ -n "$_post_key" ] && [ "$_post_key" != "unknown" ]; then
      _iter_subsystem_keys="${_iter_subsystem_keys}${_post_key}
"
    fi
  done

  local pid_summary=""
  for i in $launch_agents; do
    if [ "${slot_skipped[$i]:-0}" = "1" ]; then
      pid_summary+="${i}=skipped "
    else
      pid_summary+="${i}=${pids[$i]} "
    fi
  done
  log "Agents now running in parallel (agent_number=process_id pairs): ${pid_summary}— waiting for all to finish before scoring the iteration"

  local rc_summary=""

  # Poll all slots; as each agent exits, finalize it, then try to
  # launch a replacement if at least one other agent is still running
  # and the per-slot refill cap (1) is not reached. Refills inherit
  # the same role_prefix and prompt_builder; each refill picks a new
  # card via the prompt builder's normal claim-next-card path.
  local refill_poll_secs=1
  # Indexed (not associative) — slot indices are always integers and
  # macOS bash 3.2 lacks associative-array support.
  local -a refill_used=() slot_active=()
  for i in $launch_agents; do
    if [ "${slot_skipped[$i]:-0}" = "1" ]; then
      # Skipped slot: never polled, never refilled, never finalized.
      slot_active[$i]=0
      refill_used[$i]=99
      rc_summary+="${i}=skipped "
    else
      slot_active[$i]=1
      refill_used[$i]=0
    fi
  done
  while :; do
    local any_active=0 slot_exited_this_pass=0
    for i in $launch_agents; do
      [ "${slot_active[$i]:-0}" = "1" ] || continue
      if kill -0 "${pids[$i]}" 2>/dev/null; then
        any_active=1
        continue
      fi
      # Slot's PID is no longer running — finalize it.
      _finalize_agent_slot "$i" "$role_prefix" "${roles[$i]}" "${pids[$i]}" \
        "${before_subsystems[$i]:-unknown}" "$ts"
      rc_summary+="${i}=${_slot_rc}(r${refill_used[$i]}) "
      slot_active[$i]=0
      slot_exited_this_pass=1
    done
    # Recompute any_active (we may have just retired slots). `if/fi`
    # rather than `&&` so the loop's last-iteration exit code is always
    # zero — otherwise set -e could trip when the final slot is inactive.
    any_active=0
    for i in $launch_agents; do
      if [ "${slot_active[$i]:-0}" = "1" ]; then
        any_active=1
      fi
    done
    if [ "$slot_exited_this_pass" = "1" ]; then
      # For each just-retired slot, decide whether to refill. Refill is
      # only allowed when at least one OTHER slot is still active, so we
      # never extend iter wall-time beyond the slowest initial agent.
      for i in $launch_agents; do
        [ "${slot_active[$i]:-0}" = "0" ] || continue
        local used="${refill_used[$i]}"
        if _should_refill_slot "$i" "$used" "$any_active"; then
          local next=$((used + 1))
          log "Worker-pool refill: slot ${i} finished early, launching refill r${next} (prior agents still running)" | tee -a "$INDEX"
          _launch_agent_into_slot "$i" "$role_prefix" "$prompt_builder" "$ts" "$next"
          pids[$i]="$_slot_pid"
          roles[$i]="$_slot_role"
          before_subsystems[$i]="$_slot_before_subsystem"
          refill_used[$i]="$next"
          slot_active[$i]=1
          any_active=1
        fi
      done
    fi
    if [ "$any_active" = "0" ]; then
      break
    fi
    sleep "$refill_poll_secs"
  done
  log "Agent exit codes: ${rc_summary}" | tee -a "$INDEX"
  return 0
}

# ─── Strategy ROI tracking ─────────────────────────────────────────
#
# After each iteration, scan state files for hypotheses that reached
# CRASH-* or FIND-* status and tally by strategy letter.  Appends to
# strategy-roi.md so the signal accumulates across iterations.
# The companion build_strategy_roi_directive() injects the top
# strategies into the next deep-investigation prompt.

update_strategy_roi() {
  local roi_file="$RESULTS_DIR/strategy-roi.md"
  local tmp_tally
  tmp_tally=$(mktemp "${TMPDIR:-/tmp}/roi-tally.XXXXXX") || return 1
  local tmp_struct_agents
  tmp_struct_agents=$(mktemp "${TMPDIR:-/tmp}/roi-agents.XXXXXX") || { rm -f "$tmp_tally"; return 1; }

  if structured_state_available 2>/dev/null; then
    jq -s -r '
      .[]
      | select((.status // "") | test("^(CRASH|CRASH-|FIND|FIND-)"))
      | (.strategy // "")
      | select(. != "")
    ' "$(structured_state_hypotheses_path)" >> "$tmp_tally" 2>/dev/null || true
    structured_state_agents_with_rows > "$tmp_struct_agents" 2>/dev/null || true
  fi

  # Scan every per-agent state file for hypothesis rows whose Status
  # column contains CRASH- or FIND-.  The hypothesis table has 8 pipe-
  # delimited columns; Strategy is column 7, Status is column 8.
  local sf
  for sf in "$RESULTS_DIR"/AUDIT_STATE-*.md; do
    [ -f "$sf" ] || continue
    local agent_from_file
    agent_from_file=$(basename "$sf" | sed -nE 's/^AUDIT_STATE-([0-9]+)\.md$/\1/p')
    if [ -n "$agent_from_file" ] && grep -qxF "$agent_from_file" "$tmp_struct_agents" 2>/dev/null; then
      continue
    fi
    # Extract table rows (lines starting with |) whose Status column
    # (field 9, due to leading |) contains CRASH- or FIND-.
    # Strategy is field 8.  Table:
    # | # | Hypothesis | File | Input | Guard | Diagnostic | Strategy | Status |
    # $1  $2  $3         $4     $5      $6      $7           $8         $9
    awk -F'|' '
      {
        status = $9
        gsub(/^[ \t]+|[ \t]+$/, "", status)
        if (status ~ /^(CRASH-|FIND-)/) {
          strat = $8
          gsub(/^[ \t]+|[ \t]+$/, "", strat)
          if (strat != "" && strat != "Strategy") print strat
        }
      }
    ' "$sf" >> "$tmp_tally" 2>/dev/null || true
  done

  # Nothing found this iteration — skip silently
  if [ ! -s "$tmp_tally" ]; then
    rm -f "$tmp_tally" "$tmp_struct_agents"
    return 0
  fi

  # Append timestamped tally
  {
    echo ""
    echo "## Iteration ${iteration:-?}  ($(date '+%Y-%m-%d %H:%M'))"
    sort "$tmp_tally" 2>/dev/null | uniq -c | sort -rn | while read -r count strat; do
      echo "- ${strat}: ${count} finding(s)"
    done || true
  } >> "$roi_file"

  rm -f "$tmp_tally" "$tmp_struct_agents"
  log "strategy-roi: refreshed cumulative finding-yield table at ${roi_file} (lets next iteration's prompts bias toward strategies that have actually produced findings on this target)" | tee -a "$INDEX"
}

# Returns a short prompt block summarizing top-performing strategies
# across all iterations.  Returns empty string if no data yet.
build_strategy_roi_directive() {
  local roi_file="$RESULTS_DIR/strategy-roi.md"
  [ -f "$roi_file" ] && [ -s "$roi_file" ] || return 0

  # Aggregate all "- LETTER: N finding(s)" lines into a total per strategy
  local summary
  summary=$(awk '
    /^- [A-Z]+:/ {
      strat = $2; sub(/:$/, "", strat)
      count = $3 + 0
      total[strat] += count
    }
    END {
      for (s in total) print total[s], s
    }
  ' "$roi_file" | sort -rn | head -5 || true)

  [ -n "$summary" ] || return 0

  echo "**Strategy ROI (this session's cumulative data):** prefer strategies with proven findings."
  echo "$summary" | while read -r count strat; do
    echo "- ${strat}: ${count} total finding(s)"
  done
}

# All post-iteration housekeeping that was previously duplicated across
# the cold-start and deep-investigation branches. Each helper is fenced
# so a single failure cannot abort the audit loop under `set -e`.
## Post-iteration housekeeping is split into two phases:
##
##   - CRITICAL phase: fast file IO and outputs that the next iter's
##     prompt build reads (strategy ROI, handoff file, merged state).
##     Must complete before iter N+1 can start.
##
##   - BACKGROUND phase: LLM-heavy gates (crash-triage, find-gate,
##     patch-review) plus clustering/index passes. Their outputs are
##     informational for the next iter's prompt — at worst the agent
##     briefly investigates a soon-to-be-rejected crash before the
##     sweeper catches up. Running them in the background reclaims the
##     2–14 min gap they cost on the critical path when crashes/finds
##     exist this iteration.
##
## A previous sweeper is barrier-waited before spawning the next one so
## the gate ordering inside the background phase is preserved (cluster
## expand must run before maintain_indexes reads the new card set).
## audit_exit_trap also joins any in-flight sweeper so partial writes
## don't survive a shutdown.
AUDIT_HOUSEKEEPING_BG_PID="${AUDIT_HOUSEKEEPING_BG_PID:-}"

wait_for_background_housekeeping() {
  local pid="${AUDIT_HOUSEKEEPING_BG_PID:-}"
  [ -n "$pid" ] || return 0
  # `wait` only works on direct children; ignore any "not a child" rc.
  wait "$pid" 2>/dev/null || true
  AUDIT_HOUSEKEEPING_BG_PID=""
}

run_post_iteration_housekeeping_critical() {
  set +e
  record_iteration_guard_chain || log "WARN: record_iteration_guard_chain failed (rc=$?)" >> "$INDEX"
  # Snapshot BEFORE merge archives DISCARDED rows, else the discard-rate
  # feedback never triggers next iteration.
  snapshot_quality_feedback   || log "WARN: snapshot_quality_feedback failed (rc=$?)"   >> "$INDEX"
  warn_orphan_testcases       || log "WARN: warn_orphan_testcases failed (rc=$?)"       >> "$INDEX"
  # Close the loop on orphan testcases then salvage the HIT-but-clean ones.
  enforce_asan_for_orphans    || log "WARN: enforce_asan_for_orphans failed (rc=$?)"    >> "$INDEX"
  promote_corpus_testcases    || log "WARN: promote_corpus_testcases failed (rc=$?)"    >> "$INDEX"

  local roi_inputs=("$RESULTS_DIR/state/hypotheses.jsonl")
  local _agent_i
  for _agent_i in $(seq 1 "$NUM_AGENTS"); do
    roi_inputs+=("$(state_file_path "$_agent_i")")
  done
  housekeeping_run_if_dirty strategy-roi update_strategy_roi "${roi_inputs[@]}" \
    || log "WARN: update_strategy_roi failed (rc=$?)" >> "$INDEX"
  refresh_handoff_file        || log "WARN: refresh_handoff_file failed (rc=$?)"        >> "$INDEX"
  merge_audit_state           || log "WARN: merge_audit_state failed (rc=$?)"           >> "$INDEX"
  set -e
  return 0
}

run_post_iteration_housekeeping_background() {
  set +e
  local target_toml
  target_toml="${TARGET_TOML:-$(target_output_root "$SCRIPT_ROOT" "${TARGET_SLUG:-}" "" "")/target.toml}"
  housekeeping_run_if_dirty crash-triage triage_crash_dirs \
    "$RESULTS_DIR/crashes" "$RESULTS_DIR/crashes-needs-review" "$target_toml" \
    || log "WARN: triage_crash_dirs failed (rc=$?)" >> "$INDEX"
  warn_persistent_harness_build_failures \
    || log "WARN: warn_persistent_harness_build_failures failed (rc=$?)" >> "$INDEX"
  housekeeping_run_if_dirty find-gate validate_find_gate \
    "$RESULTS_DIR/findings" "$target_toml" \
    || log "WARN: validate_find_gate failed (rc=$?)" >> "$INDEX"
  housekeeping_run_if_dirty patch-review patch_aware_rerun_review \
    "$RESULTS_DIR/crashes" "$RESULTS_DIR/findings" \
    || log "WARN: patch_aware_rerun_review failed (rc=$?)" >> "$INDEX"
  housekeeping_run_if_dirty crash-cluster-expand expand_clusters_for_new_crashes \
    "$RESULTS_DIR/crashes" \
    || log "WARN: expand_clusters_for_new_crashes failed (rc=$?)" >> "$INDEX"
  housekeeping_run_if_dirty result-indexes maintain_indexes \
    "$RESULTS_DIR/crashes" "$RESULTS_DIR/crashes-rejected" \
    "$RESULTS_DIR/findings" \
    || log "WARN: maintain_indexes failed (rc=$?)" >> "$INDEX"
  set -e
  return 0
}

run_post_iteration_housekeeping() {
  # Bash 3.2 (macOS default) has a known bug where set -e leaks through
  # || guards inside functions when command substitutions fail internally.
  # Disable set -e here too in case any reachable callback path resets it.
  set +e
  run_post_iteration_housekeeping_critical
  # Wait for any prior sweeper before spawning a new one — keeps the
  # background phase's internal stage ordering intact (cluster-expand
  # must run before maintain_indexes consumes the new cards).
  wait_for_background_housekeeping
  run_post_iteration_housekeeping_background &
  AUDIT_HOUSEKEEPING_BG_PID=$!
  set -e
  return 0
}

# Update per-subsystem dry-streak counters based on whether this
# iteration was productive. Previously inlined twice.
update_subsystem_dry_streaks() {
  local productive="$1"   # 0 or 1
  local i subsystem
  for i in $(seq 1 "$NUM_AGENTS"); do
    subsystem=$(get_agent_subsystem "$i" 2>/dev/null || echo unknown)
    [ "$subsystem" = "unknown" ] && continue
    local agent_productive=0
    if [ "$productive" -eq 1 ] && agent_iteration_productive "$i"; then
      agent_productive=1
    fi
    if [ "$agent_productive" -eq 1 ]; then
      reset_subsystem_dry_streak "$subsystem" || true
      reset_agent_strategy_streak "$i" || true
    else
      bump_subsystem_dry_streak "$subsystem" || true
      bump_agent_strategy_streak "$i" || true
    fi
    # Update wall-clock tenure tracking per agent
    update_agent_tenure "$i" || true

    # Strategy rotation check: if this agent has been dry on the same strategy
    # for STRATEGY_DRY_STREAK_THRESHOLD iterations, rotate to the next strategy.
    # S1 (prior-fix review) gets a longer threshold because it requires deep
    # patch analysis before producing testcases — 3 dry iterations is normal.
    local strat_streak strat_threshold
    strat_streak=$(get_agent_strategy_streak "$i")
    local current_strat_for_threshold
    current_strat_for_threshold=$(get_agent_strategy "$i")
    if [ "$current_strat_for_threshold" = "S1" ]; then
      strat_threshold="$STRATEGY_S1_DRY_STREAK_THRESHOLD"
    else
      strat_threshold="$STRATEGY_DRY_STREAK_THRESHOLD"
    fi
    if [ "${strat_streak:-0}" -ge "$strat_threshold" ]; then
      local current_strat next_strat picker="rr" picker_out picker_reason=""
      current_strat=$(get_agent_strategy "$i")

      # Per-strategy completion gate (Fix #9). Read the strategy's
      # minimum-evidence floor from notes.jsonl and refuse to rotate
      # off `current_strat` until the floor is met. This stops the
      # "1 hypothesis + 3 variants → rotate" pattern that lets agents
      # touch a strategy without doing the work it actually demands.
      local strat_status strat_complete strat_evidence strat_min strat_fields
      strat_status=$(strategy_completion_for_agent "$i" "$current_strat" 2>/dev/null || echo "")
      strat_fields=$(strategy_completion_fields "$strat_status")
      IFS="$(printf '\t')" read -r strat_complete strat_evidence strat_min <<< "$strat_fields"
      if [ "$strat_complete" = "false" ]; then
        log "STRATEGY_INCOMPLETE: agent=${i} subsystem=${subsystem} strategy=$(strategy_tag "$current_strat") dry=${strat_streak}/${strat_threshold} evidence=${strat_evidence}/${strat_min} action=keep — this strategy needs more concrete work (hypotheses/testcases) before rotating off; the agent stays on it" | tee -a "$INDEX"
        # Safety valve: the agent cannot wedge on one strategy forever.
        # The valve must fire BEFORE STALL_STOP would, otherwise
        # MAX_DRY_SESSIONS terminates the run while the agent's streak
        # is still below threshold+5 — exactly the failure mode observed
        # in the curl run (5-iter STALL with all agents stuck on S1,
        # valve never reached). Cap the valve at MAX_DRY_SESSIONS-1 so
        # at least one rotation attempt always precedes STALL_STOP, but
        # keep the original threshold+5 cushion when there's room for it.
        local valve_extra=5 valve_ceiling
        valve_ceiling=$((strat_threshold + valve_extra))
        if [ "${MAX_DRY_SESSIONS:-0}" -gt 0 ] && [ "$valve_ceiling" -ge "$MAX_DRY_SESSIONS" ]; then
          valve_ceiling=$((MAX_DRY_SESSIONS - 1))
          [ "$valve_ceiling" -lt "$strat_threshold" ] && valve_ceiling="$strat_threshold"
        fi
        if [ "${strat_streak:-0}" -ge "$valve_ceiling" ]; then
          log "STRATEGY_FORCE_ROTATE: agent=${i} strategy=$(strategy_tag "$current_strat") dry=${strat_streak}/${valve_ceiling} — safety valve firing: the agent never produced enough evidence to formally complete this strategy, but it's been stuck too long; forcing a rotation so the run doesn't STALL_STOP first" | tee -a "$INDEX"
        else
          continue
        fi
      fi

      # Try LLM first; fall back to round-robin if it doesn't answer.
      picker_out=$(llm_pick_next_strategy "$i" "$current_strat" "$subsystem" "$strat_streak" 2>/dev/null) && picker="llm"
      if [ -n "${picker_out:-}" ]; then
        next_strat="${picker_out%%$'\t'*}"
        if [ "$picker_out" != "$next_strat" ]; then
          picker_reason="${picker_out#*$'\t'}"
        fi
      fi
      if [ -z "${next_strat:-}" ] || [ "$next_strat" = "$current_strat" ]; then
        next_strat=$(next_strategy_in_rotation "$current_strat")
        picker="rr"
        picker_reason="round-robin fallback"
      fi
      local from_cards to_cards from_tag to_tag card_counts
      card_counts=$(count_unclaimed_cards_for_two_strategies "$current_strat" "$next_strat" 2>/dev/null)
      IFS="$(printf '\t')" read -r from_cards to_cards <<< "$card_counts"
      from_tag=$(strategy_tag "$current_strat")
      to_tag=$(strategy_tag "$next_strat")
      log_strategy_rotation "$i" "$subsystem" "$current_strat" "$next_strat" "$strat_streak" "$strat_threshold" "$picker" "$picker_reason" \
        "rotated=${from_tag}→${to_tag} cards_left=${from_cards:-?} cards_to=${to_cards:-?}"
      set_agent_strategy "$i" "$next_strat"
      reset_agent_strategy_streak "$i" || true
    else
      # Track current strategy (may have changed if agent self-selected)
      local current_strat
      current_strat=$(get_agent_strategy "$i")
      set_agent_strategy "$i" "$current_strat"
      local strategy_action="keep"
      [ "$agent_productive" -eq 1 ] && strategy_action="reset"
      local strat_cards strat_sub_cards strat_label card_counts
      card_counts=$(count_unclaimed_cards_for_strategy_subsystem "$current_strat" "$subsystem" 2>/dev/null)
      IFS="$(printf '\t')" read -r strat_cards strat_sub_cards <<< "$card_counts"
      strat_label=$(strategy_tag "$current_strat")
      log_strategy_status "$i" "$subsystem" "$current_strat" "$strat_streak" "$strat_threshold" "$agent_productive" "$strategy_action" \
        "playing=${strat_label} cards_available=${strat_cards:-?}(in_subsystem=${strat_sub_cards:-?})"

      # Subsystem fast-rotate: when the (strategy, subsystem) pair has
      # no unclaimed cards but the *strategy* still has work elsewhere,
      # clear the agent's resume-state subsystem hint so the next
      # session re-picks from the queue. Without this, the agent waits
      # out STRATEGY_DRY_STREAK_THRESHOLD iterations on a guaranteed-
      # empty subsystem (or stays latched onto a corrupt one like the
      # /Users absolute-path case) before any rotation fires.
      #
      # Gate carefully so this doesn't fight the strategy rotator:
      # only run when the agent was unproductive AND both counts are
      # numeric AND the strategy has work to offer.
      if [ "$agent_productive" -ne 1 ] \
        && [ -n "$subsystem" ] && [ "$subsystem" != "unknown" ] \
        && case "${strat_sub_cards:-?}" in ''|*[!0-9]*) false ;; *) true ;; esac \
        && case "${strat_cards:-?}" in ''|*[!0-9]*) false ;; *) true ;; esac \
        && [ "$strat_sub_cards" -eq 0 ] && [ "$strat_cards" -gt 0 ]; then
        clear_agent_resume_state "$i" 2>/dev/null || true
        log "SUBSYSTEM_FAST_ROTATE: agent=${i} strategy=$(strategy_tag "$current_strat") subsystem='${subsystem}' has 0 unclaimed cards (but the strategy has ${strat_cards} card(s) elsewhere); cleared resume hint so the next session re-picks from the queue" | tee -a "$INDEX"
      fi
    fi
  done
}

# ─── Main loop ─────────────────────────────────────────────────────

# REMOVED forced strategy rotation. Previous version alternated PATCH_MINE/CODE_REVIEW
# every iteration, which prevented agents from sustaining multi-session depth on a
# single investigation. Now all agents get a PERSISTENT prompt that tells them to
# continue their previous investigation OR pick a new strategy if stuck.
#
# Agent count is NUM_AGENTS (default 3). Agents coordinate via state files
# to avoid overlapping subsystems; the natural spread across browser-mode
# and shell-mode subsystems falls out of that check.

# Trap unexpected exits so we can diagnose why the loop stopped.
# ERR fires on set -e failures; EXIT fires on ANY termination (signals,
# untrapped errors, normal exit). Both write to index.log AND stderr so
# the message survives even if stdout is piped/broken.
# NOTE: ERR trap uses >> (append redirect) instead of | tee to avoid
# pipefail killing the trap handler itself — the original tee pipeline
# could silently swallow the diagnostic on stdout breakage.
audit_exit_trap() {
  local line="$1"
  local rc="$2"
  # Join any in-flight background housekeeping so partially-written
  # cluster/index files don't survive the exit. The wait itself is
  # bounded by the gate functions' own timeouts.
  wait_for_background_housekeeping 2>/dev/null || true
  # Release the output-dir instance lock so a follow-up audit on the
  # same target+backend can start cleanly.
  audit_release_instance_lock 2>/dev/null || true
  # A 128+N exit means the script (or an inner foreground command it ran under
  # set -e) was terminated by signal N and the status propagated up — the
  # harness-r1 shape, which otherwise appears as a bare "rc=143" with no cause.
  # Name it here, in the script's own last log line. macOS records no sender
  # for an ordinary SIGTERM, so the origin still needs the timeout.py wrapper
  # breadcrumbs, not this line.
  local _rc_note="" _signal_name=""
  if _signal_name=$(signal_name_for_exit_status "$rc"); then
    _rc_note=" [128+${_signal_name}: script or an inner foreground command was terminated by ${_signal_name}; sender not recorded by the OS]"
  fi
  log "SCRIPT EXITING (line=${line} rc=${rc})${_rc_note}" >> "$INDEX" 2>/dev/null || true
  log "SCRIPT EXITING (line=${line} rc=${rc})${_rc_note}" >&2 || true
}

trap 'log "UNEXPECTED EXIT at line $LINENO (rc=$?)" >> "$INDEX" 2>/dev/null; log "UNEXPECTED EXIT at line $LINENO (rc=$?)" >&2' ERR
trap 'audit_signal_trap HUP 129' HUP
trap 'audit_signal_trap INT 130' INT
trap 'audit_signal_trap TERM 143' TERM
trap 'audit_exit_trap "$LINENO" "$?"' EXIT

while true; do
  if [ "$MAX_ITERATIONS" -gt 0 ] && [ "$total_iterations" -ge "$MAX_ITERATIONS" ]; then
    log "Reached the configured iteration limit (--max-iterations=${MAX_ITERATIONS}); stopping the audit cleanly. Restart bin/audit without that limit to continue the campaign."
    break
  fi

  select_ensemble_backend_for_iteration
  validate_active_model
  prepare_active_backend_runtime

  if sleep_for_active_rate_limit_cooldown; then
    continue
  fi

  total_iterations=$((total_iterations + 1))

  if [ -f "$COUNTER_FILE" ]; then
    iteration=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
  else
    iteration=0
  fi
  iteration=$((iteration + 1))
  echo "$iteration" > "$COUNTER_FILE"

  if [ "$dry_streak" -ge "$MAX_DRY_SESSIONS" ]; then
    log "STALL: ${dry_streak} iterations in a row produced no new findings or hypotheses (threshold=${MAX_DRY_SESSIONS}). The run will pause until something new appears: an open hypothesis, an eligible work card, a new fuzz lead, or a target source change." | tee -a "$INDEX"
  fi

  printf '0' > "$LLM_DECIDE_COUNTER_FILE" 2>/dev/null || true

  kill_zombie_asan || log "WARN: kill_zombie_asan failed (rc=$?)" | tee -a "$INDEX"

  # Neutralize classifier-hot vocabulary in state files + testcase headers
  # BEFORE building prompts to reduce safety-classifier false positives.
  neutralize_qa_vocab || log "WARN: neutralize_qa_vocab failed (rc=$?)" | tee -a "$INDEX"

  # Write static prompt rules file once per iteration (read by build_common_suffix).
  write_static_prompt_file || log "WARN: write_static_prompt_file failed (rc=$?)" | tee -a "$INDEX"

  # Refresh structured work cards before prompt construction. This is a
  # deterministic pre-pass: agents receive concrete, claimed work cards instead
  # of broad subsystem-selection prompts.
  refresh_structured_work_cards || log "WARN: refresh_structured_work_cards failed (rc=$?)" | tee -a "$INDEX"

  # Pre-compute per-iteration cache: blocklist, cross-agent summaries,
  # coverage-gap rankings. Prompt builders read from cache instead of
  # re-scanning state/hits logs for every agent.
  cache_iteration_data || log "WARN: cache_iteration_data failed (rc=$?)" | tee -a "$INDEX"

  # If the prior session cached too many tokens, archive state so the
  # next iteration cold-starts with a small context.
  for i in $(seq 1 "$NUM_AGENTS"); do
    enforce_context_reuse_cap "$i" || log "WARN: enforce_context_reuse_cap $i failed (rc=$?)" | tee -a "$INDEX"
  done

  # If a prior iteration left an agent with no active queue, do not spend one
  # more deep-investigation launch just to discover that. Archiving the empty
  # state lets build_deep_investigation_prompt fall back to cold-start for only
  # that agent while preserving active agents.
  archive_prelaunch_exhausted_states || log "WARN: archive_prelaunch_exhausted_states failed (rc=$?)" | tee -a "$INDEX"

  # Refresh fuzz-leads.md before each iteration so agents see the
  # latest non-noise libFuzzer crash signatures in their directive.
  # Non-fatal if it fails — the downstream reader handles missing file.
  if [ -x "bin/triage-fuzz-crashes" ]; then
    bin/triage-fuzz-crashes "$RESULTS_DIR" 20 \
      >>"$INDEX" 2>&1 || log "WARN: triage-fuzz-crashes failed (rc=$?)" | tee -a "$INDEX"
  fi

  if hard_stop_if_target_exhausted; then
    break
  fi
  if [ "$dry_streak" -ge "$MAX_DRY_SESSIONS" ]; then
    log "STALL_CONTINUE: launch allowed because new evidence remains (active work, new fuzz lead, or source change). Resetting dry_streak." | tee -a "$INDEX"
    dry_streak=0
  fi
  refresh_launch_evidence_signatures

  timestamp=$(date +%Y%m%d_%H%M%S)
  load_iteration_progress_snapshot \
    confirmed_findings_before security_crashes_before actionable_before env_blocked_before

  # Reset the per-iteration ASan-run counter for every agent. The wrapper
  # increments this and prints BUDGET: N/${ASAN_RUN_BUDGET_PER_ITERATION}
  # on each call so the agent can self-throttle.
  for i in $(seq 1 "$NUM_AGENTS"); do
    reset_asan_run_counter "$i"
    printf '0' > "$LOGDIR/.llm_decisions_${i}" 2>/dev/null || true
  done

  iteration_start_epoch=$(date +%s)
  if [ "$IS_BROWSER_TARGET" -eq 1 ]; then
    log "═══ Iteration ${iteration} starting (run #${total_iterations} this session, backend=${ACTIVE_BACKEND}); agent pool: ${BROWSER_AGENTS} browser + ${SHELL_AGENTS} shell, probe budget per agent: ${BROWSER_ASAN_RUN_BUDGET} (browser) / ${SHELL_ASAN_RUN_BUDGET} (shell); progress so far: ${confirmed_findings_before} confirmed finding(s), ${security_crashes_before} crash candidate(s), ${dry_streak}/${MAX_DRY_SESSIONS} dry iterations (stops at ${MAX_DRY_SESSIONS}) ═══" | tee -a "$INDEX"
  else
    log "═══ Iteration ${iteration} starting (run #${total_iterations} this session, backend=${ACTIVE_BACKEND}); agent pool: ${NUM_AGENTS} worker(s), probe budget per agent: ${SHELL_ASAN_RUN_BUDGET}; progress so far: ${confirmed_findings_before} confirmed finding(s), ${security_crashes_before} crash candidate(s), ${dry_streak}/${MAX_DRY_SESSIONS} dry iterations (stops at ${MAX_DRY_SESSIONS}) ═══" | tee -a "$INDEX"
  fi

  # Preflight: warn if free RAM is tight. Rough envelope: browsers ~3 GB
  # each, shells ~500 MB each, plus ~6 GB baseline for the host. The
  # user may be running this script twice concurrently with different backends,
  # so the per-script warning uses the sum of both browser and shell
  # fleets.
  if free_mb=$(_detect_free_ram_mb 2>/dev/null); then
    if [ "$IS_BROWSER_TARGET" -eq 1 ]; then
      need_mb=$(( BROWSER_AGENTS * 3072 + SHELL_AGENTS * 512 + 4096 ))
    else
      need_mb=$(( NUM_AGENTS * 512 + 4096 ))
    fi
    if [ "$free_mb" -lt "$need_mb" ]; then
      log "RAM_WARNING: only ${free_mb} MB of system memory is available right now, but this audit's working-set estimate is ${need_mb} MB (and roughly 2× that if you are running both LLM backends concurrently). The current agent pool may swap or get OOM-killed — consider lowering NUM_AGENTS / BROWSER_AGENTS / SHELL_AGENTS or closing other heavy processes." | tee -a "$INDEX"
    fi
  fi

  # Handle cold start — launch NUM_AGENTS in parallel. Each picks its own
  # subsystem and checks the others' state files to avoid overlap.
  if is_cold_start; then
    # Seed the work-card pool with breadth-first recon hypotheses
    # before the strategy rotator picks anything up. The recon pass
    # surfaces candidate bugs the rotator's S1-S8 strategies otherwise
    # take many iterations to discover (e.g. re-entrant cancel/destroy
    # UAFs in ares_process.c — found by recon, missed by S1 on the
    # same target). Cached on the target source SHA so re-entry doesn't
    # re-pay the recon cost on the same code.
    maybe_seed_recon_cards "$ACTIVE_BACKEND" || \
      log "Recon seed: skipped or failed; cold-start continues without recon-seeded cards" | tee -a "$INDEX"
    CURRENT_LAUNCH_AGENT_COUNT="$NUM_AGENTS"
    CURRENT_LAUNCH_AGENT_LIST="$(seq 1 "$NUM_AGENTS" | tr '\n' ' ' | sed 's/ $//')"
    _agent_display="$(printf '%s\n' "$CURRENT_LAUNCH_AGENT_LIST" | tr ' ' ',')"
    if [ "$IS_BROWSER_TARGET" -eq 1 ]; then
      log "Cold start: no prior agent state files exist for this target/backend, so the harness is launching all ${CURRENT_LAUNCH_AGENT_COUNT} of ${NUM_AGENTS} configured agents [${_agent_display}] in parallel (split: ${BROWSER_AGENTS} browser + ${SHELL_AGENTS} shell). Each agent will pick its own subsystem from the queue." | tee -a "$INDEX"
    else
      log "Cold start: no prior agent state files exist for this target/backend, so the harness is launching all ${CURRENT_LAUNCH_AGENT_COUNT} of ${NUM_AGENTS} configured agents [${_agent_display}] in parallel. Each agent will pick its own subsystem from the queue." | tee -a "$INDEX"
    fi
    launch_agents_and_wait "cold-start" build_cold_start_prompt "$timestamp"
    rl_rc=0; handle_rate_limit_backoff "$timestamp" 2>/dev/null || rl_rc=$?
    if [ "$rl_rc" -eq 2 ]; then
      break   # BACKEND_UNAVAILABLE: sustained rejection — stop loudly (logged inside)
    elif [ "$rl_rc" -eq 0 ]; then
      continue
    fi
    run_post_iteration_housekeeping || true

    load_iteration_progress_snapshot \
      confirmed_findings_after security_crashes_after actionable_after env_blocked_after
    new_confirmed_findings=$((confirmed_findings_after - confirmed_findings_before))
    new_security_crashes=$((security_crashes_after - security_crashes_before))
    new_env_blocked=$((env_blocked_after - env_blocked_before))
    # PRODUCTIVE only when triage actually promoted something to a
    # confirmed finding or a crash candidate. A non-autodiscard ASan
    # crash that landed in scratch but never made it through triage
    # (rejected, dedup'd, or still in flight) is NOT productive — if
    # it were, dry_streak would reset every iteration on the same
    # scratch artifact and STALL_STOP would never fire. See
    # is_state_productive() for the prior, looser semantics.
    if [ "$new_confirmed_findings" -gt 0 ] || [ "$new_security_crashes" -gt 0 ]; then
      dry_streak=0
      update_subsystem_dry_streaks 1 || true
    elif [ "$new_env_blocked" -gt 0 ]; then
      # Diagnostic iteration: cards dispositioned to ENV-BLOCKED narrow
      # the search space (the queue marks them `blocked` and stops
      # offering them). Forward progress — do not bump dry_streak. If
      # the agent only ever env-blocks, the eligible queue drains and
      # the existing exhaustion handler fires STALL_STOP without a
      # streak cap.
      log "Iteration finished — ENV-BLOCKED-DIAGNOSTIC: marked ${new_env_blocked} new env-blocked entry(ies) but produced no findings/crashes; dry_streak stays at ${dry_streak}/${MAX_DRY_SESSIONS} (queue exhaustion governs stall, not a per-streak cap)" | tee -a "$INDEX"
      update_subsystem_dry_streaks 0 || true
    else
      dry_streak=$((dry_streak + 1))
      update_subsystem_dry_streaks 0 || true
    fi
    sleep "$COOLDOWN"
    continue
  fi

  # Steady-state: launch NUM_AGENTS in parallel for deep investigation.
  active_before_launch=$(count_total_active_hypotheses 2>/dev/null || echo 0)
  if [ "$IS_BROWSER_TARGET" -ne 1 ]; then
    CURRENT_LAUNCH_AGENT_COUNT="$NUM_AGENTS"
    CURRENT_LAUNCH_AGENT_LIST="$(seq 1 "$NUM_AGENTS" | tr '\n' ' ' | sed 's/ $//')"
  elif [ "${active_before_launch:-0}" -le 1 ]; then
    CURRENT_LAUNCH_AGENT_COUNT=1
    CURRENT_LAUNCH_AGENT_LIST="1"
    if [ "${active_before_launch:-0}" -eq 1 ]; then
      for i in $(seq 1 "$NUM_AGENTS"); do
        if [ "$(count_active_hypotheses_for_agent "$i" 2>/dev/null || echo 0)" -gt 0 ]; then
          CURRENT_LAUNCH_AGENT_LIST="$i"
          break
        fi
      done
    fi
  else
    CURRENT_LAUNCH_AGENT_COUNT="$NUM_AGENTS"
    CURRENT_LAUNCH_AGENT_LIST="$(seq 1 "$NUM_AGENTS" | tr '\n' ' ' | sed 's/ $//')"
  fi
  _agent_display="$(printf '%s\n' "$CURRENT_LAUNCH_AGENT_LIST" | tr ' ' ',')"
  if [ "$IS_BROWSER_TARGET" -eq 1 ]; then
    log "Resuming ${CURRENT_LAUNCH_AGENT_COUNT} of ${NUM_AGENTS} agent(s) [${_agent_display}] in parallel for a deep-investigation pass over their prior hypotheses (${active_before_launch} open hypothesis(es) across the pool; pool split: ${BROWSER_AGENTS} browser + ${SHELL_AGENTS} shell)" | tee -a "$INDEX"
  else
    log "Resuming ${CURRENT_LAUNCH_AGENT_COUNT} of ${NUM_AGENTS} agent(s) [${_agent_display}] in parallel for a deep-investigation pass over their prior hypotheses (${active_before_launch} open hypothesis(es) across the pool)" | tee -a "$INDEX"
  fi
  launch_agents_and_wait "deep_investigation" build_deep_investigation_prompt "$timestamp"

  rl_rc=0; handle_rate_limit_backoff "$timestamp" 2>/dev/null || rl_rc=$?
  if [ "$rl_rc" -eq 2 ]; then
    break   # BACKEND_UNAVAILABLE: sustained rejection — stop loudly (logged inside)
  elif [ "$rl_rc" -eq 0 ]; then
    continue
  fi

  kill_zombie_asan || true

  run_post_iteration_housekeeping

  # Track confirmed security findings and security crash candidates separately so the
  # logs never call pending crash candidates "findings". Productivity still
  # includes net-new actionable state entries (CRASH- / FIND- / NEEDS_TESTCASE).
  load_iteration_progress_snapshot \
    confirmed_findings_after security_crashes_after actionable_after env_blocked_after
  new_confirmed_findings=$((confirmed_findings_after - confirmed_findings_before))
  new_security_crashes=$((security_crashes_after - security_crashes_before))
  new_env_blocked=$((env_blocked_after - env_blocked_before))

  iteration_was_productive=0
  # PRODUCTIVE requires a promoted finding or crash candidate. The
  # prior is_state_productive() disjunct also returned true for
  # untriaged scratch ASan output, which let dry_streak reset on
  # rejected/dedup'd crashes — "PRODUCTIVE: 0 new finding(s) and 0
  # new crash candidate(s)" appeared in the log because of that.
  if [ "$new_confirmed_findings" -gt 0 ] || [ "$new_security_crashes" -gt 0 ]; then
    iteration_was_productive=1
  fi
  update_subsystem_dry_streaks "$iteration_was_productive" || log "WARN: update_subsystem_dry_streaks failed (rc=$?)" | tee -a "$INDEX"

  # Guard-chain saturation becomes actionable after dry repetition: first seed a
  # bypass-only work card, then temporarily steer new generic claims away from
  # the saturated subsystem. Active HIT / NEEDS_TESTCASE hypotheses are left
  # intact because this only affects future card claims.
  for i in $(seq 1 "$NUM_AGENTS"); do
    subsystem=$(get_agent_subsystem "$i" 2>/dev/null || echo unknown)
    [ "$subsystem" = "unknown" ] && continue
    subsystem_is_blocklisted "$subsystem" && continue
    saturation=$(detect_guard_saturation "$subsystem" 2>/dev/null || echo "")
    sub_streak=$(get_subsystem_dry_streak "$subsystem" 2>/dev/null || echo 0)
    if [ "${sub_streak:-0}" -eq 0 ]; then
      unmark_guard_saturated_subsystem "$subsystem" || true
    fi
    if [ -n "$saturation" ] && [ "${sub_streak:-0}" -ge 5 ]; then
      gcount="${saturation%%:*}"
      gstr="${saturation#*:}"
      action_count=$(record_guard_saturation_action "$subsystem" "$gstr" 2>/dev/null || echo 1)
      append_guard_bypass_card "$subsystem" "$gstr" || true
      if [ "${action_count:-1}" -ge "${GUARD_SATURATION_ROTATE_AFTER:-2}" ]; then
        mark_guard_saturated_subsystem "$subsystem"
        log "GUARD_SATURATION: subsystem=${subsystem} keeps hitting the same defensive check ('${gstr}') in ${gcount} different hypotheses (dry=${sub_streak}, seen=${action_count}x) — new claims for this subsystem will be steered elsewhere; existing active work is preserved" | tee -a "$INDEX"
      else
        log "GUARD_SATURATION: subsystem=${subsystem} keeps hitting the same defensive check ('${gstr}') in ${gcount} different hypotheses (dry=${sub_streak}, seen=${action_count}x) — seeding a bypass-the-guard work card to break the rut; existing active work is preserved" | tee -a "$INDEX"
      fi
    fi
  done

  iter_dur_secs=$(( $(date +%s) - ${iteration_start_epoch:-$(date +%s)} ))
  if [ "$iteration_was_productive" -eq 1 ]; then
    dry_streak=0
    log "Iteration ${iteration} finished in $(fmt_secs "$iter_dur_secs") — PRODUCTIVE: ${new_confirmed_findings} new confirmed finding(s) and ${new_security_crashes} new crash candidate(s) this round; cumulative totals are now ${confirmed_findings_after} finding(s) / ${security_crashes_after} crash(es); resetting dry streak to 0" | tee -a "$INDEX"
  elif [ "$new_env_blocked" -gt 0 ]; then
    # Diagnostic iteration: the harness ruled out dead-code subsystems
    # (TLS/SSH backends not compiled, platform-only TUs, etc.) but did
    # not yet promote a finding/crash. The workqueue marks the
    # corresponding cards `blocked`, so the eligible pool shrinks every
    # such iteration — once it empties, the existing
    # target_exhausted_hard_stop_ready / eligible_work_card_exists path
    # fires STALL_STOP naturally. Do not bump dry_streak.
    log "Iteration ${iteration} finished in $(fmt_secs "$iter_dur_secs") — ENV-BLOCKED-DIAGNOSTIC: marked ${new_env_blocked} new env-blocked entry(ies) but produced no findings/crashes; dry_streak stays at ${dry_streak}/${MAX_DRY_SESSIONS} (queue exhaustion governs stall, not a per-streak cap); cumulative totals: ${confirmed_findings_after} finding(s) / ${security_crashes_after} crash(es)" | tee -a "$INDEX"
  else
    dry_streak=$((dry_streak + 1))
    log "Iteration ${iteration} finished in $(fmt_secs "$iter_dur_secs") — DRY: no new findings, no new crashes, no state changes this round; dry streak is now ${dry_streak}/${MAX_DRY_SESSIONS} (audit stops when it hits ${MAX_DRY_SESSIONS}); cumulative totals: ${confirmed_findings_after} finding(s) / ${security_crashes_after} crash(es)" | tee -a "$INDEX"
  fi

  # Queue snapshot — one line per iteration so rotation/starvation
  # bugs are diagnosable from a single grep on the index log.
  log_queue_state || true
  log_card_activity_since "${iteration_start_epoch:-0}" || true

  # Verify state files and detect exhaustion / overlap / blocklist violations.
  # Fenced: a single agent's broken state file must not kill the loop.
  for i in $(seq 1 "$NUM_AGENTS"); do
    local_state=$(state_file_path "$i")
    if [ -f "$local_state" ]; then
      pending=$(grep -c "PENDING" "$local_state" 2>/dev/null || true)
      active=$(count_active_hypotheses_for_agent "$i" 2>/dev/null || echo 0)
      subsystem=$(get_agent_subsystem "$i" 2>/dev/null || echo unknown)
      sub_streak=$(get_subsystem_dry_streak "$subsystem" 2>/dev/null || echo 0)
      if subsystem_is_blocklisted "$subsystem" 2>/dev/null; then
        log "Agent ${i} state: ${pending} hypothesis(es) PENDING on subsystem='${subsystem}' ⚠ BLOCKLISTED — will be rotated off next iteration" | tee -a "$INDEX"
      else
        log "Agent ${i} state: ${pending} queued (PENDING) + ${active} in-progress (ACTIVE) on subsystem='${subsystem}' (subsystem_dry_streak=${sub_streak})" | tee -a "$INDEX"
      fi
      if [ "${active:-0}" -eq 0 ]; then
        recovery_pair=$(recover_exhausted_agent "$i" "exhausted")
        prev_strat="${recovery_pair%% *}"
        next_strat="${recovery_pair##* }"
        log "EXHAUSTION: agent ${i} has no open hypotheses left — archiving its state and rotating strategy $(strategy_tag "$prev_strat")→$(strategy_tag "$next_strat") so the next iteration restarts this worker fresh" | tee -a "$INDEX"
      fi
    fi
  done

  # Log overlap and exhaustion warnings
  overlap=$(detect_subsystem_overlap 2>/dev/null || echo "")
  [ -n "$overlap" ] && log "OVERLAP: $overlap" | tee -a "$INDEX"
  total_pending=$(count_total_pending 2>/dev/null || true)
  total_pending=${total_pending:-0}
  if ! [[ "$total_pending" =~ ^[0-9]+$ ]]; then
    log "WARN: count_total_pending returned non-numeric value '${total_pending}'; treating as 0" | tee -a "$INDEX"
    total_pending=0
  fi
  if [ "$total_pending" -eq 0 ]; then
    # Don't wait for STALL_STOP to attempt rotation. If the queue still
    # has unclaimed work on a strategy or subsystem no agent currently
    # holds, fire the same helpers hard_stop_if_target_exhausted uses —
    # earlier rotation = fewer iterations wasted on dead strategies.
    if force_rotate_to_unclaimed_strategies; then
      log "EXHAUSTION: all agents have 0 hypotheses to test — rotating to a strategy that still has unclaimed work cards (avoids burning an iteration on empty queues)" | tee -a "$INDEX"
    elif force_rotate_to_unclaimed_subsystems; then
      log "EXHAUSTION: all agents have 0 hypotheses to test — re-pinning to an untouched subsystem that still has unclaimed work cards" | tee -a "$INDEX"
    else
      log "EXHAUSTION: all agents have 0 hypotheses to test — and no productive rotation target remains (queue empty or fully overlapping with current agent assignments); the run will stop once dry_streak hits ${MAX_DRY_SESSIONS}" | tee -a "$INDEX"
    fi
  fi

  # Cold-start (and post-archive) often leaves multiple agents on the
  # same subsystem because each agent picks the top-ranked unclaimed
  # subsystem independently. Detect that here and spread duplicates onto
  # different subsystems for the next iteration's planner.
  diversify_subsystem_collisions || true

  log "Cooling down for $(fmt_secs "$COOLDOWN") before starting the next iteration (lets background housekeeping settle and prevents tight retry loops on transient errors)"
  sleep "$COOLDOWN"
done
