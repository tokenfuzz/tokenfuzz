# The gemini backend takes the same default agent pool as every other
# backend (set above) — no backend-specific cap. An earlier conservative
# 1-agent default for agy was removed: it did not prevent the failure it
# targeted (agy's per-account quota is a *period* allocation, exhausted by
# total usage regardless of how many sessions run in parallel), and a
# genuine 429 is handled reactively by detect_rate_limit. Operators tune
# gemini parallelism with NUM_AGENTS, exactly like claude/codex/oss.

# Per-target config: output/<slug>/target.toml (gitignored, generated then reviewed).
# With --experiment, output/<slug>-<experiment>/target.toml links to that base
# config by default so bin/probe can discover both session env and target config
# from experiment scratch paths.
# Per-session captures: output/<slug>[-<experiment>]/<backend>/results/.session-env
# is authoritative for testcase/probe paths. A legacy output/<slug>[-<experiment>]/
# .session-env copy is also written for manual callers outside a results tree.
# bin/probe and friends discover both by walking up from CWD or testcase path.
TARGET_BASE_CONFIG_DIR="$(target_output_root "$SCRIPT_ROOT" "$TARGET_SLUG" "" "")"
TARGET_BASE_TOML="$TARGET_BASE_CONFIG_DIR/target.toml"
mkdir -p "$TARGET_BASE_CONFIG_DIR"

if [ ! -f "$TARGET_BASE_TOML" ]; then
  log "Seeding target config ${TARGET_BASE_TOML} by introspecting the source tree at ${TARGET_ROOT} (auto-detects build system, attacker-controllable inputs, threat model, sanitizer binaries)"
  target_seed_toml "$TARGET_ROOT" "$TARGET_BASE_TOML" ""
  log "Review ${TARGET_BASE_TOML} and edit only the unresolved or target-specific fields — keep auto-detected values unless you have a reason to override them"
fi

TARGET_CONFIG_DIR="$(target_output_root "$SCRIPT_ROOT" "$TARGET_SLUG" "" "$AUDIT_EXPERIMENT_SUFFIX")"
TARGET_TOML="$TARGET_CONFIG_DIR/target.toml"
