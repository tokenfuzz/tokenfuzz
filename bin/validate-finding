#!/usr/bin/env python3
"""Run an independent source-reading validator over one security finding."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))

import llm_invoke
import llm_usage
import prompt_render

VOTES = {"Promote": 0, "Reject": 1, "Uncertain": 2}


def parse_args(argv=None):
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--finding", required=True)
    parser.add_argument("--target-path", required=True)
    parser.add_argument("--backend", required=True, choices=("claude", "codex", "gemini", "grok", "oss"))
    parser.add_argument("--model", default="")
    parser.add_argument("--tiebreak", action="store_true")
    parser.add_argument("--gate", choices=("finding", "trigger"), default="finding")
    parser.add_argument("--target-root-is-product", action="store_true",
                        help=argparse.SUPPRESS)
    parser.add_argument("--output")
    parser.add_argument("--timeout", type=int, default=300)
    parser.add_argument("--usage-index", help=argparse.SUPPRESS)
    return parser.parse_args(argv)


def candidate(path: Path) -> dict:
    text = path.read_text(errors="replace")
    variants = [text]
    if text.splitlines():
        variants.append(text.splitlines()[0])
    for value in variants:
        try:
            parsed = json.loads(value)
        except json.JSONDecodeError:
            continue
        if isinstance(parsed, dict):
            return parsed
    return {"report": text, "source_path": str(path)}


def output_path(finding: Path, configured: str | None) -> Path:
    if configured:
        return Path(configured)
    index = 1
    while (finding.parent / f"validator-vote-{index}.json").exists():
        index += 1
    return finding.parent / f"validator-vote-{index}.json"


def validator_cwd(finding: Path, target: Path) -> Path:
    """Return one stable, isolated source view shared by this results tree."""
    results = next((parent for parent in finding.parents if parent.name == "results"), None)
    cwd = (results or finding.parent) / ".validator-cwd"
    cwd.mkdir(parents=True, exist_ok=True)
    for entry in target.iterdir():
        link = cwd / entry.name
        try:
            link.symlink_to(entry, target_is_directory=entry.is_dir())
        except FileExistsError:
            continue
        except OSError as exc:
            print(f"WARN: validator source link unavailable ({entry}): {exc}", file=sys.stderr)
    return cwd


def render_validator_prompt(args, facts: dict) -> str:
    skeptic = prompt_render.render_template("validate_tiebreak.md.j2", {}) if args.tiebreak else ""
    template = "validate_trigger_provenance.md.j2" if args.gate == "trigger" else "validate_finding.md.j2"
    product_boundary_block = ""
    if args.target_root_is_product:
        product_boundary_block = (
            "The configured benchmark target root is the product boundary for this review.\n"
            "Do not reject the whole target merely because its root-level documentation or\n"
            "comments describe it as a sample, fixture, demo, or benchmark target. Clause\n"
            "(d) still applies normally to a concrete test/fuzz/example/benchmark/demo\n"
            "subdirectory, driver, generator, or other source file that does not ship in\n"
            "the product built from this target root.\n"
        )
    return prompt_render.render_template(template, {
        "target_path": str(Path(args.target_path).resolve()),
        "candidate_json": json.dumps(facts, sort_keys=True),
        "attacker_controls": os.environ.get("TARGET_ATTACKER_CONTROLS_CSV", "bytes"),
        "product_boundary_block": product_boundary_block,
        "skeptic_block": skeptic,
        "timeout_secs": str(args.timeout),
    })


def extract_vote(text: str) -> dict | None:
    text = re.sub(r"^\s*```(?:json)?\s*$", "", text, flags=re.MULTILINE)
    decoder = json.JSONDecoder()
    for index, character in enumerate(text):
        if character != "{":
            continue
        try:
            value, _ = decoder.raw_decode(text[index:])
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict) and value.get("vote") in VOTES:
            return value
    return None


def main(argv=None) -> int:
    args = parse_args(argv)
    finding = Path(args.finding)
    target = Path(args.target_path)
    if not finding.is_file() or not target.is_dir():
        print("FATAL: finding or target path not found", file=sys.stderr)
        return 4
    llm_invoke.apply_memory_policy()
    destination = output_path(finding, args.output)
    prompt = render_validator_prompt(args, candidate(finding))
    raw = destination.with_suffix(".raw.log")
    # A stable isolated cwd keeps the CLI's system context identical across
    # validators, allowing the invariant prompt prefix to hit provider caches
    # without letting incidental writes land in the target checkout.
    status = llm_invoke.run_agent_prompt(
        args.backend, prompt, args.timeout, raw, model=args.model,
        max_turns=0, add_dirs=f"{ROOT},{target}", cwd=validator_cwd(finding, target),
    )
    llm_usage.append_usage_event(
        args.usage_index, backend=args.backend, model=args.model,
        kind=f"decision:{args.gate}-validator", prompt_text=prompt, raw_path=raw,
    )
    text = llm_invoke.extract_text(args.backend, str(raw)).replace("\r", "")
    vote = extract_vote(text)
    if vote is None:
        stdout_log = destination.with_suffix(".stdout.log")
        shutil.copy2(raw, stdout_log)
        destination.write_text(json.dumps({
            "vote": "ParseFailure", "backend": args.backend,
            "backend_rc": status, "timed_out": status == 124,
            "stdout_log": str(stdout_log),
        }, indent=2) + "\n")
        print(f"VALIDATOR_PARSE_FAILURE: no vote JSON in output (backend={args.backend})", file=sys.stderr)
        return 3
    if args.gate == "trigger" and vote["vote"] == "Reject" and not str(vote.get("disproof", "")).strip():
        vote.update(vote="Uncertain", downgraded_from="Reject", downgrade_reason="empty disproof")
    destination.write_text(json.dumps(vote, indent=2, sort_keys=True) + "\n")
    return VOTES.get(vote.get("vote"), 3)


if __name__ == "__main__":
    raise SystemExit(main())
