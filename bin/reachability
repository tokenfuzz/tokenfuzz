#!/usr/bin/env python3
"""bin/reachability — external-caller probe + severity recompute for crash reports.

Two public code-search backends are queried in parallel:

  * Sourcegraph public stream API — https://sourcegraph.com/.api/search/stream
                                    Unauthenticated, broad GitHub coverage.
  * gh search code                — official GitHub Search API via the gh CLI.
                                    Needs `gh auth login` or GH_TOKEN.

Results are cached on disk for 7 days, the request carries a polite User-Agent,
and transient failures get a single retry. 403/429 responses also create a
short backend-level cooldown so repeated symbol probes do not hammer a
rate-limited service. Each backend is independent: any one failing produces
"status": "unavailable" without blocking the others.

Filtering: hits whose repo or path contain any substring from the target's
reachability_ignore list are dropped. The list is read from output/<slug>/
target.toml and is the right place to silence the project's own sources and
known vendored copies.

Severity is the CVSS v4.0 score. The report's primitive/surface facts derive
Base metrics; proof-of-concept evidence derives the Threat metric; local
reachability, caller-control, and shipping-context facts derive Environmental
metrics. The resulting score is labeled with the v4.0 nomenclature
(CVSS-B/CVSS-BT/CVSS-BE/CVSS-BTE) and written back into the report's
Classification block.

Usage:
  bin/reachability --symbol pcre2_serialize_decode [--symbol foo] [--json]
  bin/reachability --report path/to/CRASH-XXX/      # update report.md +
                                                     # write reachability.json
  bin/reachability --report path/to/CRASH-XXX/ --severity-only
                                                     # no network; use cached
                                                     # reachability.json or zero

Env:
  REACHABILITY_MOCK_DIR   When set, backend HTTP/CLI calls are replaced by
                          reads of <dir>/<service>-<sha1(symbol)>.json. This
                          is what tests/test_reachability.sh uses; it also
                          lets you record fixtures by saving real responses.
  REACHABILITY_CACHE_DIR  Override the cache directory. Default:
                          ~/.cache/sancov-reachability/
  REACHABILITY_NEGATIVE_TTL_SECS
                          Override the 403/429 backend cooldown. Default: 300.
"""
from __future__ import annotations

import argparse
import concurrent.futures
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

HERE = Path(__file__).absolute().parent
sys.path.insert(0, str(HERE.parent / "lib"))

import cvss4  # noqa: E402
import languages  # noqa: E402
import stack_frames  # noqa: E402
import target_config as tc  # noqa: E402
from cluster_common import exact_child_file  # noqa: E402

USER_AGENT = "tokenfuzz-reachability/1.0"
DEFAULT_TIMEOUT = 10.0
BACKOFF_SECS = 30.0
CACHE_TTL_SECS = 7 * 24 * 3600
# Status codes worth a single retry. 403 is deliberately excluded: it is often
# an auth or policy response, so repeated immediate retries are not useful.
RETRY_STATUS = (429, 502, 503, 504)
NEGATIVE_CACHE_STATUS = (403, 429)
DEFAULT_NEGATIVE_TTL_SECS = 5 * 60
# Per-backend minimum gap between consecutive symbol probes. gh is bound by the
# GitHub Search API limit (30 req/min authenticated → ≥2.0s between calls);
# Sourcegraph publishes no rate limit but we stay polite.
SERVICE_THROTTLE_SECS = {
    "sourcegraph": 0.5,
    "gh": 2.0,
}

SERVICES = ("sourcegraph", "gh")


# ─── Cache ────────────────────────────────────────────────────────────────


def _cache_dir() -> Path:
    p = os.environ.get("REACHABILITY_CACHE_DIR")
    if p:
        return Path(p)
    return Path(os.path.expanduser("~/.cache/sancov-reachability"))


def _cache_path(service: str, symbol: str, language: str = "c") -> Path:
    """Cache key: (service, symbol, language) — the language filter changes
    what a probe returns, so a C-target probe must not satisfy a JS-target
    probe for the same identifier. Freshness is enforced by mtime, not by
    a date suffix in the filename — putting the date in the name caused
    near-midnight UTC misses where a freshly written file would be discarded
    seconds later when the day rolled over."""
    digest = hashlib.sha1(f"{language}|{symbol}".encode("utf-8")).hexdigest()[:16]
    return _cache_dir() / f"{service}-{digest}.json"


def _atomic_json_write(path: Path, payload: dict) -> None:
    tmp_name = ""
    path.parent.mkdir(parents=True, exist_ok=True)
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            dir=path.parent,
            prefix=f".{path.name}.",
            suffix=".tmp",
            delete=False,
        ) as f:
            tmp_name = f.name
            json.dump(payload, f, sort_keys=True)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp_name, path)
        tmp_name = ""
        try:
            dir_fd = os.open(path.parent, os.O_RDONLY)
        except OSError:
            return
        try:
            os.fsync(dir_fd)
        finally:
            os.close(dir_fd)
    finally:
        if tmp_name:
            try:
                Path(tmp_name).unlink(missing_ok=True)
            except OSError:
                pass


def _cache_read(service: str, symbol: str, language: str = "c") -> dict | None:
    p = _cache_path(service, symbol, language)
    if not p.is_file():
        return None
    try:
        age = time.time() - p.stat().st_mtime
    except OSError:
        return None
    if age > CACHE_TTL_SECS:
        return None
    try:
        return json.loads(p.read_text("utf-8"))
    except Exception:
        return None


def _cache_write(service: str, symbol: str, payload: dict, language: str = "c") -> None:
    p = _cache_path(service, symbol, language)
    try:
        _atomic_json_write(p, payload)
    except OSError:
        pass


def _negative_ttl_secs() -> float:
    raw = os.environ.get("REACHABILITY_NEGATIVE_TTL_SECS")
    if raw is None:
        return float(DEFAULT_NEGATIVE_TTL_SECS)
    try:
        return max(0.0, float(raw))
    except ValueError:
        return float(DEFAULT_NEGATIVE_TTL_SECS)


def _negative_cache_path(service: str) -> Path:
    return _cache_dir() / f"{service}-backoff.json"


def _negative_cache_read(service: str) -> dict | None:
    p = _negative_cache_path(service)
    if not p.is_file():
        return None
    try:
        age = time.time() - p.stat().st_mtime
    except OSError:
        return None
    ttl = _negative_ttl_secs()
    if ttl <= 0 or age > ttl:
        return None
    try:
        payload = json.loads(p.read_text("utf-8"))
    except Exception:
        return None
    status = payload.get("http_status", "?")
    remaining = max(0, int(ttl - age))
    return {
        "status": "unavailable",
        "error": f"backend cooldown after http {status} ({remaining}s remaining)",
        "http_status": status,
        "negative_cache": True,
    }


def _negative_cache_write(service: str, http_status: int) -> None:
    if http_status not in NEGATIVE_CACHE_STATUS or _negative_ttl_secs() <= 0:
        return
    p = _negative_cache_path(service)
    payload = {
        "status": "unavailable",
        "http_status": http_status,
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    try:
        _atomic_json_write(p, payload)
    except OSError:
        pass


# ─── HTTP with one polite retry ───────────────────────────────────────────


def _http_get(url: str, timeout: float, accept: str = "application/json") -> tuple[int, Any]:
    """Return (status_code, body). For application/json the body is parsed JSON
    when parseable, otherwise raw text. For any other accept value (e.g.
    text/event-stream) the body is returned as a raw decoded string.
    Raises urllib errors on transport failure."""
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT, "Accept": accept})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        body = resp.read().decode("utf-8", errors="replace")
        if accept == "application/json":
            try:
                return resp.status, json.loads(body)
            except json.JSONDecodeError:
                return resp.status, body
        return resp.status, body


def _http_with_retry(url: str, timeout: float, accept: str = "application/json") -> tuple[int, Any]:
    """One retry on RETRY_STATUS after BACKOFF_SECS. Other codes return as-is."""
    try:
        status, body = _http_get(url, timeout, accept)
    except urllib.error.HTTPError as e:
        status = e.code
        body = None
        if status in RETRY_STATUS:
            time.sleep(BACKOFF_SECS)
            try:
                return _http_get(url, timeout, accept)
            except urllib.error.HTTPError as e2:
                return e2.code, None
        return status, body
    if status in RETRY_STATUS:
        time.sleep(BACKOFF_SECS)
        try:
            return _http_get(url, timeout, accept)
        except urllib.error.HTTPError as e:
            return e.code, None
    return status, body


# ─── Mock layer (test fixtures) ───────────────────────────────────────────


def _mock_path(service: str, symbol: str) -> Path | None:
    mock_dir = os.environ.get("REACHABILITY_MOCK_DIR")
    if not mock_dir:
        return None
    digest = hashlib.sha1(symbol.encode("utf-8")).hexdigest()[:16]
    return Path(mock_dir) / f"{service}-{digest}.json"


def _read_mock(service: str, symbol: str) -> dict | None:
    """Mock layer for tests.

    When REACHABILITY_MOCK_DIR is set, the mock dir is treated as a hard wall:
    if a mock file exists for (service, symbol), return it; if it doesn't,
    return an "unavailable" result rather than falling through to a real
    HTTP / gh-CLI call. This keeps the test suite hermetic even when a
    report yields more symbols than the test fixture covers.
    """
    p = _mock_path(service, symbol)
    if p is None:
        return None  # mock layer disabled — fall through to real backend
    if not p.is_file():
        return {"status": "unavailable", "error": f"no mock for ({service}, {symbol})"}
    try:
        return json.loads(p.read_text("utf-8"))
    except Exception:
        return {"status": "unavailable", "error": "mock JSON unparseable"}


# ─── Backends ─────────────────────────────────────────────────────────────


# Result caps per (backend, symbol) probe. 100, not 30: the reported
# external-caller reach (distinct dependent repos) saturates well below this on
# popular APIs, and a low cap would understate that prevalence signal in the
# Reachability section. The count is reporting metadata only — it does not feed
# the CVSS score.
SOURCEGRAPH_RESULT_LIMIT = 100
GH_RESULT_LIMIT = 100


def _parse_sourcegraph_sse(body: str) -> list[dict] | None:
    """Extract all match items from a Sourcegraph stream response.

    Returns None if the body has no SSE structure at all (no `event:` lines)
    — signal of a schema drift or HTML error page returned with 200. Returns
    an empty list when the stream is well-formed but emitted no `matches`
    events (legitimate "0 hits" — Sourcegraph still emits `progress` and
    `done` in that case).
    """
    matches: list[dict] = []
    saw_event = False
    cur_event: str | None = None
    cur_data: list[str] = []

    def _flush() -> None:
        nonlocal cur_event, cur_data
        if cur_event == "matches" and cur_data:
            try:
                items = json.loads("".join(cur_data))
            except json.JSONDecodeError:
                items = None
            if isinstance(items, list):
                matches.extend(items)
        cur_event = None
        cur_data = []

    for line in body.splitlines():
        if line == "":
            _flush()
            continue
        if line.startswith("event:"):
            saw_event = True
            cur_event = line[6:].strip()
        elif line.startswith("data:"):
            v = line[5:]
            if v.startswith(" "):
                v = v[1:]
            cur_data.append(v)
    _flush()
    if not saw_event:
        return None
    return matches


def query_sourcegraph(symbol: str, timeout: float, language: str = "c") -> dict:
    """Sourcegraph public stream API. The stream is bounded by `count:` in the
    query so the response is small and terminates naturally; we read it whole
    and pull repo+path out of every `event: matches` frame.

    The `lang:` filter cuts out stray hits in other languages that happen to
    share an identifier name. It is derived from the target tree (see
    _detect_target_language) — hardcoding C made every probe for a JS/Go/Java
    target return only C-file noise. Empty `language` disables the filter."""
    mock = _read_mock("sourcegraph", symbol)
    if mock is not None:
        return mock
    lang_filter = f" lang:{language}" if language else ""
    url = "https://sourcegraph.com/.api/search/stream?" + urllib.parse.urlencode({
        "q": f"{symbol}{lang_filter} count:{SOURCEGRAPH_RESULT_LIMIT}",
        "display": str(SOURCEGRAPH_RESULT_LIMIT),
    })
    try:
        status, body = _http_with_retry(url, timeout, accept="text/event-stream")
    except (urllib.error.URLError, OSError, TimeoutError) as e:
        return {"status": "unavailable", "error": f"transport: {e!r}"}
    if status != 200 or not isinstance(body, str):
        return {"status": "unavailable", "error": f"http {status}", "http_status": status}
    parsed = _parse_sourcegraph_sse(body)
    if parsed is None:
        return {"status": "unavailable", "error": "schema mismatch (no SSE event frames)"}
    seen: dict[tuple[str, str], dict] = {}
    for item in parsed:
        if not isinstance(item, dict):
            continue
        repo = str(item.get("repository", "") or "")
        path = str(item.get("path", "") or "")
        if not repo and not path:
            continue
        key = (repo, path)
        if key not in seen:
            seen[key] = {"repo": repo, "path": path}
    return {"status": "ok", "hits": list(seen.values())}


def query_gh(symbol: str, timeout: float, language: str = "c") -> dict:
    """Use the gh CLI if available + authenticated. Anything else → unavailable."""
    mock = _read_mock("gh", symbol)
    if mock is not None:
        return mock
    if shutil.which("gh") is None:
        return {"status": "unavailable", "error": "gh CLI not installed"}
    cmd = ["gh", "search", "code", symbol, f"--limit={GH_RESULT_LIMIT}",
           "--json", "repository,path"]
    if language:
        cmd.insert(4, f"--language={language}")
    try:
        proc = subprocess.run(
            cmd,
            capture_output=True, text=True, timeout=timeout * 2,
        )
    except (subprocess.TimeoutExpired, OSError) as e:
        return {"status": "unavailable", "error": f"gh exec: {e!r}"}
    if proc.returncode != 0:
        # Most common: not authenticated, or rate-limited.
        return {"status": "unavailable", "error": (proc.stderr or "").strip()[:200] or f"gh exit {proc.returncode}"}
    try:
        items = json.loads(proc.stdout or "[]")
    except json.JSONDecodeError as e:
        return {"status": "unavailable", "error": f"gh JSON: {e!r}"}
    seen: dict[tuple[str, str], dict] = {}
    for item in items:
        if not isinstance(item, dict):
            continue
        repo_obj = item.get("repository") or {}
        repo = repo_obj.get("nameWithOwner") if isinstance(repo_obj, dict) else ""
        path = item.get("path", "")
        if not repo and not path:
            continue
        key = (str(repo), str(path))
        if key not in seen:
            seen[key] = {"repo": str(repo), "path": str(path)}
    return {"status": "ok", "hits": list(seen.values())}


BACKENDS = {
    "sourcegraph": query_sourcegraph,
    "gh": query_gh,
}


# ─── Driver: parallel, cached, filtered ───────────────────────────────────


def _apply_ignore(hits: list[dict], ignore: list[str]) -> list[dict]:
    if not ignore:
        return hits
    out = []
    for h in hits:
        repo = h.get("repo", "")
        path = h.get("path", "")
        if any(tok and (tok in repo or tok in path) for tok in ignore):
            continue
        out.append(h)
    return out


# Heuristic for "this hit is a vendored copy of the target's own source, not a
# genuine external caller." Three signals:
#   * the path contains a well-known vendored-deps subdir (vendor/, third_party/,
#     contrib/, deps/, ext/, external/, jni/, thirdparty/, 3rd_src/, ...),
#   * the path contains a basename that strongly identifies the upstream source
#     (e.g. /pcre2_substring.c, /xmlschemas.c) and a vendored-style prefix,
#   * the file is the project's own canonical source layout (e.g. .../pcre2/src/...).
# Hits with these signals are kept in the "vendored_copies" bucket so the
# severity formula isn't fooled by name collisions across repos that just
# re-include the upstream code.
_VENDORED_PREFIX_RE = re.compile(
    r"(^|/)("
    r"vendor|vendored|third_party|3rdparty|3rd[_-]?src|3rd[_-]?party|"
    r"deps|contrib|jni|thirdparty|external|ext"
    r")(/|$)",
    re.IGNORECASE,
)


# A `-`/`_`-delimited numeric version suffix (`libxml2-2.9.14`, `pcre2_10`).
# A trailing digit that is part of the name itself (`pcre2`, `libxml2`) is
# NOT delimited and so is preserved.
_VERSION_SUFFIX_RE = re.compile(r"[-_][0-9][0-9A-Za-z._]*$")


def _target_name_variants(raw: str) -> set[str]:
    """Project-name forms to match against vendored-path directory segments.

    Returns the bare name plus a version-stripped form, so a vendored tree
    named `libxml2-2.9.14` or `pcre2-10.42` still matches a `libxml2` /
    `pcre2` audit. Names come from the live target tree and slug — there is
    no hardcoded project list, so this works for any target.
    """
    raw = os.path.basename((raw or "").strip().lower().rstrip("/"))
    if not raw:
        return set()
    variants = {raw}
    stripped = _VERSION_SUFFIX_RE.sub("", raw)
    if len(stripped) >= 2:
        variants.add(stripped)
    return variants


def _segment_names_target(seg: str, target_names: set[str]) -> bool:
    """True when path segment `seg` names the project under audit.

    Matches the bare name and version/source-suffixed forms
    (`libxml2`, `libxml2-2.9`, `pcre2_src`)."""
    seg = seg.strip().lower()
    if not seg:
        return False
    return any(
        seg == name or seg.startswith(name + "-")
        or seg.startswith(name + "_") or seg.startswith(name + ".")
        for name in target_names
    )


def _is_vendored_copy(hit: dict, target_basenames: set[str],
                      target_names: set[str]) -> bool:
    path = hit.get("path", "") or ""
    if not path:
        return False
    if _VENDORED_PREFIX_RE.search(path):
        return True
    # Path carries an upstream filename AND a directory segment naming the
    # project under audit (e.g. somerepo/libxml2/xmlschemas.c is a vendored
    # copy, not a real caller). The project name is derived at runtime from
    # the target tree / slug, so this recognises any target — no hardcoded
    # per-project enumeration.
    if not (target_basenames and target_names):
        return False
    base = path.rsplit("/", 1)[-1]
    if base not in target_basenames:
        return False
    return any(_segment_names_target(seg, target_names)
               for seg in path.split("/")[:-1])


def _split_vendored(hits: list[dict], target_basenames: set[str],
                    target_names: set[str]) -> tuple[list[dict], list[dict]]:
    """Return (genuine_callers, vendored_copies) by classifying each hit."""
    genuine: list[dict] = []
    vendored: list[dict] = []
    for h in hits:
        if _is_vendored_copy(h, target_basenames, target_names):
            vendored.append(h)
        else:
            genuine.append(h)
    return genuine, vendored


def _query_one(service: str, symbol: str, timeout: float, use_cache: bool,
               language: str = "c") -> dict:
    if use_cache:
        cached = _cache_read(service, symbol, language)
        if cached is not None:
            cached.setdefault("from_cache", True)
            return cached
        cooldown = _negative_cache_read(service)
        if cooldown is not None:
            cooldown.setdefault("from_cache", True)
            return cooldown
    fn = BACKENDS[service]
    result = fn(symbol, timeout, language)
    if use_cache and result.get("status") == "ok":
        _cache_write(service, symbol, result, language)
    elif use_cache:
        try:
            http_status = int(result.get("http_status", 0))
        except (TypeError, ValueError):
            http_status = 0
        _negative_cache_write(service, http_status)
    result.setdefault("from_cache", False)
    return result


def _service_throttle_secs(service: str) -> float:
    if os.environ.get("REACHABILITY_MOCK_DIR"):
        return 0.0
    raw = os.environ.get(f"REACHABILITY_{service.upper()}_THROTTLE_SECS")
    if raw is not None:
        try:
            return max(0.0, float(raw))
        except ValueError:
            return SERVICE_THROTTLE_SECS.get(service, 0.0)
    return SERVICE_THROTTLE_SECS.get(service, 0.0)


def _query_service(service: str, symbols: list[str], timeout: float, use_cache: bool,
                   language: str = "c") -> list[tuple[str, dict]]:
    rows: list[tuple[str, dict]] = []
    throttle = _service_throttle_secs(service)
    for i, sym in enumerate(symbols):
        r = _query_one(service, sym, timeout, use_cache, language)
        rows.append((sym, r))
        if i + 1 < len(symbols) and throttle > 0 and not r.get("from_cache"):
            time.sleep(throttle)
    return rows


def query_all(symbols: list[str], ignore: list[str], timeout: float, use_cache: bool,
              target_basenames: set[str] | None = None,
              target_names: set[str] | None = None,
              entry_symbol: str | None = None,
              require_all_symbols: bool = False,
              language: str = "c") -> dict:
    """Run services in parallel, but keep each backend's symbol probes sequential.

    target_basenames: filenames recognised as coming from the upstream project
    (e.g. {"pcre2_substring.c", "pcre2_match.c"}).
    target_names: project-name aliases for the target under audit (e.g.
    {"pcre2"}), used to spot `…/<project>/…` vendored path segments.
    Hits whose basename matches a target file AND whose path is vendored
    (a vendored-style prefix, or a directory segment naming the project)
    are bucketed into `vendored_copies` rather than `external_callers` —
    those repos *ship* the bug, they don't call into a separate library.
    This dramatically tightens the severity score (which weighs
    external_callers heavily) for crashes where most search hits are
    mirror-vendored sources.

    entry_symbol: the public/caller entry point the bug is reached through.
    When given, external-caller popularity counts genuine repos that match the
    entry symbol any-frame — a real dependant reaches the entry point, not the
    target's internal frames above it.

    require_all_symbols: collision-resistance fallback when no entry symbol
    was identified but the symbols are still a crash-state call chain. With
    ≥2 probed symbols, a genuine external caller must match *every* probed
    symbol in the same file (cross-backend) — a random project that merely
    owns its own ``set_blob`` is a name collision and is dropped.

    Neither flag set (manual --symbol, narrative-mined entry points) keeps
    plain union/any-match. In every mode each unique symbol is queried at
    most once.
    """
    per_service: dict[str, dict] = {svc: {"status": "ok", "hits": [], "errors": []} for svc in SERVICES}
    target_basenames = target_basenames or set()
    target_names = target_names or set()

    max_workers = max(1, len(SERVICES))
    with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {pool.submit(_query_service, svc, symbols, timeout, use_cache,
                               language): svc for svc in SERVICES}
        for fut in concurrent.futures.as_completed(futures):
            svc = futures[fut]
            try:
                rows = fut.result()
            except Exception as e:
                rows = [(sym, {"status": "unavailable", "error": f"executor: {e!r}"}) for sym in symbols]
            entry = per_service[svc]
            for sym, r in rows:
                if r.get("status") != "ok":
                    entry["errors"].append({"symbol": sym, "error": r.get("error", "unknown")})
                    # If any symbol succeeds for a backend, the backend is still "ok"
                    # for the union. Only mark unavailable if ALL symbols failed.
                    continue
                for h in r.get("hits", []):
                    h2 = dict(h)
                    h2["matched_symbol"] = sym
                    entry["hits"].append(h2)

    def _dedup(items: list[dict]) -> list[dict]:
        """Collapse by (repo, path), first hit wins — per-backend diagnostics."""
        seen: dict[tuple[str, str], dict] = {}
        for h in items:
            k = (h.get("repo", ""), h.get("path", ""))
            if k not in seen:
                seen[k] = h
        return list(seen.values())

    # Flip status to unavailable when nothing came back AND every probe errored,
    # apply the ignore filter, split vendored copies out, and collect the
    # surviving hits across backends for cross-backend aggregation.
    all_genuine: list[dict] = []
    all_vendored: list[dict] = []
    for svc, entry in per_service.items():
        if not entry["hits"] and entry["errors"]:
            entry["status"] = "unavailable"
        entry["hits"] = _apply_ignore(entry["hits"], ignore)
        genuine, vendored = _split_vendored(entry["hits"], target_basenames, target_names)
        all_genuine.extend(genuine)
        all_vendored.extend(vendored)
        # Per-backend diagnostic counts (the table); the authoritative count is
        # the cross-backend aggregate below.
        entry["hits"] = _dedup(genuine)
        entry["vendored"] = _dedup(vendored)
        entry["count"] = len(entry["hits"])
        entry["vendored_count"] = len(entry["vendored"])

    # Cross-backend aggregation: union by (repo, path), accumulating the set of
    # probed symbols each file matched (across both backends), so an all-frames
    # gate can ask whether a file matched the whole crash-state chain.
    def _aggregate(items: list[dict]) -> dict[tuple[str, str], dict]:
        agg: dict[tuple[str, str], dict] = {}
        for h in items:
            k = (h.get("repo", ""), h.get("path", ""))
            rec = agg.get(k)
            if rec is None:
                rec = {"repo": h.get("repo", ""), "path": h.get("path", ""),
                       "_symbols": set()}
                agg[k] = rec
            sym = h.get("matched_symbol")
            if sym:
                rec["_symbols"].add(sym)
        return agg

    def _finalize(agg: dict[tuple[str, str], dict]) -> list[dict]:
        out: list[dict] = []
        for rec in agg.values():
            syms = sorted(rec["_symbols"])
            out.append({
                "repo": rec["repo"], "path": rec["path"],
                "matched_symbols": syms,
                # Back-compat single-symbol field used by older consumers.
                "matched_symbol": syms[0] if syms else "",
            })
        return out

    if entry_symbol not in set(symbols):
        entry_symbol = None
    probed = set(symbols)
    genuine_agg = _aggregate(all_genuine)
    vendored_agg = _aggregate(all_vendored)  # vendored copies are not frame-gated

    if entry_symbol is not None:
        # Popularity is "who calls the public entry point", so keep genuine
        # repos that matched the entry symbol any-frame. The internal frames
        # above it are deliberately not required — a real dependant never
        # contains them.
        caller_agg = {k: v for k, v in genuine_agg.items()
                      if entry_symbol in v["_symbols"]}
        match_mode = "entrypoint"
    elif require_all_symbols and len(probed) >= 2:
        # Crash-state chain with no identified entry point: keep only files
        # that matched every probed symbol (collision-resistant).
        caller_agg = {k: v for k, v in genuine_agg.items()
                      if probed <= v["_symbols"]}
        match_mode = "all-frames"
    else:
        caller_agg = genuine_agg
        match_mode = "any-frame"

    external_caller_hits = _finalize(caller_agg)
    vendored_copy_hits = _finalize(vendored_agg)

    services_responding = [svc for svc, e in per_service.items() if e["status"] == "ok"]
    return {
        "schema_version": 2,
        "queried_at": datetime.now(timezone.utc).isoformat(),
        "symbols": symbols,
        "entry_symbol": entry_symbol,
        "ignore": ignore,
        "language": language,
        "match_mode": match_mode,
        "external_callers": len(external_caller_hits),
        # Distinct repos, not files — the reported external-caller reach
        # (dependent-project prevalence). One repo vendoring 40 matching files
        # is one dependent project, not 40. Reporting metadata only; it does
        # not feed the CVSS score.
        "external_caller_repos": len({h["repo"] for h in external_caller_hits}),
        "external_caller_hits": external_caller_hits,
        "vendored_copies": len(vendored_copy_hits),
        "vendored_copy_hits": vendored_copy_hits,
        "services_responding": services_responding,
        "services": per_service,
    }


# ─── target.toml discovery + ignore-list extraction ───────────────────────


def _find_target_toml(start: Path) -> Path | None:
    """Walk up from `start` looking for an output/<slug>/target.toml ancestor."""
    cur = start.resolve()
    if cur.is_file():
        cur = cur.parent
    for p in [cur, *cur.parents]:
        # Case 1: we're already inside output/<slug>/...
        for anc in [p, *p.parents]:
            if anc.parent.name == "output" and (anc / "target.toml").is_file():
                return anc / "target.toml"
            if anc.name == "output":
                # Stop climbing further once we hit the output root itself.
                break
        if (p / "target.toml").is_file():
            return p / "target.toml"
    return None


def _parse_target_toml(path: Path) -> dict:
    if not path.is_file():
        return {}
    try:
        parsed = tc.parse_toml(path)
    except Exception:
        return {}
    return parsed if isinstance(parsed, dict) else {}


def _parse_target_toml_ignore(path: Path) -> list[str]:
    raw = _parse_target_toml(path).get("reachability_ignore", [])
    if not isinstance(raw, list):
        return []
    return [str(item) for item in raw if str(item)]


# ─── Severity scoring ─────────────────────────────────────────────────────
#
# Severity is a CVSS v4.0 score — one industry-standard metric, and the only
# number. The pipeline is pure mappings then the standard:
#
#   crash report ──detect_primitive──▶ primitive class
#   report fields ──classify_surface─▶ surface tier
#   reach/evidence ──────────────────▶ local threat/environment facts
#                  ──_cvss4_metrics──▶ CVSS metrics ──cvss4.score──▶ 0–10
#
# Rating bands are the CVSS standard's own: Critical ≥ 9.0, High ≥ 7.0,
# Medium ≥ 4.0, Low ≥ 0.1, None = 0.0.
#
# Reachability, attacker control, reproducer evidence, and shipping context
# are not bolted on with TokenFuzz arithmetic. They are represented with the
# CVSS v4.0 Threat/Environmental groups:
#   • E     proof-of-concept / active-exploitation evidence,
#   • CR/IR/AR local importance of the vulnerable use,
#   • MAT   caller-control / contract preconditions,
#   • M*    modified impact when the code is non-shipping.
# Supplemental CVSS metrics are deliberately not used for the score because
# the v4.0 specification says they do not affect CVSS-BTE.
#
# Derivation tables:
#   CVSS4_CLASS   primitive class → (VC, VI, VA, SC, SI, SA, AT-override)
#   _SURFACE_AVUI surface tier    → (AV, UI)
#   evidence      report/reproducer → E
#   environment   reach/shipping/control → CR/IR/AR/MAT/M*
#   PR/AC         fixed worst-case defaults (see _cvss4_metrics)

# Primitive class → the vulnerable-system Confidentiality/Integrity/
# Availability and subsequent-system C/I/A metrics, plus an optional AT
# (Attack Requirements) override for classes whose exploitation is inherently
# conditional. Values are the standard CVSS-B readings the class warrants:
#   • code-execution-capable corruption → VC/VI/VA = H/H/H,
#   • out-of-bounds reads → VC reflecting disclosure, VA:L for the crash,
#   • DoS-only → availability impact only.
# SC/SI/SA (subsequent system) are N unless the class characteristically
# crosses a security boundary (SSRF, XSS, open redirect). Each entry is a
# reviewable claim; adjust the row, never bolt on a multiplier.
#   key: (VC, VI, VA, SC, SI, SA, AT_override|None)
CVSS4_CLASS: dict[str, tuple[str, str, str, str, str, str, str | None]] = {
    # ── Memory corruption — code-execution-capable (full vuln-system CIA) ──
    "uaf_write":         ("H", "H", "H", "N", "N", "N", None),
    "double_free":       ("H", "H", "H", "N", "N", "N", None),
    "wild_write":        ("H", "H", "H", "N", "N", "N", None),
    "type_confusion":    ("H", "H", "H", "N", "N", "N", None),
    "heap_write":        ("H", "H", "H", "N", "N", "N", None),
    "stack_write":       ("H", "H", "H", "N", "N", "N", None),
    "global_write":      ("H", "H", "H", "N", "N", "N", None),
    # TSan race is write-shaped but winning the window is a precondition → AT:P.
    "data_race":         ("H", "H", "H", "N", "N", "N", "P"),
    # ── Memory reads — disclosure (+ crash availability) ──────────────────
    "uaf_read":          ("H", "N", "L", "N", "N", "N", None),
    "heap_read_big":     ("H", "N", "L", "N", "N", "N", None),
    "info_leak":         ("H", "N", "L", "N", "N", "N", None),
    "global_read":       ("L", "N", "L", "N", "N", "N", None),
    "stack_read":        ("L", "N", "L", "N", "N", "N", None),
    "heap_read_small":   ("L", "N", "L", "N", "N", "N", None),
    "wild_read":         ("L", "N", "H", "N", "N", "N", None),
    # ── DoS-only (availability) ───────────────────────────────────────────
    "null_deref":        ("N", "N", "H", "N", "N", "N", None),
    "stack_exhaustion":  ("N", "N", "H", "N", "N", "N", None),
    "bus":               ("N", "N", "H", "N", "N", "N", None),
    # OOM exploitation is inherently conditional on the allocator actually
    # being in a failing state (memory pressure / a failing hook) — a
    # precondition outside the attacker's byte control — so AT:P, the same
    # "inherently conditional" reading already applied to data_race and
    # crypto_weakness below. (An unchecked-allocation null-deref classified as
    # `null_deref` stays AT:N; splitting that into its own AT:P class needs a
    # target-agnostic allocation-failure detector and is a separate change.)
    "oom":               ("N", "N", "H", "N", "N", "N", "P"),
    "memory_leak":       ("N", "N", "H", "N", "N", "N", None),
    "regex_dos":         ("N", "N", "H", "N", "N", "N", None),
    "dos_amplification": ("N", "N", "H", "N", "N", "N", None),
    "integer_overflow":  ("N", "N", "L", "N", "N", "N", None),  # precursor
    # ── Web / application classes ─────────────────────────────────────────
    "command_injection": ("H", "H", "H", "N", "N", "N", None),
    "deserialization":   ("H", "H", "H", "N", "N", "N", None),
    "ssti":              ("H", "H", "H", "N", "N", "N", None),
    "sqli":              ("H", "H", "L", "N", "N", "N", None),
    "authn_bypass":      ("H", "H", "N", "N", "N", "N", None),
    "authz_bypass":      ("H", "L", "N", "N", "N", "N", None),
    "idor":              ("L", "L", "N", "N", "N", "N", None),
    "path_traversal":    ("H", "N", "N", "N", "N", "N", None),
    "xxe":               ("H", "N", "L", "N", "N", "N", None),
    "secrets_exposure":  ("H", "N", "N", "N", "N", "N", None),
    "ssrf":              ("L", "L", "N", "L", "N", "N", None),   # reaches subsequent system
    "prototype_pollution": ("L", "L", "L", "N", "N", "N", None),
    "xss":               ("N", "N", "N", "L", "L", "N", None),   # impact on victim (subsequent)
    "open_redirect":     ("N", "N", "N", "L", "N", "N", None),
    "csrf":              ("N", "L", "N", "N", "N", "N", None),
    "crypto_weakness":   ("H", "N", "N", "N", "N", "N", "P"),    # exploitation conditional
    "injection":         ("L", "L", "N", "N", "N", "N", None),
    # ── Recon / reasoning-confirmed ───────────────────────────────────────
    "protocol_state":    ("N", "H", "N", "N", "N", "N", None),
    "logic_regression":  ("L", "L", "N", "N", "N", "N", None),
    # "unknown" is intentionally absent: an unclassified crash gets no CVSS
    # vector (emitting one would be a number dressed as a standard).
}

# Primitive classes whose impact claims code-execution-capable corruption or
# disclosure (Confidentiality OR Integrity = H) — as opposed to availability-
# only DoS. A *sidecar-claimed* primitive in this set, unconfirmed by any
# sanitizer class and CONTRADICTED by a clean on-disk sanitizer run, is demoted
# to unclassified rather than credited H-impact (see compute_severity). DoS
# classes (null_deref/oom/stack_exhaustion/…) are deliberately excluded: a
# short clean run does not disprove a resource-exhaustion lead.
_HIGH_IMPACT_PRIMITIVES = frozenset(
    k for k, v in CVSS4_CLASS.items() if "H" in (v[0], v[1])
)

# Surface tier → (Attack Vector, User Interaction). Libraries and file-format
# parsers are scored for the reasonable worst-case embedding, per the CVSS
# v4.0 user guide's library guidance: an automated consumer (network service,
# upload pipeline) feeds them attacker bytes with no human in the loop, so
# AV:N/UI:N — the same reading NVD/CNAs apply to parser-library CVEs. The
# library's *local* deployment reality belongs in Environmental metrics, not
# in a discounted Base. UI:P ("Passive", involuntary participation of a
# targeted user) is the v4.0 analog of 3.1's UI:R and is right where a victim
# genuinely must act: running a CLI tool on attacker-supplied input.
# Non-shipping tiers still get a vector; their deployment context is
# represented through Environmental metrics.
_SURFACE_AVUI: dict[str, tuple[str, str]] = {
    "network":          ("N", "N"),
    "library":          ("N", "N"),
    "file":             ("N", "N"),
    "cli_production":   ("L", "P"),
    "dev_tool":         ("L", "P"),
    "internal":         ("L", "P"),
    "unknown":          ("N", "P"),  # untriaged: worst-case AV, but UI:P keeps
                                     # it below triaged library findings
}

# Surfaces that do not ship to end users. Their reduced local impact is encoded
# through Environmental modified impact metrics (M*) rather than a harness
# multiplier or a post-score cap.
NON_SHIPPING_SURFACES = frozenset({"dev_tool", "internal"})

# Crash classes that manifest as a single fatal signal on the malicious
# request: the process dies on that input and a supervisor respawns it, so the
# next request is unaffected and no persistent state is damaged. CVSS v4.0
# Recovery = Automatic (R:A) for these. Recovery is a *Supplemental* metric and
# does NOT change the CVSS-BTE score (the spec excludes supplementals from the
# score); it is surfaced in the rationale only so a triager reading a High
# availability band knows the impact is transient/auto-recovering, not a
# sustained takedown. Inclusion criterion: a per-request fatal signal with no
# accumulating resource cost. Resource-exhaustion DoS that grows across
# requests (oom, memory_leak) is deliberately excluded — its recovery is not
# automatic and may need operator action (R:U).
TRANSIENT_CRASH_PRIMITIVES = frozenset({"stack_exhaustion", "null_deref", "bus"})

_SEVERITY_RANK = {"None": 0, "Unknown": 0, "Low": 1, "Medium": 2,
                  "High": 3, "Critical": 4}


def _parse_repro_rate(report_text: str, fields: dict) -> tuple[int, int] | None:
    repro = fields.get("reproduction_rate", "")
    m = re.search(r"(\d+)\s*/\s*(\d+)", repro or "")
    if not m:
        # Probe-native crash rate — the harness's own reverification count, and
        # authoritative over prose: "CRASH_RATE: 3/5".
        m = re.search(r"\bcrash_rate:\s*(\d+)\s*/\s*(\d+)", report_text, re.IGNORECASE)
    if not m:
        # Strict prose fallback. Deliberately NOT keyed on a bare "run": log
        # noise like `run-sanitizer-multi` and budget counters
        # (`BUDGET: 21/60 sanitizer invocations used`) otherwise parse as a
        # reproduction rate — a real false positive that inflated E to E:P.
        m = re.search(r"\b(?:reproduc(?:tion|ed)|confirmed)(?:\s+rate)?\D{0,20}"
                      r"(\d+)\s*/\s*(\d+)", report_text, re.IGNORECASE)
    if not m:
        return None
    d = int(m.group(2))
    if d <= 0:
        return None
    return int(m.group(1)), d


def _has_repro_artifacts(report_dir: Path | None) -> bool:
    if report_dir is None:
        return False
    if any((report_dir / n).is_file() for n in ("reproduce.sh", "input.txt", "input.bin")):
        return True
    for pattern in ("testcase*", "poc*", "reproducer*", "input.*"):
        if any(report_dir.glob(pattern)):
            return True
    return False


# Probe-native CLEAN evidence embedded in a report body: the harness's
# sanitizer probe ran the saved input and it did NOT crash. Distinct from the
# BUDGET/invocation counters in the same logs (those are filtered out of
# _parse_repro_rate). `CRASH_RATE: 0/N`, `NO CRASHES in N runs`, and the
# `[probe] verdict=CLEAN` line are the harness's own reverification verdict.
_PROBE_CLEAN_RE = re.compile(
    r"\bverdict\s*=\s*clean\b|\bno crashes in \d+ runs?\b|"
    r"\bcrash_rate:\s*0\s*/\s*\d+\b",
    re.IGNORECASE,
)


def _probe_ran_clean_text(report_text: str) -> bool:
    """True when the report body records a sanitizer PROBE that ran the saved
    input and produced no crash (verdict=CLEAN / NO CRASHES / CRASH_RATE 0/N) —
    a recorded failed reproduction, equivalent to a structured 0/N rate. Lets
    the threat gate and the clean-run demotion react to clean evidence embedded
    in report.md, not only to adjacent sanitizer.txt/*.asan.txt files."""
    return bool(_PROBE_CLEAN_RE.search(report_text or ""))


def _sanitizer_ran_clean(report_dir: Path | None) -> bool:
    """True when a sanitizer artifact on disk recorded the sanitizer EXECUTING
    and producing NO crash — positive evidence that a claimed memory-corruption
    did not occur, distinct from a finding that was simply never run.

    A real crash log — any sanitizer's diagnostic (``stack_frames`` owns the
    shared signature, so ASan/HWASan/UBSan/TSan/MSan are all recognised) or a
    non-zero ``CRASH_RATE`` footer — is the opposite of clean and returns
    False, so accepted crashes are never affected. Only used to demote an
    unconfirmed *sidecar* high-impact primitive (see compute_severity);
    sanitizer-derived classes are authoritative and bypass this.
    """
    if report_dir is None:
        return False
    texts: list[str] = []
    for name in ("sanitizer.txt", "asan.txt"):
        p = report_dir / name
        if p.is_file():
            texts.append(p.read_text("utf-8", errors="replace"))
    for p in report_dir.glob("*.asan.txt"):
        texts.append(p.read_text("utf-8", errors="replace"))
    if not texts:
        return False
    saw_clean_run = False
    for t in texts:
        # A genuine sanitizer crash (any sanitizer) or a non-zero crash-rate
        # footer means a fault is recorded — not clean.
        if stack_frames.has_sanitizer_diagnostic(t) or \
                re.search(r"\bcrash_rate:\s*[1-9]", t, re.IGNORECASE):
            return False
        tl = t.lower()
        # The run header is ASAN_RUN_HEADER for asan and SANITIZER_RUN_HEADER
        # for every other sanitizer (see bin/run-sanitizer-multi) — accept both.
        if ("no crashes" in tl or "completed cleanly" in tl
                or "reached target" in tl or "success_rate" in tl
                or "asan_run_header" in tl or "sanitizer_run_header" in tl):
            saw_clean_run = True
    return saw_clean_run


def _threat_metric(report_text: str, fields: dict,
                   report_dir: Path | None) -> tuple[str, str]:
    """Derive CVSS v4.0 Exploit Maturity (E).

    The harness does not claim active real-world exploitation unless the
    report says so. Exploit Maturity is graded on *evidence*, not prose:

      * active-exploitation text                         → E:A
      * a recorded reproduction rate N/D with N>0        → E:P
      * a recorded rate N/D with N==0 (reverification    → E:U
        FAILED) — overrides any artifact on disk: a
        saved input that no longer reproduces is not
        proof-of-concept maturity
      * a reproducer/testcase artifact and no failed     → E:P
        reverification
      * triaged but none of the above                    → E:U
      * untriaged input                                  → E:X

    A bare *prose* mention of "reproducer/PoC/testcase" is deliberately NOT
    sufficient — a sentence saying a PoC "could be built" is a claim, not
    evidence, and must not grant E:P (the dominant source of inflated
    Exploit-Maturity in prose-only findings).
    """
    t = (report_text or "").lower()
    # Negation-aware: "no evidence this was exploited in the wild" is the
    # OPPOSITE claim, and every trigger phrase must name exploitation itself
    # (a bare "in the wild" is routine prose, not evidence).
    if _unnegated_search(r"\b(?:active(?:ly)? exploited|exploited in[- ]the[- ]wild|"
                         r"weaponized|exploit toolkit|mass exploitation)\b", t):
        return "A", "active exploitation evidence → E:A"
    # A probe that ran the saved input CLEAN (verdict=CLEAN / NO CRASHES /
    # CRASH_RATE 0/N embedded in the report body) is a recorded failed
    # reproduction and overrides any stale testcase artifact — the same reading
    # as a structured 0/N rate. Checked BEFORE the rate parse so a misread
    # budget counter can never grant E:P over real clean probe evidence.
    if _probe_ran_clean_text(report_text):
        return "U", "probe ran the saved input clean (verdict=CLEAN / 0-of-N) → E:U"
    rate = _parse_repro_rate(report_text, fields)
    if rate is not None:
        n, d = rate
        if n > 0:
            return "P", f"reproduction rate {n}/{d} → E:P"
        # n == 0: the harness recorded a reverification and it FAILED. A
        # reproducer that no longer fires is not proof-of-concept maturity,
        # and this verdict overrides a stale artifact still on disk.
        return "U", f"reproduction rate {n}/{d}: reverification failed → E:U"
    if _has_repro_artifacts(report_dir):
        return "P", "reproducer/testcase artifact on disk → E:P"
    if _report_is_triaged(fields):
        return "U", "no reproducer artifact or positive reproduction → E:U"
    return "X", "threat evidence not defined → E:X"


def _limited_caller_control(fields: dict) -> tuple[bool, str]:
    """Whether local caller control adds an Environmental attack requirement."""
    controls = (fields.get("caller_controls", "") or "").lower()
    trigger = (fields.get("trigger_source", "") or "").lower()
    parameter = (fields.get("parameter_control", "") or "").lower()
    trusted = (fields.get("trusted_caller_actions", "") or "").lower()

    limited_re = re.compile(r"\b(length|size|count|number|offset|index|flag|option|enum|"
                            r"timing|race|env|fs-state|protocol-state|"
                            r"call-sequence|call order)\b")
    byte_re = re.compile(r"\b(byte|bytes|buffer|blob|input|payload|content|"
                         r"document|request|packet|file)\b")
    none_re = re.compile(r"\b(none|not controlled|no caller control)\b")

    if parameter and re.search(r"\b(indirect|computed|configuration|config|harness-only|"
                               r"trusted|application-supplied)\b", parameter):
        return True, "parameter control is indirect/trusted → MAT:P"
    if trusted and re.search(r"\b(private|internal|struct|mutation|harness-only|"
                             r"callback|ordering|sequence)\b", trusted):
        if not re.search(r"\b(?:normal(?:ly)?|public|documented|no private)\b", trusted):
            return True, "trusted caller action required → MAT:P"

    if controls.strip():
        if none_re.search(controls):
            return True, "caller control absent → MAT:P"
        # Full byte control dominates: "document contents and length" is a
        # caller who shapes the whole input, not one limited to its length.
        # The limited-shape reading applies only when no byte/content word
        # appears alongside it.
        if byte_re.search(controls):
            return False, "caller controls input bytes → MAT:X"
        if limited_re.search(controls):
            return True, "caller controls limited trigger shape → MAT:P"
        return False, ""

    if not trigger.strip():
        return False, ""
    if limited_re.search(trigger):
        return True, "trigger source requires local state/control → MAT:P"
    return False, ""


# Trigger tokens that can be driven by a *remote* attacker in some real
# deployment, so they do not localise the attack vector: a race/timing window
# is reached by concurrent remote requests; protocol-state by attacker-sent
# messages; env/fs-state by content the attacker supplies remotely. Module-level
# so both the localisation gate and the trigger-token veto share one definition.
_REMOTE_CAPABLE_RE = re.compile(r"\b(timing|race|data[- ]?race|"
                                r"protocol[- ]?state|env|environment|"
                                r"fs[- ]?state|file[- ]?system[- ]?state)\b")

# A local API/call-ordering trigger: the structured `call-sequence` token plus
# the common free-prose phrasings. Deliberately excludes the `both` token — in
# free prose "both" is the ordinary English word ("both calls must run"), so it
# is matched only when scoped to the structured trigger_source field.
_CALL_SEQUENCE_RE = re.compile(r"\bcall[- ]sequence\b|"
                               r"\bcall[- ]order(?:ing)?\b|\bcallback ordering\b|"
                               r"\bapi call[- ]sequence\b|"
                               r"\b(?:sequence|ordering|order) of (?:\w+\s+){0,3}calls?\b")

# The structured set-difference lib/triage.sh records in the `## Contract
# concern` section: `requires [<csv>] outside attacker_controls=[...]`. This is
# the exact set of trigger components triage determined the attacker does NOT
# control, computed once against the target's threat model (with triage's own
# token normalisation/expansion). The scorer consumes that authoritative result
# rather than re-deriving the set-difference — the tokens are already canonical.
_CONTRACT_OOB_RE = re.compile(
    r"requires\s*\[([^\]]*)\]\s*outside\s+attacker_controls=", re.IGNORECASE)


def _contract_oob_components(fields: dict) -> set[str]:
    """Trigger components triage recorded as outside the target's declared
    attacker_controls. Empty set when the report carries no such annotation —
    e.g. trigger ⊆ attacker_controls (promoted) or a contract concern raised for
    a different reason (violated contract / harness-only parameters), neither of
    which establishes that *only* a local call-sequence gates the primitive."""
    m = _CONTRACT_OOB_RE.search(fields.get("_report_text", "") or "")
    if not m:
        return set()
    return {t.strip().lower() for t in m.group(1).split(",") if t.strip()}


def _local_caller_only(fields: dict) -> tuple[bool, str]:
    """Whether the primitive is reachable only by a trusted local caller.

    The surface worst-case-embedding rule (``_SURFACE_AVUI``) sets AV:N for a
    library on the premise — from the CVSS v4.0 user guide's library guidance —
    that some external boundary feeds the vulnerable code attacker-controlled
    *bytes*. That premise fails when the trigger instead requires a trusted
    in-process caller to drive a privileged API/call sequence (install
    allocator hooks, reorder public calls, mutate private state) and exposes no
    attacker-controlled byte/content path. Then the only actor who can reach
    the primitive is a local caller: Attack Vector is Local (AV:L) and the
    required setup is an intrinsic Attack Requirement (AT:P) — not merely an
    Environmental MAT:P override of this deployment.

    Deliberately narrower than ``_limited_caller_control``: a remote attacker
    who merely shapes a length/size/flag field is still AV:N, so those signals
    do not gate the vector here. The byte/content guard takes precedence — any
    attacker-controlled byte path keeps the surface AV — so a genuine
    parse-the-bytes bug can never be localised by a misclassified field.

    Localisation requires *positive* local-caller evidence (call-sequence /
    call-order in controls, trusted/application-supplied parameters, or a
    private/internal trusted action). A bare contract concern or generic
    ``Trigger source: api`` is intentionally NOT enough: those establish the
    trigger is not pure attacker bytes, but not that only a trusted local caller
    can reach it. Contract concern is already represented as Environmental
    MAT:P in ``_cvss4_metrics``.
    """
    controls = (fields.get("caller_controls", "") or "").lower()
    trigger = (fields.get("trigger_source", "") or "").lower()
    parameter = (fields.get("parameter_control", "") or "").lower()
    trusted = (fields.get("trusted_caller_actions", "") or "").lower()

    # Authoritative localisation from triage's structured set-difference. When
    # the *only* trigger component outside the attacker's control is a local
    # `call-sequence`, the primitive is reachable solely by a trusted in-process
    # caller driving that ordering — the attacker-controlled bytes (the `both`
    # case) are mere setup. That is AV:L/AT:P, and it holds even for
    # trigger_source=both, where the byte veto below would otherwise keep AV:N.
    #
    # The subset test is exact and conservative — it localises ONLY when the
    # out-of-control set is {call-sequence} and nothing else:
    #   * {bytes,call-sequence} or {bytes} → bytes are out of attacker control
    #     too, so a byte path is part of the gating trigger → stay AV:N;
    #   * {timing}/{race}/{env}/… → remotely reachable in some deployment → AV:N;
    #   * a contract concern from a violated contract / harness-only parameters
    #     emits no `requires [...] outside` line → empty set → stay AV:N.
    # A genuine byte-parser has trigger ⊆ attacker_controls (promoted, no
    # concern) and never localises; a target that exposes the call-sequence
    # declares it in attacker_controls, clearing it from the set → AV:N.
    oob = _contract_oob_components(fields)
    if oob and oob <= {"call-sequence"}:
        return True, ("trigger's only out-of-attacker-control component is a "
                      "local call-sequence → AV:L/AT:P")

    # Words denoting attacker-supplied *data/content* reaching the code (as
    # opposed to call ordering, numeric/flag shape, or environmental state).
    # Inclusion criterion: a term a triage report uses for the bytes/text the
    # caller feeds the primitive. Widening this list only ever *keeps* a crash
    # at the surface AV (the safe direction); it never downgrades one.
    byte_re = re.compile(r"\b(byte|bytes|buffer|blob|input|payload|content|"
                         r"document|request|response|packet|file|stream|"
                         r"string|text|char|data|message|body|header|token|"
                         r"json|xml|html|url|uri|utf-?8|unicode|encoding)\b")
    # `both` is the structured triage trigger-source token that expands to
    # `bytes,call-sequence` (lib/triage.sh _expand_trigger_components): it
    # asserts a byte path alongside the call-sequence, so it must veto
    # localisation exactly like a bare `bytes` would. Scope it to the
    # trigger_source field ONLY — in free-prose caller_controls/parameter_control
    # "both" is the ordinary English word ("both calls must be made in order")
    # and vetoing there would wrongly keep a genuine local call-sequence bug at
    # AV:N (over-severity). The generic byte/content words apply to every field.
    trigger_is_byte = byte_re.search(trigger) or re.search(r"\bboth\b", trigger)
    # A structured `call-sequence` trigger_source is authoritative: the triage
    # pass classified the trigger as a local call ordering, not attacker bytes,
    # so incidental byte/content words in the free-prose caller_controls /
    # parameter_control (e.g. "caller controls … subject bytes, match-context
    # callback") must NOT veto localisation — the same trigger-scoped reading
    # already applied to the `both` token just above. A genuine parse-the-bytes
    # bug instead carries trigger_source=bytes/both (vetoed here), so this never
    # localises a real byte-reachable crash; it only stops the prose byte-word
    # veto from over-scoring a re-entrancy/callback/call-order crash whose
    # subject bytes are present but are not the proximate trigger.
    trigger_is_call_sequence = bool(re.search(r"\bcall[- ]sequence\b", trigger)) \
        and not trigger_is_byte
    # Any attacker-controlled byte/content path means an external boundary can
    # reach the primitive — keep the surface Attack Vector (AV:N for libraries).
    if trigger_is_byte:
        return False, ""
    if not trigger_is_call_sequence and (byte_re.search(controls) or byte_re.search(parameter)):
        return False, ""

    # Trigger tokens that are NOT unambiguously local. Each can be driven by a
    # remote attacker in some real deployment, so the trigger token alone does
    # not decide attacker proximity: a `race`/`timing` bug is reached by
    # concurrent *remote* requests to a multithreaded server; `protocol-state`
    # by attacker-sent messages; `env` and `fs-state` by content the attacker
    # supplies remotely (CGI maps HTTP headers to env vars — Shellshock;
    # upload-then-parse makes file contents attacker-controlled). Because each
    # is remotely reachable whenever attacker content flows through it, the
    # conservative classification is the surface AV:N — localising would
    # under-rate real network bugs. When trigger_source names one of these,
    # veto localisation on EVERY signal below (including a trusted parameter or
    # caller action): the trigger itself may be attacker-reachable, so AV:N must
    # win. Scoped to the structured trigger_source field (like the `both` token)
    # so a free-prose mention does not over-veto; `call-sequence` is the one
    # local-by-nature token and is intentionally absent here. The extra
    # precondition these triggers carry is still captured as an Attack
    # Requirement / Environmental MAT:P elsewhere.
    if _REMOTE_CAPABLE_RE.search(trigger):
        return False, ""

    # A call-ordering trigger, in either the controls prose or the structured
    # trigger_source field. Matches the literal `call-sequence` token and the
    # common free-prose phrasings ("the sequence of public API calls", "ordering
    # of calls"). This is the precise call-ordering signal — NOT the coarse
    # `Trigger source: api`, which every library bug carries and is excluded.
    # Past this point only `call-sequence` and the trusted local
    # parameter/action signals localise; the remote-capable trigger tokens have
    # already been vetoed above.
    if _CALL_SEQUENCE_RE.search(controls) or _CALL_SEQUENCE_RE.search(trigger):
        return True, "trigger is a local API/call-sequence, not attacker bytes → AV:L/AT:P"
    if parameter and re.search(r"\b(trusted|application-supplied|harness-only)\b", parameter):
        return True, "trigger needs trusted/application-supplied parameters → AV:L/AT:P"
    if (trusted and re.search(r"\b(private|internal|mutation|callback|ordering|sequence)\b", trusted)
            and not re.search(r"\b(?:normal(?:ly)?|public|documented|no private)\b", trusted)):
        return True, "trigger needs a trusted private/callback caller action → AV:L/AT:P"
    return False, ""


def _environmental_requirement(surface_label: str) -> tuple[str, str]:
    """Local CR/IR/AR importance from the *shipping context* of the surface.

    Deliberately not a function of external-caller counts. How many third-party
    projects depend on an API measures ecosystem prevalence, not the importance
    of the affected asset to a consuming environment — the concept CR/IR/AR is
    defined for. Prevalence is prioritisation metadata (reported separately as
    external-caller reach), so it must not move the CVSS score. Tiering here is
    purely deployment surface: an internet-facing service warrants H; an
    ordinary shipped library/file/CLI warrants M; non-shipping code L."""
    if surface_label in NON_SHIPPING_SURFACES:
        return "L", f"non-shipping {surface_label} use → CR/IR/AR:L"
    if surface_label == "network":
        return "H", "network-facing deployment → CR/IR/AR:H"
    if surface_label in {"library", "file", "cli_production"}:
        return "M", "ordinary deployed library/file/CLI use → CR/IR/AR:M"
    # Unclassified surface (e.g. `unknown`): no deployment context to tier on.
    # Leave the requirement Not Defined so scoring falls back to the CVSS-B
    # worst case (CR/IR/AR default to H), rather than discounting on the absence
    # of caller evidence — that absence is a popularity signal, not an asset-
    # importance one, and must not lower the score.
    return "X", "surface kind unclassified → CR/IR/AR not defined (CVSS-B baseline)"


def _non_shipping_modified_impacts(surface_label: str,
                                   metrics: dict[str, str]) -> tuple[dict[str, str], str]:
    """Reduce local impact for non-shipping code with Environmental M* metrics."""
    if surface_label not in NON_SHIPPING_SURFACES:
        return {}, ""
    if surface_label == "internal":
        value = "N"
        note = "internal harness is not deployed → modified impacts:N"
    else:
        value = "L"
        note = "non-shipping tool impact is local/dev-only → modified impacts:L"
    mapping = {
        "VC": "MVC", "VI": "MVI", "VA": "MVA",
        "SC": "MSC", "SI": "MSI", "SA": "MSA",
    }
    mods = {mod: value for base, mod in mapping.items() if metrics.get(base) != "N"}
    return mods, note


def _cvss4_metrics(prim_key: str, surface_label: str, fields: dict,
                   reach: dict, contract_concern: bool,
                   report_dir: Path | None = None) -> tuple[dict[str, str] | None, list[str]]:
    """Derive CVSS v4.0 metrics for a classified crash.

    Returns (metrics, derivation-notes), or (None, notes) when the primitive
    is unclassified (no vector). Base metrics describe the vulnerability
    class/surface; Threat and Environmental metrics describe the local audit
    context without introducing TokenFuzz-specific arithmetic.
    """
    cls = CVSS4_CLASS.get(prim_key)
    if cls is None:
        return None, [f"primitive={prim_key} is unclassified — no CVSS vector"]
    vc, vi, va, sc, si, sa, at_override = cls
    av, ui = _SURFACE_AVUI.get(surface_label, _SURFACE_AVUI["unknown"])
    surface_av = av
    # Base AT captures intrinsic class-level preconditions. Local caller
    # contract/control concerns are Environmental MAT below.
    at = at_override or "N"
    # Attack Vector reflects how the attacker reaches the primitive, not just
    # where the code is deployed. The surface worst-case embedding (AV:N)
    # assumes an external boundary feeds the primitive attacker-controlled
    # bytes. When the trigger instead requires a trusted local caller to drive
    # a privileged API/call sequence and exposes no byte path, the attacker is
    # local: AV:L, and the setup is an intrinsic Attack Requirement (AT:P).
    # The setup requirement (AT:P) is intrinsic to the trigger and holds even
    # when the surface already reads AV:L; the AV override only applies when
    # the surface worst-case would otherwise be AV:N.
    local_only, local_note = _local_caller_only(fields)
    if local_only:
        at = "P"
    av_localised = local_only and av == "N"
    if av_localised:
        av = "L"
    metrics = {
        "AV": av, "AC": "L", "AT": at, "PR": "N", "UI": ui,
        "VC": vc, "VI": vi, "VA": va, "SC": sc, "SI": si, "SA": sa,
    }
    e, e_note = _threat_metric(fields.get("_report_text", ""), fields, report_dir)
    if e != "X":
        metrics["E"] = e
    req, req_note = _environmental_requirement(surface_label)
    if req != "X":
        metrics.update({"CR": req, "IR": req, "AR": req})
    limited, limited_note = _limited_caller_control(fields)
    if contract_concern or limited:
        metrics["MAT"] = "P"
    mods, mods_note = _non_shipping_modified_impacts(surface_label, metrics)
    metrics.update(mods)
    notes = [
        f"surface={surface_label} → AV:{surface_av}/UI:{ui}",
        f"class={prim_key} → VC:{vc}/VI:{vi}/VA:{va}/SC:{sc}/SI:{si}/SA:{sa}",
    ]
    if local_only:
        notes.append(local_note)
        if av_localised:
            notes.append(f"local-only trigger → AV:{av} (overrides surface AV:{surface_av}), AT:{at}")
        else:
            notes.append(f"local-only trigger → AT:{at} (surface already AV:{surface_av})")
    else:
        notes.append(f"class preconditions → AT:{at}")
    notes += [
        "PR:N (worst case — no auth signal), AC:L",
        e_note,
        req_note,
    ]
    if contract_concern:
        notes.append("caller contract concern → MAT:P")
    if limited_note:
        notes.append(limited_note)
    if mods_note:
        notes.append(mods_note)
    return metrics, notes


def detect_primitive(report_text: str) -> tuple[str, str]:
    """Return (primitive_key, human_label).

    Inspect both the narrative and any inline ASan output. ASan reports the
    sanitizer class and the read/write direction on *different lines*, so
    they are detected independently and combined. The size, when present in
    a `READ of size N` / `WRITE of size N` line, distinguishes info-leak
    shaped reads (≥16 bytes) from DoS-shaped 1-byte reads.
    """
    t = report_text.lower()

    # ── Direction (read / write) ──────────────────────────────────
    rw = "?"
    rw_size: int | None = None
    m = re.search(r"\bwrite of size\s+(\d+)", t)
    if m:
        rw, rw_size = "write", int(m.group(1))
    if rw == "?":
        m = re.search(r"\bread of size\s+(\d+)", t)
        if m:
            rw, rw_size = "read", int(m.group(1))
    if rw == "?":
        if re.search(r"\bwrite\b.{0,30}\boverflow|out-of-range write", t):
            rw = "write"
        elif re.search(r"\bread\b.{0,30}\boverflow|out-of-range read", t):
            rw = "read"

    # ── Sanitizer class ───────────────────────────────────────────
    # Authoritative SIGBUS: the sanitizer headline names BUS / SIGBUS. A bus
    # error is a misalignment / unmapped-access DoS (N,N,H), NOT a wild WRITE —
    # match it before the corruption branches and the read/write-direction
    # fallbacks so an incidental "WRITE of size N" frame (e.g. a memmove deep
    # in the faulting libc stack) or a SCARINESS `wild-addr-write` tag cannot
    # mis-route a bus error to a code-execution-capable corruption class.
    if re.search(r"addresssanitizer:\s*bus\b|"
                 r"summary:[^\n]*sanitizer:\s*bus\b|"
                 r"\bsigbus\b|\bbus error\b", t):
        return "bus", "BUS / SIGBUS"

    # use-after-poison is ASan's "freed by the container, not by free()"
    # shape — same type-state pivot as a UAF, scored identically.
    if re.search(r"heap[- ]use[- ]after[- ]free|\buse[- ]after[- ]free\b|"
                 r"\buse[- ]after[- ]poison\b", t):
        if rw == "write":
            return "uaf_write", "use-after-free WRITE"
        return "uaf_read", "use-after-free" + (" READ" if rw == "read" else "")

    # Invalid frees (free of a non-malloc'd pointer, alloc/dealloc mismatch)
    # are the same allocator-state corruption family as double-free.
    if re.search(r"\bdouble[- ]free\b|"
                 r"attempting free on address which was not malloc|"
                 r"\balloc[- ]dealloc[- ]mismatch\b|\binvalid[- ]free\b", t):
        return "double_free", "double-free / invalid free"

    # C++ type confusion: ClusterFuzz's "Bad-cast to X from Y" crash type and
    # Clang CFI's cast-check failure are both precise sanitizer-grade signals.
    # (UBSan's vptr check lands here too, via the UBSan branch below.)
    if re.search(r"\bbad-cast\b|"
                 r"control flow integrity check\b.{0,120}\bduring cast\b|"
                 r"\bcfi\b.{0,40}\bbad[- ]cast\b", t):
        return "type_confusion", "type confusion (bad-cast)"

    # Wild-address WRITE: explicit textual cue *or* an ASan SCARINESS line
    # tagged `wild-addr-write`.
    if re.search(r"wild[- ]addr[- ]write|wild-?addr.*write|wild[- ]address[ -]write", t):
        return "wild_write", "wild-addr WRITE"

    if re.search(r"\bstack-buffer-overflow\b|\bstack-use-after-(?:scope|return)\b|"
                 r"\bdynamic-stack-buffer-overflow\b", t):
        if rw == "write":
            return "stack_write", "stack WRITE" + (f" of {rw_size} byte(s)" if rw_size else "")
        return "stack_read", "stack READ" + (f" of {rw_size} byte(s)" if rw_size else "")

    # ASan's hyphenated `stack-overflow` token is recursion/stack exhaustion
    # (DoS), not a buffer overflow — must be checked after the
    # stack-buffer-overflow branch above.
    if re.search(r"\bstack-overflow\b|\bstack exhaustion\b", t):
        return "stack_exhaustion", "stack exhaustion (deep recursion)"

    if re.search(r"\bglobal-buffer-overflow\b", t):
        if rw == "write":
            return "global_write", "global WRITE" + (f" of {rw_size} byte(s)" if rw_size else "")
        return "global_read", "global READ" + (f" of {rw_size} byte(s)" if rw_size else "")

    # Heap-buffer-overflow (or unspecified buffer overflow).
    if re.search(r"\bheap-buffer-overflow\b|\bcontainer-overflow\b|\bintra-object-overflow\b", t):
        if rw == "write":
            return "heap_write", f"heap WRITE of {rw_size} byte(s)" if rw_size else "heap WRITE"
        if rw_size is not None and rw_size >= 16:
            return "heap_read_big", f"heap READ of {rw_size} byte(s)"
        return "heap_read_small", f"heap READ of {rw_size} byte(s)" if rw_size else "heap READ"

    # negative-size-param is a memcpy/memset with a negative (huge unsigned)
    # size — write-shaped corruption (ClusterFuzz scores it as such).
    if re.search(r"\bnegative-size-param\b", t):
        return "heap_write", "negative-size param"

    # LeakSanitizer memory leaks are a resource-DoS class. Must be matched
    # before the generic "leak(ed|s)" info-disclosure fallback below, which
    # is about *data* leaking, not allocations. The strong LSan tokens are
    # literal sanitizer output and stay authoritative; the bare "memory
    # leak(s)" phrase is prose-matchable ("memory leak was ruled out") so it
    # goes through the negation guard.
    if re.search(r"\bleaksanitizer\b|\bdetected memory leaks\b|"
                 r"\b(?:direct|indirect) leak of\b", t):
        return "memory_leak", "memory leak"
    if _unnegated_search(r"\bmemory leaks?\b", t):
        return "memory_leak", "memory leak"

    # Allocator / resource exhaustion (OSS-Fuzz treats these as non-security
    # unless the size is attacker-amplified — that case is dos_amplification).
    if re.search(r"\ballocation-size-too-big\b|\bout-of-memory\b|"
                 r"\brss limit (?:exhausted|exceeded)\b|\bexceeds maximum supported size\b", t):
        return "oom", "allocation/OOM resource exhaustion"

    # MSan / KMSAN use of uninitialized memory — a literal *diagnostic*
    # token, so it must classify here (authoritative), not via the prose
    # "uninit" fallback below, which runs AFTER the web-vuln regexes and
    # could lose to an incidental narrative mention of some web class.
    # The bare tool names are deliberately NOT matched: "no MemorySanitizer
    # diagnostic was produced" / "MSan build unavailable" is routine triage
    # prose, not a finding. Only the diagnostic line shapes count.
    if re.search(r"warning: memorysanitizer:|"
                 r"\buse-of-uninit(?:ialized)?-value\b|"
                 r"\bkmsan:\s*uninit-value\b|\bbug:\s*kmsan\b", t):
        return "info_leak", "uninitialized value (MSan)"

    if re.search(r"undefinedbehaviorsanitizer|:[0-9]+:[0-9]+: runtime error:", t):
        if re.search(r"out of bounds|object-size|pointer[- ]overflow", t):
            return "heap_read_small", "UBSan bounds/object-size"
        if "misaligned" in t:
            return "bus", "UBSan alignment"
        if "null pointer" in t:
            return "null_deref", "UBSan null pointer"
        if "vptr" in t:
            # An object accessed through a vptr of the wrong dynamic type IS
            # type confusion — same class ClusterFuzz calls Bad-cast — not a
            # small-read DoS.
            return "type_confusion", "UBSan vptr type confusion"
        if re.search(r"(?:signed|unsigned) integer overflow|"
                     r"shift exponent .{0,40} is too large|"
                     r"negation of .{0,40} cannot be represented", t):
            return "integer_overflow", "UBSan integer overflow"

    if re.search(r"threadsanitizer: data race|^warning: data race$", t, re.MULTILINE):
        return "data_race", "data race"

    # A near-null faulting address is a null dereference (DoS), authoritative
    # over a stray read/write-direction line below: ASan's `SEGV on unknown
    # address 0x000…` in the first unmapped page is a null pointer deref
    # (N,N,H), not a heap read — even if some frame logged a "READ of size N".
    m_nullseg = re.search(r"segv on unknown address 0x0*([0-9a-f]+)", t)
    if m_nullseg and int(m_nullseg.group(1), 16) < 0x1000:
        return "null_deref", "null/SEGV (near-null address)"

    # Direction-only fallbacks (no class found, but the report has WRITE/READ).
    if rw == "write":
        return "heap_write", f"WRITE of {rw_size} byte(s)" if rw_size else "WRITE"
    if rw == "read":
        if rw_size is not None and rw_size >= 16:
            return "heap_read_big", f"READ of {rw_size} byte(s)"
        return "heap_read_small", f"READ of {rw_size} byte(s)" if rw_size else "READ"

    # ── Web/application vulnerability classes ────────────────────
    # Run before the DoS-shaped fallbacks so a finding with a clear
    # web-vuln Type (open redirect, SSRF, etc.) is not misread as
    # null/SEGV or unclassified. Memory-safety classes above already
    # short-circuited via ASan/UBSan/TSan keywords; what reaches this
    # point is non-sanitizer-triggered findings.
    web = detect_web_vuln(t)
    if web is not None:
        return web

    # SEGV: discriminate by faulting address, the way ClusterFuzz does.
    # A near-null address (< 0x1000, one unmapped page) is a classic null
    # deref (DoS); anything else is a wild-pointer access whose direction
    # ("caused by a READ/WRITE memory access") decides read vs write tier.
    # Without the address line, fall through to the plain null/SEGV bucket.
    m = re.search(r"segv on unknown address 0x0*([0-9a-f]+)", t)
    if m:
        addr = int(m.group(1), 16)
        if addr >= 0x1000:
            if re.search(r"caused by a write memory access", t):
                return "wild_write", f"SEGV WRITE at wild address 0x{addr:x}"
            return "wild_read", f"SEGV READ at wild address 0x{addr:x}"
        return "null_deref", "null/SEGV (near-null address)"

    # Non-memory-safety crashes (DoS-shaped).
    if "null deref" in t or re.search(r"\bsegv\b", t) or "null pointer" in t:
        return "null_deref", "null/SEGV"
    if re.search(r"\bbus\b", t) or "sigbus" in t:
        return "bus", "BUS"
    if _unnegated_search(r"\b(info[- ]disclosure|information disclosure|internal representation|leak(?:ed|s)?)\b", t):
        return "info_leak", "information disclosure"
    if _unnegated_search(r"\b(uninit|uninitialized|uninitialised)\b", t):
        return "info_leak", "uninitialized read"
    # Prose-only "type confusion" stays in the conservative small-read tier:
    # the 34-point type_confusion class is reserved for sanitizer-grade
    # signals (Bad-cast / CFI / vptr, matched above) or a deliberate
    # structured `Primitive: type_confusion` field. Mitigation/background
    # prose ("hardening against type confusion") must not mint a
    # high-impact primitive from a keyword.
    if _unnegated_search(r"\b(type confusion|type mismatch|type validation|unchecked elements?)\b", t):
        return "heap_read_small", "type-state mismatch"

    # ── Recon / reasoning-confirmed classes ───────────────────────
    # Patterns for non-ASan findings the harness's audit-recon pass and
    # the validator quorum have promoted. These keep promoted reasoning
    # findings from collapsing to "unknown=8" at scoring time. Each
    # pattern requires the named class as a distinct phrase, and
    # _unnegated_search drops mentions whose clause rules the class out
    # ("no cache poisoning", "not a downgrade").
    if _unnegated_search(r"\b(?:dns[- ]?)?cache poisoning\b|\bcookie poisoning\b|"
                         r"\bsession (?:fixation|poisoning)\b|\b(?:tcp|protocol) downgrade\b|"
                         r"\bprotocol[- ]state corruption\b", t):
        return "protocol_state", "protocol-state corruption"
    if _unnegated_search(r"\bdos[- ]amplification\b|\bdecompression bomb\b|"
                         r"\balgorithmic complexity (?:attack|amplification)\b|"
                         r"\bquadratic (?:blowup|amplification)\b|"
                         r"\bmemory amplification\b", t):
        return "dos_amplification", "DoS amplification"
    if _unnegated_search(r"\bdefense[- ]in[- ]depth regression\b|"
                         r"\bsecurity feature (?:disabled|defeated|bypassed)\b|"
                         r"\b(?:silently )?(?:defeats|disables) (?:dns0x20|spoofing protection)\b", t):
        return "logic_regression", "logic regression / DiD"

    return "unknown", "unclassified"


# Ordered list of (regex, primitive_key, human_label). Order matters: the
# first match wins, so put more specific phrases first. Patterns are case-
# insensitive and applied to the full lowercased report text.
#
# Anchored phrasing: each pattern requires the *named class* to appear as a
# distinct phrase. We do not match bare words like "injection" or "bypass"
# alone — those generate noise on prose like "no auth bypass observed".
_WEB_VULN_PATTERNS: list[tuple[re.Pattern[str], str, str]] = [
    # RCE-shaped
    (re.compile(r"\b(?:os|shell|command)[- ]?injection\b|\brce\b|\bremote code execution\b"),
     "command_injection", "command injection"),
    (re.compile(r"\b(?:insecure )?deserialization\b|\bunsafe deserialization\b|"
                r"\bpickle deserialization\b|\bunserialize\b"),
     "deserialization", "insecure deserialization"),
    (re.compile(r"\bsql[- ]?injection\b|\bsqli\b"),
     "sqli", "SQL injection"),
    (re.compile(r"\bserver[- ]side template injection\b|\bssti\b|\btemplate injection\b"),
     "ssti", "server-side template injection"),
    # Auth / access control
    (re.compile(r"\bauthentication bypass\b|\bauthn[- ]bypass\b|\blogin bypass\b|"
                r"\bsession (?:fixation|hijack(?:ing)?)\b"),
     "authn_bypass", "authentication bypass"),
    (re.compile(r"\bauthorization bypass\b|\bauthz[- ]bypass\b|"
                r"\bprivilege escalation\b|\baccess[- ]control bypass\b|"
                r"\bbroken access control\b"),
     "authz_bypass", "authorization bypass"),
    (re.compile(r"\b(?:insecure direct object reference|idor)\b"),
     "idor", "insecure direct object reference"),
    # File / network exfil
    (re.compile(r"\b(?:server[- ]side request forgery|ssrf)\b"),
     "ssrf", "server-side request forgery"),
    # Note: no bare `../../` alternative here — crash reports routinely quote
    # raw input bytes (testcase paths, corpus content) containing `../..`,
    # which would misclassify a memory-safety or DoS report as traversal.
    # The named phrases are the anchored signal.
    (re.compile(r"\b(?:path|directory) traversal\b|\barbitrary file (?:read|write|disclosure)\b"),
     "path_traversal", "path traversal"),
    (re.compile(r"\b(?:xml external entity|xxe)\b"),
     "xxe", "XML external entity"),
    (re.compile(r"\b(?:credential|secret|token|api[- ]key) (?:leak|exposure|disclosure)\b|"
                r"\bhard[- ]coded (?:credential|secret|key|password)\b"),
     "secrets_exposure", "credentials/secrets exposure"),
    # Client / web-app classes
    (re.compile(r"\bprototype pollution\b"),
     "prototype_pollution", "prototype pollution"),
    (re.compile(r"\b(?:stored|reflected|dom|persistent) xss\b|\bcross[- ]site scripting\b|\bxss\b"),
     "xss", "cross-site scripting"),
    (re.compile(r"\bopen[- ]redirect\b|\bunvalidated redirect\b|\bcwe[- ]?601\b"),
     "open_redirect", "open redirect"),
    (re.compile(r"\b(?:csrf|cross[- ]site request forgery)\b"),
     "csrf", "cross-site request forgery"),
    # Misc
    (re.compile(r"\b(?:redos|regex(?:p)? dos|catastrophic backtracking)\b"),
     "regex_dos", "regex DoS"),
    (re.compile(r"\bweak (?:hash|crypto|cipher|prng|rng)\b|\binsecure (?:random|cipher|hash)\b|"
                r"\bbroken (?:cryptography|crypto|cipher|hash)\b"),
     "crypto_weakness", "weak/broken cryptography"),
    # Generic injection fallback (only when explicitly named — see anchor)
    (re.compile(r"\b(?:crlf|header|http header|response splitting|xpath|ldap|nosql)[- ]?injection\b"),
     "injection", "injection"),
]


# Negation guard for narrative-driven classification. Reports routinely
# *rule classes out* in prose, and the negation can sit on EITHER side of
# the class name:
#   before — "no SQL injection is possible", "we did not find an XXE"
#   after  — "SQL injection is not possible", "cache poisoning was ruled out"
# A bare keyword match on such a sentence would invent a finding class, so a
# match counts only when neither side of its clause carries a negation token.
# The clause is cut at sentence/segment boundaries INCLUDING commas, so
# "input is not sanitized, leading to SQL injection" stays positive (the
# "not" is in the previous comma-clause). A trailing concessive ("…but not
# exploitable", "…though not reachable") is NOT treated as a class negation —
# the bug is still real, just qualified — so those connectors cap the
# forward scan.
# Negation when it sits BEFORE the class name ("no SQL injection", "did not
# find an XXE", "absence of any traversal"). The full set, including the
# mechanism-flavoured ones, is safe here because they all read as ruling the
# class out when they precede it.
_NEGATION_BEFORE_RE = re.compile(
    r"\b(?:no|not|never|without|neither|nor|"
    r"cannot|can't|couldn't|doesn't|don't|didn't|isn't|wasn't|aren't|won't|"
    r"rules? out|ruled out|absence of|free (?:of|from)|"
    r"unable to|impossible|"
    # Prevention/mitigation verbs before the class name assert the DEFENSE,
    # not the bug ("prevents type confusion", "mitigates SQL injection",
    # "hardening against XXE"). Before-position only: in after-position
    # ("XSS mitigations were insufficient") the same stems often assert the
    # bug, so they stay out of _NEGATION_AFTER_RE.
    r"prevent(?:s|ed|ing)?|mitigat(?:e[sd]?|ing|ions?)|avoid(?:s|ed|ing)?|"
    r"protect(?:s|ed|ing)? (?:against|from)|guard(?:s|ed|ing)? against|"
    r"harden(?:s|ed|ing)? against|defend(?:s|ed|ing)? against)\b"
)
# Negation when it sits AFTER the class name ("SQL injection is not possible",
# "cache poisoning was ruled out"). This set is deliberately NARROWER: a
# trailing "without …", "absence of …", or "free of …" almost always
# describes the *mechanism* of the bug ("command injection … without
# escaping", "overflow because the code is free of bounds checks"), not a
# denial of the class — counting those would suppress real findings.
_NEGATION_AFTER_RE = re.compile(
    r"\b(?:not|never|cannot|can't|couldn't|isn't|wasn't|aren't|won't|"
    r"rules? out|ruled out|impossible)\b"
)
_CLAUSE_BOUNDARY = (".", ";", ",", ":", "\n")
# Concessive connectors that start a new logical clause for negation purposes:
# "SQLi but not exploitable" still asserts the SQLi.
_CONCESSIVE_RE = re.compile(r"\b(?:but|however|though|although|yet|still)\b")


def _next_clause(text: str, pos: int) -> tuple[str, str]:
    """Clause text from `pos` to the next boundary, plus the boundary char
    that ended it ('' at end of text)."""
    cands = [text.find(ch, pos) for ch in _CLAUSE_BOUNDARY]
    cands = [c for c in cands if c != -1]
    end = min(cands) if cands else len(text)
    return text[pos:end], (text[end] if end < len(text) else "")


def _match_is_negated(text: str, start: int, end: int) -> bool:
    """True when the clause around [start, end) carries a negation of the
    matched class — looking both before (full negation set) and after
    (narrower, mechanism-aware set) the match."""
    clause_start = max((text.rfind(ch, 0, start) for ch in _CLAUSE_BOUNDARY),
                       default=-1) + 1
    before = text[clause_start:start]
    after, boundary = _next_clause(text, end)
    # A colon directly after the class name introduces a qualifier, not a new
    # statement ("SQL injection: not possible", "SSRF: ruled out"). Step over
    # it and fold the qualifier clause into the after-scan so the trailing
    # negation is seen. A non-colon boundary (period/semicolon/comma) is a
    # genuine clause end and stops the scan.
    if boundary == ":":
        nxt, _ = _next_clause(text, text.find(":", end) + 1)
        after = after + " " + nxt
    concessive = _CONCESSIVE_RE.search(after)
    if concessive:
        after = after[:concessive.start()]
    return bool(_NEGATION_BEFORE_RE.search(before)
                or _NEGATION_AFTER_RE.search(after))


def _unnegated_search(pattern: str | re.Pattern[str], text: str,
                      flags: int = 0) -> bool:
    """re.search that ignores matches whose clause negates them (either side)."""
    pat = re.compile(pattern, flags) if isinstance(pattern, str) else pattern
    return any(not _match_is_negated(text, m.start(), m.end())
               for m in pat.finditer(text))


def detect_web_vuln(text_lower: str) -> tuple[str, str] | None:
    """Return (primitive_key, human_label) for a web/app-vuln narrative,
    or None if no class matched. Operates on already-lowercased text.
    Negated mentions ("no SQL injection observed") do not classify."""
    for pat, key, label in _WEB_VULN_PATTERNS:
        if _unnegated_search(pat, text_lower):
            return key, label
    return None


# Primitive keys that are derived from prose REGEX (web/app classes +
# recon/reasoning classes), not from a precise sanitizer signal. When a
# report also carries a structured Primitive field, that deliberate
# classification outranks a prose-regex guess — but a sanitizer-class match
# (heap-buffer-overflow, UAF, data race, …) is precise and always wins. This
# is the precedence rule applied in compute_severity. info_leak is *excluded*
# here: it doubles as a sanitizer-ish "uninitialized read" detection, so it
# stays authoritative.
_NARRATIVE_ONLY_PRIMITIVES = frozenset({
    "command_injection", "deserialization", "sqli", "ssti", "authn_bypass",
    "authz_bypass", "idor", "ssrf", "path_traversal", "xxe",
    "secrets_exposure", "prototype_pollution", "xss", "open_redirect",
    "csrf", "regex_dos", "crypto_weakness", "injection",
    "protocol_state", "dos_amplification", "logic_regression",
})


# ── Surface classification (drives AV/UI and Environmental use) ──────────
#
# The surface tier feeds CVSS AV/UI and helps derive the Environmental
# requirement and non-shipping modified-impact metrics, purely from the surface
# *kind*. External-caller counts / popularity do not enter the score — they are
# ecosystem-prevalence prioritisation metadata, reported separately; vendored
# copies likewise stay as reachability facts.


# The set of surface tier labels the classifier can emit. Severity maps each
# to CVSS AV/UI via _SURFACE_AVUI; the Reachability section displays the
# label. There are no per-tier point values — the tier is a label, not a score.
SURFACE_TIERS = frozenset({
    "network", "library", "file",
    "cli_production", "dev_tool", "internal", "unknown",
})


# ── Dev/test/maintenance tool detection ──────────────────────────────────
#
# The single most important calibration in v2: a memory-safety bug in code
# that never ships to end users (test drivers, fuzzers, maintenance tooling)
# is not a security finding under any industry framework. Microsoft Bug Bar,
# Project Zero, and OSS-Fuzz all explicitly exclude these unless the bug is
# reachable from a real input surface.
#
# Detection looks at three signals — any one is sufficient:
#   1. Surface or Boundary text mentions maint/test/fuzz/maintenance.
#   2. The narrative cites a path under maint/, tests/, fuzz/, examples/, etc.
#   3. The crashing binary or function name matches a known test-tool pattern
#      (ucptest, *test, *_test, gtest, *_fuzzer, test_*).

# Match a dev/test/maint keyword only when it appears as a path component
# (preceded by start/whitespace/slash/quote/backtick/open-paren-bracket).
# Critically, '.' is NOT in the allowed prefix set — that prevents URL
# hostnames like `attacker.example/after-otc` from being misread as the
# `examples/` directory, and likewise prevents `lib.tests/` style match
# against a member-access expression. The keyword must also be followed
# by `/` (path separator) — the original behavior — so `samples_file.c`
# does not match.
_DEV_TOOL_PATH_RE = re.compile(
    r"(?:^|[\s/\"'`(\[<])("
    r"maint|maintenance|tests?|testdata|test_data|"
    r"fuzz|fuzzers?|fuzzing|"
    r"benchmark|benchmarks?|"
    r"examples?|samples?|demo|demos|"
    r"tools/test|unittests?"
    r")/",
    re.IGNORECASE,
)
# Test-binary name shapes. A bare `[a-z]+test` substring is deliberately NOT
# matched: it fires on ordinary English ("latest", "contest", "attestation",
# every superlative of a t-ending adjective — "greatest", "fastest") and would
# collapse a real bug to the dev_tool tier. Three precise shapes are matched
# instead:
#   1. a digit/underscore in the stem (`pcre2test`, `tool2test`),
#   2. a delimited test/fuzz marker (`api_test`, `run-test`, `test_main`,
#      `fuzz-foo`) — the `_`/`-` is what makes it a driver name, not a word,
#   3. an explicit list of bare all-alpha driver basenames.
# Inclusion criterion for the list: recurring upstream test/bench driver
# basenames that carry no digit/delimiter AND collide with no common English
# word (so shapes 1–2 cannot catch them). `runtest`/`testapi` are libxml2's
# drivers, `ucptest`/`pcre2test` are pcre2's; none are English words, unlike
# the `*test` superlatives above. Add a name here only when it meets both
# halves of the criterion.
_DEV_TOOL_NAME_RE = re.compile(
    r"\b("
    r"ucptest|selftest|unittests?|gtest|doctest|"
    r"runtest|runsuite|apitest|testapi|parsetest|regtest|"
    r"fuzztest|smoketest|conformancetest|"
    r"[a-z][a-z0-9_]*[0-9_][a-z0-9_]*test|"
    r"[a-z0-9]+[_-](?:test|fuzz)|(?:test|fuzz)[_-][a-z0-9_]+|"
    r"[a-z][a-z0-9_]*_fuzzer"
    r")\b",
    re.IGNORECASE,
)
# Surface "type" prefix that classifies a bug as living in non-shipping
# code. The Surface field has shape "<type> — <human description>"; the
# type word(s) before the em-dash are what we classify on. Matching on
# the description risks false positives — e.g. "library-api — C harness
# calls a public library entry point" describes a library bug, the
# harness is just how we exercise the API. Only the type prefix is
# authoritative for "where does this bug live."
_DEV_TOOL_TYPE_RE = re.compile(
    r"^\s*(maint(?:enance)?(?:[- ]tool)?|test[- ]?tool|test[- ]?driver|"
    r"developer[- ]tool|dev[- ]tool|fuzzer|fuzz[- ]?harness|fuzz[- ]?target)\b",
    re.IGNORECASE,
)
_INTERNAL_TYPE_RE = re.compile(
    r"^\s*(internal|harness|internal[- ]?harness)\b", re.IGNORECASE,
)
# Explicit dev/test/fuzz phrases in free-text Boundary prose ("fuzz harness
# bytes only", "maintenance tool input"). Distinct from _DEV_TOOL_NAME_RE,
# which matches *binary names*: a Boundary that describes the input surface in
# words is just as authoritative when it names a non-shipping driver. Each
# alternative pairs a non-shipping qualifier with a tool/driver noun — bare
# "harness" is deliberately NOT matched, so "C harness calls a public library
# entry point" (the harness is the exercise mechanism, not the bug location)
# is preserved. Applied only after the production-Surface override in
# _is_dev_tool, so a real library-api/network/cli surface still wins.
_DEV_TOOL_BOUNDARY_RE = re.compile(
    r"\b("
    r"test[- ](?:harness|driver|tool|program|binary|runner)|"
    r"fuzz(?:ing)?[- ](?:harness|target|driver|tool)|"
    r"maintenance[- ](?:tool|program|utility|script)|"
    r"(?:developer|dev)[- ]tool|"
    r"non[- ]shipping"
    r")\b",
    re.IGNORECASE,
)


def _surface_type_prefix(surface_value: str) -> str:
    """Extract the type word(s) before the first em-dash / hyphen description.

    `library-api — C harness calls ...` → `library-api`
    `maint-tool — harness embeds a test program` → `maint-tool`
    `cli — pcre2grep tool` → `cli`
    Surfaces without a separator return as-is (already type-only).
    """
    if not surface_value:
        return ""
    # Em-dash, double-dash, or " — "/" - " separator.
    for sep in (" — ", " – ", " -- ", " - "):
        if sep in surface_value:
            return surface_value.split(sep, 1)[0].strip()
    return surface_value.strip()


_KNOWN_PRODUCTION_TYPE_RE = re.compile(
    r"^\s*(network|library[- ]?api|library api|public api|file[- ]?format|"
    r"file format|parser|decoder|cli|command[- ]?line)\b",
    re.IGNORECASE,
)


def _is_dev_tool(surface_value: str, boundary_value: str, report_text: str) -> tuple[bool, str]:
    """Return (is_dev_tool, reason). Returns the first signal that matched.

    Priority order matters here. The Surface field's type prefix is the
    authoritative source for "where does this bug live":

      1. If the type prefix names a dev/test/maint tool → dev_tool.
      2. If the type prefix names a production surface (network/library/
         file/cli) → trust it; the Boundary or narrative might mention a
         test harness as the *input mechanism*, but that doesn't change
         where the bug lives. (This was the v2-1 false positive: Surface
         said "cli — shipped CLI" but Boundary said "pcre2test input"
         and our path/name signals incorrectly demoted to dev_tool.)
      3. Only when Surface is unspecified do we fall back to Boundary
         and narrative-path signals.
    """
    s_full = surface_value or ""
    s_type = _surface_type_prefix(s_full)
    b = boundary_value or ""

    if s_type and _DEV_TOOL_TYPE_RE.search(s_type):
        return True, f"surface type is a dev/test/maint tool: {s_type!r}"

    # Surface clearly names a production tier — trust it, do not let
    # Boundary/narrative override.
    if s_type and _KNOWN_PRODUCTION_TYPE_RE.search(s_type):
        return False, ""

    if _DEV_TOOL_NAME_RE.search(b):
        return True, f"boundary cites a known test-tool name: {b.strip()[:60]!r}"
    bm = _DEV_TOOL_BOUNDARY_RE.search(b)
    if bm:
        return True, f"boundary describes a dev/test/fuzz surface: {bm.group(0)!r}"
    if _DEV_TOOL_PATH_RE.search(report_text or ""):
        m = _DEV_TOOL_PATH_RE.search(report_text)
        return True, f"narrative cites a dev/test path: {m.group(0).strip()!r}"
    return False, ""


def _is_internal_surface(surface_value: str) -> bool:
    s_type = _surface_type_prefix(surface_value)
    return bool(s_type and _INTERNAL_TYPE_RE.search(s_type))


def _classify_surface(surface_value: str, boundary_value: str,
                      report_text: str,
                      report_triaged: bool = True) -> tuple[str, str]:
    """Map the report's structured fields to a surface tier label.

    Returns (tier_label, reason). Classification is anchored on the **type
    prefix** of the Surface field (the part before the em-dash) — the
    description after the dash is prose that often mentions a harness or test
    driver as the *exercise mechanism*, not the location of the bug.
    Mis-anchoring on prose was the v1 bug that let `library-api — C harness
    calls a public library entry point` get classified as a dev_tool because
    of the word "harness".

    The tier is a function of the surface *kind* only — never of external-caller
    counts. Caller popularity is ecosystem prevalence, not a surface
    characteristic, and is reported separately rather than folded into the
    score (see _environmental_requirement).

    Order:
      1. Dev/test/maintenance tool — first via type prefix, then path/name
         fallback. A bug in non-shipping code gets modified Environmental
         impacts rather than a post-score cap.
      2. Internal harness — audit-internal only.
      3. Surface tier from the type prefix (network/library/file/cli).
    """
    is_dev, dev_reason = _is_dev_tool(surface_value, boundary_value, report_text)
    if is_dev:
        return "dev_tool", dev_reason

    if _is_internal_surface(surface_value):
        return "internal", "internal harness (audit-only)"

    s_type = _surface_type_prefix(surface_value).lower()

    # Empty or literally "unknown" surface field. An un-triaged bare crash dir
    # (e.g. a benchmark `model-direct` baseline) and a triaged report whose
    # author just left Surface blank both land here; with no surface kind to
    # anchor on, the conservative `unknown` tier applies. (Caller count is never
    # consulted to rescue the tier — prevalence is not reachability evidence:
    # every caller of an API is a "caller", but only a misusing one hits a
    # misuse bug.)
    if not s_type or s_type == "unknown":
        if not report_triaged:
            return ("unknown",
                    "report carries no structured reach fields — un-triaged; "
                    "surface left unassessed")
        if not s_type:
            return "unknown", "surface field empty"
        return "unknown", "surface type unrecognised: 'unknown'"

    if any(t in s_type for t in ("network", "daemon", "rpc", "socket", "server")):
        return "network", "network-facing service"
    if any(t in s_type for t in ("library-api", "library api", "public api", "libfuzzer")):
        return "library", "library API"
    if any(t in s_type for t in ("file-format", "file format", "parser", "decoder")):
        return "file", "file-format parser"
    if any(t in s_type for t in ("cli", "command line", "command-line")):
        return "cli_production", "production CLI tool"

    return "unknown", f"surface type unrecognised: {s_type!r}"


def _has_contract_concern(report_text: str) -> bool:
    """True when triage annotated the report with a contract concern.

    Triage keeps these crashes in ``crashes/`` but prepends a report-visible
    ``## Contract concern`` section. That section is authoritative when present
    so scoring stays reproducible from REPORT.md alone. It is not the *only*
    trigger: ``extract_report_fields`` also honours the ``.contract-flagged``
    sidecar so a flagged bundle whose section was never written (or was
    dropped on regeneration) still derives MAT:P.
    """
    return bool(re.search(r"^## Contract concern\s*$", report_text or "", re.MULTILINE))


def _contract_concern(fields: dict) -> tuple[bool, str]:
    """Whether the caller contract is in question — drives CVSS MAT:P.

    A violated/misused contract or a triage contract concern means the local
    attack path carries a requirement in this target's environment
    (CVSS v4.0 Modified Attack Requirements: P). An obeyed/unstated contract
    is the standard reachable case.
    """
    v = (fields.get("caller_contract", "") or "").lower()
    if "violat" in v or "misuse" in v:
        return True, "caller contract violated → MAT:P"
    if fields.get("_contract_flagged") or _has_contract_concern(fields.get("_report_text", "")):
        return True, "triage contract concern → MAT:P"
    return False, ""


# Structured reach fields the harness's triage pass writes into REPORT.md.
# A report carrying none of them has not been triaged — reachability is then
# scoring raw sanitizer output, and an un-triaged report with no surface kind
# stays at the conservative `unknown` tier (see _classify_surface).
_TRIAGE_REACH_FIELDS = ("surface", "trigger_source", "caller_contract", "caller_controls")


def _report_is_triaged(fields: dict) -> bool:
    """True iff the report carries at least one structured reach field.

    The harness fills Surface / Trigger source / Caller contract / Caller
    controls into a structured REPORT.md during triage. A bare crash dir
    (e.g. a benchmark `model-direct` workspace, or any un-triaged dir fed
    straight to `bin/reachability`) carries none of them. reachability uses
    this to decide whether the external-caller probe may rescue a missing
    Surface field — see _classify_surface."""
    return any(
        str(fields.get(key, "") or "").strip() for key in _TRIAGE_REACH_FIELDS
    )


def classify_surface(fields: dict, reach: dict) -> tuple[str, str]:
    """Resolve the surface tier label + reason from the report fields. The tier
    feeds severity through CVSS AV/UI and Environmental metrics. The external-
    caller probe (`reach`) is not consulted: prevalence is prioritisation
    metadata, not a surface characteristic (see _environmental_requirement)."""
    return _classify_surface(
        fields.get("surface", ""), fields.get("boundary", ""),
        fields.get("_report_text", ""),
        _report_is_triaged(fields),
    )


# ── Reproduction facts ───────────────────────────────────────────────────
#
# Reproducer evidence feeds the standard Threat metric E. Cluster size remains
# a verification/priority fact because CVSS v4.0 has no cluster-confirmation
# metric.


def _repro_facts(report_text: str, fields: dict, cluster_size: int,
                 report_dir: Path | None = None) -> list[str]:
    """Human-readable reproduction/verification facts for the rationale
    section. Descriptive only — never feeds the CVSS score."""
    facts: list[str] = []
    rate = _parse_repro_rate(report_text, fields)
    if rate is not None:
        n, d = rate
        facts.append(f"reproduction rate {n}/{d}")
    if cluster_size >= 2:
        facts.append(f"cluster of {cluster_size} reports")
    if report_dir is not None:
        have_san = (any((report_dir / n).is_file() for n in ("sanitizer.txt", "asan.txt"))
                    or any(report_dir.glob("*.asan.txt")))
        have_tc = any(report_dir.glob("testcase*")) or any(report_dir.glob("poc*"))
        if have_san and have_tc:
            facts.append("testcase + sanitizer log on disk")
        elif have_san:
            facts.append("sanitizer log on disk")
        elif have_tc:
            facts.append("testcase on disk")
    return facts


# ── Report-field extraction ──────────────────────────────────────────────


_TABLE_FIELD_RE = re.compile(
    r"^\|\s*(?P<key>[A-Za-z][A-Za-z0-9 _-]+?)\s*\|\s*(?P<val>.*?)\s*\|\s*$"
)
_BARE_FIELD_RE = re.compile(
    r"^(?P<key>[A-Za-z][A-Za-z0-9 _-]+?)\s*:\s*(?P<val>.+?)\s*$"
)
_FIELD_KEYS = {
    "surface", "trigger source", "caller contract", "caller controls",
    "trusted caller actions", "parameter control", "reproduction rate",
    "boundary", "primitive", "class", "advisory",
}


def extract_report_fields(report_text: str, report_dir: Path | None = None) -> dict:
    """Pull the structured fields the harness emits into REPORT.md.

    Reads two shapes the templates write:
      * markdown table rows: ``| Surface | library-api — ... |``
      * bare-label lines:    ``Surface: library-api``
    First win is kept (the table is rendered first), so a stray bare line
    later in the narrative cannot override the canonical table value.

    If a sidecar ``.llm_fields.json`` exists in ``report_dir``, its values
    are merged in as a *fallback* — they fill only the fields the report
    left blank. The agent-authored Fields table is always authoritative.
    This is the LLM hybrid pass: an inexpensive single-shot LLM call
    classifies the report into the enums the scorer understands (Surface
    tier, Primitive class, Caller controls/contract) when the agent did
    not write them. Scoring stays deterministic from the resulting field
    values.
    """
    out: dict[str, str] = {}
    for raw in report_text.splitlines():
        m = _TABLE_FIELD_RE.match(raw)
        if m:
            key = m.group("key").strip().lower()
            if key in _FIELD_KEYS and key not in out:
                val = m.group("val").strip()
                if val and val not in ("Value", "—", "-"):
                    out[key] = val
            continue
        m = _BARE_FIELD_RE.match(raw)
        if m:
            key = m.group("key").strip().lower()
            if key in _FIELD_KEYS and key not in out:
                val = m.group("val").strip()
                if val and val not in ("—", "-"):
                    out[key] = val

    fields = {
        "surface":           out.get("surface", ""),
        "trigger_source":    out.get("trigger source", ""),
        "caller_contract":   out.get("caller contract", ""),
        "caller_controls":   out.get("caller controls", ""),
        "trusted_caller_actions": out.get("trusted caller actions", ""),
        "parameter_control":  out.get("parameter control", ""),
        "reproduction_rate": out.get("reproduction rate", ""),
        "boundary":          out.get("boundary", ""),
        "primitive_field":   out.get("primitive", ""),
        "class_field":       out.get("class", ""),
        "advisory":          out.get("advisory", ""),
    }
    if report_dir is not None:
        _merge_llm_fields_sidecar(report_dir, fields)
        # Triage's machine-readable contract flag. The report-visible
        # ``## Contract concern`` section is authoritative when present, but
        # the sidecar is an independent trigger so a bundle that was flagged
        # by an older triage (sidecar only) — or whose section was dropped by
        # a later report regeneration — still derives Environmental MAT:P
        # rather than silently scoring as if no concern existed.
        if (report_dir / ".contract-flagged").is_file():
            fields["_contract_flagged"] = "1"
    return fields


# Mapping from LLM-sidecar JSON keys to internal field names. Both the
# JSON key set and the enum values are documented in lib/triage.sh
# alongside the prompt. The sidecar can also carry free-form text — e.g.
# the LLM may emit `surface: "library-api — Ghost members public API"`
# which is merged verbatim (the same prose an agent would write).
_LLM_FIELD_SIDECAR_KEYS = (
    ("surface",         "surface"),
    ("primitive",       "primitive_field"),
    ("trigger_source",  "trigger_source"),
    ("caller_contract", "caller_contract"),
    ("caller_controls", "caller_controls"),
    ("trusted_caller_actions", "trusted_caller_actions"),
    ("parameter_control", "parameter_control"),
    ("boundary",        "boundary"),
    ("class",           "class_field"),
    ("advisory",        "advisory"),
)


def _merge_llm_fields_sidecar(report_dir: Path, fields: dict) -> None:
    """If ``.llm_fields.json`` exists alongside the report, fill blanks
    in ``fields`` from it. Existing (agent-authored) values are never
    overridden — the LLM pass is a fallback only, so agents that emit
    proper fields remain authoritative."""
    sidecar = report_dir / ".llm_fields.json"
    if not sidecar.is_file():
        return
    try:
        data = json.loads(sidecar.read_text("utf-8", errors="replace"))
    except (OSError, ValueError):
        return
    if not isinstance(data, dict):
        return
    for sidecar_key, internal_key in _LLM_FIELD_SIDECAR_KEYS:
        if fields.get(internal_key):
            continue  # agent value wins
        v = data.get(sidecar_key)
        if isinstance(v, str) and v.strip():
            fields[internal_key] = v.strip()


_CLUSTER_SIZE_RE = re.compile(r"\((\d+)\s+reports?\b", re.IGNORECASE)


def _detect_cluster_size(report_text: str) -> int:
    """Pull cluster size from the report's Cluster row.

    Two shapes the harness writes:
      | Cluster | CL-abc123 (singleton)                |
      | Cluster | CL-abc123 (4 reports: id1, id2, ...) |
    Falls back to 1 (singleton) when nothing parseable is found.
    """
    for raw in report_text.splitlines():
        m = _TABLE_FIELD_RE.match(raw)
        if not m:
            continue
        if m.group("key").strip().lower() != "cluster":
            continue
        val = m.group("val")
        n = _CLUSTER_SIZE_RE.search(val)
        if n:
            return max(1, int(n.group(1)))
        return 1
    return 1


# ── Top-level scorer ─────────────────────────────────────────────────────


def compute_severity(report_text: str, reachability: dict | None,
                     cluster_size: int = 1, report_dir: Path | None = None) -> dict:
    """Score one report's severity as a CVSS v4.0 score.

    Steps, each a pure mapping:
      1. classify the crash into a primitive class (detect_primitive),
      2. classify the surface tier (classify_surface),
      3. derive CVSS Base/Threat/Environmental metrics (_cvss4_metrics),
      4. score with the vendored reference scorer (lib/cvss4),
      5. return the score with the CVSS nomenclature (B/BT/BE/BTE).

    Cluster size is returned as a descriptive verification fact and drives
    triage priority elsewhere; CVSS v4.0 has no cluster-confirmation metric.

    Returns a dict whose contract for downstream tools is: ``level`` (the
    CVSS qualitative band) and ``score`` (the CVSS v4.0 score, a float, or
    None when the primitive is unclassified).
    """
    fields = extract_report_fields(report_text, report_dir=report_dir)
    # Pass the report text through so the surface classifier can detect
    # dev/test paths in the narrative even when the Surface field is unset.
    fields["_report_text"] = report_text

    # Primitive: prefer a structured Primitive field that names a known class
    # (the LLM hybrid pass writes this) when the narrative detector fell
    # through to "unknown" or matched only a prose-regex web/recon class. A
    # precise sanitizer-class match (ASan / UBSan / TSan) is never overridden.
    prim_key, prim_label = detect_primitive(report_text)
    # A precise ASan/UBSan/TSan class match is authoritative — never overridden
    # or demoted below.
    sanitizer_authoritative = prim_key != "unknown" and prim_key not in _NARRATIVE_ONLY_PRIMITIVES
    primitive_field = (fields.get("primitive_field") or "").strip().lower()
    if primitive_field in CVSS4_CLASS and primitive_field != "unknown":
        if prim_key == "unknown" or prim_key in _NARRATIVE_ONLY_PRIMITIVES:
            prim_key = primitive_field
            prim_label = primitive_field.replace("_", " ")
    elif fields.get("class_field"):
        class_key, class_label = detect_primitive(fields["class_field"])
        if class_key in CVSS4_CLASS and (prim_key == "unknown" or prim_key in _NARRATIVE_ONLY_PRIMITIVES):
            prim_key = class_key
            prim_label = class_label

    # A sidecar/narrative HIGH-IMPACT primitive (memory-corruption or
    # disclosure) that no sanitizer class confirmed AND that an on-disk
    # sanitizer run actively CONTRADICTS (ran clean, no crash) must not score
    # code-execution impact — that is an unverified model claim, which is a
    # product non-goal. Demote to unclassified (no CVSS vector). ASan-derived
    # classes are authoritative (bypassed), and a pure-static finding with no
    # sanitizer run is untouched (it has no clean-run artifact), so a real
    # code-review lead keeps its vector and is graded down through E:U instead.
    if (not sanitizer_authoritative
            and prim_key in _HIGH_IMPACT_PRIMITIVES
            and (_sanitizer_ran_clean(report_dir) or _probe_ran_clean_text(report_text))):
        prim_label = f"{prim_label} (unconfirmed: sanitizer ran clean)"
        prim_key = "unknown"

    reach_data = reachability or {"services": {}, "external_callers": 0, "vendored_copies": 0}
    surface_label, surface_reason = classify_surface(fields, reach_data)
    # A crash that faults inside the audit harness/driver with no target frame
    # anywhere in the report is not a target vulnerability — score it as the
    # internal audit surface (non-shipping → modified impacts:N), which floors
    # the impact instead of crediting it as a library-popular AV:N crash. Only
    # overrides a shipping surface; an already-internal/dev tier is unchanged.
    if surface_label not in NON_SHIPPING_SURFACES and _crash_is_harness_rooted(report_text):
        surface_label = "internal"
        surface_reason = ("crash faults in the audit harness/driver with no target-library "
                          "frame anywhere in the report — harness-rooted, not a target bug")
    concern, concern_note = _contract_concern(fields)

    metrics, derivation = _cvss4_metrics(prim_key, surface_label, fields, reach_data,
                                         concern, report_dir)
    repro_facts = _repro_facts(report_text, fields, cluster_size, report_dir)
    non_shipping = surface_label in NON_SHIPPING_SURFACES

    if metrics is None:
        # Unclassified crash — no CVSS vector. Honest placeholder; downstream
        # rank is 0 (sorts below any scored finding).
        return {
            "level": "Unknown",
            "score": None,
            "cvss": None,
            "primitive": prim_label,
            "primitive_key": prim_key,
            "surface_label": surface_label,
            "surface_reason": surface_reason,
            "derivation": derivation,
            "non_shipping": non_shipping,
            "repro_facts": repro_facts,
            "cluster_size": cluster_size,
            "fields_used": {k: v for k, v in fields.items() if not k.startswith("_")},
        }

    base_metrics = cvss4.base_metrics(metrics)
    base_score = cvss4.score(base_metrics)
    base_vector = cvss4.vector(base_metrics)
    cvss_score = cvss4.score(metrics)
    cvss_vector = cvss4.vector(metrics)
    cvss_rating = cvss4.rating(cvss_score)
    cvss_name = cvss4.nomenclature(metrics)

    return {
        "level": cvss_rating,
        "score": cvss_score,
        "cvss": {
            "vector": cvss_vector,
            "score": cvss_score,
            "rating": cvss_rating,
            "nomenclature": cvss_name,
            "base_vector": base_vector,
            "base_score": base_score,
            "base_rating": cvss4.rating(base_score),
        },
        "primitive": prim_label,
        "primitive_key": prim_key,
        "metrics": metrics,
        "derivation": derivation + ([concern_note] if concern_note else []),
        "surface_label": surface_label,
        "surface_reason": surface_reason,
        "non_shipping": non_shipping,
        "repro_facts": repro_facts,
        "cluster_size": cluster_size,
        "fields_used": {k: v for k, v in fields.items() if not k.startswith("_")},
    }


# ─── Report mode: rewrite Severity + Reachability section ─────────────────


REACH_HEADING = "## Reachability — external callers"
SEV_HEADING = "## Severity rationale"


# Match an identifier that is *immediately* followed by `(`, with optional
# backticks and whitespace in between. This is the call-shape that matters —
# struct fields and bytecode opcodes (start_subject, OP_CBRA) lack the `(`
# and so are correctly excluded. The backtick form (``ident()``) catches the
# common markdown rendering in reports.
_CALL_RE = re.compile(r"`?([a-zA-Z_][a-zA-Z0-9_]{3,})`?\s*\(")
# Library-shaped identifier. Two conventions are accepted everywhere:
#   * snake_case with at least one underscore — pcre2_match, BIO_new, EVP_DigestInit
#   * lowerCamelCase — at least two lowercase chars, then an uppercase letter,
#     then more chars — xmlShellReadline, xmlConvertSGMLCatalog, htmlNewDoc
# Plain lowercase identifiers (usershell, malloc, printf) are rejected: they
# rarely correspond to externally-callable library APIs and add probe noise.
# Plain PascalCase starting with an uppercase letter (FooBar) is accepted
# only for the languages whose *externally-callable functions* are
# conventionally PascalCase (see _PASCAL_OK_LANGUAGES). ALL_CAPS macros stay
# rejected via _MACRO_SYMBOL_RE.
_LIB_SYMBOL_RE = re.compile(
    r"^(?:"
    r"[a-zA-Z][a-zA-Z0-9]*_[a-zA-Z0-9_]+"
    r"|"
    r"[a-z][a-z0-9]+[A-Z][a-zA-Z0-9]+"
    r")$"
)
# PascalCase with at least one lowercase letter (NewDecoder, ParseDocument).
_PASCAL_SYMBOL_RE = re.compile(r"^[A-Z][a-zA-Z0-9]*[a-z][a-zA-Z0-9]*$")
# Languages whose public, externally-callable API names are conventionally
# PascalCase. Go exports are PascalCase by definition; Java/Kotlin/Swift/JS/TS
# public methods commonly are too. Rust (snake_case fns; PascalCase = types),
# Python (snake_case fns; PascalCase = classes), and PHP/Ruby are deliberately
# EXCLUDED: there a PascalCase token is a type/class name, so probing it would
# search type *definitions*, not callers, inflating the count. Those languages
# still match snake_case / lowerCamelCase via _LIB_SYMBOL_RE. Tokens are
# code-search language names (see _SEARCH_LANGUAGE / _detect_target_language).
_PASCAL_OK_LANGUAGES = frozenset({
    "go", "java", "kotlin", "swift", "javascript", "typescript",
})


def _symbol_shape_ok(tok: str, language: str = "c") -> bool:
    """True when `tok` looks like an externally-callable API name for the
    target's language."""
    if _LIB_SYMBOL_RE.match(tok):
        return True
    if language.lower() in _PASCAL_OK_LANGUAGES:
        return bool(_PASCAL_SYMBOL_RE.match(tok))
    return False
_SYMBOL_STOPLIST = {
    "entry", "location", "trigger", "impact", "error", "class", "type",
    "result", "size", "byte", "bytes", "addresssanitizer", "heap", "stack",
    "global", "buffer", "overflow", "value", "offset", "false", "true",
    "none", "null", "summary", "classification", "reproduction", "candidate",
    "reachability", "data", "flow", "trace",
}

_RUNTIME_SYMBOL_RE = re.compile(
    r"^(?:_?asan_|__asan|__sanitizer|__interceptor|asan_interceptors)",
    re.IGNORECASE,
)
_MACRO_SYMBOL_RE = re.compile(r"^[A-Z0-9_]+$")
# ASan frame parsing, the runtime/libc/sanitizer ignore filter, and crash-state
# frame selection now live in lib/stack_frames (+ lib/clusterfuzz_stacktrace) —
# the same pipeline the dedup signature uses. _extract_symbols_from_asan calls
# into it rather than re-deriving its own ASan regexes here.


def _symbol_token_ok(tok: str, language: str = "c") -> bool:
    """Shared probe-symbol filter: drops runtime/macro/stop-listed tokens and
    anything that fails the library-symbol shape for `language`."""
    if _RUNTIME_SYMBOL_RE.search(tok):
        return False
    if _MACRO_SYMBOL_RE.match(tok):
        return False
    if tok.lower() in _SYMBOL_STOPLIST:
        return False
    return _symbol_shape_ok(tok, language)


def _extract_symbols_from_report(report_text: str, language: str = "c") -> list[str]:
    """Best-effort extraction of public API entry-point identifiers.

    Hard rule: an identifier is only considered if it appears with ``(``
    directly after it (with optional backticks/whitespace). That rules out
    struct-field references like ``re->top_bracket`` and bytecode opcodes
    like ``OP_CBRA`` that are common in crash-report prose but are not
    callable symbols.

    `language` widens the accepted identifier shape for non-C targets
    (PascalCase Go exports etc.) — see _symbol_shape_ok.

    Two-tier scanning order so Entry/Location lines are mined first:
      tier 1: lines beginning with Entry: or Location:
      tier 2: data-flow arrow lines (``→``, ``->``)
      tier 3: any other line with a call-shape identifier

    Returns up to 5 symbols in discovery order. The cap protects backends
    from a noisy report producing dozens of throwaway probes.
    """
    out: list[str] = []
    seen: set[str] = set()

    tier1: list[str] = []
    tier2: list[str] = []
    tier3: list[str] = []
    for raw in report_text.splitlines():
        s = raw.strip()
        if re.match(r"^-?\s*\*{0,2}(Entry|Location)\*{0,2}\s*:", s, re.IGNORECASE):
            tier1.append(s)
            continue
        if "→" in s or "->" in s:
            tier2.append(s)
            continue
        if _CALL_RE.search(s):
            tier3.append(s)

    for line in tier1 + tier2 + tier3:
        for m in _CALL_RE.finditer(line):
            tok = m.group(1)
            if tok in seen:
                continue
            if not _symbol_token_ok(tok, language):
                continue
            seen.add(tok)
            out.append(tok)
            if len(out) >= 5:
                return out
    return out


def _entry_symbol_from_report(report_text: str, language: str = "c") -> str | None:
    """First public entry-point symbol from an explicit ``Entry:`` report line.

    These lines are the report author's structured claim about how a normal
    caller reaches the issue, so they are a better caller-popularity signal
    than an internal fault frame when present. Only call-shaped identifiers are
    accepted, using the same shape/stop-list as general report extraction.
    """
    for raw in (report_text or "").splitlines():
        s = raw.strip()
        if not re.match(r"^-?\s*\*{0,2}Entry\*{0,2}\s*:", s, re.IGNORECASE):
            continue
        for m in _CALL_RE.finditer(s):
            tok = m.group(1)
            if _symbol_token_ok(tok, language):
                return tok
    return None


# Crash-state symbols are a fallback when no caller-entry symbol can be
# identified. Normal sanitizer-backed reports use _crash_entrypoint_symbol
# below so caller popularity is measured at the public/reachable entry point,
# not the internal fault chain. We still keep this crash-state extractor for
# older sparse reports because it is safer than mining free-text prose full of
# internal helpers and generated scoring labels.
#
# How many fallback frames: the crash site (#0) plus its immediate caller.
# ClusterFuzz caps crash state at 3 frames; we stay below that to bound queries
# when the better entrypoint path is unavailable.
CRASH_STATE_PROBE_FRAMES = 2


def _frame_probe_symbol(frame: stack_frames.StackFrame, language: str = "c") -> str | None:
    parts = frame.state_function.split("::")
    leaf = parts[-1].strip()
    # Shape filters apply to the bare callee name (the qualifier is just a
    # disambiguator).
    if not leaf or not _symbol_token_ok(leaf, language):
        return None
    # Probe form: method + immediate enclosing class when present.
    return "::".join(p.strip() for p in parts[-2:]) if len(parts) >= 2 else leaf


def _extract_symbols_from_asan(asan_text: str, language: str = "c") -> list[str]:
    """Reachability symbols taken from the crash state's top frames.

    Frame parsing, the runtime/libc/sanitizer/std-lib/main ignore filter, and
    function-name normalization are delegated to lib/stack_frames — the same
    crash-state pipeline the dedup signature uses — so a C++ frame like
    ``sampledb::Engine::Store::set_blob(unsigned int, std::__1::vector<...>)``
    is normalized to ``sampledb::Engine::Store::set_blob``.

    The probe keeps **one level of the enclosing scope** — ``Store::set_blob``,
    not the bare leaf ``set_blob``. A bare C++ method name is far too general
    for code search: ``set_blob`` / ``parse_id`` collide with thousands of
    unrelated projects, inflating the external-caller count with noise. One
    qualifier level is distinctive enough to suppress those collisions while
    still matching a genuine external reuse of the class; the fully qualified
    path (``sampledb::Engine::Store::set_blob``) would be too narrow — it only
    ever matches the target itself. C symbols have no ``::`` and probe as-is
    (``pcre2_match``), so they are unaffected.

    The leaf (callee) name is held to the same library-symbol shape and
    stop-list as report-prose symbols so macro/runtime tokens are dropped.
    Returns at most CRASH_STATE_PROBE_FRAMES symbols.
    """
    out: list[str] = []
    seen: set[str] = set()
    # Pull the full crash state (≤ MAX_CRASH_STATE_FRAMES) and keep the first
    # CRASH_STATE_PROBE_FRAMES whose leaf survives the symbol-shape filter, so a
    # leading frame whose leaf is not library-shaped (e.g. ``run``) does not
    # cost us a usable probe.
    for frame in stack_frames.interesting_frames(
        asan_text, want=stack_frames.MAX_CRASH_STATE_FRAMES
    ):
        probe = _frame_probe_symbol(frame, language)
        if not probe:
            continue
        if probe in seen:
            continue
        seen.add(probe)
        out.append(probe)
        if len(out) >= CRASH_STATE_PROBE_FRAMES:
            break
    return out


def _primary_sanitizer_frames(sanitizer_text: str) -> list[stack_frames.StackFrame]:
    """Primary fault-stack frames only, excluding allocation/free context.

    ``lib/stack_frames`` intentionally builds the ClusterFuzz crash state and
    may include UAF context frames after the fault stack for deduplication. For
    caller-popularity scoring we need the normal call path into the fault, not
    "freed by" / "previously allocated by" context, so this parser stops at the
    first secondary-context marker.
    """
    frames: list[stack_frames.StackFrame] = []
    fallback_frames: list[stack_frames.StackFrame] = []
    in_report = False

    def _context_starts(line: str) -> bool:
        s = line.strip().lower()
        if not s:
            return False
        if s.startswith("summary:"):
            return True
        if s.startswith("address "):
            return True
        if s.startswith(("shadow bytes", "hint:", "register values:")):
            return True
        if any(marker.lower() in s for marker in stack_frames.STATE_STOP_MARKERS):
            return True
        # MSan origin stacks: every origin description starts with this
        # prefix ("… created by a heap allocation/deallocation/argument …").
        if s.startswith("uninitialized value was created"):
            return True
        # TSan second access stack: "[Previous ][atomic ]read/write of size N
        # at 0x… by thread T1:". The *first* access header precedes any frame,
        # so this only ever cuts the secondary access stack.
        if re.match(r"(?:previous )?(?:atomic )?(?:read|write) of size \d+", s):
            return True
        return (
            "freed by thread" in s
            or "previously allocated by" in s
            or "allocated by thread" in s
            or ("created by" in s and "thread" in s)
        )

    for line in (sanitizer_text or "").splitlines():
        if re.search(r"\b(?:ERROR|WARNING):\s+(?:Address|HWAddress|Memory|Thread)Sanitizer\b", line):
            in_report = True
            frames = []
            continue
        frame = stack_frames.parse_asan_frame(line)
        if not in_report:
            if fallback_frames and _context_starts(line):
                break
            if frame is not None:
                fallback_frames.append(frame)
            continue
        if frames and _context_starts(line):
            break
        if frame is not None:
            frames.append(frame)

    raw = frames or fallback_frames
    return [frame for frame in raw if not stack_frames.is_ignored_frame(frame)]


# Driver/entry functions that mark a harness frame rather than target code.
_HARNESS_DRIVER_FUNCS = frozenset({"main", "llvmfuzzertestoneinput"})
# A source file whose name marks it as the audit harness/driver (agents write
# `*_harness.c` / `harness.c`), not the target library under audit.
_HARNESS_FILE_RE = re.compile(r"(?:^|[\\/_-])harness[\w-]*\.[ch]\w*\b", re.IGNORECASE)
# A `file.ext:line` location (real source) vs a bare module offset such as
# `(dyld:arm64e+0x..)`, which is a system/runtime frame, not target source.
_SOURCE_LOC_RE = re.compile(r"[\w.+-]+\.\w+:\d+")


def _frame_is_harness_driver(frame: stack_frames.StackFrame) -> bool:
    """A fault frame that belongs to the audit harness/driver, not the target."""
    if (frame.function or "").strip().lower() in _HARNESS_DRIVER_FUNCS:
        return True
    return bool(_HARNESS_FILE_RE.search(frame.location or ""))


def _frame_is_target_source(frame: stack_frames.StackFrame) -> bool:
    """A fault frame in real source that is neither the harness nor a
    system/runtime frame — i.e. the target library (or a dependency)."""
    if stack_frames.is_ignored_frame(frame):
        return False
    if _frame_is_harness_driver(frame):
        return False
    return bool(_SOURCE_LOC_RE.search(frame.location or ""))


def _crash_is_harness_rooted(report_text: str) -> bool:
    """True when the crash faults in the audit harness/driver itself and the
    target library is absent from the ENTIRE sanitizer report.

    Conservative by design — severity has to stay trustworthy for the
    benchmark. A crash is only treated as harness-rooted when BOTH:

      * the primary fault leaf (#0) is a harness/driver frame, AND
      * no target-source frame appears anywhere in the report, including the
        "freed by" / "allocated by" / origin context stacks.

    The second clause preserves a genuine *library* lifetime bug whose final
    dereference surfaces in the caller but whose freed/allocated memory is
    library-owned: such a report carries a library frame in its context stack
    and is scored normally (as a caller-contract concern), not zeroed. This is
    the case both reviewers flagged where a bare "#0 is harness ⇒ reject" rule
    would wrongly under-score a real bug.

    Note we read the raw leaf frame directly rather than via
    ``_primary_sanitizer_frames`` — that helper applies ClusterFuzz's ignore
    rules, which drop ``^main`` (exactly the harness entry we need to see).
    """
    leaf = None
    in_report = False
    for line in (report_text or "").splitlines():
        # Any sanitizer headline opens the trace (shared signature, so
        # UBSan/TSan/MSan are recognised too, not only ASan/HWASan).
        if not in_report and stack_frames.has_sanitizer_diagnostic(line):
            in_report = True
            continue
        if in_report and leaf is None:
            frame = stack_frames.parse_asan_frame(line)
            if frame is not None:
                leaf = frame
                break
    if leaf is None or not _frame_is_harness_driver(leaf):
        return False
    for line in (report_text or "").splitlines():
        frame = stack_frames.parse_asan_frame(line)
        if frame is not None and _frame_is_target_source(frame):
            return False
    return True


def _crash_entrypoint_symbol(asan_text: str, language: str = "c",
                             report_text: str = "") -> str | None:
    """Caller entry point used for external-caller popularity.

    Prefer an explicit report ``Entry:`` line. Otherwise use the deepest
    interesting frame in the primary sanitizer fault stack, walking the full
    primary stack rather than the capped ClusterFuzz crash state. Secondary
    context stacks (allocation/free, MSan value origin, TSan second access,
    thread creation) are ignored so cleanup or bookkeeping APIs do not become
    the caller-popularity symbol.
    """
    sym = _entry_symbol_from_report(report_text, language)
    if sym:
        return sym
    for frame in reversed(_primary_sanitizer_frames(asan_text)):
        probe = _frame_probe_symbol(frame, language)
        if probe:
            return probe
    return None


def _no_symbols_reachability(ignore: list[str], symbols: list[str] | None = None,
                             status: str = "no_symbols",
                             reason: str = "no public API symbols extracted") -> dict:
    symbols = symbols or []
    return {
        "schema_version": 2,
        "queried_at": datetime.now(timezone.utc).isoformat(),
        "status": status,
        "symbols": symbols,
        "ignore": ignore,
        "external_callers": 0,
        "external_caller_repos": 0,
        "external_caller_hits": [],
        "vendored_copies": 0,
        "vendored_copy_hits": [],
        "services_responding": [],
        "services": {
            svc: {
                "status": "not_run",
                "hits": [],
                "vendored": [],
                "count": 0,
                "vendored_count": 0,
                "errors": [{"symbol": symbols[0] if symbols else "", "error": reason}],
            }
            for svc in SERVICES
        },
    }


def _asan_text_has_dev_path(asan_text: str) -> bool:
    return bool(re.search(r"(^|[ /])(maint|test|tests|testing|fuzz|fuzzer|bench|example|examples)/", asan_text))


def _format_reachability_section(reach: dict) -> str:
    lines = [REACH_HEADING, ""]
    # Each `_…_` italic note is its own paragraph (blank-line separated)
    # so render-md doesn't fold them into a single line. Folded, the
    # second underscore-pair (e.g. `_Symbols: cli_production…_`) is
    # broken by the inner `_` in the symbol names and the literal
    # underscores leak through to the rendered HTML.
    notes: list[str] = [f"_Probed at: {reach.get('queried_at', '?')}_"]
    if reach.get("status") == "no_symbols":
        notes.append("_Status: no public API symbols extracted; external search was not run._")
    elif reach.get("status") == "local_symbols_only":
        notes.append("_Status: local ASan frame symbols only; external search skipped for dev/test surface._")
    elif reach.get("status") == "external_skipped":
        reason = ""
        for block in (reach.get("services") or {}).values():
            errors = block.get("errors") or []
            if errors and errors[0].get("error"):
                reason = errors[0]["error"]
                break
        if reason:
            notes.append(f"_Status: external caller search skipped ({reason}); severity uses local report fields only._")
        else:
            notes.append("_Status: external caller search skipped; severity uses local report fields only._")
    if reach.get("symbols"):
        notes.append(f"_Symbols: {', '.join(reach['symbols'])}_")
    if reach.get("language"):
        notes.append(f"_Language filter: {reach['language']}_")
    if reach.get("match_mode") == "entrypoint":
        entry = reach.get("entry_symbol")
        entry_note = f" (`{entry}`)" if entry else ""
        notes.append(
            "_Match mode: entrypoint — a caller matches the public entry "
            f"point{entry_note} any-frame; the internal crash-state chain is "
            "not required (a real dependant never contains it)._"
        )
    elif reach.get("match_mode") == "all-frames":
        notes.append(
            "_Match mode: all-frames — no public entry point identified, so a "
            "caller must match every crash-state frame in one file "
            "(collision-resistant)._"
        )
    if reach.get("ignore"):
        notes.append(f"_Ignore filter: {', '.join(reach['ignore'])}_")
    lines.append("\n\n".join(notes))
    lines.append("")
    n_external = reach.get("external_callers", 0)
    n_vendored = reach.get("vendored_copies", 0)
    frame_note = {
        "entrypoint": " + entrypoint", "all-frames": " + all-frames",
    }.get(reach.get("match_mode"), "")
    lines.append(
        f"**External callers (genuine, after ignore + vendor{frame_note} filter): {n_external}**"
    )
    if n_vendored:
        lines.append(
            f"**Vendored copies of upstream source (ship the bug, do not call): {n_vendored}**"
        )
    lines.append("")
    lines.append("| Backend | Status | Genuine hits | Vendored copies |")
    lines.append("|---------|--------|--------------|-----------------|")
    for svc in SERVICES:
        e = (reach.get("services") or {}).get(svc, {})
        status = e.get("status", "?")
        n = e.get("count", 0)
        v = e.get("vendored_count", 0)
        lines.append(f"| {svc} | {status} | {n} | {v} |")
    errors_by_service = {
        svc: (reach.get("services") or {}).get(svc, {}).get("errors") or []
        for svc in SERVICES
    }
    if any(errors_by_service.values()):
        lines.append("")
        lines.append("Backend errors:")
        for svc in SERVICES:
            errors = errors_by_service.get(svc) or []
            if not errors:
                continue
            shown = []
            for err in errors[:3]:
                sym = err.get("symbol", "?") if isinstance(err, dict) else "?"
                msg = err.get("error", "unknown") if isinstance(err, dict) else str(err)
                shown.append(f"{sym}: {msg}")
            suffix = "" if len(errors) <= 3 else f"; +{len(errors) - 3} more"
            lines.append(f"- `{svc}`: " + "; ".join(shown) + suffix)
    hits = reach.get("external_caller_hits") or []
    if hits:
        lines.append("")
        lines.append("Top genuine callers:")
        for h in hits[:10]:
            repo = h.get("repo", "")
            path = h.get("path", "")
            syms = h.get("matched_symbols") or ([h["matched_symbol"]] if h.get("matched_symbol") else [])
            sym_note = f" (symbols: `{', '.join(syms)}`)" if syms else ""
            lines.append(f"- `{repo}` :: `{path}`" + sym_note)
    vhits = reach.get("vendored_copy_hits") or []
    if vhits:
        lines.append("")
        lines.append("Vendored copies (these projects re-include the upstream source):")
        for h in vhits[:5]:
            repo = h.get("repo", "")
            path = h.get("path", "")
            lines.append(f"- `{repo}` :: `{path}`")
        if len(vhits) > 5:
            lines.append(f"- … +{len(vhits) - 5} more vendored copies")
    return "\n".join(lines) + "\n"


def _format_severity_line(sev: dict) -> str:
    """Single-line severity that downstream tools parse.

    Shape (classified):
      - **Severity**: <Level> (CVSS-BTE 4.0: <score> <rating>; <vector>; \
primitive=<class>; surface=<tier>)
    Shape (unclassified):
      - **Severity**: Unknown (unclassified — no CVSS vector)

    The leading ``<Level>`` word and the ``CVSS-* 4.0: <score>`` token are the
    contract downstream tools rely on (cluster-crashes, export-repro,
    render-md). The rest is human-readable rationale.
    """
    cv = sev.get("cvss")
    if cv is None:
        return ("- **Severity**: Unknown (unclassified — no CVSS vector; "
                f"primitive={sev['primitive']})")
    parts = [
        f"{cv.get('nomenclature', 'CVSS-B')} 4.0: {cv['score']} {cv['rating']}",
        cv["vector"],
        f"primitive={sev['primitive']}",
        f"surface={sev['surface_label']}",
    ]
    return f"- **Severity**: {sev['level']} ({'; '.join(parts)})"


def _replace_severity_line(text: str, new_line: str, *, synthesize: bool = True) -> str:
    """Replace the first '- **Severity**: ...' line, or insert under '## Classification'.

    When `synthesize=False`, the function ONLY replaces an existing bullet
    and does not insert / create a stub Classification section if none is
    found. Callers pass `synthesize=False` when the Fields-table Severity
    cell is the authoritative source — synthesizing a duplicate bullet
    (or worse, a stub heading) would undo the slim-shape cleanup that
    recon FIND reports rely on.
    """
    lines = text.splitlines()
    sev_re = re.compile(r"^-\s*\*\*Severity\*\*\s*:")
    for i, line in enumerate(lines):
        if sev_re.match(line):
            lines[i] = new_line
            return "\n".join(lines) + ("\n" if text.endswith("\n") else "")
    if not synthesize:
        return text
    # No existing line — insert after "## Classification".
    for i, line in enumerate(lines):
        if line.strip().lower().startswith("## classification"):
            lines.insert(i + 1, new_line)
            return "\n".join(lines) + ("\n" if text.endswith("\n") else "")
    # Fall back: prepend a stub Classification section.
    stub = ["## Classification", new_line, ""]
    return "\n".join(stub + lines) + ("\n" if text.endswith("\n") else "")


def _format_severity_field(sev: dict) -> str:
    """Fields-table cell: ``<Level> (CVSS-BTE 4.0: <score>)`` or ``Unknown`` when the
    primitive is unclassified. The colon after the version keeps the score from
    reading as a second version number (``4.0 6.0``)."""
    if sev.get("score") is None:
        return "Unknown"
    name = (sev.get("cvss") or {}).get("nomenclature", "CVSS-B")
    return f"{sev['level']} ({name} 4.0: {sev['score']})"


def _replace_structured_field(text: str, field: str, value: str) -> tuple[str, bool]:
    """Replace an existing structured report field. Returns (new_text, changed).

    Agent reports commonly carry a top `| Field | Value |` table plus the
    generated Classification severity line. `bin/reachability` is the owner of
    recomputed severity, so keep the table in sync when that row exists. We do
    not create a new table row here; reports without a structured field already
    have the generated severity line as the single source of truth.

    The bool return lets `update_report` skip the verbose
    `- **Severity**: <level> (auto: …)` bullet when the Fields table already
    carries the canonical row — recon-materialized FINDs use the Fields table
    as the only writer for Severity and would otherwise have a stub
    `## Classification` section synthesized under them on every run.
    """
    lines = text.splitlines()
    wanted = field.lower()
    changed = False
    for i, line in enumerate(lines):
        if not line.startswith("|"):
            continue
        parts = line.split("|")
        if len(parts) < 4 or parts[1].strip().lower() != wanted:
            continue
        old_cell = parts[2]
        new_cell = f" {value} "
        if len(new_cell) < len(old_cell):
            new_cell = new_cell + (" " * (len(old_cell) - len(new_cell)))
        parts[2] = new_cell
        lines[i] = "|".join(parts)
        changed = True
        break
    if not changed:
        bare_re = re.compile(rf"^({re.escape(field)}\s*:\s*).*$", re.IGNORECASE)
        for i, line in enumerate(lines):
            if bare_re.match(line):
                lines[i] = bare_re.sub(lambda m: f"{m.group(1)}{value}", line)
                changed = True
                break
    new_text = "\n".join(lines) + ("\n" if text.endswith("\n") else "")
    return new_text, changed


def _replace_reachability_section(text: str, new_section: str) -> str:
    """Append-or-replace the auto reachability section. Idempotent."""
    if REACH_HEADING in text:
        # Replace existing block: from REACH_HEADING up to next "## " heading or EOF.
        pattern = re.compile(
            r"^" + re.escape(REACH_HEADING) + r".*?(?=^## |\Z)",
            re.MULTILINE | re.DOTALL,
        )
        return pattern.sub(new_section, text, count=1)
    sep = "" if text.endswith("\n") else "\n"
    return text + sep + "\n" + new_section


def _format_severity_section(sev: dict) -> str:
    """Render the severity explainer block.

    Transparency is the point: a reader sees the CVSS 4.0 vector, the score,
    and exactly how each metric was derived from the report's fields — without
    re-running anything. Every line is computed from `sev`, so re-running
    --report regenerates it deterministically.
    """
    lines = [SEV_HEADING, ""]
    cv = sev.get("cvss")
    if cv is None:
        lines.append(
            f"_Severity is the **CVSS v4.0 score**. This crash is "
            f"**unclassified** (primitive={sev['primitive']}), so no CVSS "
            f"vector is derivable and no score is assigned. Classify the "
            f"primitive (set a `Primitive:` field) to score it._"
        )
        lines.append("")
        return "\n".join(lines) + "\n"

    lines.append(
        "_Severity is the **CVSS v4.0 score** — one industry-standard metric, "
        "computed by the vendored FIRST reference scorer. Base metrics come "
        "from the primitive and surface, with Attack Vector/Requirements also "
        "reflecting the trigger's caller-control facts (a trusted local "
        "API/call-sequence reads as AV:L/AT:P). Threat/Environmental metrics "
        "come from reproducibility, caller control, reachability, and local "
        "shipping context. Cluster size remains a priority/verification fact "
        "because CVSS v4.0 has no cluster metric._"
    )
    lines.append("")
    lines.append(f"**{cv.get('nomenclature', 'CVSS-B')} v4.0**: `{cv['vector']}` → **{cv['score']} ({cv['rating']})**")
    lines.append(f"**CVSS-B baseline**: `{cv['base_vector']}` → **{cv['base_score']} ({cv['base_rating']})**")
    lines.append("")
    lines.append("| Metric | Value | Derived from |")
    lines.append("|:-------|:-----:|:-------------|")
    m = sev["metrics"]
    surface_av = _SURFACE_AVUI.get(sev["surface_label"], _SURFACE_AVUI["unknown"])[0]
    if m["AV"] == "L" and surface_av == "N":
        av_from = (f"local API/call-sequence trigger "
                   f"(surface `{sev['surface_label']}` worst-case is AV:N)")
    else:
        av_from = f"surface tier = `{sev['surface_label']}`"
    lines.append(f"| Attack Vector (AV)        | {m['AV']} | {av_from} |")
    lines.append(f"| Attack Complexity (AC)    | {m['AC']} | fixed — not separately modelled |")
    lines.append(f"| Attack Requirements (AT)  | {m['AT']} | intrinsic attack preconditions |")
    lines.append(f"| Privileges Required (PR)  | {m['PR']} | worst case — no auth signal |")
    lines.append(f"| User Interaction (UI)     | {m['UI']} | surface tier |")
    lines.append(f"| Vuln Conf/Integ/Avail     | {m['VC']}/{m['VI']}/{m['VA']} | primitive class = `{sev['primitive_key']}` |")
    lines.append(f"| Subseq Conf/Integ/Avail   | {m['SC']}/{m['SI']}/{m['SA']} | primitive class |")
    if any(k in m for k in ("E", "CR", "IR", "AR", "MAT", "MAV", "MUI", "MVC", "MVI", "MVA", "MSC", "MSI", "MSA")):
        lines.append(f"| Threat Exploit Maturity (E) | {m.get('E', 'X')} | reproducer / exploit evidence |")
        lines.append(f"| Env Requirements (CR/IR/AR) | {m.get('CR', 'X')}/{m.get('IR', 'X')}/{m.get('AR', 'X')} | reachability + local use |")
        env_attack = "/".join(m.get(k, "X") for k in ("MAV", "MAC", "MAT", "MPR", "MUI"))
        lines.append(f"| Env Modified AV/AC/AT/PR/UI | {env_attack} | caller control / local deployment |")
        env_impact = "/".join(m.get(k, "X") for k in ("MVC", "MVI", "MVA", "MSC", "MSI", "MSA"))
        lines.append(f"| Env Modified C/I/A impacts | {env_impact} | local shipping context |")
    lines.append("")
    lines.append(f"**Severity level: {sev['level']}** — CVSS bands: Critical ≥ 9.0, "
                 "High ≥ 7.0, Medium ≥ 4.0, Low ≥ 0.1, None = 0.0.")
    if sev.get("primitive_key") in TRANSIENT_CRASH_PRIMITIVES:
        lines.append("")
        lines.append(
            "> **Recovery: Automatic (`R:A`) — supplemental, score unchanged.** "
            "This is a single-request fatal crash: the process dies on the "
            "malicious input and a supervisor respawns it, so the availability "
            "loss is transient rather than a sustained takedown. CVSS v4.0 "
            "Recovery is a Supplemental metric and does not affect the CVSS-BTE "
            "score, so the availability band above reflects worst-case "
            "(sustained) impact. For a service that respawns per request, read "
            "the operational severity one band lighter than the number."
        )
    if sev.get("non_shipping"):
        lines.append("")
        lines.append(
            f"> **Non-shipping surface represented through Environmental metrics.** This bug lives "
            f"in `{sev['surface_label']}` code (test/maintenance/internal "
            f"harness) that does not ship to end users, so local modified "
            f"impact metrics reduce the CVSS-BTE score without a custom cap."
        )
    facts = sev.get("repro_facts") or []
    if facts:
        lines.append("")
        lines.append("**Verification facts** (not part of severity — triage priority): "
                     + "; ".join(facts) + ".")
    lines.append("")
    lines.append("_Field derivation (each line is a reviewable claim):_")
    for note in sev.get("derivation", []):
        lines.append(f"- {note}")
    return "\n".join(lines) + "\n"


def _strip_auto_sections(text: str) -> str:
    """Remove auto-generated content before re-scoring.

    On every --report run we regenerate the Reachability section, the
    Severity rationale section, AND the `- **Severity**: ... (auto: ...)`
    line. If any of those remain in the input we feed to the classifier,
    their prose (which mentions 'tests/' and 'maint/' as examples, plus
    the last run's reach reasons) loops back as input and trips the
    dev/test path regex on every subsequent run. Strip them first so
    scoring only sees the agent-authored part of the report.
    """
    out = text
    for heading in (REACH_HEADING, SEV_HEADING):
        if heading in out:
            pattern = re.compile(
                r"^" + re.escape(heading) + r".*?(?=^## |\Z)",
                re.MULTILINE | re.DOTALL,
            )
            out = pattern.sub("", out)
    # Drop any auto-generated Severity line(s) — they carry the previous
    # run's reach reasons/vector in their tail prose.
    out = re.sub(
        r"^-\s*\*\*Severity\*\*\s*:.*\((?:auto:|CVSS(?:-[A-Z]+)?\s+4\.0:).*$",
        "", out, flags=re.MULTILINE,
    )
    return out


def _replace_severity_section(text: str, new_section: str) -> str:
    """Append-or-replace the Severity rationale section. Idempotent."""
    if SEV_HEADING in text:
        pattern = re.compile(
            r"^" + re.escape(SEV_HEADING) + r".*?(?=^## |\Z)",
            re.MULTILINE | re.DOTALL,
        )
        return pattern.sub(new_section, text, count=1)
    sep = "" if text.endswith("\n") else "\n"
    return text + sep + "\n" + new_section


# Reach fields the scorer resolves (from the report, or the LLM sidecar as a
# fallback) and surfaces into the Fields table when a report omits them. This
# makes a model-direct report — whose freeform model author wrote none of these
# and which never ran the harness's per-cell triage — read in the same style as
# a harness crash, where the audit agent authors these rows directly. Display
# labels and order mirror the harness report template. Keyed by the internal
# field name used in severity["fields_used"].
_SURFACED_REACH_FIELDS = (
    ("class_field",     "Class"),
    ("primitive_field", "Primitive"),
    ("surface",         "Surface"),
    ("trigger_source",  "Trigger source"),
    ("caller_contract", "Caller contract"),
    ("caller_controls", "Caller controls"),
    ("trusted_caller_actions", "Trusted caller actions"),
    ("parameter_control", "Parameter control"),
    ("boundary",        "Boundary"),
    ("advisory",        "Advisory"),
)

# A field counts as already present (and is left untouched — agent-authored
# values always win) if it appears as a `| Field | … |` table row OR a bare
# `Field:` line.
_KNOWN_FIELD_LABELS = frozenset({
    "class", "severity", "file", "function", "line", "target",
    "primitive", "surface", "trigger source", "caller contract",
    "caller controls", "trusted caller actions", "parameter control",
    "boundary", "advisory",
})

# A `|` table is the report's Fields table only when a row carries one of these
# identity labels: the `Field` header cell, the always-present Severity/Class
# rows, or a reach label. File/Function/Line/Target are deliberately excluded —
# they double as evidence/stack-table column headers (`| File | Note |`), so
# matching them would mistake an evidence table for the Fields table, either
# suppressing synthesis or appending reach rows into the wrong table.
_FIELDS_TABLE_IDENTITY = frozenset(
    {"field"} | (_KNOWN_FIELD_LABELS - {"file", "function", "line", "target"})
)


def _field_present(text: str, field: str) -> bool:
    wanted = field.lower()
    bare_re = re.compile(rf"^{re.escape(field)}\s*:", re.IGNORECASE)
    for line in text.splitlines():
        if line.startswith("|"):
            parts = line.split("|")
            if len(parts) >= 4 and parts[1].strip().lower() == wanted:
                return True
        elif bare_re.match(line):
            return True
    return False


def _find_fields_table_end(lines: list[str]) -> int:
    """Index of the last row of the report's Fields table — the first
    contiguous run of `|` rows carrying a known structured field label
    (Class/Severity/File/…). Returns -1 when the report has no such table."""
    i, n = 0, len(lines)
    while i < n:
        if lines[i].lstrip().startswith("|"):
            j = i
            has_known = False
            while j < n and lines[j].lstrip().startswith("|"):
                parts = lines[j].split("|")
                if len(parts) >= 3 and parts[1].strip().lower() in _FIELDS_TABLE_IDENTITY:
                    has_known = True
                j += 1
            if has_known:
                return j - 1
            i = j
        else:
            i += 1
    return -1


def _cell(v: str) -> str:
    """Flatten a value to a single Markdown table cell."""
    return " ".join(v.split()).replace("|", r"\|")


def _insert_fields_rows(text: str, rows: list[tuple[str, str]]) -> str:
    """Append `| Field | Value |` rows to the report's Fields table. No-op if
    the report has no such table (callers synthesize one first)."""
    if not rows:
        return text
    lines = text.splitlines()
    end = _find_fields_table_end(lines)
    if end < 0:
        return text
    indent = lines[end][:len(lines[end]) - len(lines[end].lstrip())]
    new = [f"{indent}| {f} | {_cell(v)} |" for f, v in rows]
    lines[end + 1:end + 1] = new
    return "\n".join(lines) + ("\n" if text.endswith("\n") else "")


def _synthesize_fields_table(text: str, severity: dict, used: dict) -> str:
    """Build a `## Fields` table for a report that has none — some model authors
    write bare `Field: value` lines, or omit the fields entirely — so every
    report renders the same tabular style as a harness crash. Rows are the
    scored Severity plus whichever reach fields resolved.

    The table is emitted under a canonical `## Fields` heading (the shape
    `bin/export-repro` and the harness report template both use), and any bare
    `Field: value` lines are left in place: the harness deliberately keeps the
    Fields table duplicated as bare labels below it so downstream regex parsers
    (`bin/export-repro`, `bin/cluster-crashes`, `lib/triage.sh`) keep working,
    and `bin/render-md` hides that duplicate block from HTML. Removing the bare
    labels here would make those fields invisible to export. No-op if there is
    nothing beyond Severity to table (keeps the slim recon template unchanged)."""
    rows: list[tuple[str, str]] = [("Severity", _format_severity_field(severity))]
    for key, label in _SURFACED_REACH_FIELDS:
        v = (used.get(key) or "").strip()
        if v:
            rows.append((label, _cell(v)))
    if len(rows) <= 1:
        return text
    lines = text.splitlines()
    table = ["## Fields", "", "| Field | Value |", "| :---- | :---- |"]
    table += [f"| {f} | {v} |" for f, v in rows]
    # Lead with the Fields section: place it after the first heading, or at the
    # top when the report has no heading.
    idx = 0
    for i, line in enumerate(lines):
        if line.startswith("#"):
            idx = i + 1
            break
    lines[idx:idx] = ["", *table, ""]
    return "\n".join(lines) + ("\n" if text.endswith("\n") else "")


def update_report(report_path: Path, reachability: dict, severity: dict) -> None:
    text = report_path.read_text("utf-8", errors="replace")
    used = severity.get("fields_used") or {}
    # A report with no Fields table (model-direct / bare-label authors) gets one
    # synthesized so it reads like a harness crash; one that already has a table
    # keeps it and only gains the rows it is missing (below).
    if _find_fields_table_end(text.splitlines()) < 0:
        text = _synthesize_fields_table(text, severity, used)
    text, fields_sev_updated = _replace_structured_field(
        text, "Severity", _format_severity_field(severity),
    )
    # Surface the reach fields the scorer used into the Fields table when the
    # report omits them (insert-if-absent; never overwrite an authored row).
    to_add = [
        (label, used[key].strip())
        for key, label in _SURFACED_REACH_FIELDS
        if (used.get(key) or "").strip() and not _field_present(text, label)
    ]
    if to_add:
        text = _insert_fields_rows(text, to_add)
    # Always update an existing `- **Severity**: …` bullet (legacy crash
    # reports rely on the auto-formula being kept in sync), but never
    # synthesize one — that would inject a stub `## Classification`
    # heading into the slim recon-finding template on every run.
    text = _replace_severity_line(
        text, _format_severity_line(severity), synthesize=not fields_sev_updated,
    )
    text = _replace_reachability_section(text, _format_reachability_section(reachability))
    text = _replace_severity_section(text, _format_severity_section(severity))
    report_path.write_text(text, "utf-8")


# ─── Human-readable summary ───────────────────────────────────────────────


def render_human(reach: dict, severity: dict | None = None) -> str:
    out: list[str] = []
    out.append(f"Reachability for: {', '.join(reach['symbols'])}")
    if reach.get("ignore"):
        out.append(f"  Ignore filter: {', '.join(reach['ignore'])}")
    out.append(f"  External callers (genuine):  {reach.get('external_callers', 0)}")
    if reach.get("vendored_copies"):
        out.append(f"  Vendored copies (excluded): {reach['vendored_copies']}")
    for svc in SERVICES:
        e = (reach.get("services") or {}).get(svc, {})
        line = f"  {svc:9s} status={e.get('status', '?'):11s} hits={e.get('count', 0)}"
        if e.get("vendored_count"):
            line += f"  (+{e['vendored_count']} vendored)"
        out.append(line)
    if severity is not None:
        out.append("")
        cv = severity.get("cvss")
        if cv is None:
            out.append(f"Severity: Unknown (unclassified — no CVSS vector; "
                       f"primitive={severity['primitive']})")
        else:
            out.append(f"Severity: {severity['level']} "
                       f"({cv.get('nomenclature', 'CVSS-B')} 4.0: {cv['score']} {cv['rating']})")
            out.append(f"  vector     {cv['vector']}")
            out.append(f"  base       {cv['base_score']} {cv['base_rating']}  {cv['base_vector']}")
            out.append(f"  primitive  {severity['primitive']} ({severity['primitive_key']})")
            out.append(f"  surface    {severity['surface_label']}")
            facts = severity.get("repro_facts") or []
            if facts:
                out.append(f"  verification (priority, not severity): {'; '.join(facts)}")
    return "\n".join(out)


# ─── CLI ──────────────────────────────────────────────────────────────────


def _resolve_target_toml(args: argparse.Namespace,
                         report_dir: Path | None) -> Path | None:
    """Locate the target's output/<slug>/target.toml: from --target if given,
    otherwise by walking up from the report dir. Shared by the ignore-list and
    build-system readers."""
    if args.target:
        candidate = Path.cwd() / "output" / args.target / "target.toml"
        return candidate if candidate.is_file() else None
    if report_dir is not None:
        return _find_target_toml(report_dir)
    return None


def _resolve_ignore(args: argparse.Namespace, report_dir: Path | None) -> list[str]:
    ignore: list[str] = list(args.ignore or [])
    seed_path = _resolve_target_toml(args, report_dir)
    if seed_path is not None:
        for tok in _parse_target_toml_ignore(seed_path):
            if tok not in ignore:
                ignore.append(tok)
    return ignore


def _session_env_value(report_dir: Path | None, key: str) -> str:
    """Read an allowlisted KEY from the nearest .session-env at or above the
    report dir, parsed by the shared target_config.read_session_env.

    bin/audit writes one .session-env per results tree, so the nearest one on
    the direct path up names the exact target even when the output slug differs
    from the target slug (e.g. output/<slug>-<experiment>/). We walk direct
    ancestors only — deliberately NOT tc.find_session_dir, whose sideways
    output/* scan can bind a crash under one results tree to an unrelated
    sibling target's session."""
    if report_dir is None:
        return ""
    for anc in [report_dir.resolve(), *report_dir.resolve().parents]:
        if not (anc / ".session-env").is_file():
            continue
        try:
            return tc.read_session_env(anc).get(key, "").strip()
        except Exception:
            return ""
    return ""


def _authoritative_target_root(args: argparse.Namespace,
                               report_dir: Path | None) -> Path | None:
    """The target source checkout, from sources that name it unambiguously:
    an explicit --target slug, the audit-exported TARGET_ROOT, or the
    TARGET_ROOT recorded in the report tree's .session-env. Unlike the
    slug/path heuristic these never bind the wrong project when the output
    slug differs from the target slug."""
    if args.target:
        candidate = Path.cwd() / "targets" / args.target
        if candidate.is_dir():
            return candidate
    env_root = os.environ.get("TARGET_ROOT", "").strip()
    if env_root and Path(env_root).is_dir():
        return Path(env_root)
    sess_root = _session_env_value(report_dir, "TARGET_ROOT")
    if sess_root and Path(sess_root).is_dir():
        return Path(sess_root)
    return None


def _resolve_repo_type(args: argparse.Namespace, report_dir: Path | None) -> str:
    """Resolve the target's VCS type (git/hg/none) the way the rest of the
    harness does: the authoritative ``TARGET_REPO_TYPE`` the audit exports or
    records in .session-env, else live detection on the authoritative
    TARGET_ROOT (env / .session-env). repo_type is NOT a target.toml field —
    bin/setup-target never seeds it (see lib/workqueue.py and bin/audit, which
    use the same env-or-detect order).

    Deliberately does NOT fall back to the slug/path heuristic: when the
    output slug differs from the target slug, that heuristic can bind the
    wrong project (and its repo type), which would mis-skip or mis-run
    external search. An unresolved target stays no-signal ('') instead."""
    env = os.environ.get("TARGET_REPO_TYPE", "").strip().lower()
    if env:
        return env
    sess = _session_env_value(report_dir, "TARGET_REPO_TYPE").strip().lower()
    if sess:
        return sess
    root = _authoritative_target_root(args, report_dir)
    if root is None:
        return ""
    try:
        return tc.detect_repo_type(root).strip().lower()
    except Exception:
        return ""


# Registry language name → code-search language token. Both Sourcegraph's
# `lang:` filter and `gh search code --language` accept linguist-style names
# (case-insensitively), so one token serves both backends. Only `cpp` needs
# renaming; every other lib/languages.py name is already the linguist name.
_SEARCH_LANGUAGE = {"cpp": "c++"}

# Directory names whose subtrees are NOT the target's own source: build
# output, VCS metadata, and checked-in dependency / vendored trees. Tested
# against the path's parts *relative to the target root*, never as an
# absolute-substring match — a checkout under `/build/...`, or even a tmpdir
# named `build_xxxx`, would otherwise make every path contain "/build" and
# skip the whole tree (observed: language detection collapsing to "c" for a
# Go target under such a path, which then disabled PascalCase probing). The
# vendored names mirror _VENDORED_PREFIX_RE: a Go target with a big
# `third_party/native/*.c` blob must not be language-detected as C.
_SKIP_DIR_PARTS = frozenset({
    "build", ".git", "node_modules",
    "vendor", "vendored", "third_party", "thirdparty", "3rdparty",
    "deps", "contrib", "external",
})

# Header extensions are shared/ambiguous (a .h sits in a C *or* C++ project,
# and the registry assigns .h to C), so they are NEUTRAL for the C-vs-C++
# language vote — only implementation files decide it. Without this, a C++
# library that is mostly headers and a few .cc files would be detected as
# plain C and searched with `lang:c`, missing the real C++ callers.
_HEADER_EXTS = frozenset({".h", ".hh", ".hpp", ".hxx", ".h++"})

# Build systems whose language is native C/C++ — for these the declared
# build_system does not disambiguate C from C++, so we still vote on
# implementation extensions. Every other build_system (cargo→rust, go→go,
# maven/gradle→java, npm→javascript, …) names a language unambiguously and is
# trusted directly.
_NATIVE_SEARCH_LANGS = frozenset({"c", "c++"})


def _is_skipped_path(path: Path, root: Path) -> bool:
    try:
        rel = path.relative_to(root)
    except ValueError:
        rel = path
    return any(part in _SKIP_DIR_PARTS for part in rel.parts)


def _detect_target_language(target_root: Path | None,
                            declared: str = "") -> str:
    """Code-search language token for the target tree.

    `declared` is the linguist token derived from the target's build_system
    (a structured source — lib/languages.py). When it names a non-native
    language it is authoritative and returned directly. Otherwise (native
    C/C++, or no build_system) the language is decided by majority
    *implementation* extension across the target's own tree, with headers
    treated as neutral and vendored/generated subtrees skipped. Defaults to
    "c" when nothing resolves, preserving the historical filter."""
    if declared and declared not in _NATIVE_SEARCH_LANGS:
        return declared
    if target_root is None:
        return declared or "c"
    tally: dict[str, int] = {}
    try:
        for path in target_root.rglob("*"):
            if _is_skipped_path(path, target_root):
                continue
            ext = path.suffix.lower()
            if ext in _HEADER_EXTS:
                continue
            lang = languages.for_source_ext(ext)
            if lang is not None:
                tally[lang.name] = tally.get(lang.name, 0) + 1
    except OSError:
        pass
    if not tally:
        return declared or "c"
    name = max(tally.items(), key=lambda kv: kv[1])[0]
    return _SEARCH_LANGUAGE.get(name, name)


def _parse_target_toml_build_system(path: Path) -> str:
    """Read the `build_system = "<slug>"` value from target.toml."""
    raw = _parse_target_toml(path).get("build_system", "")
    return str(raw).strip()


def _declared_search_language(args: argparse.Namespace,
                              report_dir: Path | None) -> str:
    """Linguist code-search token derived from the target's build_system, or
    "" when none resolves. build_system is a structured source, so it outranks
    file-extension counting for the languages it identifies unambiguously."""
    seed_path = _resolve_target_toml(args, report_dir)
    if seed_path is None:
        return ""
    bs = _parse_target_toml_build_system(seed_path)
    if not bs:
        return ""
    lang = languages.for_build_system(bs)
    if lang is None:
        return ""
    return _SEARCH_LANGUAGE.get(lang.name, lang.name)


def _resolve_target_root(args: argparse.Namespace,
                         report_dir: Path | None) -> Path | None:
    """Locate the target's source checkout under targets/<slug>. Prefer the
    authoritative sources (--target / TARGET_ROOT / .session-env); only fall
    back to a walk-up heuristic when none is available. Shared by identity
    resolution and repo-type detection so both bind the same tree.

    Note repo-type detection uses _authoritative_target_root directly and
    skips the heuristic — a wrong bind there mis-skips/mis-runs external
    search. The heuristic remains acceptable for identity (language /
    vendored-name) enrichment, where a wrong bind only degrades filtering."""
    root = _authoritative_target_root(args, report_dir)
    if root is not None:
        return root
    return _heuristic_target_root(report_dir)


def _heuristic_target_root(report_dir: Path | None) -> Path | None:
    """Last-resort walk-up when no authoritative target root is available:
    bind targets/<output-slug> when it exists, else the first sorted target
    with a source layout. Can bind the wrong project when the output slug
    differs from the target slug, so it is used only for identity enrichment,
    never for repo-type decisions."""
    if report_dir is None:
        return None
    source_exts = languages.all_source_exts()
    # Recover the slug deterministically from the canonical
    # output/<slug>/... layout the report lives under, so the right
    # target is bound even when several exist under targets/. Falling
    # back to "first child with source" could bind the wrong project
    # (and therefore the wrong language/vendored-name set).
    slug_hint = ""
    cur = report_dir.resolve()
    for anc in [cur, *cur.parents]:
        if anc.parent is not None and anc.parent.name == "output":
            slug_hint = anc.name
            break
    # Walk up to find <repo_root>/targets/<slug>/.
    for p in [cur, *cur.parents]:
        tt = p / "targets"
        if not tt.is_dir():
            continue
        # Prefer the slug-matched dir; then deterministic (sorted) order so
        # the bound target does not depend on filesystem iteration order.
        # Pick the first with a recognizable source layout (top-level or
        # src/ source files in any registry language).
        candidates: list[Path] = []
        if slug_hint and (tt / slug_hint).is_dir():
            candidates.append(tt / slug_hint)
        candidates += sorted(c for c in tt.iterdir() if c.is_dir())
        for child in candidates:
            children = list(child.glob("*")) + list((child / "src").glob("*"))
            if any(c.suffix.lower() in source_exts for c in children):
                return child
    return None


def _resolve_target_identity(args: argparse.Namespace,
                             report_dir: Path | None) -> tuple[set[str], set[str], str]:
    """Discover the upstream project's source filenames, name aliases, and
    code-search language.

    Walks upward to find a targets/<slug> source root, then enumerates
    source-file basenames there (any registry language, not just C — a JS or
    Go target's vendored copies must be recognisable too). Also derives
    project-name aliases from the resolved root directory and the --target
    slug, so a vendored `…/<project>/…` path segment can be recognised for
    *any* target.

    Returns (basenames, names, language). basenames/names may be empty when
    nothing resolves — the prefix regex (third_party/, vendor/, …) still
    catches the common case, and an empty name set simply disables the
    segment heuristic. language falls back to "c"."""
    source_exts = languages.all_source_exts()
    target_root = _resolve_target_root(args, report_dir)
    target_names: set[str] = set()
    if args.target:
        target_names |= _target_name_variants(args.target)
    declared = _declared_search_language(args, report_dir)
    if target_root is None:
        return set(), target_names, _detect_target_language(None, declared)
    target_names |= _target_name_variants(target_root.name)
    basenames: set[str] = set()
    try:
        for path in target_root.rglob("*"):
            # Stay inside the target's own tree but skip build output and
            # checked-in dependency / vendored dirs — building a giant set
            # across vendored deps inside the target itself defeats the
            # purpose of this filter. Relative-parts check (not absolute
            # substring) so a checkout under a `build`-named ancestor isn't
            # skipped whole.
            if _is_skipped_path(path, target_root):
                continue
            if path.suffix.lower() in source_exts:
                basenames.add(path.name)
    except OSError:
        pass
    return basenames, target_names, _detect_target_language(target_root, declared)


def _run_batch(results_dir: Path, args: argparse.Namespace) -> int:
    """Walk <results_dir>/crashes/CRASH-*/ and run --report on each.

    Per-crash failures don't stop the loop — they're logged and the run
    continues. A single summary table prints at the end.
    """
    crashes_root = results_dir / "crashes"
    if not crashes_root.is_dir():
        print(f"reachability: no crashes/ subdir under {results_dir}", file=sys.stderr)
        return 2
    dirs = sorted(p for p in crashes_root.iterdir()
                  if p.is_dir() and p.name.startswith("CRASH-")
                  and _find_report_md_in_dir(p) is not None)
    if not dirs:
        print(f"reachability: no CRASH-*/report.md under {crashes_root}", file=sys.stderr)
        return 0
    rows: list[tuple[str, str, str, int, str]] = []
    for cdir in dirs:
        sub_argv = ["--report", str(cdir), "--json"]
        if args.no_cache:
            sub_argv.append("--no-cache")
        if args.severity_only:
            sub_argv.append("--severity-only")
        if args.target:
            sub_argv += ["--target", args.target]
        if args.language is not None:
            sub_argv += ["--language", args.language]
        for tok in args.ignore or []:
            sub_argv += ["--ignore", tok]
        sub_argv += ["--timeout", str(args.timeout)]
        try:
            # Reuse main() in-process — same mocks/cache, same target.toml
            # discovery. We capture its output by redirecting stdout.
            import io, contextlib
            buf = io.StringIO()
            with contextlib.redirect_stdout(buf):
                rc = main(sub_argv)
            payload = json.loads(buf.getvalue() or "{}")
            sev = payload.get("severity") or {}
            reach = payload.get("reachability") or {}
            rows.append((
                cdir.name, "ok" if rc == 0 else f"rc={rc}",
                sev.get("level", "?"), int(reach.get("external_callers", 0)),
                sev.get("primitive", "?"),
            ))
        except Exception as e:
            rows.append((cdir.name, f"err: {e!r}", "?", 0, "?"))
    # Summary table.
    print(f"\n=== Reachability batch summary ({len(rows)} crash dirs) ===")
    print(f"{'ID':<24} {'Status':<10} {'Severity':<10} {'Callers':>7}  Primitive")
    print(f"{'-'*24} {'-'*10} {'-'*10} {'-'*7}  {'-'*30}")
    for cid, status, level, callers, prim in rows:
        print(f"{cid:<24} {status:<10} {level:<10} {callers:>7}  {prim}")
    return 0


def _find_report_md_in_dir(report_dir: Path) -> Path | None:
    # exact_child_file walks the real directory entries, so the returned
    # Path carries the on-disk case. On case-insensitive filesystems
    # (macOS APFS default, Docker Desktop bind mounts) both "report.md"
    # and "REPORT.md" resolve to the same entry; a naive (report_dir /
    # name).is_file() probe returns a Path with whatever case we asked
    # for, and a later write_text through that Path can leave the
    # visible entry under the wrong case — which then trips the
    # exact-case bundle gate in lib/triage.sh:_triage_has_exact_file.
    return exact_child_file(report_dir, ("report.md", "REPORT.md"))


def _resolve_report_arg(report_arg: Path) -> tuple[Path, Path] | None:
    if report_arg.is_file():
        return report_arg.parent, report_arg
    report_md = _find_report_md_in_dir(report_arg)
    if report_md is None:
        return None
    return report_arg, report_md


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(prog="bin/reachability", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--symbol", action="append", default=[], help="Symbol to probe (repeatable)")
    ap.add_argument("--report", type=Path, default=None, help="Crash dir containing report.md")
    ap.add_argument("--batch", type=Path, default=None,
                    help="Results dir; runs --report on every crashes/CRASH-*/ underneath")
    ap.add_argument("--target", default=None, help="Target slug (loads ignore from output/<slug>/target.toml)")
    ap.add_argument("--ignore", action="append", default=[], help="Substring to drop from hits (repeatable)")
    ap.add_argument("--language", default=None,
                    help="Code-search language filter for both backends "
                         "(linguist name, e.g. c, c++, go, javascript). "
                         "Default: derived from the target tree; 'none' disables the filter")
    ap.add_argument("--json", action="store_true", help="Emit JSON instead of human summary")
    ap.add_argument("--no-cache", action="store_true", help="Bypass the 7-day cache")
    ap.add_argument("--severity-only", action="store_true",
                    help="With --report: only recompute Severity (uses adjacent reachability.json when present; otherwise skips external search)")
    ap.add_argument("--harness-rooted-check", action="store_true",
                    help="With --report: read-only — print 1 and exit 0 if the crash "
                         "faults entirely in the audit harness/driver (leaf frame is the "
                         "driver AND no target-library frame appears anywhere); else print "
                         "0 and exit 1. No scoring, no external search.")
    ap.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT, help="Per-request timeout (seconds)")
    args = ap.parse_args(argv)

    if args.severity_only and args.report is None and args.batch is None:
        print("reachability: --severity-only requires --report or --batch", file=sys.stderr)
        return 2
    if args.harness_rooted_check and args.report is None:
        print("reachability: --harness-rooted-check requires --report", file=sys.stderr)
        return 2

    if args.batch is not None:
        return _run_batch(args.batch, args)

    use_cache = not args.no_cache

    report_md: Path | None = None
    report_dir: Path | None = None
    adjacent_asan_text = ""
    symbols_from_asan = False
    if args.report is not None:
        resolved = _resolve_report_arg(args.report)
        if resolved is None:
            print(f"reachability: report.md/REPORT.md not found under {args.report}", file=sys.stderr)
            return 2
        report_dir, report_md = resolved
        report_text = report_md.read_text("utf-8", errors="replace")
        # sanitizer.txt is canonical; asan.txt is a legacy alias kept as a
        # fallback so older bundles shipped to maintainers stay readable.
        asan_path: Path | None = None
        for name in ("sanitizer.txt", "asan.txt"):
            candidate = report_dir / name
            if candidate.is_file():
                asan_path = candidate
                break
        if asan_path is not None:
            try:
                adjacent_asan_text = asan_path.read_text("utf-8", errors="replace")
            except OSError:
                adjacent_asan_text = ""
        if args.harness_rooted_check:
            # Read-only fast path: combine the report (which embeds the trace)
            # with every adjacent sanitizer artifact so the leaf/context scan
            # sees the full fault stack regardless of which file carries it or
            # how it is named at triage time (sanitizer.txt, asan.txt,
            # *_confirm.asan.txt, …) — not just one fixed filename.
            texts = [report_text]
            for name in ("sanitizer.txt", "asan.txt"):
                p = report_dir / name
                if p.is_file():
                    texts.append(p.read_text("utf-8", errors="replace"))
            for p in sorted(report_dir.glob("*.asan.txt")):
                texts.append(p.read_text("utf-8", errors="replace"))
            rooted = _crash_is_harness_rooted("\n".join(texts))
            print("1" if rooted else "0")
            return 0 if rooted else 1
    else:
        report_text = ""
        if not args.symbol:
            ap.print_help()
            return 2

    ignore = _resolve_ignore(args, report_dir)
    repo_type = _resolve_repo_type(args, report_dir)
    # Resolve the target's language BEFORE symbol extraction: the accepted
    # identifier shape depends on it (Go exports are PascalCase; a C-only
    # shape would never probe them).
    target_basenames, target_names, language = _resolve_target_identity(args, report_dir)
    if args.language is not None:
        language = "" if args.language.strip().lower() == "none" else args.language.strip()

    # Symbols: an explicit --symbol overrides everything. For sanitizer-backed
    # reports, external-caller popularity is measured at one caller-entry
    # symbol: an explicit report Entry line when available, otherwise the
    # deepest product frame in the primary fault stack. That keeps severity
    # tied to "who calls the public/reachable entry point" without requiring
    # downstream projects to contain the target's internal crash chain. Report
    # prose mining remains the fallback for findings with no sanitizer stack.
    symbols = list(args.symbol)
    entry_symbol: str | None = None
    stripped_report_text = _strip_auto_sections(report_text) if report_md is not None else ""
    if report_md is not None:
        if not symbols and adjacent_asan_text:
            entry_symbol = _crash_entrypoint_symbol(
                adjacent_asan_text, language, stripped_report_text)
            if entry_symbol:
                symbols = [entry_symbol]
                symbols_from_asan = True
            else:
                symbols = _extract_symbols_from_asan(adjacent_asan_text, language)
                symbols_from_asan = bool(symbols)
        if not symbols:
            symbols = _extract_symbols_from_report(stripped_report_text, language)

    reachability_json_path = report_dir / "reachability.json" if report_dir is not None else None

    local_symbols_only = symbols_from_asan and _asan_text_has_dev_path(adjacent_asan_text)

    if repo_type == "none":
        reach = _no_symbols_reachability(
            ignore,
            symbols=symbols,
            status="external_skipped",
            reason="target repo_type=none; external caller search skipped",
        )
        if reachability_json_path is not None:
            reachability_json_path.write_text(json.dumps(reach, indent=2, sort_keys=True), "utf-8")
    elif args.severity_only:
        if reachability_json_path is not None and reachability_json_path.is_file():
            try:
                reach = json.loads(reachability_json_path.read_text("utf-8"))
            except Exception as e:
                print(f"reachability: cannot read {reachability_json_path}: {e}", file=sys.stderr)
                return 4
        else:
            reach = _no_symbols_reachability(
                ignore,
                symbols=symbols,
                status="external_skipped",
                reason="external search skipped by --severity-only",
            )
            if reachability_json_path is not None:
                reachability_json_path.write_text(json.dumps(reach, indent=2, sort_keys=True), "utf-8")
    elif local_symbols_only:
        reach = _no_symbols_reachability(
            ignore,
            symbols=symbols,
            status="local_symbols_only",
            reason="local ASan frame symbol from dev/test surface; external search skipped",
        )
        if reachability_json_path is not None:
            reachability_json_path.write_text(json.dumps(reach, indent=2, sort_keys=True), "utf-8")
    elif not symbols and report_md is not None:
        reach = _no_symbols_reachability(ignore)
        if reachability_json_path is not None:
            reachability_json_path.write_text(json.dumps(reach, indent=2, sort_keys=True), "utf-8")
    else:
        # Sanitizer-backed reports normally carry a caller-entry symbol:
        # popularity counts callers of that entry, any-frame (see query_all).
        # When no entry point was identified, crash-state symbols are still a
        # call chain, so the all-frames collision gate applies. Manual
        # --symbol lists and narrative-mined entry points stay union/any-match.
        reach = query_all(symbols, ignore, args.timeout, use_cache,
                          target_basenames, target_names,
                          entry_symbol=entry_symbol,
                          require_all_symbols=symbols_from_asan,
                          language=language)
        if reachability_json_path is not None:
            reachability_json_path.write_text(json.dumps(reach, indent=2, sort_keys=True), "utf-8")

    severity: dict | None = None
    if report_md is not None:
        cluster_size = _detect_cluster_size(report_text)
        # Strip our own auto-generated sections before scoring — otherwise
        # the explainer text in the rationale section (which mentions
        # 'tests/', 'maint/' as examples) feeds back into the dev/test
        # path detector on subsequent runs and spuriously collapses the
        # surface tier. Scoring should only see the agent-authored part
        # of the report.
        scoring_text = _strip_auto_sections(report_text)
        # Append asan.txt when adjacent — it has the canonical ASan summary
        # (class + READ/WRITE of size N + SCARINESS line) that the report
        # narrative may only paraphrase. Increases classifier accuracy without
        # changing what gets persisted.
        if report_dir is not None:
            if adjacent_asan_text:
                scoring_text = scoring_text + "\n" + adjacent_asan_text
        severity = compute_severity(scoring_text, reach, cluster_size=cluster_size,
                                    report_dir=report_dir)
        update_report(report_md, reach, severity)

    if args.json:
        payload: dict[str, Any] = {"reachability": reach}
        if severity is not None:
            payload["severity"] = severity
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(render_human(reach, severity))

    return 0


if __name__ == "__main__":
    sys.exit(main())
