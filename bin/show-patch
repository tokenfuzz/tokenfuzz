#!/usr/bin/env python3
"""Show a bounded Git patch with compact errors and per-session memoization."""

from __future__ import annotations

import hashlib
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "lib"))
from command_tools import find_executable
from file_tools import capture_command, clipped_prefix


USAGE = """Usage: bin/show-patch <commit> [<path>...] [git show flags]
  Defaults to --unified=${PATCH_CONTEXT:-10}; pass --unified=N or set
  PATCH_CONTEXT=N to override. Caller flags (--stat, --no-patch, --unified)
  pass through unchanged.
"""


def fail(message: str, status: int = 2) -> int:
    print(f"[show-patch] {message}", file=sys.stderr)
    return status


def numeric_env(name: str, default: int) -> tuple[int, int]:
    value = os.environ.get(name, str(default))
    if not value.isdigit():
        return 0, fail(f"non-numeric {name}: {value}")
    return int(value), 0


def git_run(
    git: str,
    repository: Path,
    args: list[str],
    *,
    capture: bool = False,
    quiet_stderr: bool = False,
) -> subprocess.CompletedProcess[bytes]:
    return subprocess.run(
        [git, "-C", str(repository), *args],
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.DEVNULL if quiet_stderr else None,
    )


def repository_root(git: str) -> tuple[Path | None, int]:
    explicit = os.environ.get("SHOW_PATCH_REPO_ROOT")
    target = os.environ.get("TARGET_ROOT")
    if explicit:
        candidate = Path(explicit)
        valid = candidate.joinpath(".git").exists() and git_run(
            git, candidate, ["rev-parse", "--git-dir"], capture=True, quiet_stderr=True
        ).returncode == 0
        if not valid:
            return None, fail(f"not a git repository: {candidate}")
        return candidate, 0
    if target:
        candidate = Path(target)
        if candidate.joinpath(".git").exists() and git_run(
            git, candidate, ["rev-parse", "--git-dir"], capture=True, quiet_stderr=True
        ).returncode == 0:
            return candidate, 0
    completed = subprocess.run(
        [git, "rev-parse", "--show-toplevel"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    if completed.returncode != 0:
        return None, fail("not inside a git repository and TARGET_ROOT is unset")
    return Path(completed.stdout.decode().strip()), 0


def cache_paths(
    repository: Path, args: list[str], context: int, lines: int, byte_cap: int
) -> tuple[Path | None, Path | None]:
    results = os.environ.get("RESULTS_DIR")
    if os.environ.get("PATCH_NO_CACHE", "0") == "1" or not results:
        return None, None
    results_path = Path(results)
    if not results_path.is_dir():
        return None, None
    payload = (
        f"REPO={repository}\0CTX={context}\0LINES={lines}\0BYTES={byte_cap}\0"
        + " ".join(args)
        + "\0"
    ).encode()
    key = hashlib.sha1(payload).hexdigest()
    cache_dir = results_path / ".show-patch-cache"
    try:
        cache_dir.mkdir(parents=True, exist_ok=True)
    except OSError:
        return None, None
    return cache_dir / key, cache_dir / f"{key}.out"


def emit_cached(marker: Path, cached: Path) -> bool:
    if not cached.is_file():
        return False
    try:
        hits = int(marker.read_text().strip() or "1") + 1
    except (OSError, ValueError):
        hits = 2
    try:
        marker.write_text(f"{hits}\n")
    except OSError:
        pass
    data = cached.read_bytes()
    lines = data.count(b"\n")
    print(
        f"[show-patch: cached at {cached} ({len(data)} bytes, {lines} lines, "
        f"call #{hits}). First 40 lines below; Read the cache file for full, or "
        "re-run with PATCH_NO_CACHE=1.]"
    )
    preview_lines = data.splitlines(keepends=True)[:40]
    sys.stdout.flush()
    sys.stdout.buffer.write(b"".join(preview_lines))
    if lines > 40:
        print(f"... ({lines - 40} more lines in {cached})")
    return True


def main(argv: list[str] | None = None) -> int:
    args = [arg for arg in (sys.argv[1:] if argv is None else argv) if arg != "--no-pager"]
    if not args:
        print(USAGE, file=sys.stderr, end="")
        return 2

    context, status = numeric_env("PATCH_CONTEXT", 10)
    if status:
        return status
    max_lines, status = numeric_env("PATCH_MAX_LINES", 1500)
    if status:
        return status
    max_bytes, status = numeric_env("PATCH_MAX_BYTES", 32768)
    if status:
        return status
    stat_tail_lines, status = numeric_env("PATCH_STAT_TAIL_LINES", 20)
    if status:
        return status

    git = find_executable("git")
    if not git:
        return fail("git not found in PATH")
    repository, status = repository_root(git)
    if status or repository is None:
        return status

    if not args[0].startswith("-"):
        verified = git_run(
            git,
            repository,
            ["rev-parse", "--verify", "--quiet", f"{args[0]}^{{commit}}"],
            capture=True,
            quiet_stderr=True,
        )
        if verified.returncode != 0:
            return fail(
                f"unknown revision: {args[0]} (try a longer hash, or check `git log`)",
                128,
            )

    marker, cached = cache_paths(repository, args, context, max_lines, max_bytes)
    if marker is not None and cached is not None and emit_cached(marker, cached):
        return 0
    if marker is not None:
        try:
            marker.write_text("1\n")
        except OSError:
            pass

    override = any(
        arg.startswith("--unified=")
        or arg in (
            "--unified",
            "-U",
            "--stat",
            "--no-patch",
            "--shortstat",
            "--name-only",
            "--name-status",
        )
        or (arg.startswith("-U") and arg[2:].isdigit())
        for arg in args
    )
    show_args = ["show", *(args if override else [f"--unified={context}", *args])]
    if max_lines <= 0 and max_bytes <= 0:
        return git_run(git, repository, show_args).returncode

    command = [git, "-C", str(repository), *show_args]
    with capture_command(command, capture_stderr=False) as completed, tempfile.TemporaryDirectory(
        prefix="show-patch-"
    ) as directory:
        line_view = Path(directory) / "line-view"
        total_lines = 0
        with completed.stdout.open("rb") as source, line_view.open("wb") as target:
            for line in source:
                total_lines += 1
                if max_lines <= 0 or total_lines <= max_lines:
                    target.write(line)
        total_bytes = completed.stdout.stat().st_size
        line_clipped = max_lines > 0 and total_lines > max_lines
        byte_clipped = max_bytes > 0 and line_view.stat().st_size > max_bytes
        view = Path(directory) / "view"
        if byte_clipped:
            view.write_bytes(clipped_prefix(line_view, max_bytes))
        else:
            os.replace(line_view, view)

        if cached is not None:
            temporary_cache = cached.with_name(f".{cached.name}.{os.getpid()}.tmp")
            try:
                with view.open("rb") as source, temporary_cache.open("wb") as target:
                    shutil.copyfileobj(source, target, 1024 * 1024)
                os.replace(temporary_cache, cached)
            except OSError:
                temporary_cache.unlink(missing_ok=True)
        with view.open("rb") as source:
            shutil.copyfileobj(source, sys.stdout.buffer, 1024 * 1024)
        sys.stdout.flush()

        if line_clipped or byte_clipped:
            if line_clipped and byte_clipped:
                print(
                    f"\n[show-patch: clipped at {max_lines} of {total_lines} lines AND "
                    f"{max_bytes} of {total_bytes} bytes. Tree of this commit:"
                )
            elif line_clipped:
                print(
                    f"\n[show-patch: clipped at {max_lines} of {total_lines} lines. "
                    "Tree of this commit:"
                )
            else:
                print(
                    f"\n[show-patch: clipped at {max_bytes} of {total_bytes} bytes. "
                    "Tree of this commit:"
                )
            stat_command = [git, "-C", str(repository), "show", "--stat", "--format=", *args]
            with capture_command(stat_command) as stat:
                shown = stat_total = 0
                with stat.stdout.open("rb") as stream:
                    for line in stream:
                        stat_total += 1
                        if stat_tail_lines <= 0 or shown < stat_tail_lines:
                            sys.stdout.buffer.write(line)
                            shown += 1
            sys.stdout.flush()
            if stat_tail_lines > 0 and stat_total > stat_tail_lines:
                print(
                    f"  ... ({stat_total - stat_tail_lines} more files; "
                    "PATCH_STAT_TAIL_LINES=0 to widen)"
                )
            print(
                f"Drill in: bin/show-patch {args[0]} -- <file>, or "
                "PATCH_MAX_LINES=0 PATCH_MAX_BYTES=0 for the full diff.]"
            )
        return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
