#!/bin/bash
# cleanup_state — wipe transient audit state under output/<target>/<backend>/results/
# while preserving every crash, rejected crash, finding, and rejected finding artifact.
#
# Backends: every backend directory under each target (override with
# --backend NAME or --backends a,b,c).
# Targets: every directory under output/ (override with --target NAME, repeatable).
#
# By default, inside each results/ dir the following are PRESERVED:
#   crashes/                  promoted security crash candidates
#   crashes-rejected/         rejected crashes (incl. .autodiscard markers)
#   crashes-needs-review/     borderline LLM-confirm rejections
#   findings/                 confirmed security findings only. Non-security
#                             FINDs (correctness / data-integrity / robustness)
#                             are moved out at triage time, not stored here.
#   findings-rejected/        findings rejected by the substance gate
#   corpus/                   coverage-confirmed testcase seeds
#   coverage/                 edge journals used by queue ranking
#   fuzz-crashes/             raw fuzzer crash artifacts awaiting triage
#   fuzz-leads.md             summarized fuzzer leads
#   guards-db.md              cross-session guard/bypass memory
#   strategy-roi.md           strategy outcome history
#
# Override the preserve set with --keep NAME (repeatable) or --keep-only csv.
#
# Everything else inside results/ is removed (state/, scratch-N/,
# work-cards.jsonl, patch-cards.jsonl, AUDIT_STATE*.md, *.log, *.jsonl,
# .session-env, .state_archive/, etc.). The results/ directory itself is kept;
# .gitkeep markers inside preserved dirs are not touched.
#
# logs/ is intentionally NOT touched — that is bin/cleanup_logs's job.
# target.toml and output/<target>/{CRASH,FINDING}-CLUSTERS.* are also left alone.
#
# Usage:
#   bin/cleanup_state                       # clean all targets, default backends
#   bin/cleanup_state --dry-run             # show what would be removed
#   bin/cleanup_state --target firefox      # only firefox
#   bin/cleanup_state --target firefox --target libxml2
#   bin/cleanup_state --backend <backend>
#   bin/cleanup_state --backends <backend-list>
#   bin/cleanup_state --keep state          # also preserve structured state/
#   bin/cleanup_state --keep-only crashes,findings
#   bin/cleanup_state --output-root /path/to/output
#
# Exit codes: 0 success (incl. nothing to do), 2 usage error, 1 partial failure.

set -uo pipefail

usage() {
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

dry_run=0
quiet=0
backends_csv=""
backends_set=0
targets=()
output_root=""
extra_keep=()
keep_only_csv=""
keep_only_set=0  # tracks whether --keep-only was explicitly passed (even with "")

# Default preserve list. findings/ holds confirmed security findings only;
# rejected FINDs are quarantined next to it for auditability.
default_keep=(
    "crashes"
    "crashes-rejected"
    "crashes-needs-review"
    "findings"
    "findings-rejected"
    "corpus"
    "coverage"
    "fuzz-crashes"
    "fuzz-leads.md"
    "guards-db.md"
    "strategy-roi.md"
)

while [ $# -gt 0 ]; do
    case "$1" in
        -n|--dry-run) dry_run=1; shift ;;
        -q|--quiet)   quiet=1;   shift ;;
        -h|--help)    usage 0 ;;
        --backends)
            [ $# -ge 2 ] || { echo "[cleanup_state] --backends needs a value" >&2; exit 2; }
            backends_csv="$2"; backends_set=1; shift 2 ;;
        --backends=*) backends_csv="${1#--backends=}"; backends_set=1; shift ;;
        --backend)
            [ $# -ge 2 ] || { echo "[cleanup_state] --backend needs a value" >&2; exit 2; }
            backends_csv="$2"; backends_set=1; shift 2 ;;
        --backend=*) backends_csv="${1#--backend=}"; backends_set=1; shift ;;
        --target)
            [ $# -ge 2 ] || { echo "[cleanup_state] --target needs a value" >&2; exit 2; }
            targets+=("$2"); shift 2 ;;
        --target=*) targets+=("${1#--target=}"); shift ;;
        --output-root)
            [ $# -ge 2 ] || { echo "[cleanup_state] --output-root needs a value" >&2; exit 2; }
            output_root="$2"; shift 2 ;;
        --output-root=*) output_root="${1#--output-root=}"; shift ;;
        --keep)
            [ $# -ge 2 ] || { echo "[cleanup_state] --keep needs a value" >&2; exit 2; }
            extra_keep+=("$2"); shift 2 ;;
        --keep=*) extra_keep+=("${1#--keep=}"); shift ;;
        --keep-only)
            [ $# -ge 2 ] || { echo "[cleanup_state] --keep-only needs a value" >&2; exit 2; }
            keep_only_csv="$2"; keep_only_set=1; shift 2 ;;
        --keep-only=*) keep_only_csv="${1#--keep-only=}"; keep_only_set=1; shift ;;
        --) shift; break ;;
        -*) echo "[cleanup_state] unknown option: $1" >&2; exit 2 ;;
        *)  echo "[cleanup_state] unexpected positional arg: $1" >&2; exit 2 ;;
    esac
done

# Resolve output root: explicit flag > $REPO_ROOT/output > script-relative.
if [ -z "$output_root" ]; then
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    repo_root="$(cd "$script_dir/.." && pwd)"
    output_root="$repo_root/output"
fi

if [ ! -d "$output_root" ]; then
    echo "[cleanup_state] output root not found: $output_root" >&2
    exit 2
fi
output_root="$(cd "$output_root" && pwd -P)"

valid_component() {
    local name="$1"
    case "$name" in
        ""|"."|".."|.*|*/*|*..*) return 1 ;;
    esac
    return 0
}

path_is_under() {
    python3 - "$1" "$2" <<'PY'
import os
import sys

root = os.path.realpath(sys.argv[1])
path = os.path.realpath(sys.argv[2])
try:
    ok = os.path.commonpath([root, path]) == root
except ValueError:
    ok = False
sys.exit(0 if ok and path != root else 1)
PY
}

parsed_backends=()
if [ "$backends_set" -eq 1 ]; then
    # Parse backends CSV into array, trimming whitespace, dropping empties.
    IFS=',' read -r -a backends <<< "$backends_csv"
    for b in "${backends[@]}"; do
        b="${b## }"; b="${b%% }"
        [ -n "$b" ] && parsed_backends+=("$b")
    done
    if [ "${#parsed_backends[@]}" -eq 0 ]; then
        echo "[cleanup_state] no backends to clean" >&2
        exit 2
    fi
fi

# Resolve preserve list. --keep-only replaces the defaults; --keep adds.
# --keep-only "" is honored as an explicit empty list and rejected
# below (we refuse to wipe results/ wholesale without an explicit
# affirmation).
preserve=()
if [ "$keep_only_set" -eq 1 ]; then
    if [ -n "$keep_only_csv" ]; then
        IFS=',' read -r -a only_arr <<< "$keep_only_csv"
        for k in "${only_arr[@]}"; do
            k="${k## }"; k="${k%% }"
            [ -n "$k" ] && preserve+=("$k")
        done
    fi
    # else: --keep-only was passed with empty value → preserve stays
    #       empty → falls through to the empty-list rejection below.
else
    preserve+=("${default_keep[@]}")
    for k in "${extra_keep[@]:-}"; do
        [ -n "$k" ] && preserve+=("$k")
    done
fi
if [ "${#preserve[@]}" -eq 0 ]; then
    echo "[cleanup_state] preserve list is empty — refusing to wipe results/" >&2
    exit 2
fi

# Reject preserve entries that contain a slash, leading dot, or .. — those
# are out of scope for this tool and almost always a typo.
for k in "${preserve[@]}"; do
    case "$k" in
        */*|*..*|.*|"") echo "[cleanup_state] invalid --keep entry: '$k'" >&2; exit 2 ;;
    esac
done

# If no --target given, enumerate every direct subdir of output_root.
if [ "${#targets[@]}" -eq 0 ]; then
    while IFS= read -r -d '' d; do
        targets+=("$(basename "$d")")
    done < <(find "$output_root" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
fi

if [ "${#targets[@]}" -eq 0 ]; then
    [ "$quiet" -eq 1 ] || echo "[cleanup_state] no targets under $output_root"
    exit 0
fi

cleaned=0
skipped=0
failed=0
preserved_total=0

# Test if $1 is in the preserve list (basename match, case-sensitive).
is_preserved() {
    local name="$1"
    local p
    for p in "${preserve[@]}"; do
        [ "$name" = "$p" ] && return 0
    done
    return 1
}

for target in "${targets[@]}"; do
    if ! valid_component "$target"; then
        echo "[cleanup_state] invalid target component: '$target'" >&2
        failed=$((failed + 1))
        continue
    fi
    target_backends=()
    if [ "$backends_set" -eq 1 ]; then
        target_backends=("${parsed_backends[@]}")
    else
        while IFS= read -r -d '' d; do
            target_backends+=("$(basename "$(dirname "$d")")")
        done < <(find "$output_root/$target" -mindepth 2 -maxdepth 2 -type d -name results -print0 2>/dev/null)
    fi
    if [ "${#target_backends[@]}" -eq 0 ]; then
        skipped=$((skipped + 1))
        continue
    fi

    for backend in "${target_backends[@]}"; do
        if ! valid_component "$backend"; then
            echo "[cleanup_state] invalid backend component for $target: '$backend'" >&2
            failed=$((failed + 1))
            continue
        fi
        results_dir="$output_root/$target/$backend/results"
        if [ ! -d "$results_dir" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        # Resolve the absolute path so a moving working directory does not
        # turn rm into rm -rf / by accident. We refuse to delete a path
        # whose name is empty, "/", or does not contain "results".
        abs_results="$(cd "$results_dir" && pwd -P)"
        case "$abs_results" in
            ""|"/") echo "[cleanup_state] refusing to clean suspicious path: '$abs_results'" >&2
                    failed=$((failed + 1))
                    continue ;;
        esac
        case "$abs_results" in
            */results) ;;
            *) echo "[cleanup_state] refusing to clean unexpected path: '$abs_results'" >&2
               failed=$((failed + 1))
               continue ;;
        esac
        if ! path_is_under "$output_root" "$abs_results"; then
            echo "[cleanup_state] refusing to clean path outside output root: '$abs_results'" >&2
            failed=$((failed + 1))
            continue
        fi

        # Walk the immediate children of results/. find -mindepth 1
        # -maxdepth 1 does not follow symlinks (we never -L here).
        to_remove=()
        kept_here=0
        while IFS= read -r -d '' entry; do
            base="$(basename "$entry")"
            if is_preserved "$base"; then
                kept_here=$((kept_here + 1))
                continue
            fi
            to_remove+=("$entry")
        done < <(find "$abs_results" -mindepth 1 -maxdepth 1 -print0 2>/dev/null)

        preserved_total=$((preserved_total + kept_here))

        if [ "${#to_remove[@]}" -eq 0 ]; then
            [ "$quiet" -eq 1 ] || printf '%s: already clean (%d preserved)\n' \
                "$abs_results" "$kept_here"
            cleaned=$((cleaned + 1))
            continue
        fi

        if [ "$dry_run" -eq 1 ]; then
            printf '[dry-run] %s: would remove %d entries (%d preserved)\n' \
                "$abs_results" "${#to_remove[@]}" "$kept_here"
            for e in "${to_remove[@]}"; do
                printf '[dry-run]   - %s\n' "$(basename "$e")"
            done
            continue
        fi

        local_failed=0
        for e in "${to_remove[@]}"; do
            if ! rm -rf -- "$e" 2>/dev/null; then
                printf '[cleanup_state] failed to remove %s\n' "$e" >&2
                local_failed=$((local_failed + 1))
            fi
        done

        if [ "$local_failed" -eq 0 ]; then
            [ "$quiet" -eq 1 ] || printf '%s: removed %d entries, %d preserved\n' \
                "$abs_results" "${#to_remove[@]}" "$kept_here"
            cleaned=$((cleaned + 1))
        else
            failed=$((failed + 1))
        fi
    done
done

if [ "$dry_run" -eq 0 ] && [ "$quiet" -eq 0 ]; then
    printf 'cleaned=%d skipped=%d failed=%d preserved=%d\n' \
        "$cleaned" "$skipped" "$failed" "$preserved_total"
fi

[ "$failed" -eq 0 ] || exit 1
exit 0
