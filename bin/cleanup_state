#!/usr/bin/env python3
"""Reset target output while preserving target metadata and requested entries."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

TOOL = "cleanup_state"
BUILTIN_PRESERVE = {"target.toml", ".ground-truth.json"}
REPO_ROOT = Path(__file__).absolute().parent.parent
sys.path.insert(0, str(REPO_ROOT / "lib"))

from cleanup import (  # noqa: E402
    CleanupArgumentParser,
    args_before_double_dash,
    directory_entries,
    parse_csv,
    path_is_under,
    remove_entry,
    resolve_output_root,
    target_slugs,
    valid_component,
    valid_slug,
)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = CleanupArgumentParser(
        prog=TOOL,
        tool=TOOL,
        description=(
            "Reset output/<target> while preserving target metadata. Backend filters "
            "limit deletion to selected backend directories."
        ),
    )
    parser.add_argument("-n", "--dry-run", action="store_true")
    parser.add_argument("-q", "--quiet", action="store_true")
    parser.set_defaults(backends=None, keep_only=None)
    parser.add_argument("--backends", dest="backends", default=argparse.SUPPRESS)
    parser.add_argument("--backend", dest="backends", default=argparse.SUPPRESS)
    parser.add_argument("--target", action="append", default=[])
    parser.add_argument("--output-root", default="")
    parser.add_argument("--keep", action="append", default=[])
    parser.add_argument("--keep-only", default=argparse.SUPPRESS)
    parser.add_argument("positionals", nargs="*", help=argparse.SUPPRESS)
    args = parser.parse_args(args_before_double_dash(argv))
    if args.positionals:
        parser.exit(2, f"[{TOOL}] unexpected positional arg: {args.positionals[0]}\n")
    return args


def preserve_names(args: argparse.Namespace) -> list[str]:
    if args.keep_only is not None:
        return parse_csv(args.keep_only)
    return [name for name in args.keep if name]


def selected_entries(
    target: Path,
    target_slug: str,
    backends: list[str] | None,
    preserve: set[str],
) -> tuple[list[Path], int, int, int]:
    """Return entries, preserved count, skipped count, and validation failures."""
    entries: list[Path] = []
    kept = 0
    skipped = 0
    failed = 0
    if backends is not None:
        for backend in backends:
            if not valid_component(backend):
                print(
                    f"[{TOOL}] invalid backend component for {target_slug}: '{backend}'",
                    file=sys.stderr,
                )
                failed += 1
                continue
            entry = target / backend
            if not entry.exists() and not entry.is_symlink():
                skipped += 1
            elif backend in preserve:
                kept += 1
            else:
                entries.append(entry)
        return entries, kept, skipped, failed

    for entry in directory_entries(target):
        if entry.name in preserve:
            kept += 1
        else:
            entries.append(Path(entry.path))
    return entries, kept, skipped, failed


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    output_root = resolve_output_root(args.output_root, REPO_ROOT)
    if output_root is None:
        raw_root = Path(args.output_root) if args.output_root else REPO_ROOT / "output"
        print(f"[{TOOL}] output root not found: {raw_root}", file=sys.stderr)
        return 2

    backends = None if args.backends is None else parse_csv(args.backends)
    if args.backends is not None and not backends:
        print(f"[{TOOL}] no backends to clean", file=sys.stderr)
        return 2

    preserve = preserve_names(args)
    for name in preserve:
        if not valid_component(name):
            print(f"[{TOOL}] invalid --keep entry: '{name}'", file=sys.stderr)
            return 2
    preserve_set = BUILTIN_PRESERVE | set(preserve)

    targets = target_slugs(output_root, args.target)
    if not targets:
        if not args.quiet:
            print(f"[{TOOL}] no targets under {output_root}")
        return 0

    cleaned = 0
    skipped = 0
    failed = 0
    preserved_total = 0
    for target_slug in targets:
        if not valid_slug(target_slug):
            print(f"[{TOOL}] invalid target component: '{target_slug}'", file=sys.stderr)
            failed += 1
            continue
        target_dir = output_root.joinpath(*target_slug.split("/"))
        if not target_dir.is_dir():
            skipped += 1
            continue
        try:
            target = target_dir.resolve(strict=True)
        except OSError:
            skipped += 1
            continue
        if target == Path("/"):
            print(f"[{TOOL}] refusing to clean suspicious path: '{target}'", file=sys.stderr)
            failed += 1
            continue
        if not path_is_under(output_root, target):
            print(
                f"[{TOOL}] refusing to clean path outside output root: '{target}'",
                file=sys.stderr,
            )
            failed += 1
            continue

        try:
            to_remove, kept, target_skipped, validation_failed = selected_entries(
                target, target_slug, backends, preserve_set
            )
        except OSError:
            print(f"[{TOOL}] failed to inspect {target}", file=sys.stderr)
            failed += 1
            continue
        skipped += target_skipped
        failed += validation_failed
        preserved_total += kept

        if not to_remove:
            if not args.quiet:
                print(f"{target}: already clean ({kept} preserved)")
            cleaned += 1
            continue
        if args.dry_run:
            print(
                f"[dry-run] {target}: would remove {len(to_remove)} entries "
                f"({kept} preserved)"
            )
            for entry in to_remove:
                print(f"[dry-run]   - {entry.name}")
            continue

        local_failed = 0
        for entry in to_remove:
            try:
                remove_entry(entry)
            except OSError:
                print(f"[{TOOL}] failed to remove {entry}", file=sys.stderr)
                local_failed += 1
        if local_failed:
            failed += 1
        else:
            if not args.quiet:
                print(
                    f"{target}: removed {len(to_remove)} entries, {kept} preserved"
                )
            cleaned += 1

    if not args.dry_run and not args.quiet:
        print(
            f"cleaned={cleaned} skipped={skipped} failed={failed} "
            f"preserved={preserved_total}"
        )
    return 1 if failed else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
