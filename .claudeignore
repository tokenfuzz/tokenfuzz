# ============================================================================
# .claudeignore — Memory-Optimized Configuration for Claude Code
# ============================================================================
# Place this file in your project root. Uses .gitignore syntax.
# Goal: Slash token usage 50-75% without losing access to source code,
#        configs you actually edit, or test files you need Claude to work with.
#
# IMPORTANT: .claudeignore reduces what Claude *indexes and reads into context*.
#   For hard security blocks (secrets, credentials), also configure deny rules
#   in .claude/settings.json — .claudeignore alone is NOT a security boundary.
#
# Customize: Delete sections for languages/frameworks you don't use.
#            Use ! (negation) to re-include specific files if needed.
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 0. AUDIT BACKUP — old/redundant files
# ──────────────────────────────────────────────────────────────────────────────
prompts-backup/
skills.zip
# NOTE: prompts/ is NOT ignored — it contains reference docs (ANTI_PATTERNS.md,
# REPRODUCTION.md, etc.) that skills and CLAUDE.md may reference. Blocking it
# caused the indexer to miss critical files. Skills are the canonical source for
# strategy details; prompts/ serves as backup reference.


# ──────────────────────────────────────────────────────────────────────────────
# 1. DEPENDENCY DIRECTORIES (biggest token hogs — easily 30k-100k tokens each)
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
bower_components/
jspm_packages/
.pnp/
.pnp.js

# Python
.venv/
venv/
env/
ENV/
.conda/
site-packages/
*.egg-info/

# Ruby
vendor/bundle/

# Go
vendor/           # Go vendor directory (go.sum is kept — it's small & useful)

# Rust
target/           # Cargo build output (can be enormous)

# Java / Kotlin / Scala
.gradle/
.m2/
build/libs/

# PHP
vendor/

# .NET / C#
packages/
.nuget/

# Swift / iOS
Pods/
.build/
DerivedData/

# Elixir
deps/
_build/


# ──────────────────────────────────────────────────────────────────────────────
# 2. LOCK FILES (30k-80k tokens each — Claude doesn't need exact pinned versions)
# ──────────────────────────────────────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
Gemfile.lock
Pipfile.lock
poetry.lock
uv.lock
composer.lock
Cargo.lock
go.sum
*.resolved       # NuGet, Paket, etc.
flake.lock


# ──────────────────────────────────────────────────────────────────────────────
# 3. BUILD OUTPUT & COMPILED ARTIFACTS
# ──────────────────────────────────────────────────────────────────────────────
dist/
build/
out/
output/
.next/
.nuxt/
.svelte-kit/
.turbo/
.vercel/
.output/
.cache/
.parcel-cache/
.webpack/
.vite/

# Minified / bundled / sourcemaps (massive, unreadable by Claude)
*.min.js
*.min.css
*.bundle.js
*.bundle.css
*.chunk.js
*.chunk.css
*.map
*.LICENSE.txt

# Compiled binaries
*.o
*.so
*.dylib
*.dll
*.exe
*.class
*.jar
*.war
*.pyc
*.pyo
*.pyd
*.wasm


# ──────────────────────────────────────────────────────────────────────────────
# 4. TEST ARTIFACTS & COVERAGE (reports are big; test SOURCE files are kept)
# ──────────────────────────────────────────────────────────────────────────────
coverage/
htmlcov/
.coverage
.nyc_output/
lcov.info
*.lcov
.pytest_cache/
.tox/
__pycache__/
.mypy_cache/
.ruff_cache/
.pytype/

# Snapshot files (can be huge, regenerated by tests)
__snapshots__/
*.snap

# Test fixtures / large test data (un-comment if your fixtures are big)
# __fixtures__/
# test-data/
# fixtures/


# ──────────────────────────────────────────────────────────────────────────────
# 5. IDE, EDITOR & OS FILES
# ──────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
*.sublime-project
*.sublime-workspace


# ──────────────────────────────────────────────────────────────────────────────
# 6. VERSION CONTROL INTERNALS
# ──────────────────────────────────────────────────────────────────────────────
.git/
.hg/
.svn/


# ──────────────────────────────────────────────────────────────────────────────
# 7. SECRETS & ENVIRONMENT FILES
#    (Also add deny rules in .claude/settings.json for hard enforcement)
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example       # Keep the example template — it documents expected vars
*.pem
*.key
*.cert
*.p12
*.keystore
*.jks
*.credentials
*.secret


# ──────────────────────────────────────────────────────────────────────────────
# 8. LOGS, TEMPORARY FILES & DATABASES
# ──────────────────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.swp
*.sqlite
*.sqlite3
*.db


# ──────────────────────────────────────────────────────────────────────────────
# 9. MEDIA & LARGE BINARY ASSETS (Claude can't meaningfully parse these)
# ──────────────────────────────────────────────────────────────────────────────
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv
*.flac
*.ogg
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.iso
*.dmg
*.pdf
*.psd
*.ai
*.sketch
*.fig
*.xd

# Large image directories (keep individual images Claude might reference)
# assets/images/
# public/images/

# Fonts (binary, no code value)
*.woff
*.woff2
*.ttf
*.otf
*.eot


# ──────────────────────────────────────────────────────────────────────────────
# 10. DOCUMENTATION YOU DON'T NEED CLAUDE TO READ
#     (Keep README.md, CONTRIBUTING.md, and docs you actively work on)
# ──────────────────────────────────────────────────────────────────────────────
# docs/            # Un-comment if your docs folder is large and not being edited
CHANGELOG.md
CHANGELOG
HISTORY.md
LICENSE
LICENSE.md
LICENSE.txt
NOTICE
AUTHORS
CONTRIBUTORS


# ──────────────────────────────────────────────────────────────────────────────
# 11. CI/CD & INFRASTRUCTURE (rarely needs editing via Claude)
# ──────────────────────────────────────────────────────────────────────────────
# .github/         # Un-comment if you don't need Claude to edit CI workflows
# .circleci/
# .gitlab-ci.yml
# Jenkinsfile


# ──────────────────────────────────────────────────────────────────────────────
# 12. TERRAFORM / INFRASTRUCTURE STATE (huge, sensitive)
# ──────────────────────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars           # May contain secrets


# ──────────────────────────────────────────────────────────────────────────────
# 13. DATA SCIENCE & ML ARTIFACTS
# ──────────────────────────────────────────────────────────────────────────────
*.h5
*.hdf5
*.pkl
*.pickle
*.onnx
*.pt
*.pth
*.safetensors
*.ckpt
*.model
*.npy
*.npz
*.parquet
*.feather
*.arrow
.ipynb_checkpoints/
wandb/
mlruns/
lightning_logs/


# ──────────────────────────────────────────────────────────────────────────────
# 14. DOCKER & CONTAINER ARTIFACTS
# ──────────────────────────────────────────────────────────────────────────────
# Dockerfile         # Keep — Claude often needs to edit these
# docker-compose.yml # Keep
*.tar
docker-data/


# ──────────────────────────────────────────────────────────────────────────────
# 15. MONOREPO / GENERATED CODE
# ──────────────────────────────────────────────────────────────────────────────
# generated/       # Un-comment for auto-generated API clients, protobuf output, etc.
# .graphql/
# storybook-static/


# ============================================================================
# WHAT THIS FILE INTENTIONALLY KEEPS (do NOT ignore these):
# ============================================================================
# ✅ All source code (src/, lib/, app/, pages/, components/, etc.)
# ✅ Test source files (tests/, __tests__/, *.test.*, *.spec.*)
# ✅ Config files you edit (tsconfig, eslint, prettier, vite, next, etc.)
# ✅ package.json, pyproject.toml, Cargo.toml, go.mod, Gemfile
# ✅ Dockerfile, docker-compose.yml, Makefile
# ✅ README.md, CLAUDE.md, .claudeignore itself
# ✅ .env.example (via negation above)
# ✅ Migration files (database schemas)
# ✅ CI workflow files (unless you un-comment section 11)
# ============================================================================
