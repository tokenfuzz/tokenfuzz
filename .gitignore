# Project runtime state
AUDIT_STATE*.md.bak
output/*
# Commit only the canary target's config; everything else under output/ is
# runtime data. (See targets/canary — the committed ground-truth target.)
!output/canary/
output/canary/*
!output/canary/target.toml
!output/canary/ground-truth.json
scratch/
scratch-*/
targets/*
# Commit the synthetic canary ground-truth target; all other target trees are
# operator-provisioned working copies. Skip every sanitizer build dir
# (build-asan, build-ubsan, …); *.log under it is already ignored below.
!targets/canary/
targets/canary/build-*/

# bin/benchmark ledger + run artifacts (operator data, not source)
benchmark-results.md
benchmark-results.html
benchmark-results.*.bak.md

# OS artifacts
.DS_Store
Thumbs.db

# Editor and IDE files
*~
*.swp
*.swo
.idea/
.vscode/

# Local tool settings
.antigravitycli/
.claude/
.codex/

# Python environments and caches
.pytest_cache/
.venv/
*.py[cod]
*.pyo
__pycache__/

# Logs
*.log

# zsh completion cache (zsh auto-writes this when ZDOTDIR points at
# lib/wrappers/_zdotdir/ during agent sessions — see bin/audit)
lib/wrappers/_zdotdir/.zcompdump*

# Documentation builds
/site/
