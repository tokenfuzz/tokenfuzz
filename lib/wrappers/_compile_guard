#!/usr/bin/env bash
# Compiler wrapper for audit agent shells. It passes through to the real
# compiler, but refuses outputs that would land directly in the audit repo root
# or top-level scratch-N dirs. Harness binaries belong under RESULTS_DIR/scratch-N
# and should normally be built by bin/probe.
set -u

wrapper_dir="${1:-}"
tool="${2:-}"
shift 2 || exit 2

[ -n "$wrapper_dir" ] && [ -n "$tool" ] || {
  echo "[compile-guard] internal usage: _compile_guard <wrapper-dir> <tool> ..." >&2
  exit 2
}

script_root="$(cd "$wrapper_dir/../.." && pwd -P)"
cwd="$(pwd -P)"

_find_real_tool() {
  local name="$1" dir real_dir
  local old_ifs="$IFS"
  IFS=:
  for dir in $PATH; do
    [ -n "$dir" ] || dir="."
    real_dir="$(cd "$dir" 2>/dev/null && pwd -P)" || continue
    [ "$real_dir" = "$wrapper_dir" ] && continue
    if [ -x "$real_dir/$name" ]; then
      printf '%s/%s\n' "$real_dir" "$name"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

real_tool="$(_find_real_tool "$tool")" || {
  echo "[compile-guard] real compiler not found after wrapper: $tool" >&2
  exit 127
}

_has_source_arg=0
_suppress_output=0
_out_paths=()
_prev=""
for arg in "$@"; do
  if [ -n "$_prev" ]; then
    case "$_prev" in
      -o) _out_paths+=("$arg") ;;
    esac
    _prev=""
    continue
  fi
  case "$arg" in
    -o)
      _prev="-o"
      ;;
    -o?*)
      _out_paths+=("${arg#-o}")
      ;;
    -E|-M|-MM|-###|--version|-dumpversion|-dumpmachine|-print-*|--print-*)
      _suppress_output=1
      ;;
    *.c|*.cc|*.cpp|*.cxx|*.C|*.m|*.mm|*.S|*.s|*.i|*.ii|*.o|*.a)
      _has_source_arg=1
      ;;
  esac
done

if [ -n "$_prev" ]; then
  exec "$real_tool" "$@"
fi

_reject_output() {
  local out="$1" reason="$2"
  echo "[compile-guard] refusing compiler output in audit repo root: $out" >&2
  echo "[compile-guard] reason: $reason" >&2
  echo "[compile-guard] write harnesses under \$RESULTS_DIR/scratch-N and run them with bin/probe." >&2
  echo "[compile-guard] set AUDIT_ALLOW_ROOT_COMPILER_OUTPUT=1 to override for a trusted local experiment." >&2
  exit 2
}

if [ "${AUDIT_ALLOW_ROOT_COMPILER_OUTPUT:-0}" != "1" ] && [ "$cwd" = "$script_root" ]; then
  if [ "${#_out_paths[@]}" -eq 0 ] && [ "$_has_source_arg" -eq 1 ] && [ "$_suppress_output" -eq 0 ]; then
    _reject_output "a.out/object-in-cwd" "compiler command has source inputs but no explicit safe -o path"
  fi

  for out in "${_out_paths[@]}"; do
    case "$out" in
      /*)
        rel="${out#$script_root/}"
        if [ "$rel" != "$out" ]; then
          case "$rel" in
            output/*|targets/*) ;;
            scratch-[0-9]*/*|scratch-[0-9]*|*/*) _reject_output "$out" "absolute output resolves under the audit repo instead of output/ or targets/" ;;
            *) _reject_output "$out" "absolute output resolves to a top-level audit repo artifact" ;;
          esac
        fi
        ;;
      output/*|./output/*|targets/*|./targets/*)
        ;;
      scratch-[0-9]*/*|scratch-[0-9]*)
        _reject_output "$out" "top-level scratch-N is not the active RESULTS_DIR scratch directory"
        ;;
      */*)
        _reject_output "$out" "relative output would create an artifact under the audit repo outside output/ or targets/"
        ;;
      *)
        _reject_output "$out" "relative basename output would create a root-level artifact"
        ;;
    esac
  done
fi

exec "$real_tool" "$@"
