#!/usr/bin/env bash
# grep wrapper: caps output via lib/wrappers/_cap and skips any `logs/` dir plus
# VCS metadata in recursive scans. Unlike rg, `--exclude-dir` (BSD and GNU) only
# matches a directory's own name, not its ancestors, so grep cannot restrict the
# skip to the harness output tree the way rg-safe/rg do. A full `logs/` skip is
# the safe choice here: it guarantees no self-output leak (session transcripts,
# prompt dumps, .raw/ spills, vendored .gemini-home/), and target source that
# happens to live under a `logs/` dir stays reachable via `bin/rg-safe`, the
# documented source-search tool. `--exclude-dir` is a no-op without -r/-R, so
# always-on is safe for single-file calls.
_dir="$(cd "$(dirname "$0")" && pwd)"
exec "$_dir/_cap" "$_dir" grep "-c,-l,-q,-L" \
  --exclude-dir=logs \
  --exclude-dir=.git \
  --exclude-dir=.hg \
  "$@"
