#!/usr/bin/env bash
# Output-capping wrapper used by lib/wrappers/grep and lib/wrappers/rg.
# Caps stdout/stderr separately so a runaway match doesn't flood agent context
# and diagnostics don't look like search results. For plain rg/grep searches,
# stop reading stdout after the visible line budget is exceeded; otherwise a
# broad match still pays to emit megabytes that the wrapper later discards.
# Pass-through flags exit early since their output is already bounded.
#
# Two caps fire independently:
#   line cap   — CAP_LINES (default 200)     protects against many small matches
#   byte cap   — default head+tail cap       protects against few huge matches
#                explicit CAP_BYTES=N keeps the legacy chop-at-N behavior
# Per-tool bypass: AGENT_WRAPPERS_BYPASS (space/comma list, or "all") runs the
#   named tools uncapped — e.g. AGENT_WRAPPERS_BYPASS=rg leaves grep/sed capped.
#   Intended for A/B experiments on the cap's effect on bug-finding.
# A single match line in a JSON-shaped haystack (codex .log.raw transcripts)
# can be hundreds of KB, defeating the line cap alone. The default byte path
# uses lib/output_cap.sh's ~50 KiB head+tail spill so the agent sees enough
# context without replaying a huge command result on every later turn. The
# full stream is saved under logs/.raw/outcap when RESULTS_DIR is available.
#
# Stub usage:
#   exec "$_dir/_cap" "$_dir" <tool> "<flag>,<flag>,..." "$@"
set -uo pipefail

_wrapper_dir="$1"; shift
_tool="$1"; shift
_passthrough="$1"; shift

_cap_lines="${CAP_LINES:-200}"
_cap_bytes_explicit=0
[ "${CAP_BYTES+x}" = "x" ] && _cap_bytes_explicit=1
_cap_bytes="${CAP_BYTES:-131072}"
case "$_cap_lines" in
  ''|*[!0-9]*) echo "${_tool}: CAP_LINES must be a non-negative integer" >&2; exit 2 ;;
esac
case "$_cap_bytes" in
  ''|*[!0-9]*) echo "${_tool}: CAP_BYTES must be a non-negative integer" >&2; exit 2 ;;
esac

if [ -r "$_wrapper_dir/../output_cap.sh" ]; then
  # shellcheck source=../output_cap.sh
  . "$_wrapper_dir/../output_cap.sh"
fi

# Find the real binary, skipping our own wrapper directory in PATH so we
# don't recurse into ourselves.
_real=""
IFS=: read -ra _dirs <<< "$PATH"
for _d in "${_dirs[@]}"; do
  [ "$_d" = "$_wrapper_dir" ] && continue
  if [ -x "$_d/$_tool" ]; then _real="$_d/$_tool"; break; fi
done
[ -n "$_real" ] || { echo "${_tool}: real binary not found" >&2; exit 127; }

# AGENT_WRAPPERS_BYPASS runs named tools UNCAPPED — a space/comma list, or
# "all". It exists to A/B the cap's effect on bug-finding per tool (e.g.
# AGENT_WRAPPERS_BYPASS=rg leaves grep/sed capped). Glob exclusions the
# rg/grep wrapper already put in "$@" (logs/, .git/) are kept, so a bypassed
# rg still skips self-output noise.
_bypass=" ${AGENT_WRAPPERS_BYPASS:-} "   # pad so the glob matches whole words
case "${_bypass//,/ }" in                # commas optional
  *" all "*|*" ${_tool} "*) exec "$_real" "$@" ;;
esac

# Pass-through for flags that produce bounded output already.
# Tools with no such flags (e.g. sed) pass an empty list — skip the scan.
#
# The scan stops at the `--` end-of-options separator so a positional
# argument that happens to equal a passthrough flag (e.g. a literal
# pattern `-c` in `grep -- -c FILE`, or a filename `-l`) cannot falsely
# trigger passthrough and bypass the line/byte caps.
if [ -n "$_passthrough" ]; then
  IFS=','
  read -ra _flags <<< "$_passthrough"
  unset IFS
  for _arg in "$@"; do
    [ "$_arg" = "--" ] && break
    for _flag in "${_flags[@]}"; do
      [ "$_arg" = "$_flag" ] && exec "$_real" "$@"
    done
  done
fi

# Clip a file in place to at most $_cap_bytes, falling back to the last
# newline so we never emit a partial trailing line. No-op when cap=0 or
# python3 is unavailable. Returns 0 if a clip happened, 1 otherwise.
_clip_to_bytes() {
  local _file="$1" _cap="$2" _bytes
  [ "$_cap" -gt 0 ] || return 1
  _bytes=$(wc -c < "$_file" | tr -d ' ')
  _bytes=${_bytes:-0}
  [ "$_bytes" -gt "$_cap" ] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$_file" "$_cap" <<'PY'
import sys
path, cap = sys.argv[1], int(sys.argv[2])
with open(path, "rb") as f:
    data = f.read(cap)
i = data.rfind(b"\n")
if i >= 0:
    data = data[:i + 1]
with open(path, "wb") as f:
    f.write(data)
PY
  return 0
}

_emit_capped() {
  local _file="$1"
  local _stream="$2"
  local _line_count_kind="${3:-exact}"
  local _orig_lines _orig_bytes _line_capped=0 _byte_capped=0
  # Empty stream → nothing to emit and nothing to cap (0 lines/bytes trips
  # neither cap), so skip the wc/cat work entirely. stderr is empty on the
  # large majority of grep/rg/sed calls, so this drops ~3 forks per call —
  # it compounds across the thousands of search calls an audit makes.
  [ -s "$_file" ] || return 0
  # One `wc -lc` instead of separate `wc -l` + `wc -c`: both BSD and GNU wc
  # print "<lines> <bytes>" for -lc. `read` strips the leading whitespace,
  # so no `tr` fork is needed either.
  read -r _orig_lines _orig_bytes <<< "$(wc -lc < "$_file")"
  _orig_lines=${_orig_lines:-0}
  _orig_bytes=${_orig_bytes:-0}

  # 1) Line cap: rewrite file in place so the byte step sees the clipped form.
  if [ "$_cap_lines" -gt 0 ] && [ "$_orig_lines" -gt "$_cap_lines" ]; then
    local _clip_tmp; _clip_tmp=$(mktemp) || return 1
    head -n "$_cap_lines" "$_file" > "$_clip_tmp"
    mv "$_clip_tmp" "$_file"
    _line_capped=1
  fi

  # 2) Byte cap on whatever survived.
  #
  # Default path: use output_cap.sh's head+tail replacement so broad
  # searches show both ends and spill the full original to disk. If the
  # operator explicitly sets CAP_BYTES, preserve the historical chop-at-N
  # contract and footer shape for compatibility/debugging.
  local _use_output_cap=0
  if [ "$_cap_bytes_explicit" -eq 0 ] \
     && [ "$_cap_bytes" -gt 0 ] \
     && declare -F cap_output_file >/dev/null 2>&1; then
    _use_output_cap=1
  fi

  if [ "$_stream" = "stderr" ]; then
    if [ "$_use_output_cap" -eq 1 ]; then
      cap_output_file "$_file" "${_tool}-${_stream}" >&2
    else
      _clip_to_bytes "$_file" "$_cap_bytes" && _byte_capped=1
      cat "$_file" >&2
    fi
    if [ "$_line_capped" -eq 1 ]; then
      if [ "$_line_count_kind" = "at-least" ]; then
        printf '... (at least %s total stderr lines — output truncated to %s. Narrow your search.)\n' \
          "$_orig_lines" "$_cap_lines" >&2
      else
        printf '... (%s total stderr lines — output truncated to %s. Narrow your search.)\n' \
          "$_orig_lines" "$_cap_lines" >&2
      fi
    fi
    if [ "$_use_output_cap" -eq 0 ] && [ "$_byte_capped" -eq 1 ]; then
      printf '... (stderr clipped at %s bytes of %s. Narrow your search.)\n' \
        "$_cap_bytes" "$_orig_bytes" >&2
    fi
  else
    if [ "$_use_output_cap" -eq 1 ]; then
      cap_output_file "$_file" "${_tool}-${_stream}"
    else
      _clip_to_bytes "$_file" "$_cap_bytes" && _byte_capped=1
      cat "$_file"
    fi
    if [ "$_line_capped" -eq 1 ]; then
      if [ "$_line_count_kind" = "at-least" ]; then
        printf '... (at least %s total stdout lines — output truncated to %s. Narrow your search.)\n' \
          "$_orig_lines" "$_cap_lines"
      else
        printf '... (%s total stdout lines — output truncated to %s. Narrow your search.)\n' \
          "$_orig_lines" "$_cap_lines"
      fi
    fi
    if [ "$_use_output_cap" -eq 0 ] && [ "$_byte_capped" -eq 1 ]; then
      printf '... (stdout clipped at %s bytes of %s. Narrow your search.)\n' \
        "$_cap_bytes" "$_orig_bytes"
    fi
  fi
}

# Capture stdout and stderr separately, cap each stream, and preserve the
# stream they are emitted on. This avoids mixing diagnostics into matches.
_out_tmp=$(mktemp) || exit 1
_err_tmp=$(mktemp) || { rm -f "$_out_tmp"; exit 1; }
trap 'rm -f "$_out_tmp" "$_err_tmp"' EXIT

_stdout_line_count_kind=exact
_fast_stdout_cap=0
case "$_tool" in
  rg|grep)
    # For normal search output, we only ever display CAP_LINES lines plus a
    # footer. Read one extra line, then let head close the pipe so broad
    # matches stop early. Count/list/quiet modes have already passed through
    # above, so this does not affect exact query modes.
    if [ "$_cap_lines" -gt 0 ]; then
      _fast_stdout_cap=1
    fi
    ;;
esac

if [ "$_fast_stdout_cap" -eq 1 ]; then
  _line_limit=$((_cap_lines + 1))
  "$_real" "$@" 2> "$_err_tmp" | head -n "$_line_limit" > "$_out_tmp"
  _pipe_status=("${PIPESTATUS[@]}")
  _rc="${_pipe_status[0]:-0}"
  _head_rc="${_pipe_status[1]:-0}"
  if [ "$_head_rc" -eq 0 ]; then
    _captured_lines=$(wc -l < "$_out_tmp" | tr -d ' ')
    _captured_lines=${_captured_lines:-0}
    if [ "$_captured_lines" -gt "$_cap_lines" ]; then
      _stdout_line_count_kind=at-least
      # rg/grep often report SIGPIPE after head has collected enough visible
      # output. The visible result is a successful capped search, not a tool
      # diagnostic.
      case "$_rc" in
        13|141) _rc=0 ;;
      esac
    fi
  fi
else
  "$_real" "$@" > "$_out_tmp" 2> "$_err_tmp"
  _rc=$?
fi

_emit_capped "$_out_tmp" stdout "$_stdout_line_count_kind"
_emit_capped "$_err_tmp" stderr
exit "$_rc"
