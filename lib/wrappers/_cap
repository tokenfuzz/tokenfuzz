#!/usr/bin/env bash
# Output-capping wrapper used by lib/wrappers/grep, lib/wrappers/rg and
# lib/wrappers/sed. Runs the real tool and caps stdout/stderr separately by
# BYTES, so a runaway match doesn't flood agent context and diagnostics don't
# look like search results.
#
# Size is bounded by the byte cap: a ~50 KiB head+tail spill via
# lib/output_cap.sh. Bytes are the right bound whatever the match shape — a
# single JSON-shaped match line in a codex .log.raw can be hundreds of KB, so a
# line count would miss it. The full stream is spilled under logs/.raw/outcap
# when RESULTS_DIR is set. Set CAP_BYTES=N for a hard chop-at-N instead, or
# CAP_BYTES=0 to disable the byte cap.
#
# Per-tool bypass: AGENT_WRAPPERS_BYPASS (space/comma list, or "all") runs the
#   named tools uncapped — for A/B experiments on the cap's effect on bug-finding.
# Pass-through flags (-c/-l/-q/...) exit early since their output is bounded.
#
# Stub usage:
#   exec "$_dir/_cap" "$_dir" <tool> "<flag>,<flag>,..." "$@"
set -uo pipefail

_wrapper_dir="$1"; shift
_tool="$1"; shift
_passthrough="$1"; shift

_cap_bytes_explicit=0
[ "${CAP_BYTES+x}" = "x" ] && _cap_bytes_explicit=1
_cap_bytes="${CAP_BYTES:-131072}"
case "$_cap_bytes" in
  ''|*[!0-9]*) echo "${_tool}: CAP_BYTES must be a non-negative integer" >&2; exit 2 ;;
esac

if [ -r "$_wrapper_dir/../output_cap.sh" ]; then
  # shellcheck source=../output_cap.sh
  . "$_wrapper_dir/../output_cap.sh"
fi

# Find the real binary, skipping our own wrapper directory in PATH so we
# don't recurse into ourselves.
_real=""
IFS=: read -ra _dirs <<< "$PATH"
for _d in "${_dirs[@]}"; do
  [ "$_d" = "$_wrapper_dir" ] && continue
  if [ -x "$_d/$_tool" ]; then _real="$_d/$_tool"; break; fi
done
[ -n "$_real" ] || { echo "${_tool}: real binary not found" >&2; exit 127; }

# AGENT_WRAPPERS_BYPASS runs named tools UNCAPPED — a space/comma list, or
# "all". It exists to A/B the cap's effect on bug-finding per tool (e.g.
# AGENT_WRAPPERS_BYPASS=rg leaves grep/sed capped). The exclusions the rg/grep
# wrapper already put in "$@" (the harness output-logs tree, VCS metadata) are
# kept, so a bypassed rg still skips self-output noise.
_bypass=" ${AGENT_WRAPPERS_BYPASS:-} "   # pad so the glob matches whole words
case "${_bypass//,/ }" in                # commas optional
  *" all "*|*" ${_tool} "*) exec "$_real" "$@" ;;
esac

# Pass-through for flags that produce bounded output already.
# Tools with no such flags (e.g. sed) pass an empty list — skip the scan.
#
# The scan stops at the `--` end-of-options separator so a positional
# argument that happens to equal a passthrough flag (e.g. a literal
# pattern `-c` in `grep -- -c FILE`, or a filename `-l`) cannot falsely
# trigger passthrough and bypass the byte cap.
if [ -n "$_passthrough" ]; then
  IFS=','
  read -ra _flags <<< "$_passthrough"
  unset IFS
  for _arg in "$@"; do
    [ "$_arg" = "--" ] && break
    for _flag in "${_flags[@]}"; do
      [ "$_arg" = "$_flag" ] && exec "$_real" "$@"
    done
  done
fi

# Clip a file in place to at most $_cap_bytes, falling back to the last
# newline so we never emit a partial trailing line. No-op when cap=0 or
# python3 is unavailable. Returns 0 if a clip happened, 1 otherwise.
_clip_to_bytes() {
  local _file="$1" _cap="$2" _bytes
  [ "$_cap" -gt 0 ] || return 1
  _bytes=$(wc -c < "$_file" | tr -d ' ')
  _bytes=${_bytes:-0}
  [ "$_bytes" -gt "$_cap" ] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$_file" "$_cap" <<'PY'
import sys
path, cap = sys.argv[1], int(sys.argv[2])
with open(path, "rb") as f:
    data = f.read(cap)
i = data.rfind(b"\n")
if i >= 0:
    data = data[:i + 1]
with open(path, "wb") as f:
    f.write(data)
PY
  return 0
}

_emit_capped() {
  local _file="$1"
  local _stream="$2"
  local _orig_bytes _byte_capped=0
  # Empty stream → nothing to emit or cap. stderr is empty on the large
  # majority of grep/rg/sed calls, so this drops the wc/cat forks per call.
  [ -s "$_file" ] || return 0

  # Default path: output_cap.sh's head+tail replacement so broad output shows
  # both ends and spills the full original to disk. An explicit CAP_BYTES keeps
  # the historical chop-at-N contract and footer shape for debugging.
  local _use_output_cap=0
  if [ "$_cap_bytes_explicit" -eq 0 ] \
     && [ "$_cap_bytes" -gt 0 ] \
     && declare -F cap_output_file >/dev/null 2>&1; then
    _use_output_cap=1
  fi

  if [ "$_use_output_cap" -eq 1 ]; then
    if [ "$_stream" = "stderr" ]; then cap_output_file "$_file" "${_tool}-${_stream}" >&2
    else cap_output_file "$_file" "${_tool}-${_stream}"; fi
    return 0
  fi

  _orig_bytes=$(wc -c < "$_file" | tr -d ' ')
  _orig_bytes=${_orig_bytes:-0}
  _clip_to_bytes "$_file" "$_cap_bytes" && _byte_capped=1
  if [ "$_stream" = "stderr" ]; then
    cat "$_file" >&2
    [ "$_byte_capped" -eq 1 ] && printf '... (stderr clipped at %s bytes of %s. Narrow your search.)\n' \
      "$_cap_bytes" "$_orig_bytes" >&2
  else
    cat "$_file"
    [ "$_byte_capped" -eq 1 ] && printf '... (stdout clipped at %s bytes of %s. Narrow your search.)\n' \
      "$_cap_bytes" "$_orig_bytes"
  fi
}

# Capture stdout and stderr separately, byte-cap each, and preserve the stream
# they are emitted on. This avoids mixing diagnostics into matches.
_out_tmp=$(mktemp) || exit 1
_err_tmp=$(mktemp) || { rm -f "$_out_tmp"; exit 1; }
trap 'rm -f "$_out_tmp" "$_err_tmp"' EXIT

"$_real" "$@" > "$_out_tmp" 2> "$_err_tmp"
_rc=$?

_emit_capped "$_out_tmp" stdout
_emit_capped "$_err_tmp" stderr
exit "$_rc"
