# Gemini must be able to inspect ignored target checkouts and audit state.
# Keep the very large generated artifacts out of Gemini file/search tools.
output/**/logs/*.log.raw
output/**/logs/.iter_cache/
output/**/results/.show-patch-cache/
output/**/results/scratch-*/**/*.dSYM/**
targets/**/.git/
targets/**/build/
targets/**/build-*/
targets/**/.libs/
